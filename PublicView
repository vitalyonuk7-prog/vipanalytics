<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<base target="_top">
<title>Team Schedule</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
body{background:#f5f7fa;color:#2d3748}
.hdr{background:linear-gradient(135deg,#1e293b,#334155);color:#fff;padding:16px 22px;display:flex;align-items:center;justify-content:space-between}
.hdr h1{font-size:19px;font-weight:900}
.hdr .sub{font-size:11px;opacity:0.5;margin-top:2px}
.badge{padding:5px 12px;background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.3);border-radius:20px;font-size:11px;font-weight:700;color:#fbbf24}
.ctrl{padding:12px 18px;background:#fff;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.btn{padding:6px 13px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-size:12px;font-weight:700;border-radius:8px;cursor:pointer}
.btn:hover{background:#f1f5f9}
.btn.on{background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border-color:transparent}
.btn.today{color:#6366f1}
.seg{display:flex;border:1.5px solid #e2e8f0;border-radius:8px;overflow:hidden}
.seg button{padding:6px 12px;border:none;font-size:11px;font-weight:700;cursor:pointer;background:#fff;color:#64748b}
.seg button.on{background:#6366f1;color:#fff}
.seg.tz button.on{background:#0ea5e9}
.main{padding:16px 18px}
.team-tabs{display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap}
.grid{background:#fff;border-radius:14px;border:1.5px solid #e2e8f0;overflow:hidden;overflow-x:auto}
.grid-title{font-size:15px;font-weight:800;color:#1e293b;margin-bottom:12px}
.empty{padding:50px;text-align:center;color:#94a3b8;font-size:13px}

.lbl-tooltip {
  position: fixed; z-index: 9999; background: #1e293b; color: #fff;
  padding: 8px 12px; border-radius: 10px; font-size: 12px; font-weight: 600;
  max-width: 220px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  pointer-events: none; display: none; line-height: 1.4;
}
</style>
</head>
<body>
<div id="lblTooltip" class="lbl-tooltip"></div>
<div class="hdr">
  <div><h1>🗓️ Team Schedule</h1><div class="sub">Slotornado Analytics — Read-only view</div></div>
  <div class="badge">👁️ View Only</div>
</div>
<div class="ctrl" id="ctrl"></div>
<div class="main" id="main"><div class="empty">Loading...</div></div>

<script>
var ttData = "TIMETABLE_DATA_PLACEHOLDER";
var tz = 'kyiv';
var viewMode = 'week';
var selTeam = null;
var viewDate = new Date(); viewDate.setHours(0,0,0,0);

var shColors = ['#6366f1','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#84cc16'];
var colMap = {};
var MON = ['January','February','March','April','May','June','July','August','September','October','November','December'];
var DN  = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

function pad(n){return String(n).padStart(2,'0');}
function dk(d){return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());}
function today(){return dk(new Date());}

function adjTime(t){
  if(!t) return '';
  if(tz==='warsaw'){var p=t.split(':');var h=parseInt(p[0])-1;if(h<0)h=23;return pad(h)+':'+p[1];}
  return t;
}
function rgba(hex,a){var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return 'rgba('+r+','+g+','+b+','+a+')';}

function getShift(asgn, date) {
  var key = dk(date);
  if (asgn.exceptions) {
    var ex = asgn.exceptions.find(function(e){return e.date===key;});
    if (ex) {
      if (ex.type==='off') return null;
      if (ex.type==='custom') {
        var base=(ttData.shifts||[]).find(function(s){return s.id===asgn.shiftId;});
        if(!base) return null;
        return {id:base.id,name:base.name,pattern:base.pattern,workDays:base.workDays,restDays:base.restDays,daysOff:base.daysOff,startTime:ex.customStart,endTime:ex.customEnd,_custom:true};
      }
      if (ex.shiftId) return (ttData.shifts||[]).find(function(s){return s.id===ex.shiftId;})||null;
      return null;
    }
  }
  if (!asgn.startDate||!asgn.shiftId) return null;
  var sh=(ttData.shifts||[]).find(function(s){return s.id===asgn.shiftId;});
  if (!sh) return null;
  var start=new Date(asgn.startDate+'T00:00:00');
  var diff=Math.floor((date-start)/86400000);
  if (diff<0) return null;
  if (sh.pattern==='5/2') {
    var dn=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][date.getDay()];
    return (sh.daysOff||'Sat,Sun').split(',').indexOf(dn)!==-1?null:sh;
  }
  var cycle=(sh.workDays||5)+(sh.restDays||2);
  return diff%cycle<(sh.workDays||5)?sh:null;
}

function lunchEnd(start, asgn) {
  if (!start) return '';
  var dur = parseInt((asgn&&asgn.lunchDuration)||60);
  var p=start.split(':'), total=parseInt(p[0])*60+parseInt(p[1]||0)+dur;
  return String(Math.floor(total/60)%24).padStart(2,'0')+':'+String(total%60).padStart(2,'0');
}
function getLunch(asgn, dateKey){
  if(!asgn) return null;
  return ((asgn.lunchOverrides||{})[dateKey]) || asgn.defaultLunch || null;
}

function getLabels(){return ttData.labels||[];}

function mgrN(asgn){return asgn.managerEmail?asgn.managerEmail.split('@')[0]:'?';}

function getDates(){
  var dates=[];
  if(viewMode==='day'){dates.push(new Date(viewDate));}
  else if(viewMode==='week'){
    var d=new Date(viewDate),day=d.getDay(),diff=day===0?-6:1-day;
    d.setDate(d.getDate()+diff);
    for(var i=0;i<7;i++){dates.push(new Date(d));d.setDate(d.getDate()+1);}
  } else {
    var d2=new Date(viewDate.getFullYear(),viewDate.getMonth(),1);
    var end=new Date(viewDate.getFullYear(),viewDate.getMonth()+1,0);
    var sd=d2.getDay(); d2.setDate(d2.getDate()+(sd===0?-6:1-sd));
    while(d2<=end||d2.getDay()!==1){dates.push(new Date(d2));d2.setDate(d2.getDate()+1);if(dates.length>42)break;}
  }
  return dates;
}

function buildColMap(){
  colMap={};
  (ttData.shifts||[]).forEach(function(s,i){colMap[s.id]=shColors[i%shColors.length];});
}

function showLblTip(e, text, desc) {
  var tip = document.getElementById('lblTooltip');
  tip.innerHTML = '<div style="font-weight:800;font-size:13px;margin-bottom:2px">'+text+'</div>'+(desc?'<div style="opacity:0.7;font-size:11px">'+desc+'</div>':'');
  tip.style.display = 'block';
  var x = e.clientX + 12, y = e.clientY + 12;
  if (x + 230 > window.innerWidth) x = e.clientX - 230;
  if (y + 60 > window.innerHeight) y = e.clientY - 60;
  tip.style.left = x + 'px'; tip.style.top = y + 'px';
}
function hideLblTip() { document.getElementById('lblTooltip').style.display='none'; }

function renderLegend(main) {
  var labels = ttData.labels || [];
  if (!labels.length) return;
  var wrap = document.createElement('div');
  wrap.style.cssText = 'margin-top:16px;background:#fff;border-radius:12px;border:1.5px solid #e2e8f0;padding:14px 18px';
  var title = document.createElement('div');
  title.style.cssText = 'font-size:11px;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px';
  title.textContent = '🏷️ Labels';
  wrap.appendChild(title);
  var grid = document.createElement('div');
  grid.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px';
  labels.forEach(function(lbl) {
    var item = document.createElement('div');
    item.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 12px;border-radius:8px;border:1.5px solid #e2e8f0;background:#fafafa';
    var chip = document.createElement('span');
    chip.style.cssText = 'padding:3px 10px;border-radius:6px;font-size:11px;font-weight:700;background:'+lbl.color+';color:'+(lbl.textColor||'#fff');
    chip.textContent = lbl.text;
    item.appendChild(chip);
    if (lbl.description) {
      var desc = document.createElement('span');
      desc.style.cssText = 'font-size:12px;color:#64748b';
      desc.textContent = lbl.description;
      item.appendChild(desc);
    }
    grid.appendChild(item);
  });
  wrap.appendChild(grid);
  main.appendChild(wrap);
}

function render(){buildColMap();renderCtrl();renderMain();}

function renderCtrl(){
  var c=document.getElementById('ctrl'); c.innerHTML='';
  function btn(t,fn,cls){var b=document.createElement('button');b.className='btn'+(cls?' '+cls:'');b.innerHTML=t;b.onclick=fn;c.appendChild(b);}
  btn('◀',function(){nav(-1);});
  btn('▶',function(){nav(1);});
  btn('Today',function(){viewDate=new Date();viewDate.setHours(0,0,0,0);render();},'today');

  var vs=document.createElement('div');vs.className='seg';
  ['day','week','month'].forEach(function(m){var b=document.createElement('button');b.textContent=m[0].toUpperCase()+m.slice(1);if(viewMode===m)b.className='on';b.onclick=function(){viewMode=m;render();};vs.appendChild(b);});
  c.appendChild(vs);

  var ts=document.createElement('div');ts.className='seg tz';
  [['kyiv','🇺🇦 Kyiv'],['warsaw','🇵🇱 Warsaw']].forEach(function(p){var b=document.createElement('button');b.textContent=p[1];if(tz===p[0])b.className='on';b.onclick=function(){tz=p[0];render();};ts.appendChild(b);});
  c.appendChild(ts);
}

function nav(dir){
  var d=new Date(viewDate);
  if(viewMode==='week') d.setDate(d.getDate()+dir*7);
  else if(viewMode==='day') d.setDate(d.getDate()+dir);
  else d.setMonth(d.getMonth()+dir);
  viewDate=d; render();
}

function renderMain(){
  var main=document.getElementById('main'); main.innerHTML='';
  if(typeof ttData==='string'){main.innerHTML='<div class="empty">⚠️ Data not loaded — please re-deploy and refresh.</div>';return;}
  if(!ttData.teams||!ttData.teams.length){main.innerHTML='<div class="empty">No schedule data.</div>';return;}

  // Team tabs
  if(!selTeam) selTeam=ttData.teams[0].id;
  var tabs=document.createElement('div');tabs.className='team-tabs';
  ttData.teams.forEach(function(t){
    var b=document.createElement('button');b.className='btn'+(t.id===selTeam?' on':'');
    b.textContent='👥 '+t.name;b.onclick=function(){selTeam=t.id;render();};tabs.appendChild(b);
  });
  main.appendChild(tabs);

  var teamAs=(ttData.assignments||[]).filter(function(a){return a.teamId===selTeam;});

  // Fallback: if no match, use all assignments
  if(!teamAs.length && (ttData.assignments||[]).length){
    selTeam=(ttData.assignments[0].teamId);
    teamAs=(ttData.assignments||[]).filter(function(a){return a.teamId===selTeam;});
  }

  if(!teamAs.length){main.innerHTML+='<div class="empty">No managers assigned to this team.</div>';return;}

  var tod=today();
  if(viewMode==='week') renderWeek(main,teamAs,tod);
  else if(viewMode==='month') renderMonth(main,teamAs,tod);
  else renderDay(main,teamAs,tod);
  renderLegend(main);
}

// ── WEEK VIEW ──
function renderWeek(main,teamAs,tod){
  var dates=getDates();
  var title=document.createElement('div');title.className='grid-title';
  title.textContent=MON[dates[0].getMonth()]+' '+dates[0].getDate()+' – '+MON[dates[6].getMonth()]+' '+dates[6].getDate()+', '+dates[6].getFullYear();
  main.appendChild(title);

  var wrap=document.createElement('div');wrap.className='grid';

  // Header row
  var hdr=document.createElement('div');
  hdr.style.cssText='display:grid;grid-template-columns:160px repeat(7,minmax(100px,1fr));background:#f8fafc;border-bottom:2px solid #e2e8f0';
  var lc=document.createElement('div');lc.style.cssText='padding:10px 12px;font-size:10px;font-weight:800;color:#94a3b8;text-transform:uppercase;border-right:2px solid #e2e8f0';lc.textContent='Manager';hdr.appendChild(lc);
  dates.forEach(function(d){
    var key=dk(d);var isT=key===tod;var isW=d.getDay()===0||d.getDay()===6;
    var cell=document.createElement('div');
    cell.style.cssText='padding:8px 4px;text-align:center;border-right:1px solid #f1f5f9;background:'+(isT?'#eef2ff':isW?'#fafafa':'transparent');
    cell.innerHTML='<div style="font-size:11px;font-weight:700;color:'+(isW?'#c4b5fd':'#94a3b8')+'">'+DN[(d.getDay()+6)%7]+'</div>'+
      '<div style="width:30px;height:30px;border-radius:50%;background:'+(isT?'#6366f1':'transparent')+';color:'+(isT?'#fff':isW?'#a78bfa':'#1e293b')+';font-size:14px;font-weight:'+(isT?900:700)+';display:flex;align-items:center;justify-content:center;margin:3px auto 0">'+d.getDate()+'</div>';
    hdr.appendChild(cell);
  });
  wrap.appendChild(hdr);

  // Manager rows
  // Sort by shift start time (earliest first)
  var sorted = teamAs.slice().sort(function(a,b){
    var sa=(ttData.shifts||[]).find(function(s){return s.id===a.shiftId;});
    var sb=(ttData.shifts||[]).find(function(s){return s.id===b.shiftId;});
    var ta=sa?parseInt((sa.startTime||'99:00').replace(':','')):(9999);
    var tb=sb?parseInt((sb.startTime||'99:00').replace(':','')):(9999);
    return ta-tb;
  });
  sorted.forEach(function(asgn){
    var sh=(ttData.shifts||[]).find(function(s){return s.id===asgn.shiftId;});
    var row=document.createElement('div');
    row.style.cssText='display:grid;grid-template-columns:160px repeat(7,minmax(100px,1fr));border-bottom:1px solid #f1f5f9;height:110px';

    // Name cell
    var nc=document.createElement('div');nc.style.cssText='padding:10px 12px;border-right:2px solid #e2e8f0;display:flex;flex-direction:column;justify-content:center;background:#fafafa;overflow:hidden';
    nc.innerHTML='<div style="font-weight:700;font-size:12px;color:#1e293b;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+mgrN(asgn)+'</div>'+
      '<div style="font-size:10px;color:#94a3b8;margin-top:2px">'+(sh?sh.name:'No shift')+'</div>';
    row.appendChild(nc);

    dates.forEach(function(d){
      var key=dk(d);var activeSh=getShift(asgn,d);
      var isT=key===tod;var isW=d.getDay()===0||d.getDay()===6;
      var col=activeSh?(colMap[activeSh.id]||'#6366f1'):null;
      var cell=document.createElement('div');
      cell.style.cssText='padding:5px;border-right:1px solid #f1f5f9;display:flex;align-items:stretch;justify-content:center;height:110px;box-sizing:border-box;background:'+(isT?'#f5f3ff':isW&&!activeSh?'#fafafa':'#fff');

      if(activeSh){
        var s=adjTime(activeSh.startTime);var e2=adjTime(activeSh.endTime);
        var lunch=adjTime(getLunch(asgn,key));
        var lbls=(asgn.dayLabels||{})[key]||[];
        var lblHtml=lbls.map(function(lid){var l=(ttData.labels||[]).find(function(x){return x.id===lid;});return l?'<span onmouseenter="showLblTip(event,'+JSON.stringify(l.text)+','+JSON.stringify(l.description||'')+')" onmouseleave="hideLblTip()" style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:9px;font-weight:700;background:'+l.color+';color:'+(l.textColor||'#fff')+';cursor:pointer">'+l.text+'</span>':''}).join('');
        var inner=document.createElement('div');
        inner.style.cssText='width:100%;height:100%;padding:7px 8px;background:'+rgba(col,0.08)+';border:1.5px solid '+rgba(col,0.22)+';border-radius:8px;text-align:center;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;gap:0';
        // Shift name
        var _n1=document.createElement('div');_n1.style.cssText='font-size:12px;font-weight:800;color:'+col+';overflow:hidden;text-overflow:ellipsis;white-space:nowrap';_n1.textContent=activeSh.name;inner.appendChild(_n1);
        // Hours
        var _n2=document.createElement('div');_n2.style.cssText='font-size:11px;color:'+col+';opacity:0.75;margin-top:2px';_n2.textContent=s+'–'+e2;inner.appendChild(_n2);
        // Lunch badge (always same height slot — empty if no lunch)
        var _lunchWrap=document.createElement('div');_lunchWrap.style.cssText='margin-top:5px;min-height:26px;display:flex;align-items:center;justify-content:center';
        if(lunch){var _ls=document.createElement('span');_ls.style.cssText='display:inline-flex;align-items:center;gap:3px;padding:4px 9px;background:#fef3c7;border:1.5px solid #f59e0b;border-radius:6px;font-size:11px;font-weight:800;color:#d97706';_ls.textContent='🍽️ '+lunch+' – '+lunchEnd(lunch,asgn);_lunchWrap.appendChild(_ls);}
        inner.appendChild(_lunchWrap);
        // Labels (always same height slot — empty if no labels)
        var _lblWrap=document.createElement('div');_lblWrap.style.cssText='margin-top:3px;min-height:20px;display:flex;flex-wrap:wrap;gap:3px;justify-content:center;align-items:center';
        if(lblHtml) _lblWrap.innerHTML=lblHtml;
        inner.appendChild(_lblWrap);
        cell.appendChild(inner);
      } else {
        var ex=asgn.exceptions&&asgn.exceptions.find(function(e){return e.date===key&&e.type==='off';});
        if(ex){cell.innerHTML='<div style="padding:2px 6px;background:#fef9f0;border:1.5px solid #f59e0b;border-radius:5px;font-size:8px;font-weight:800;color:#f59e0b">🏖️ OFF</div>';}
        else if(asgn.shiftId){cell.innerHTML='<div style="font-size:9px;color:#cbd5e1">— off —</div>';}
      }
      row.appendChild(cell);
    });
    wrap.appendChild(row);
  });

  main.appendChild(wrap);
}

// ── MONTH VIEW ──
function renderMonth(main,teamAs,tod){
  var dates=getDates();var curMon=viewDate.getMonth();
  var title=document.createElement('div');title.className='grid-title';
  title.textContent=MON[viewDate.getMonth()]+' '+viewDate.getFullYear();
  main.appendChild(title);

  var wrap=document.createElement('div');wrap.className='grid';
  var hdr=document.createElement('div');hdr.style.cssText='display:grid;grid-template-columns:repeat(7,1fr);background:#f8fafc;border-bottom:2px solid #e2e8f0';
  DN.forEach(function(dn,di){var h=document.createElement('div');h.style.cssText='padding:8px 0;text-align:center;font-size:11px;font-weight:800;color:'+(di>=5?'#a78bfa':'#64748b')+';text-transform:uppercase';h.textContent=dn;hdr.appendChild(h);});
  wrap.appendChild(hdr);

  var grid=document.createElement('div');grid.style.cssText='display:grid;grid-template-columns:repeat(7,1fr)';
  dates.forEach(function(d){
    var key=dk(d);var isT=key===tod;var isW=d.getDay()===0||d.getDay()===6;var isOth=d.getMonth()!==curMon;
    var cell=document.createElement('div');
    cell.style.cssText='min-height:110px;padding:6px;border-right:1px solid #f1f5f9;border-bottom:1px solid #f1f5f9;background:'+(isT?'#f5f3ff':isOth?'#fafafa':isW?'#fdfdff':'#fff');
    var dn2=document.createElement('div');
    dn2.style.cssText='display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:50%;background:'+(isT?'#6366f1':'transparent')+';color:'+(isT?'#fff':isOth?'#cbd5e1':isW?'#a78bfa':'#1e293b')+';font-size:11px;font-weight:'+(isT?900:700)+';margin-bottom:3px';
    dn2.textContent=d.getDate();cell.appendChild(dn2);

    var sortedM=teamAs.slice().sort(function(a,b){var sa=(ttData.shifts||[]).find(function(s){return s.id===a.shiftId;});var sb=(ttData.shifts||[]).find(function(s){return s.id===b.shiftId;});return (sa?parseInt((sa.startTime||'99:00').replace(':','')):(9999))-(sb?parseInt((sb.startTime||'99:00').replace(':','')):(9999));});
    sortedM.forEach(function(asgn){
      var activeSh=getShift(asgn,d);
      var isOff=!activeSh&&(asgn.exceptions&&asgn.exceptions.find(function(e){return e.date===key&&e.type==='off';}));
      if(!activeSh&&!isOff) return;
      var pill=document.createElement('div');
      if(activeSh){
        var col=colMap[activeSh.id]||'#6366f1';
        var s=adjTime(activeSh.startTime);var e2=adjTime(activeSh.endTime);
        var lunch=adjTime(getLunch(asgn,key));
        var lbls=(asgn.dayLabels||{})[key]||[];
        var lblHtml=lbls.map(function(lid){var l=(ttData.labels||[]).find(function(x){return x.id===lid;});return l?'<span onmouseenter="showLblTip(event,'+JSON.stringify(l.text)+','+JSON.stringify(l.description||'')+')" onmouseleave="hideLblTip()" style="display:inline-block;padding:2px 5px;border-radius:4px;font-size:8px;font-weight:700;background:'+l.color+';color:'+(l.textColor||'#fff')+';cursor:pointer">'+l.text+'</span>':''}).join('');
        pill.style.cssText='padding:2px 4px;border-radius:4px;background:'+rgba(col,0.08)+';border-left:2px solid '+col+';margin-bottom:2px';
        pill.innerHTML='<div style="font-size:10px;font-weight:800;color:'+col+';overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+mgrN(asgn)+'</div>'+
          '<div style="font-size:9px;color:'+col+';opacity:0.7">'+s+'–'+e2+'</div>'+(lunch?'<div><span style=\"display:inline-flex;align-items:center;padding:1px 4px;background:#fef3c7;border:1px solid #fde68a;border-radius:3px;font-size:6px;font-weight:700;color:#d97706\">🍽️ '+lunch+' – '+lunchEnd(lunch,asgn)+'</span></div>':'')+
          (lblHtml?'<div>'+lblHtml+'</div>':'');
      } else {
        pill.style.cssText='padding:2px 4px;border-radius:4px;background:#fff7ed;border-left:2px solid #f59e0b;margin-bottom:2px';
        pill.innerHTML='<div style="font-size:8px;font-weight:700;color:#92400e">'+mgrN(asgn)+' OFF</div>';
      }
      cell.appendChild(pill);
    });
    grid.appendChild(cell);
  });
  wrap.appendChild(grid);
  main.appendChild(wrap);
}

// ── DAY VIEW ──
function renderDay(main,teamAs,tod){
  var d=viewDate;var key=dk(d);var isT=key===tod;var di=(d.getDay()+6)%7;
  var title=document.createElement('div');title.className='grid-title';
  title.textContent=DN[di]+', '+d.getDate()+' '+MON[d.getMonth()]+' '+d.getFullYear();
  if(isT){var sp=document.createElement('span');sp.style.cssText='margin-left:8px;padding:2px 10px;background:#6366f1;color:#fff;border-radius:20px;font-size:10px;font-weight:700';sp.textContent='Today';title.appendChild(sp);}
  main.appendChild(title);

  if(!teamAs.length){main.innerHTML+='<div class="empty">No managers assigned.</div>';return;}
  var mgrs=teamAs.map(function(a){
    var activeSh=getShift(a,d);
    var col=activeSh?(colMap[activeSh.id]||'#6366f1'):'#94a3b8';
    var sH=activeSh?parseInt((activeSh.startTime||'09:00').split(':')[0]):null;
    var eH=activeSh?parseInt((activeSh.endTime||'18:00').split(':')[0]):null;
    if(eH===0)eH=24;
    if(tz==='warsaw'&&sH!==null){sH--;eH--;if(sH<0)sH=0;if(eH<0)eH=24;}
    return{asgn:a,activeSh:activeSh,col:col,sH:sH,eH:eH};
  });

  var wrap=document.createElement('div');wrap.className='grid';
  var cols='60px repeat('+mgrs.length+',1fr)';
  var hdr=document.createElement('div');hdr.style.cssText='display:grid;grid-template-columns:'+cols+';background:#f8fafc;border-bottom:2px solid #e2e8f0';
  var tz2=document.createElement('div');tz2.style.cssText='padding:10px 8px;font-size:9px;font-weight:800;color:#94a3b8;text-transform:uppercase;border-right:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center';tz2.textContent=tz==='warsaw'?'WAW':'KYV';hdr.appendChild(tz2);
  mgrs.forEach(function(info){
    var cell=document.createElement('div');cell.style.cssText='padding:8px;border-right:1px solid #e2e8f0;text-align:center;border-top:3px solid '+info.col;
    cell.innerHTML='<div style="font-size:11px;font-weight:800;color:#1e293b">'+mgrN(info.asgn)+'</div><div style="margin-top:3px">'+
      (info.activeSh?'<span style="padding:2px 8px;background:'+rgba(info.col,0.1)+';border-radius:20px;font-size:9px;font-weight:700;color:'+info.col+'">'+info.activeSh.name+' · '+adjTime(info.activeSh.startTime)+'–'+adjTime(info.activeSh.endTime)+'</span>':
      '<span style="padding:2px 8px;background:#fef2f2;border-radius:20px;font-size:9px;font-weight:700;color:#ef4444">Day Off</span>')+'</div>';
    hdr.appendChild(cell);
  });
  wrap.appendChild(hdr);

  var body=document.createElement('div');body.style.cssText='max-height:540px;overflow-y:auto';
  var nowH=new Date().getHours();
  for(var h=0;h<=23;h++){
    var isCur=isT&&nowH===h;
    var hRow=document.createElement('div');hRow.style.cssText='display:grid;grid-template-columns:'+cols+';min-height:56px;border-bottom:1px solid '+(isCur?'#c4b5fd':'#f1f5f9')+';background:'+(isCur?'#faf5ff':'#fff');
    var tl=document.createElement('div');tl.style.cssText='padding:0 8px;font-size:11px;font-weight:'+(isCur?800:600)+';color:'+(isCur?'#6366f1':'#94a3b8')+';border-right:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center;background:'+(isCur?'#f0ebff':'#fafafa');tl.textContent=pad(h)+':00';hRow.appendChild(tl);
    (function(hr){
      mgrs.forEach(function(info){
        var cell=document.createElement('div');cell.style.cssText='border-right:1px solid #f1f5f9';
        if(info.activeSh&&info.sH!==null){
          var cross=info.eH<info.sH;
          var isWork=cross?(hr>=info.sH||hr<info.eH):(hr>=info.sH&&hr<info.eH);
          if(isWork){
            cell.style.background=rgba(info.col,0.08);
            var lunch=adjTime(getLunch(info.asgn,key));
            var lunchH=lunch?parseInt(lunch.split(':')[0]):-1;
            if(hr===lunchH){
              cell.style.background='#fffbeb';
              cell.innerHTML='<div style="width:100%;height:100%;padding:6px 8px;background:#fffbeb;border-left:3px solid #f59e0b;display:flex;flex-direction:column;justify-content:center">'+
                '<div style="font-size:12px;font-weight:800;color:#d97706">🍽️ Lunch</div>'+
                '<div style="font-size:11px;color:#f59e0b;margin-top:2px">'+lunch+' – '+lunchEnd(lunch,info.asgn)+'</div>'+
                '</div>';
            } else if(hr===info.sH){
              var lbls=(info.asgn.dayLabels||{})[key]||[];
              var lblHtml=lbls.map(function(lid){var l=(ttData.labels||[]).find(function(x){return x.id===lid;});return l?'<span onmouseenter="showLblTip(event,'+JSON.stringify(l.text)+','+JSON.stringify(l.description||'')+')" onmouseleave="hideLblTip()" style="padding:1px 4px;border-radius:3px;font-size:7px;font-weight:700;background:'+l.color+';color:'+(l.textColor||'#fff')+';cursor:pointer">'+l.text+'</span>':''}).join(' ');
              cell.innerHTML='<div style="margin:4px;padding:3px 6px;background:'+rgba(info.col,0.18)+';border-left:2px solid '+info.col+';border-radius:0 5px 5px 0"><div style="font-size:9px;font-weight:800;color:'+info.col+'">'+info.activeSh.name+'</div>'+(lblHtml?'<div style="margin-top:2px">'+lblHtml+'</div>':'')+'</div>';
            }
          }
        }
        hRow.appendChild(cell);
      });
    })(h);
    body.appendChild(hRow);
  }
  wrap.appendChild(body);
  main.appendChild(wrap);
}

render();
</script>
