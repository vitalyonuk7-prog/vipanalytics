  }
}

function addBonusCategoryOption(categoryName) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('BONUS CATEGORIES');
    if (!sheet) return { error: 'Sheet not found' };
    
    // Check if exists in column D
    var data = sheet.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][3] || '').trim() === categoryName) return { error: 'Category already exists' };
    }
    
    // Find first empty cell in column D (after header)
    var col4 = sheet.getRange('D:D').getValues();
    var insertRow = 2;
    for (var j = 1; j < col4.length; j++) {
      if (String(col4[j][0] || '').trim()) insertRow = j + 2;
      else break;
    }
    // Actually find proper empty row
    insertRow = 2;
    for (var j = 1; j < col4.length; j++) {
      if (String(col4[j][0] || '').trim()) { insertRow = j + 2; }
    }
    sheet.getRange(insertRow, 4).setValue(categoryName);
    return { success: true };
  } catch (e) {
    return { error: e.message };
  }
}

function removeBonusCategoryOption(categoryName) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('BONUS CATEGORIES');
    if (!sheet) return { error: 'Sheet not found' };
    
    var data = sheet.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][3] || '').trim() === categoryName) {
        sheet.getRange(i + 1, 4).clearContent();
        // Also clear categories assigned to this from column B
        for (var j = 1; j < data.length; j++) {
          if (String(data[j][1] || '').trim() === categoryName) {
            sheet.getRange(j + 1, 2).clearContent();
          }
        }
        return { success: true };
      }
    }
    return { error: 'Category not found' };
  } catch (e) {
    return { error: e.message };
  }
}

function syncBonusNames(names) {
