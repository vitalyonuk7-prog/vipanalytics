function resolveQaAppeal(params) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('QA_APPEALS');
    if (!sheet) return { error: 'No appeals sheet' };
    var data = sheet.getDataRange().getValues();
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var idCol = headers.indexOf('id');
    var statusCol = headers.indexOf('status');
    var commentCol = headers.indexOf('admin_comment');
    var resolvedAtCol = headers.indexOf('resolved_at');
    var resolvedByCol = headers.indexOf('resolved_by');
    var aid = String(params.id || '');
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][idCol]) === aid) {
        sheet.getRange(i+1, statusCol+1).setValue(params.status || 'rejected');
        sheet.getRange(i+1, commentCol+1).setValue(params.comment || '');
        sheet.getRange(i+1, resolvedAtCol+1).setValue(new Date().toISOString());
        sheet.getRange(i+1, resolvedByCol+1).setValue(params.resolved_by || '');
        // Update the scorecard for ALL statuses
        var mgr = String(data[i][headers.indexOf('manager')]);
        var moRaw = data[i][headers.indexOf('month')];
        var mo = (moRaw instanceof Date) ? moRaw.getFullYear() + '-' + String(moRaw.getMonth()+1).padStart(2,'0') : String(moRaw || '').trim();
        var fbi = parseInt(data[i][headers.indexOf('bi')]);
        var fei = parseInt(data[i][headers.indexOf('ei')]);
        var ffi = headers.indexOf('fi') >= 0 ? parseInt(data[i][headers.indexOf('fi')]) : -1;
        Logger.log('resolveQaAppeal: looking for mgr=' + mgr + ' mo=' + mo + ' fi=' + ffi + ' bi=' + fbi + ' ei=' + fei);
        var resSheet = ss.getSheetByName('QA_RESULTS');
        if (resSheet) {
          var rData = resSheet.getDataRange().getValues();
          var rH = rData[0].map(function(h){return String(h).trim().toLowerCase();});
          var rMgr = rH.indexOf('manager'); var rMo = rH.indexOf('month'); var rFj = rH.indexOf('failures_json'); var rSc = rH.indexOf('score');
          Logger.log('resolveQaAppeal: scanning ' + (rData.length-1) + ' result rows');
          for (var ri = 1; ri < rData.length; ri++) {
            var rRowMo = rData[ri][rMo];
            if (rRowMo instanceof Date) rRowMo = rRowMo.getFullYear() + '-' + String(rRowMo.getMonth()+1).padStart(2,'0');
            else rRowMo = String(rRowMo || '').trim();
            if (String(rData[ri][rMgr]).toLowerCase() === mgr.toLowerCase() && rRowMo === mo) {
              Logger.log('resolveQaAppeal: found scorecard at row ' + (ri+1));
              var failures = []; try { failures = JSON.parse(String(rData[ri][rFj] || '[]')); } catch(e){}
              var matched = false;
              for (var fi = 0; fi < failures.length; fi++) {
                // Match by fi (global index) if available, fallback to bi+ei
                var isMatch = (ffi >= 0) ? (fi === ffi) : (parseInt(failures[fi].bi) === fbi && parseInt(failures[fi].ei) === fei);
                if (isMatch) {
                  matched = true;
                  Logger.log('resolveQaAppeal: matched failure fi=' + fi + ' status=' + params.status);
                  if (params.status === 'accepted') {
                    failures[fi].original_pct = failures[fi].pct;
                    failures[fi].pct = 0;
                    failures[fi].appealed = 'accepted';
                    failures[fi].appeal_comment = params.comment || '';
                  } else if (params.status === 'downgraded') {
                    failures[fi].original_pct = failures[fi].pct;
                    failures[fi].original_level = failures[fi].level;
                    failures[fi].level = params.new_level || 'warning';
                    failures[fi].pct = parseFloat(params.new_pct) || 0;
                    failures[fi].appealed = 'downgraded';
                    failures[fi].appeal_comment = params.comment || '';
                  } else {
                    // rejected
                    failures[fi].appealed = 'rejected';
                    failures[fi].appeal_comment = params.comment || '';
                  }
                  break;
                }
              }
              if (!matched) Logger.log('resolveQaAppeal: NO failure matched bi=' + fbi + ' ei=' + fei + ' in ' + failures.length + ' failures');
              // Recalculate score
              var totalDeduct = 0;
              failures.forEach(function(f) { if (f.level !== 'warning') totalDeduct += parseFloat(f.pct) || 0; });
              var newScore = Math.max(0, 100 - totalDeduct);
              Logger.log('resolveQaAppeal: new score=' + newScore + ' deducted=' + totalDeduct);
              resSheet.getRange(ri+1, rFj+1).setValue(JSON.stringify(failures));
              resSheet.getRange(ri+1, rSc+1).setValue(newScore);
              break;
            }
          }
        }
        return { success: true };
      }
    }
    return { error: 'Appeal not found' };
  } catch(e) { return { error: e.message }; }
}

