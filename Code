function checkAccess() {
  try {
    var email = Session.getActiveUser().getEmail().toLowerCase().trim();
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('ACCESS');
    if (!sheet) return { allowed: true, role: 'admin', email: email, manager: '' };
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { allowed: false, email: email };
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var emailCol = headers.indexOf('email');
    var roleCol = headers.indexOf('role');
    var mgrCol = headers.indexOf('manager');
    if (emailCol === -1) return { allowed: true, role: 'admin', email: email, manager: '' };
    for (var i = 1; i < data.length; i++) {
      var rowEmail = String(data[i][emailCol] || '').toLowerCase().trim();
      if (rowEmail === email) {
        var role = roleCol >= 0 ? String(data[i][roleCol] || 'user').toLowerCase().trim() : 'user';
        var mgr = mgrCol >= 0 ? String(data[i][mgrCol] || '').trim() : '';
        return { allowed: true, role: role, email: email, manager: mgr };
      }
    }
    return { allowed: false, email: email };
  } catch(e) {
    return { allowed: true, role: 'user', email: '', manager: '', error: e.message };
  }
}

function loginUser(params) {
  try {
    var inputEmail = String(params.email || '').toLowerCase().trim();
    var inputPassword = String(params.password || '').trim();
    
    if (!inputEmail || !inputPassword) return { error: 'Email and password are required' };
    
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('ACCESS');
    if (!sheet) return { error: 'ACCESS sheet not found' };
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { error: 'No users configured' };
    
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var emailCol = headers.indexOf('email');
    var roleCol = headers.indexOf('role');
    var pwCol = headers.indexOf('password');
    var mgrCol = headers.indexOf('manager');
    
    if (emailCol === -1 || pwCol === -1) return { error: 'Invalid ACCESS sheet structure' };
    
    for (var i = 1; i < data.length; i++) {
      var rowEmail = String(data[i][emailCol] || '').toLowerCase().trim();
      if (rowEmail === inputEmail) {
        var storedPw = String(data[i][pwCol] || '').trim();
        if (storedPw === inputPassword) {
          var role = roleCol >= 0 ? String(data[i][roleCol] || 'user').toLowerCase().trim() : 'user';
          var mgr = mgrCol >= 0 ? String(data[i][mgrCol] || '').trim() : '';
          var nameCol = headers.indexOf('name');
          var nickCol = headers.indexOf('nickname');
          var emojiCol = headers.indexOf('emoji');
          var userName = nameCol >= 0 ? String(data[i][nameCol] || '').trim() : '';
          var nickname = nickCol >= 0 ? String(data[i][nickCol] || '').trim() : '';
          var userEmoji = emojiCol >= 0 ? String(data[i][emojiCol] || '').trim() : '';
          if (params.remember) {
            saveRememberMe_(inputEmail, inputPassword);
          } else {
            clearRememberMe_();
          }
          return { allowed: true, role: role, email: inputEmail, manager: mgr, name: userName, nickname: nickname, emoji: userEmoji };
        } else {
          return { error: 'Incorrect password' };
        }
      }
    }
    
    return { error: 'User not found' };
  } catch(e) {
    return { error: e.message };
  }
}

function getRememberMe() {
  try {
    // Clean up shared _anon key that may have been created
    var props = PropertiesService.getScriptProperties();
    props.deleteProperty('rmb__anon');
    var gEmail = Session.getActiveUser().getEmail();
    // If we can't identify the Google user, DON'T auto-fill (prevents cross-user leaks)
    if (!gEmail || gEmail === '') return { success: false };
    var props = PropertiesService.getScriptProperties();
    var key = 'rmb_' + gEmail.replace(/[^a-zA-Z0-9]/g, '_');
    var val = props.getProperty(key);
    if (val) {
      var obj = JSON.parse(val);
      return { success: true, email: obj.e || '', password: obj.p || '' };
    }
    return { success: false };
  } catch(e) {
    return { success: false };
  }
}

function saveRememberMe_(email, password) {
  try {
    var gEmail = Session.getActiveUser().getEmail();
    if (!gEmail || gEmail === '') return; // Can't identify user - skip
    var props = PropertiesService.getScriptProperties();
    var key = 'rmb_' + gEmail.replace(/[^a-zA-Z0-9]/g, '_');
    props.setProperty(key, JSON.stringify({ e: email, p: password }));
  } catch(e) {}
}

function clearRememberMe_() {
  try {
    var gEmail = Session.getActiveUser().getEmail();
    if (!gEmail || gEmail === '') return;
    var props = PropertiesService.getScriptProperties();
    var key = 'rmb_' + gEmail.replace(/[^a-zA-Z0-9]/g, '_');
    props.deleteProperty(key);
  } catch(e) {}
}

function updateRememberMe(email, password) {
  try {
    saveRememberMe_(email, password);
    return { success: true };
  } catch(e) {
    return { error: e.message };
  }
}

function changeOwnPassword(params) {
  try {
    var email = String(params.email || '').toLowerCase().trim();
    var curPw = String(params.currentPassword || '').trim();
    var newPw = String(params.newPassword || '').trim();
    if (!email || !curPw || !newPw) return { error: 'All fields are required' };
    if (newPw.length < 4) return { error: 'New password must be at least 4 characters' };
    
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('ACCESS');
    if (!sheet) return { error: 'ACCESS sheet not found' };
    
    var data = sheet.getDataRange().getValues();
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var emailCol = headers.indexOf('email');
    var pwCol = headers.indexOf('password');
    if (emailCol === -1 || pwCol === -1) return { error: 'Invalid ACCESS sheet' };
    
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][emailCol] || '').toLowerCase().trim() === email) {
        if (String(data[i][pwCol] || '').trim() !== curPw) return { error: 'Current password is incorrect' };
        sheet.getRange(i + 1, pwCol + 1).setValue(newPw);
        // Update saved remember-me
        saveRememberMe_(email, newPw);
        return { success: true };
      }
    }
    return { error: 'User not found' };
  } catch(e) {
    return { error: e.message };
  }
}

