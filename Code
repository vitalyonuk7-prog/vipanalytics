/******************** TYPE MAPPING ********************/
function getTypeMapping() {
  var result = { tagToType: {}, typeMapping: {}, typeToTotal: {}, totalGroups: {} };
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    // Try both "TYPE" and "[TYPE]" sheet names
    var sheet = ss.getSheetByName('TYPE') || ss.getSheetByName('[TYPE]');
    if (sheet) {
      var data = sheet.getDataRange().getValues();
      for (var i = 1; i < data.length; i++) {
        var typeName = String(data[i][0] || '').trim();
        var tagsRaw = String(data[i][1] || '').trim();
        var totalGroup = String(data[i][2] || '').trim();
        if (!typeName || !tagsRaw) continue;
        
        // Parse tags - can be JSON array or single tag
        var tags = [];
        if (tagsRaw.charAt(0) === '[') {
          try { tags = JSON.parse(tagsRaw); } catch(e) { tags = [tagsRaw]; }
        } else {
          tags = tagsRaw.split(',').map(function(t) { return t.trim(); });
        }
        
        if (!result.typeMapping[typeName]) result.typeMapping[typeName] = [];
        
        tags.forEach(function(tag) {
          var t = String(tag).toLowerCase().trim().replace(/"/g, '');
          if (t) {
            result.tagToType[t] = typeName;
            result.typeMapping[typeName].push(t);
          }
        });
        
        // TOTAL group mapping
        if (totalGroup) {
          result.typeToTotal[typeName] = totalGroup;
          if (!result.totalGroups[totalGroup]) result.totalGroups[totalGroup] = [];
          if (result.totalGroups[totalGroup].indexOf(typeName) === -1) {
            result.totalGroups[totalGroup].push(typeName);
          }
        }
      }
    }
    Logger.log('TYPE mapping loaded: ' + Object.keys(result.tagToType).length + ' tags → ' + Object.keys(result.typeMapping).length + ' types, ' + Object.keys(result.totalGroups).length + ' total groups');
  } catch (e) {
    Logger.log('Error loading TYPE mapping: ' + e);
  }
  return result;
}

