/**
 * Get filtered retention counts based on filters
 * @param {Object} params - {mode: 'monthly'|'weekly', filters: {vipType, manager, trafficType, country}}
 */
/**
 * Get filtered deposit counts based on filters
 * @param {Object} params - {filters: {vipType, manager, trafficType, country}}
 */
function matchesFilters(player, filters) {
  // VIP Type filter
  if (filters.vipType && filters.vipType.length > 0) {
    var vipType = getVipTypeFromTags(player.tags);
    if (!filters.vipType.includes(vipType)) {
      return false;
    }
  }
  
  // Manager filter
  if (filters.manager && filters.manager.length > 0) {
    var manager = getManagerFromTags(player.tags);
    if (!filters.manager.includes(manager)) {
      return false;
    }
  }
  
  // Traffic Type filter
  if (filters.trafficType && filters.trafficType.length > 0) {
    if (!filters.trafficType.includes(player.trafficType || '')) {
      return false;
    }
  }
  
  // Country filter
  if (filters.country && filters.country.length > 0) {
    if (!filters.country.includes(player.country || '')) {
      return false;
    }
  }
  
  return true;
}

/**
 * Extract VIP type from tags
 */
function getVipTypeFromTags(tags) {
  if (!tags) return '';
  var t = String(tags).toLowerCase();
  if (t.indexOf('ann_vip') !== -1) return 'VIP';
  if (t.indexOf('ann') !== -1 && t.indexOf('vip') === -1) return 'Silent';
  if (t.indexOf('vip') !== -1 && t.indexOf('ann') === -1) return 'Super VIP';
  return '';
}

/**
 * Extract manager from tags
 */
function getManagerFromTags(tags) {
  if (!tags) return '';
  var t = String(tags).toLowerCase();
  if (t.indexOf('ann') !== -1) return 'Ann';
  if (t.indexOf('vlad') !== -1) return 'Vlad';
  if (t.indexOf('kate') !== -1) return 'Kate';
  if (t.indexOf('max') !== -1) return 'Max';
  return '';
}

function getWeeklyRetentionData() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  
  var ftdSheets = [];
  var activeSheets = [];
  
  // Знаходимо weekly sheets за форматом DD.MM - DD.MM
  sheets.forEach(function(sheet) {
    var name = sheet.getName();
    // Формат: 22.12 - 28.12 FTD або 22.12 - 28.12 ACTIVE
    var weekPattern = /^\d{2}\.\d{2}\s*-\s*\d{2}\.\d{2}/;
    
    if (weekPattern.test(name)) {
      if (name.indexOf('FTD') !== -1 && name.indexOf('ACTIVE') === -1) {
        ftdSheets.push(sheet);
      } else if (name.indexOf('ACTIVE') !== -1) {
        activeSheets.push(sheet);
      }
    }
  });
  
  // Helper функція для парсингу дат з назв тижнів
  function parseWeekDateBackend(weekStr) {
    var parts = weekStr.split('-');
    if (parts.length !== 2) return null;
    var startParts = parts[0].trim().split('.');
    if (startParts.length !== 2) return null;
    var day = parseInt(startParts[0]);
    var month = parseInt(startParts[1]);
    var now = new Date();
    var currentYear = now.getFullYear();
    // If month is in the future relative to current month, assume previous year
    var year = (month > now.getMonth() + 1) ? currentYear - 1 : currentYear;
    return new Date(year, month - 1, day);
  }
  
  // Сортуємо sheets ХРОНОЛОГІЧНО
  function sortSheetsByDate(sheetList) {
    return sheetList.sort(function(a, b) {
      var aWeek = extractWeekName(a.getName());
      var bWeek = extractWeekName(b.getName());
      var aDate = parseWeekDateBackend(aWeek);
      var bDate = parseWeekDateBackend(bWeek);
      if (!aDate || !bDate) return 0;
      return aDate - bDate;
    });
  }
  
  ftdSheets = sortSheetsByDate(ftdSheets);
  activeSheets = sortSheetsByDate(activeSheets);
  
  var result = {
    weeks: [],
    rows: []
  };
  
  // Отримуємо назви тижнів з ACTIVE sheets
  activeSheets.forEach(function(sheet) {
    var weekName = extractWeekName(sheet.getName());
    result.weeks.push(weekName);
  });
  
  // Для кожного FTD тижня рахуємо retention
  ftdSheets.forEach(function(ftdSheet, ftdIdx) {
    var ftdName = ftdSheet.getName();
    var weekName = extractWeekName(ftdName);
    
    var ftdData = getSheetData(ftdSheet);
    var ftdCount = ftdData.length;
    var ftdPlayerIds = ftdData.map(function(p) { return p.id; });
    
    var row = {
      week: weekName,
      ftdCount: ftdCount,
      retention: []
    };
    
    // Рахуємо retention для ВСІХ тижнів (з пропусками для минулого)
    for (var i = 0; i < activeSheets.length; i++) {
      if (i < ftdIdx) {
        // Минулий тиждень - пропускаємо
        row.retention.push({count: 0, pct: 0});
        continue;
      }
      
      var activeSheet = activeSheets[i];
      var activeData = getSheetData(activeSheet);
      
      var retainedCount = 0;
      ftdPlayerIds.forEach(function(ftdId) {
        var found = activeData.some(function(p) {
          return p.id === ftdId;
        });
        if (found) retainedCount++;
      });
      
      row.retention.push({
        count: retainedCount,
        pct: ftdCount > 0 ? retainedCount / ftdCount : 0
      });
    }
    
    result.rows.push(row);
  });
  
  return result;
}

function extractWeekName(sheetName) {
  // Витягуємо дати з формату "22.12 - 28.12 FTD" або "22.12 - 28.12 ACTIVE"
  var match = sheetName.match(/(\d{2}\.\d{2}\s*-\s*\d{2}\.\d{2})/);
  if (match) {
    return match[1].trim();
  }
  return sheetName;
}


function normalizeGroupId(id) {
  return String(id).trim();
}

function parseGroupIdsFromRaw(raw) {
  var rawStr = String(raw).trim();
  if (!rawStr || rawStr === '' || rawStr === 'undefined' || rawStr === 'null') return [];
  var ids = [];
  try {
    if (rawStr.charAt(0) === '[') {
      ids = JSON.parse(rawStr.replace(/'/g, '"'));
    } else if (rawStr.indexOf(',') !== -1) {
      ids = rawStr.split(',').map(function(s) { return s.trim().replace(/["']/g, ''); });
    } else {
      ids = [rawStr.replace(/["']/g, '').trim()];
    }
  } catch(e) {
    ids = rawStr.replace(/[\[\]"']/g, '').split(',').map(function(s) { return s.trim(); });
  }
  return ids.map(function(id) { return String(id).trim(); }).filter(function(id) { return id && id !== '' && id !== 'undefined'; });
}

// Robust group ID matching: compares both string and numeric forms
function groupIdMatch(playerIds, targetIds) {
  // Build lookup with both original and numeric forms
  var playerSet = {};
  playerIds.forEach(function(id) {
    var s = String(id).trim();
    playerSet[s] = true;
    // numeric form (no leading zeros)
    var n = s.replace(/^0+/, '') || '0';
    playerSet[n] = true;
    // padded to 5 digits
    if (/^\d+$/.test(s)) playerSet[('00000' + parseInt(s, 10)).slice(-5)] = true;
  });
  
  for (var i = 0; i < targetIds.length; i++) {
    var tid = String(targetIds[i]).trim();
    if (playerSet[tid]) return true;
    var tn = tid.replace(/^0+/, '') || '0';
    if (playerSet[tn]) return true;
    if (/^\d+$/.test(tid) && playerSet[('00000' + parseInt(tid, 10)).slice(-5)]) return true;
  }
  return false;
}

function getRetentionV2Data(params) {
  try {
    var mode = params && params.mode || 'weekly_ftd';
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // 1. Read GROUPS sheet
    var groupsSheet = ss.getSheetByName('GROUPS');
    if (!groupsSheet) return { error: 'GROUPS sheet not found' };
    
    var gData = groupsSheet.getDataRange().getValues();
    var gHeaders = gData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var gGroupCol = gHeaders.indexOf('group');
    var gNameCol = gHeaders.indexOf('name');
    var gRateCol = -1;
    for (var gi = 0; gi < gHeaders.length; gi++) {
      if (gHeaders[gi].indexOf('retention') !== -1 && gHeaders[gi].indexOf('rate') !== -1) { gRateCol = gi; break; }
    }
    var gTypeCol = -1;
    for (var gi = 0; gi < gHeaders.length; gi++) {
      if (gHeaders[gi].indexOf('retention') !== -1 && gHeaders[gi].indexOf('type') !== -1) { gTypeCol = gi; break; }
    }
    if (gGroupCol === -1 || gNameCol === -1) return { error: 'GROUPS sheet missing GROUP or NAME columns' };
    
    var allGroups = [];
    for (var r = 1; r < gData.length; r++) {
      var rawGroup = String(gData[r][gGroupCol] || '').trim();
      var name = String(gData[r][gNameCol] || '').trim();
      var rate = gRateCol >= 0 ? String(gData[r][gRateCol] || '').trim() : '';
      var rType = gTypeCol >= 0 ? String(gData[r][gTypeCol] || '').trim().toLowerCase() : '';
      if (!name) continue;
      
      var groupIds = parseGroupIdsFromRaw(rawGroup);
      
      var nameLower = name.toLowerCase();
      var isFTD = nameLower.indexOf('ftd') !== -1;
      var isActive = nameLower.indexOf('active') !== -1;
      if (!isFTD && !isActive) continue;
      
      var orderMatch = name.match(/\((\d+)\s*week\)/i) || name.match(/\((\d+)\s*month\)/i);
      var order = orderMatch ? parseInt(orderMatch[1]) : 999;
      var monthMatch = name.match(/\(([A-Z]+)\)/i);
      var monthName = monthMatch ? monthMatch[1] : '';
      
      allGroups.push({ groupIds: groupIds, name: name, rate: rate, retType: rType || 'week', isFTD: isFTD, isActive: isActive, order: order, monthName: monthName });
    }
    
    var isWeekly = mode.indexOf('weekly') !== -1;
    var isMom = mode.indexOf('mom') !== -1;
    var filterType = isWeekly ? 'week' : 'month';
    
    var ftdGroups = allGroups.filter(function(g) { return g.retType === filterType && g.isFTD; });
    var activeGroups = allGroups.filter(function(g) { return g.retType === filterType && g.isActive; });
    ftdGroups.sort(function(a, b) { return a.order - b.order; });
    activeGroups.sort(function(a, b) { return a.order - b.order; });
    
    // 2. Read GENERAL DASHBOARD — emails, groups, country, tags, stag
    var gdSheet = ss.getSheetByName('GENERAL DASHBOARD');
    if (!gdSheet) return { error: 'GENERAL DASHBOARD sheet not found' };
    
    var gdData = gdSheet.getDataRange().getValues();
    var gdH = gdData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var emailCol = gdH.indexOf('email');
    var groupsCol = gdH.indexOf('groups');
    var countryCol = gdH.indexOf('country');
    var tagsCol = gdH.indexOf('tags');
    var stagCol = gdH.indexOf('stag');
    var disCol = gdH.indexOf('disabled');
    if (emailCol === -1 || groupsCol === -1) return { error: 'GENERAL DASHBOARD missing email or groups column' };
    
    // Financial columns for modal data
    var depSumCol = -1, cashSumCol = -1, depCntCol = -1, inoutCol = -1;
    for (var hi = 0; hi < gdH.length; hi++) {
      if (gdH[hi].indexOf('deposit_sum') !== -1 && gdH[hi].indexOf('promo') === -1 && depSumCol === -1) depSumCol = hi;
      if (gdH[hi].indexOf('cashout_sum') !== -1 && cashSumCol === -1) cashSumCol = hi;
      if (gdH[hi] === 'lifetime_deposit_count_total' || gdH[hi] === 'deposit_count_total') depCntCol = hi;
      if (gdH[hi] === 'inout' || gdH[hi] === 'in_out' || gdH[hi] === 'lifetime_inout') inoutCol = hi;
    }
    
    var trafficMapping = getTrafficTypeMapping();
    
    // Build player data
    var playerGroups = {};  // email -> group ids array
    var playerDetails = {}; // email -> full player details for client-side modals
    
    for (var p = 1; p < gdData.length; p++) {
      var email = String(gdData[p][emailCol] || '').trim().toLowerCase();
      if (!email) continue;
      var rawGrp = String(gdData[p][groupsCol] || '').trim();
      var pGroups = parseGroupIdsFromRaw(rawGrp);
      playerGroups[email] = pGroups;
      
      var country = countryCol !== -1 ? String(gdData[p][countryCol] || '') : '';
      var tags = tagsCol !== -1 ? String(gdData[p][tagsCol] || '') : '';
      var stag = stagCol !== -1 ? String(gdData[p][stagCol] || '') : '';
      var trafficType = '', trafficDir = '', trafficSrc = '';
      if (stag) {
        var info = trafficMapping[stag.split('_')[0]];
        if (info && typeof info === 'object') { trafficType = info.type || ''; trafficDir = info.direction || ''; trafficSrc = info.source || ''; }
        else if (info) trafficType = String(info);
      }
      var depS = depSumCol !== -1 ? Number(gdData[p][depSumCol]) || 0 : 0;
      var cashS = cashSumCol !== -1 ? Number(gdData[p][cashSumCol]) || 0 : 0;
      playerDetails[email] = {
        country: country, trafficType: trafficType, trafficDirection: trafficDir, trafficSource: trafficSrc,
        tags: tags, status: disCol !== -1 ? String(gdData[p][disCol] || 'none') : 'none',
        deposits: depS, cashouts: cashS,
        inout: inoutCol !== -1 ? Number(gdData[p][inoutCol]) || 0 : (depS - cashS),
        actualDeposits: depCntCol !== -1 ? Number(gdData[p][depCntCol]) || 0 : 0
      };
    }
    
    Logger.log('RetV2: ' + Object.keys(playerGroups).length + ' players loaded');
    
    // DEBUG: Log sample data to diagnose matching
    var samplePlayerEmails = Object.keys(playerGroups).slice(0, 3);
    samplePlayerEmails.forEach(function(e) {
      Logger.log('DEBUG player "' + e + '" groups: [' + playerGroups[e].join(', ') + ']');
    });
    Logger.log('DEBUG FTD groups to match:');
    ftdGroups.slice(0, 3).forEach(function(g) {
      Logger.log('  "' + g.name + '" groupIds: [' + g.groupIds.join(', ') + ']');
    });
    Logger.log('DEBUG ACTIVE groups to match:');
    activeGroups.slice(0, 3).forEach(function(g) {
      Logger.log('  "' + g.name + '" groupIds: [' + g.groupIds.join(', ') + ']');
    });
    
    // 3. Build player email arrays per group
    function getEmailsInGroup(groupDef) {
      var result = [];
      var gids = groupDef.groupIds;
      for (var email in playerGroups) {
        if (groupIdMatch(playerGroups[email], gids)) {
          result.push(email);
        }
      }
      return result;
    }
    
    var ftdSets = ftdGroups.map(function(g) { return { def: g, emails: getEmailsInGroup(g) }; });
    var activeSets = activeGroups.map(function(g) { return { def: g, emails: getEmailsInGroup(g) }; });
    
    // DEBUG: Log how many players matched each group
    ftdSets.forEach(function(s) {
      Logger.log('DEBUG FTD "' + s.def.name + '" (ids: ' + s.def.groupIds.join(',') + '): ' + s.emails.length + ' players matched');
    });
    activeSets.forEach(function(s) {
      Logger.log('DEBUG ACTIVE "' + s.def.name + '" (ids: ' + s.def.groupIds.join(',') + '): ' + s.emails.length + ' players matched');
    });
    // DEBUG: Check if ANY player has ANY of the GROUPS IDs
    var allTargetIds = [];
    ftdGroups.concat(activeGroups).forEach(function(g) {
      g.groupIds.forEach(function(id) { allTargetIds.push(id); });
    });
    var matchCount = 0;
    for (var email in playerGroups) {
      if (groupIdMatch(playerGroups[email], allTargetIds)) matchCount++;
    }
    Logger.log('DEBUG TOTAL players matching ANY group: ' + matchCount + ' out of ' + Object.keys(playerGroups).length);
    Logger.log('DEBUG All target group IDs: [' + allTargetIds.join(', ') + ']');
    // Sample of actual player group IDs (unique)
    var samplePGIds = {};
    var ct = 0;
    for (var email in playerGroups) {
      if (ct > 50) break;
      playerGroups[email].forEach(function(id) { samplePGIds[id] = true; });
      ct++;
    }
    Logger.log('DEBUG Sample player group IDs: [' + Object.keys(samplePGIds).sort().join(', ') + ']');
    
    // 4. Build result with pre-calculated retention + raw email arrays
    var srcEmailArrays = [];
    var activeEmailArrays = [];
    activeSets.forEach(function(a) { activeEmailArrays.push(a.emails); });
    
    var sourceRows = isMom ? activeSets : ftdSets;
    var result;
    
    if (isWeekly) {
      result = { weeks: [], rows: [], srcEmails: [], activeEmails: activeEmailArrays, playerDetails: playerDetails };
      activeSets.forEach(function(a) { result.weeks.push(a.def.rate); });
      
      sourceRows.forEach(function(src, srcIdx) {
        var srcEmails = src.emails;
        srcEmailArrays.push(srcEmails);
        var srcSet = {};
        srcEmails.forEach(function(e) { srcSet[e] = true; });
        
        var row = { week: src.def.rate, ftdCount: srcEmails.length, retention: [] };
        for (var i = 0; i < activeSets.length; i++) {
          if (i < srcIdx) { row.retention.push({ count: 0, pct: 0 }); continue; }
          var retainedCount = 0;
          activeSets[i].emails.forEach(function(e) { if (srcSet[e]) retainedCount++; });
          row.retention.push({ count: retainedCount, pct: srcEmails.length > 0 ? retainedCount / srcEmails.length : 0 });
        }
        result.rows.push(row);
      });
      result.srcEmails = srcEmailArrays;
    } else {
      result = { months: [], rows: [], srcEmails: [], activeEmails: activeEmailArrays, playerDetails: playerDetails };
      activeSets.forEach(function(a) { result.months.push(a.def.monthName || a.def.rate); });
      
      sourceRows.forEach(function(src, srcIdx) {
        var srcEmails = src.emails;
        srcEmailArrays.push(srcEmails);
        var srcSet = {};
        srcEmails.forEach(function(e) { srcSet[e] = true; });
        
        var row = { month: src.def.monthName || src.def.rate, ftdCount: srcEmails.length, retention: [] };
        for (var i = srcIdx; i < activeSets.length; i++) {
          var retainedCount = 0;
          activeSets[i].emails.forEach(function(e) { if (srcSet[e]) retainedCount++; });
          row.retention.push({ count: retainedCount, pct: srcEmails.length > 0 ? retainedCount / srcEmails.length : 0 });
        }
        result.rows.push(row);
      });
      result.srcEmails = srcEmailArrays;
    }
    
    return result;
  } catch(e) {
    Logger.log('RetV2 error: ' + e.message);
    return { error: e.message };
  }
}

