function getCellPlayers(params) {
  var month = params.month;
  var depositRange = params.depositRange;
  
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  var ftdSheetName = month.toUpperCase() + ' FTD';
  Logger.log('Looking for FTD: ' + ftdSheetName);
  
  var ftdSheet = ss.getSheetByName(ftdSheetName);
  if (!ftdSheet) {
    ftdSheetName = month.charAt(0).toUpperCase() + month.slice(1).toLowerCase() + ' FTD';
    ftdSheet = ss.getSheetByName(ftdSheetName);
  }
  if (!ftdSheet) {
    return {error: 'Sheet not found: ' + month + ' FTD (tried: ' + ftdSheetName + ')'};
  }
  
  // Load GENERAL DASHBOARD
  var gdSheet = ss.getSheetByName('GENERAL DASHBOARD');
  if (!gdSheet) {
    return {error: 'Sheet "GENERAL DASHBOARD" not found'};
  }
  var gdPlayers = getDetailedSheetData(gdSheet);
  // Build lookup map: id → player object
  var gdMap = {};
  gdPlayers.forEach(function(p) { gdMap[p.id] = p; });
  Logger.log('GENERAL DASHBOARD loaded: ' + gdPlayers.length + ' players');
  
  // Get FTD player IDs
  var ftdData = ftdSheet.getDataRange().getValues();
  var ftdHeaders = ftdData[0];
  var ftdIdIdx = -1;
  for (var i = 0; i < ftdHeaders.length; i++) {
    if (ftdHeaders[i] === 'id') ftdIdIdx = i;
  }
  
  var ftdPlayerIds = [];
  for (var i = 1; i < ftdData.length; i++) {
    var id = String(ftdData[i][ftdIdIdx] || '').trim();
    if (id) ftdPlayerIds.push(id);
  }
  Logger.log('FTD player IDs: ' + ftdPlayerIds.length);
  
  function buildPlayerInfo(player) {
    return {
      id: player.id,
      email: player.email,
      country: player.country,
      status: player.status,
      tags: player.tags || '',
      trafficType: player.trafficType || '',
      trafficDirection: player.trafficDirection || '',
      trafficSource: player.trafficSource || '',
      actualDeposits: player.depositCount,
      depositSum: player.depositSum || 0,
      cashoutSum: player.cashoutSum || 0,
      inout: player.inout || 0,
      foundIn: 'GENERAL DASHBOARD'
    };
  }
  
  if (depositRange === 'FTD') {
    var ftdAchieved = [];
    var seenPlayers = {};
    ftdPlayerIds.forEach(function(playerId) {
      if (seenPlayers[playerId]) return;
      var player = gdMap[playerId];
      if (player) {
        ftdAchieved.push(buildPlayerInfo(player));
        seenPlayers[playerId] = true;
      }
    });
    return {
      achieved: ftdAchieved,
      dropped: [],
      month: month,
      range: depositRange,
      total: ftdPlayerIds.length
    };
  }
  
  var parsed = parseDepositRange(depositRange);
  var min = parsed.min;
  var max = parsed.max;
  
  var achieved = [];
  var dropped = [];
  
  ftdPlayerIds.forEach(function(playerId) {
    var player = gdMap[playerId];
    if (!player) return;
    
    var deposits = player.depositCount;
    var inRange = max === null ? (deposits >= min) : (deposits >= min && deposits <= max);
    
    if (inRange) {
      achieved.push(buildPlayerInfo(player));
    } else {
      dropped.push(buildPlayerInfo(player));
    }
  });
  
  Logger.log('Result: ' + achieved.length + ' achieved, ' + dropped.length + ' dropped');
  
  return {
    achieved: achieved,
    dropped: dropped,
    month: month,
    range: depositRange,
    total: ftdPlayerIds.length
  };
}

function getDetailedSheetData(sheet) {
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  
  var idIdx = -1;
  var emailIdx = -1;
  var countryIdx = -1;
  var statusIdx = -1;
  var depositCountIdx = -1;
  var tagsIdx = -1;
  var stagIdx = -1;
  var depositSumIdx = -1;
  var cashoutSumIdx = -1;
  var inoutIdx = -1;
  
  for (var i = 0; i < headers.length; i++) {
    var h = String(headers[i] || '').toLowerCase().trim();
    if (h === 'id' && idIdx === -1) idIdx = i;
    if (h === 'email' && emailIdx === -1) emailIdx = i;
    if (h === 'country' && countryIdx === -1) countryIdx = i;
    if (h === 'disabled') statusIdx = i;
    if (h === 'lifetime_deposit_count_total') depositCountIdx = i;
    if (h === 'tags') tagsIdx = i;
    if (h === 'stag') stagIdx = i;
    if (h === 'lifetime_deposit_sum_total' || h === 'deposit_sum_total') depositSumIdx = i;
    if (h === 'lifetime_cashout_sum_total' || h === 'cashout_sum_total') cashoutSumIdx = i;
    if (h === 'inout' || h === 'in_out' || h === 'lifetime_inout') inoutIdx = i;
  }
  
  var trafficMapping = getTrafficTypeMapping();
  
  var result = [];
  for (var i = 1; i < data.length; i++) {
    var row = data[i];
    if (!row[idIdx]) continue;
    
    var stag = stagIdx !== -1 ? String(row[stagIdx] || '') : '';
    var trafficType = '';
    var trafficDirection = '';
    var trafficSource = '';
    if (stag) {
      var stagPrefix = stag.split('_')[0];
      var info = trafficMapping[stagPrefix];
      if (info) {
        if (typeof info === 'object') {
          trafficType = info.type || '';
          trafficDirection = info.direction || '';
          trafficSource = info.source || '';
        } else {
          trafficType = info; // backwards compat: string value
        }
      }
    }
    
    var depSum = depositSumIdx !== -1 ? Number(row[depositSumIdx]) || 0 : 0;
    var cashSum = cashoutSumIdx !== -1 ? Number(row[cashoutSumIdx]) || 0 : 0;
    var inout = inoutIdx !== -1 ? Number(row[inoutIdx]) || 0 : (depSum - cashSum);
    
    result.push({
      id: String(row[idIdx]).trim(),
      email: emailIdx !== -1 ? String(row[emailIdx] || '') : '',
      country: countryIdx !== -1 ? String(row[countryIdx] || '') : '',
      status: statusIdx !== -1 ? String(row[statusIdx] || 'none') : 'none',
      depositCount: depositCountIdx !== -1 ? Number(row[depositCountIdx]) || 0 : 0,
      tags: tagsIdx !== -1 ? String(row[tagsIdx] || '') : '',
      trafficType: trafficType,
      trafficDirection: trafficDirection,
      trafficSource: trafficSource,
      depositSum: depSum,
      cashoutSum: cashSum,
      inout: inout
    });
  }
  
  return result;
}

