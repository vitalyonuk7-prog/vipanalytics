/** 
 * RUN THIS FROM APPS SCRIPT EDITOR to diagnose group matching.
 * Go to Apps Script → select debugGroupMatching → Run
 * Then check View → Logs
 */
function debugGroupMatching() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // 1. GROUPS sheet
  var groupsSheet = ss.getSheetByName('GROUPS');
  if (!groupsSheet) { Logger.log('ERROR: GROUPS sheet not found'); return; }
  var gData = groupsSheet.getDataRange().getValues();
  var gHeaders = gData[0];
  Logger.log('=== GROUPS SHEET ===');
  Logger.log('Headers: ' + JSON.stringify(gHeaders));
  Logger.log('Total rows: ' + (gData.length - 1));
  
  // Log first 5 rows raw
  for (var r = 1; r < Math.min(6, gData.length); r++) {
    Logger.log('Row ' + r + ': ' + JSON.stringify(gData[r]));
  }
  
  // Find columns
  var gH = gHeaders.map(function(h) { return String(h).trim().toLowerCase(); });
  var groupCol = gH.indexOf('group');
  var nameCol = gH.indexOf('name');
  Logger.log('group col index: ' + groupCol + ', name col index: ' + nameCol);
  
  if (groupCol >= 0) {
    Logger.log('--- Raw GROUP column values (first 10): ---');
    for (var r = 1; r < Math.min(11, gData.length); r++) {
      var raw = gData[r][groupCol];
      Logger.log('  Row ' + r + ': type=' + typeof raw + ', value=' + JSON.stringify(raw) + ', toString="' + String(raw) + '"');
    }
  }
  
  // 2. GENERAL DASHBOARD
  var gdSheet = ss.getSheetByName('GENERAL DASHBOARD');
  if (!gdSheet) { Logger.log('ERROR: GENERAL DASHBOARD not found'); return; }
  var gdData = gdSheet.getDataRange().getValues();
  var gdH = gdData[0].map(function(h) { return String(h).trim().toLowerCase(); });
  var emailCol = gdH.indexOf('email');
  var groupsCol = gdH.indexOf('groups');
  Logger.log('\n=== GENERAL DASHBOARD ===');
  Logger.log('Headers: ' + JSON.stringify(gdData[0]));
  Logger.log('Total rows: ' + (gdData.length - 1));
  Logger.log('email col: ' + emailCol + ', groups col: ' + groupsCol);
  
  if (groupsCol >= 0) {
    Logger.log('--- Raw GROUPS column values (first 10 non-empty): ---');
    var logged = 0;
    for (var p = 1; p < gdData.length && logged < 10; p++) {
      var raw = gdData[p][groupsCol];
      if (raw && String(raw).trim() !== '' && String(raw).trim() !== '[]') {
        Logger.log('  Row ' + p + ': type=' + typeof raw + ', value=' + JSON.stringify(raw) + ', toString="' + String(raw) + '"');
        logged++;
      }
    }
    if (logged === 0) {
      Logger.log('  ⚠️ ALL groups values are EMPTY! No player has any group assigned.');
      // Check if column name is correct
      Logger.log('  All column headers: ' + JSON.stringify(gdH));
      // Try to find any column containing "group"
      for (var c = 0; c < gdH.length; c++) {
        if (gdH[c].indexOf('group') !== -1) {
          Logger.log('  Found column with "group" at index ' + c + ': "' + gdH[c] + '"');
          // Show sample values from this column
          for (var p2 = 1; p2 < Math.min(6, gdData.length); p2++) {
            Logger.log('    Row ' + p2 + ': ' + JSON.stringify(gdData[p2][c]));
          }
        }
      }
    }
    
    // Count non-empty groups
    var nonEmpty = 0;
    for (var p = 1; p < gdData.length; p++) {
      var raw = String(gdData[p][groupsCol] || '').trim();
      if (raw && raw !== '' && raw !== '[]') nonEmpty++;
    }
    Logger.log('Players with non-empty groups: ' + nonEmpty + ' out of ' + (gdData.length - 1));
  }
  
  Logger.log('\n=== DONE ===');
}

