function getBonusReportData(sheetName) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName(sheetName);
    if (!sheet) return { error: 'Sheet "' + sheetName + '" not found' };
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { error: 'No data in sheet' };
    
    var headers = data[0].map(function(h) { return String(h).trim(); });
    var colMap = {};
    headers.forEach(function(h, i) { colMap[h] = i; });
    
    var rows = [];
    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var period = row[colMap['Period']] || '';
      var type = row[colMap['Type']] || '';
      var title = row[colMap['Title']] || '';
      
      if (!period && !type && !title) continue;
      if (String(title).indexOf('Strategy total') === 0) continue;
      if (String(title).indexOf('Aggregated') === 0) continue;
      if (!type) continue;
      
      rows.push({
        period: String(period),
        type: String(type),
        title: String(title),
        currency: String(row[colMap['Currency']] || ''),
        amountIssued: Number(row[colMap['Amount issued']] || 0),
        countIssued: Number(row[colMap['Count of issued']] || 0),
        amountCancelled: Number(row[colMap['Amount cancelled']] || 0),
        countCancelled: Number(row[colMap['Count of cancelled']] || 0),
        countWagerDone: Number(row[colMap['Count if wager done']] || 0),
        amountRejected: Number(row[colMap['Amount rejected']] || 0),
        depositEUR: Number(row[colMap['Deposit sum in EUR']] || 0),
        betsEUR: Number(row[colMap['Bets sum in EUR']] || 0),
        winEUR: Number(row[colMap['Win sum in EUR']] || 0),
        wagerDoneAmount: Number(row[colMap['Amount Wager Done']] || 0),
        wagerDoneEUR: Number(row[colMap['Amount Wager Done in EUR']] || 0),
        total: Number(row[colMap['Total']] || 0),
        totalInEUR: Number(row[colMap['Total in EUR']] || 0),
        countActive: Number(row[colMap['Count of active']] || 0)
      });
    }
    
    return { rows: rows };
  } catch (e) {
    return { error: e.message };
  }
}

