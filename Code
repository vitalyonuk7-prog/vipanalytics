      sheet.setColumnWidth(2, 200);
      sheet.setColumnWidth(4, 200);
      sheet.getRange('A1:B1').setFontWeight('bold').setBackground('#667eea').setFontColor('#fff');
      sheet.getRange('D1').setFontWeight('bold').setBackground('#667eea').setFontColor('#fff');
    }
    
    var data = sheet.getDataRange().getValues();
    var mapping = {};
    var categoryOptions = [];
    
    for (var i = 1; i < data.length; i++) {
      var name = String(data[i][0] || '').trim();
      var cat = String(data[i][1] || '').trim();
