function updateList(listId, updates) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('Lists');
    if (!sheet) return { error: 'Lists sheet not found' };
    var allData = sheet.getDataRange().getValues();
    var headers = allData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var cId = headers.indexOf('id');
    var prioMap = { 1: 'high', 2: 'high', 3: 'medium', 4: 'low', 5: 'low' };
    
    for (var i = 1; i < allData.length; i++) {
      if (String(allData[i][cId]) === listId) {
        var row = i + 1;
        if (updates.name !== undefined) sheet.getRange(row, headers.indexOf('name') + 1).setValue(updates.name);
        if (updates.priority !== undefined) {
          var pVal = typeof updates.priority === 'number' ? (prioMap[updates.priority] || 'medium') : updates.priority;
          sheet.getRange(row, headers.indexOf('priority') + 1).setValue(pVal);
        }
        if (updates.comments !== undefined) {
          var notesCol = headers.indexOf('notes');
          if (notesCol === -1) notesCol = headers.indexOf('comments');
          if (notesCol !== -1) sheet.getRange(row, notesCol + 1).setValue(updates.comments);
        }
        if (updates.players !== undefined) sheet.getRange(row, headers.indexOf('players') + 1).setValue(JSON.stringify(updates.players));
        if (updates.status !== undefined) {
          var statusCol = headers.indexOf('status');
          if (statusCol !== -1) sheet.getRange(row, statusCol + 1).setValue(updates.status);
        }
        var updCol = headers.indexOf('updated');
        if (updCol !== -1) sheet.getRange(row, updCol + 1).setValue(new Date());
        return { success: true };
      }
    }
    return { error: 'List not found' };
  } catch(e) {
    return { error: e.message };
  }
}

