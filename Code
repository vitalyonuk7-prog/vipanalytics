// =============================================
// ONBOARDING — CREATE GOOGLE MEET CALLS
// =============================================
function createOnboardingMeetings(params) {
  // params: { userEmail, tutorEmail (per day), days: [{index, name, date, tutorEmail}], planName }
  try {
    var calendar = CalendarApp.getDefaultCalendar();
    var results = [];
    var errors = [];

    (params.days || []).forEach(function(day) {
      if (!day.date || !day.tutorEmail) return; // skip days without tutor or date

      try {
        var dateObj = new Date(day.date + 'T10:00:00'); // 10:00 Kyiv default
        var endObj  = new Date(day.date + 'T10:30:00'); // 30 min

        var title = '[Onboarding] ' + params.planName + ' - ' + (day.name || 'Day '+(day.index+1));
        var guests = [params.userEmail, day.tutorEmail].filter(function(e, i, arr) { return e && arr.indexOf(e) === i; });

        var event = calendar.createEvent(title, dateObj, endObj, {
          description: 'Onboarding session: ' + (day.name||'Day '+(day.index+1)) + ' | Trainee: ' + params.userEmail + ' | Tutor: ' + day.tutorEmail,
          guests: guests.join(','),
          sendInvites: true
        });

        // Add Google Meet conference via Advanced Calendar Service
        var meetUrl = null;
        try {
          var advEvent = Calendar.Events.patch(
            { conferenceData: { createRequest: { requestId: Utilities.getUuid(), conferenceSolutionKey: { type: 'hangoutsMeet' } } } },
            'primary', event.getId(), { conferenceDataVersion: 1 }
          );
          var eps = advEvent.conferenceData && advEvent.conferenceData.entryPoints;
          if (eps) {
            var videoEp = eps.filter(function(e){ return e.entryPointType === 'video'; })[0];
            if (videoEp) meetUrl = videoEp.uri;
          }
        } catch(meetErr) {
          // Meet API may not be enabled - still create event without Meet
          Logger.log('Meet conference creation failed: ' + meetErr);
        }

        results.push({
          dayIndex: day.index,
          dayName: day.name,
          date: day.date,
          eventId: event.getId(),
          meetUrl: meetUrl,
          calUrl: event.getOriginalCalendarId ? null : 'https://calendar.google.com/calendar/r/eventedit/'+event.getId()
        });

      } catch(dayErr) {
        errors.push('Day '+(day.index+1)+': '+dayErr.message);
      }
    });

    return { success: true, meetings: results, errors: errors };
  } catch(e) {
    return { error: e.message };
  }
}


// =============================================
// ONBOARDING SCHEDULING - Free/Busy + Single Meeting
// =============================================
function getFreeBusy(params) {
  // Uses CalendarApp to get busy slots for each email
  try {
    var startOfDay = new Date(params.date + 'T07:00:00');
    var endOfDay   = new Date(params.date + 'T22:00:00');
    var busy = {};
    params.emails.forEach(function(email) {
      busy[email] = [];
      try {
        // Get all calendars we have access to for this user
        var cals = CalendarApp.getCalendarsByName(email);
        // Also try by ID (email = calendar ID for Google accounts)
        var cal = CalendarApp.getCalendarById(email);
        var allCals = cal ? [cal] : cals;
        allCals.forEach(function(c) {
          var events = c.getEvents(startOfDay, endOfDay);
          events.forEach(function(ev) {
            if (ev.getMyStatus() !== CalendarApp.GuestStatus.NO) {
              busy[email].push({
                start: ev.getStartTime().toISOString(),
                end: ev.getEndTime().toISOString()
              });
            }
          });
        });
      } catch(e2) {
        Logger.log('FreeBusy error for ' + email + ': ' + e2);
      }
    });
    return { success: true, busy: busy };
  } catch(e) {
    return { error: e.message };
  }
}

function createSingleMeeting(params) {
  try {
    var tz = 'Europe/Kiev';
    var guests = [params.userEmail, params.tutorEmail]
      .filter(function(e,i,a){ return e && a.indexOf(e)===i; })
      .map(function(e){ return { email: e }; });

    // Single API call — create event WITH Meet conference in one request
    var eventResource = {
      summary: params.title,
      description: params.description || '',
      start: { dateTime: params.date + 'T' + params.startTime + ':00', timeZone: tz },
      end:   { dateTime: params.date + 'T' + params.endTime   + ':00', timeZone: tz },
      attendees: guests,
      conferenceData: {
        createRequest: {
          requestId: params.date + '-' + params.startTime + '-' + params.userEmail.split('@')[0],
          conferenceSolutionKey: { type: 'hangoutsMeet' }
        }
      }
    };

    var created = Calendar.Events.insert(eventResource, 'primary', {
      conferenceDataVersion: 1,
      sendUpdates: 'all'
    });

    var meetUrl = null;
    var eps = (created.conferenceData && created.conferenceData.entryPoints) || [];
    for (var i = 0; i < eps.length; i++) {
      if (eps[i].entryPointType === 'video') { meetUrl = eps[i].uri; break; }
    }

    Logger.log('createSingleMeeting: id=' + created.id + ' meetUrl=' + meetUrl);
    return { success: true, eventId: created.id, meetUrl: meetUrl };
  } catch(e) {
    Logger.log('createSingleMeeting ERROR: ' + e.message);
    return { error: e.message };
  }
}

