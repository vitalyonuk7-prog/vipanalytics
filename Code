// ==========================================

function getPaymentsData() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('PAYMENTS');
    if (!sheet) return { error: 'Sheet "PAYMENTS" not found' };
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { error: 'No data in PAYMENTS sheet' };
    
    var headers = data[0].map(function(h) { return String(h).trim(); });
    var headersLower = headers.map(function(h) { return h.toLowerCase(); });
    
    function findCol() {
      for (var i = 0; i < arguments.length; i++) {
        var key = String(arguments[i]).toLowerCase();
        for (var j = 0; j < headersLower.length; j++) {
          if (headersLower[j] === key) return j;
        }
      }
      // Partial match fallback
      for (var i = 0; i < arguments.length; i++) {
        var key = String(arguments[i]).toLowerCase();
        for (var j = 0; j < headersLower.length; j++) {
          if (headersLower[j].indexOf(key) !== -1 || key.indexOf(headersLower[j]) !== -1) return j;
        }
      }
      return -1;
    }
    
    var cEmail = findCol('email', 'player email', 'e-mail');
    var cCreated = findCol('created at', 'createdat', 'created', 'date created', 'date');
    var cFinished = findCol('finished at', 'finishedat', 'finished', 'date finished');
    var cType = findCol('type');
    var cTypeTotal = findCol('type total', 'typetotal', 'type_total');
    var cManager = findCol('manager');
    var cCountry = findCol('country');
    var cPaySys = findCol('payment system', 'paymentsystem', 'payment_system', 'pay system', 'system');
    var cProvider = findCol('provider');
    var cSuccess = findCol('success', 'status', 'is_success', 'result');
    var cCurrency = findCol('currency');
    var cAmount = findCol('amount', 'sum', 'value');
    var cPlayer = findCol('player', 'player name', 'name');
    var cBonusCode = findCol('bonus code', 'bonuscode', 'bonus_code', 'promo code', 'promocode');
    
    var rows = [];
    var types = {}, typeTotals = {}, managers = {}, countries = {}, paymentSystems = {}, providers = {};
    
    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var email = cEmail >= 0 ? String(row[cEmail] || '').trim().toLowerCase() : '';
      var type = cType >= 0 ? String(row[cType] || '').trim() : '';
      var typeTotal = cTypeTotal >= 0 ? String(row[cTypeTotal] || '').trim() : '';
      var manager = cManager >= 0 ? String(row[cManager] || '').trim() : '';
      var country = cCountry >= 0 ? String(row[cCountry] || '').trim() : '';
      var paymentSystem = cPaySys >= 0 ? String(row[cPaySys] || '').trim() : '';
      var provider = cProvider >= 0 ? String(row[cProvider] || '').trim() : '';
      var currency = cCurrency >= 0 ? String(row[cCurrency] || '').trim() : '';
      var amount = cAmount >= 0 ? Number(row[cAmount] || 0) : 0;
      var player = cPlayer >= 0 ? String(row[cPlayer] || '').trim() : '';
      var bonusCode = cBonusCode >= 0 ? String(row[cBonusCode] || '').trim() : '';
      
      var created = '';
      if (cCreated >= 0 && row[cCreated]) {
        var cd = row[cCreated];
        if (cd instanceof Date) created = Utilities.formatDate(cd, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
        else created = String(cd);
      }
      var finished = '';
      if (cFinished >= 0 && row[cFinished]) {
        var fd = row[cFinished];
        if (fd instanceof Date) finished = Utilities.formatDate(fd, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
        else finished = String(fd);
      }
      
      var success = false;
      if (cSuccess >= 0) {
        var sv = row[cSuccess];
        var svs = String(sv).toLowerCase().trim();
        success = sv === true || sv === 1 || svs === 'true' || svs === 'success' || svs === 'yes' || svs === 'ok' || svs === 'approved' || svs === 'completed' || svs === 'accepted' || svs === '1';
      }
      
      if (!email && !type && !amount) continue;
      
      rows.push({
        email: email, player: player, createdAt: created, finishedAt: finished,
        type: type, typeTotal: typeTotal, manager: manager, country: country,
        paymentSystem: paymentSystem, provider: provider,
        success: success, currency: currency, amount: amount,
        bonusCode: bonusCode
      });
      
      if (type) types[type] = true;
      if (typeTotal) typeTotals[typeTotal] = true;
      if (manager) managers[manager] = true;
      if (country) countries[country] = true;
      if (paymentSystem) paymentSystems[paymentSystem] = true;
      if (provider) providers[provider] = true;
    }
    
    return {
      rows: rows,
      headers: headers,
      columnMap: { email:cEmail, created:cCreated, finished:cFinished, type:cType, typeTotal:cTypeTotal, manager:cManager, country:cCountry, paymentSystem:cPaySys, provider:cProvider, success:cSuccess, currency:cCurrency, amount:cAmount, player:cPlayer, bonusCode:cBonusCode },
      filters: {
        types: Object.keys(types).sort(),
        typeTotals: Object.keys(typeTotals).sort(),
        managers: Object.keys(managers).sort(),
        countries: Object.keys(countries).sort(),
        paymentSystems: Object.keys(paymentSystems).sort(),
        providers: Object.keys(providers).sort()
      }
    };
  } catch (e) {
    return { error: e.message };
  }
}

