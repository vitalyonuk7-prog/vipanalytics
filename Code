function getAdminPanelData() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var result = { users: [], pages: [], allRoles: [], rolePermissions: {} };
    
    var accessSheet = ss.getSheetByName('ACCESS');
    if (accessSheet) {
      var aData = accessSheet.getDataRange().getValues();
      var aHeaders = aData[0].map(function(h) { return String(h).trim().toLowerCase(); });
      var seenRoles = {};
      
      for (var i = 1; i < aData.length; i++) {
        var user = {};
        aHeaders.forEach(function(h, idx) { user[h] = String(aData[i][idx] || '').trim(); });
        user._row = i + 1;
        result.users.push(user);
        if (user.role) seenRoles[user.role.toLowerCase()] = true;
      }
      result.allRoles = Object.keys(seenRoles).sort();
    }
    if (result.allRoles.length === 0) result.allRoles = ['admin', 'user'];
    
    var defaultPages = getDefaultPages_();
    result.pages = defaultPages;
    
    // Read/Create ROLES sheet (rows=roles, cols=pages)
    var rolesSheet = ss.getSheetByName('ROLES');
    
    if (rolesSheet) {
      var firstHeader = String(rolesSheet.getRange(1, 1).getValue()).trim().toLowerCase();
      if (firstHeader !== 'role') {
        Logger.log('ROLES sheet invalid (first header: ' + firstHeader + '), rebuilding...');
        ss.deleteSheet(rolesSheet);
        rolesSheet = null;
      }
    }
    
    if (!rolesSheet) {
      rolesSheet = ss.insertSheet('ROLES');
      var pageIds = defaultPages.map(function(p) { return p.id; });
      var headers = ['role'].concat(pageIds);
      var allData = [headers];
      
      result.allRoles.forEach(function(roleName) {
        var row = [roleName];
        pageIds.forEach(function() { row.push('TRUE'); });
        allData.push(row);
      });
      
      // Write all at once (faster + no bugs)
      rolesSheet.getRange(1, 1, allData.length, allData[0].length).setValues(allData);
      rolesSheet.getRange(1, 1, 1, headers.length).setFontWeight('bold');
      rolesSheet.autoResizeColumns(1, headers.length);
      Logger.log('ROLES sheet created: ' + headers.length + ' cols, ' + result.allRoles.length + ' roles');
    }
    
    var rData = rolesSheet.getDataRange().getValues();
    var rHeaders = rData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var roleColIdx = rHeaders.indexOf('role');
    
    // Add missing page columns (avoiding duplicates)
    var existingPageMap = {};
    rHeaders.forEach(function(h) { if (h && h !== 'role') existingPageMap[h] = true; });
    defaultPages.forEach(function(dp) {
      if (!existingPageMap[dp.id]) {
        var lastCol = rolesSheet.getLastColumn() + 1;
        rolesSheet.getRange(1, lastCol).setValue(dp.id).setFontWeight('bold');
        for (var r = 2; r <= rolesSheet.getLastRow(); r++) {
          rolesSheet.getRange(r, lastCol).setValue('TRUE');
        }
        existingPageMap[dp.id] = true;
      }
    });
    
    // Add missing role rows
    var existingRoles = [];
    for (var r = 1; r < rData.length; r++) {
      existingRoles.push(String(rData[r][roleColIdx] || '').trim().toLowerCase());
    }
    result.allRoles.forEach(function(roleName) {
      if (existingRoles.indexOf(roleName) === -1) {
        var row = [roleName];
        for (var c = 1; c < rHeaders.length; c++) row.push('TRUE');
        rolesSheet.appendRow(row);
      }
    });
    
    // Re-read
    rData = rolesSheet.getDataRange().getValues();
    rHeaders = rData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    
    // Merge roles from ROLES sheet into allRoles
    for (var r = 1; r < rData.length; r++) {
      var rn = String(rData[r][roleColIdx] || '').trim().toLowerCase();
      if (rn && result.allRoles.indexOf(rn) === -1) result.allRoles.push(rn);
    }
    result.allRoles.sort();
    
    for (var r = 1; r < rData.length; r++) {
      var roleName = String(rData[r][roleColIdx] || '').trim().toLowerCase();
      if (!roleName) continue;
      result.rolePermissions[roleName] = {};
      for (var c = 0; c < rHeaders.length; c++) {
        if (c === roleColIdx) continue;
        var pageId = rHeaders[c];
        if (!pageId) continue;
        var val = String(rData[r][c] || '').trim().toUpperCase();
        result.rolePermissions[roleName][pageId] = (val === 'TRUE' || val === 'YES' || val === '1');
      }
    }
    
    result.success = true;
    return result;
    
  } catch(e) {
    Logger.log('getAdminPanelData error: ' + e);
    return { error: e.message, users: [], pages: [], allRoles: [] };
  }
}

