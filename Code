function sendSmsWebhook(params) {
  try {
    var email = String(params.email || '').trim();
    var phone = String(params.phone || '').trim();
    var text = String(params.text || '').trim();
    var locale = String(params.locale || 'en').trim();
    var sender = String(params.sender || '').trim();
    
    if (!email) return { error: 'No email' };
    if (!phone) return { error: 'No phone' };
    if (!text) return { error: 'No message text' };
    
    var webhookUrl = getSmsWebhookUrl();
    if (!webhookUrl) return { error: 'Webhook URL not configured' };
    
    var payload = { email: email, phone: phone, text: text, locale: locale, timestamp: new Date().toISOString(), source: 'slotornado_analytics' };
    var response = UrlFetchApp.fetch(webhookUrl, { method: 'post', contentType: 'application/json', payload: JSON.stringify(payload), muteHttpExceptions: true });
    var code = response.getResponseCode();
    
    if (code >= 200 && code < 300) {
      var ss = SpreadsheetApp.getActiveSpreadsheet();
      var logSheet = ss.getSheetByName('SMS_LOG');
      if (!logSheet) {
        logSheet = ss.insertSheet('SMS_LOG');
        logSheet.appendRow(['date', 'sender', 'email', 'phone', 'locale', 'text']);
        logSheet.getRange(1, 1, 1, 6).setFontWeight('bold');
      }
      logSheet.appendRow([new Date().toLocaleString(), sender, email, phone, locale, text]);
      return { success: true };
    } else {
      return { error: 'HTTP ' + code };
    }
  } catch (e) { return { error: e.toString() }; }
}

