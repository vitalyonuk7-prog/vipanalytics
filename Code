    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { role: role, pages: 'all' };
    
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var roleCol = headers.indexOf('role');
    if (roleCol === -1) return { role: role, pages: 'all' };
    
    for (var r = 1; r < data.length; r++) {
      if (String(data[r][roleCol] || '').trim().toLowerCase() === role) {
        var allowed = [];
        for (var c = 0; c < headers.length; c++) {
          if (c === roleCol) continue;
          var pageId = headers[c];
          var val = String(data[r][c] || '').trim().toUpperCase();
          if (pageId && (val === 'TRUE' || val === 'YES' || val === '1')) {
            allowed.push(pageId);
          }
        }
        return { role: role, pages: allowed };
      }
    }
    
    return { role: role, pages: 'all' };
