/******************** CLOSURE ANALYTICS ********************/

function getClosureEnrichment() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var result = { reasons: {}, manualData: {}, appUsers: [] };
    
    // 1. Read profiling closure reasons
    var profSheet = ss.getSheetByName('PROFILING') || ss.getSheetByName('[PROFILING]');
    if (profSheet) {
      var profData = profSheet.getDataRange().getValues();
      if (profData.length > 1) {
        var profHeaders = profData[0].map(function(h) { return String(h || '').trim().toLowerCase(); });
        var profEmailIdx = -1;
        var profClosureReasonIdx = -1;
        
        for (var h = 0; h < profHeaders.length; h++) {
          if (profHeaders[h].indexOf('email') !== -1 && profEmailIdx === -1) profEmailIdx = h;
          if (profHeaders[h].indexOf('closure reason') !== -1 || profHeaders[h] === 'closure_reason') profClosureReasonIdx = h;
        }
        
        if (profEmailIdx !== -1 && profClosureReasonIdx !== -1) {
          for (var r = 1; r < profData.length; r++) {
            var email = String(profData[r][profEmailIdx] || '').trim().toLowerCase();
            var reason = String(profData[r][profClosureReasonIdx] || '').trim();
            if (email && reason) {
              result.reasons[email] = reason;
            }
          }
        }
      }
    }
    
    // 2. Read/Create CLOSURE_DATA sheet (with manager column)
    var closureSheet = ss.getSheetByName('CLOSURE_DATA');
    if (!closureSheet) {
      closureSheet = ss.insertSheet('CLOSURE_DATA');
      closureSheet.appendRow(['player_id', 'email', 'closure_date', 'reopening_date', 'manager', 'notes']);
      closureSheet.getRange(1, 1, 1, 6).setFontWeight('bold');
    } else {
      // Ensure manager column exists
      var existingHeaders = closureSheet.getRange(1, 1, 1, closureSheet.getLastColumn()).getValues()[0];
      var hasManager = existingHeaders.some(function(h) { return String(h).trim().toLowerCase() === 'manager'; });
      if (!hasManager) {
        var nextCol = closureSheet.getLastColumn() + 1;
        closureSheet.getRange(1, nextCol).setValue('manager').setFontWeight('bold');
      }
    }
    
    var closureSheetData = closureSheet.getDataRange().getValues();
    if (closureSheetData.length > 1) {
      var cHeaders = closureSheetData[0].map(function(h) { return String(h || '').trim().toLowerCase(); });
      var cIdIdx = cHeaders.indexOf('player_id');
      var cClosureDateIdx = cHeaders.indexOf('closure_date');
      var cReopeningDateIdx = cHeaders.indexOf('reopening_date');
      var cManagerIdx = cHeaders.indexOf('manager');
      var cNotesIdx = cHeaders.indexOf('notes');
      
      for (var r = 1; r < closureSheetData.length; r++) {
        var pid = String(closureSheetData[r][cIdIdx] || '').trim();
        if (pid) {
          result.manualData[pid] = {
            closureDate: cClosureDateIdx !== -1 ? formatDateVal_(closureSheetData[r][cClosureDateIdx]) : '',
            reopeningDate: cReopeningDateIdx !== -1 ? formatDateVal_(closureSheetData[r][cReopeningDateIdx]) : '',
            manager: cManagerIdx !== -1 ? String(closureSheetData[r][cManagerIdx] || '').trim() : '',
            notes: cNotesIdx !== -1 ? String(closureSheetData[r][cNotesIdx] || '') : ''
          };
        }
      }
    }
    
    // 3. Read app users from ACCESS sheet
    var accessSheet = ss.getSheetByName('ACCESS');
    if (accessSheet) {
      var aData = accessSheet.getDataRange().getValues();
      var aH = aData[0].map(function(h) { return String(h).trim().toLowerCase(); });
      var nameIdx = -1, emailIdx = -1;
      for (var i = 0; i < aH.length; i++) {
        if (aH[i] === 'name' && nameIdx === -1) nameIdx = i;
        if (aH[i] === 'email' && emailIdx === -1) emailIdx = i;
      }
      for (var r = 1; r < aData.length; r++) {
        var uName = nameIdx !== -1 ? String(aData[r][nameIdx] || '').trim() : '';
        var uEmail = emailIdx !== -1 ? String(aData[r][emailIdx] || '').trim() : '';
        if (uName || uEmail) {
          result.appUsers.push(uName || uEmail);
        }
      }
    }
    
    Logger.log('Closure enrichment: ' + Object.keys(result.reasons).length + ' reasons, ' + Object.keys(result.manualData).length + ' manual, ' + result.appUsers.length + ' users');
    return result;
    
  } catch (e) {
    Logger.log('ERROR in getClosureEnrichment: ' + e.toString());
    return { reasons: {}, manualData: {}, appUsers: [], error: e.toString() };
  }
}

function formatDateVal_(val) {
  if (!val) return '';
  if (Object.prototype.toString.call(val) === '[object Date]') {
    return isNaN(val.getTime()) ? '' : Utilities.formatDate(val, Session.getScriptTimeZone(), 'yyyy-MM-dd');
  }
  return String(val).trim();
}

