function getPlayerLists() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('Lists');
    if (!sheet) return { lists: [] };
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { lists: [] };
    
    var headers = data[0].map(function(h) { return String(h).trim().toLowerCase(); });
    
    // Migration: add status column if missing
    if (headers.indexOf('status') === -1) {
      var lastCol = headers.length + 1;
      sheet.getRange(1, lastCol).setValue('status');
      sheet.getRange(1, lastCol).setFontWeight('bold');
      headers.push('status');
    }
    
    var ci = function(name) {
      for (var i = 0; i < headers.length; i++) {
        if (headers[i] === name) return i;
      }
      return -1;
    };
    
    var cId = ci('id');
    var cName = ci('name');
    var cPlayers = ci('players');
    var cPriority = ci('priority');
    var cNotes = ci('notes');
    var cStatus = ci('status');
    var cCreated = ci('created');
    var cUpdated = ci('updated');
    
    var lists = [];
    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var id = cId >= 0 ? String(row[cId] || '') : '';
      if (!id) continue;
      
      var playersJson = cPlayers >= 0 ? String(row[cPlayers] || '[]') : '[]';
      var players;
      try { players = JSON.parse(playersJson); } catch(e) { players = []; }
      
      lists.push({
        id: id,
        name: cName >= 0 ? String(row[cName] || '') : '',
        players: players,
        priority: cPriority >= 0 ? String(row[cPriority] || 'medium') : 'medium',
        notes: cNotes >= 0 ? String(row[cNotes] || '') : '',
        status: cStatus >= 0 ? String(row[cStatus] || 'backlog') : 'backlog',
        created: cCreated >= 0 ? String(row[cCreated] || '') : '',
        updated: cUpdated >= 0 ? String(row[cUpdated] || '') : '',
        rowIndex: i + 1
      });
    }
    
    return { lists: lists };
  } catch(e) {
    return { error: e.message, lists: [] };
  }
}

function savePlayerList(data) {
