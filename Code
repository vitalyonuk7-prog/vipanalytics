function getCellPlayersRetentionV2(params) {
  try {
    var srcLabel = params.srcLabel;   // period label e.g. "05.01 - 11.01"
    var tgtLabel = params.tgtLabel;   // active period label
    var mode = params.mode || 'weekly_ftd';
    var isMom = mode.indexOf('mom') !== -1;
    var isWeekly = mode.indexOf('weekly') !== -1;
    var filterType = isWeekly ? 'week' : 'month';
    
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // 1. Read GROUPS sheet to find src/tgt group IDs
    var groupsSheet = ss.getSheetByName('GROUPS');
    if (!groupsSheet) return { error: 'GROUPS sheet not found' };
    
    var gData = groupsSheet.getDataRange().getValues();
    var gHeaders = gData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    var gGroupCol = gHeaders.indexOf('group');
    var gNameCol = gHeaders.indexOf('name');
    var gRateCol = -1;
    for (var gi = 0; gi < gHeaders.length; gi++) {
      if (gHeaders[gi].indexOf('retention') !== -1 && gHeaders[gi].indexOf('rate') !== -1) { gRateCol = gi; break; }
    }
    var gTypeCol = -1;
    for (var gi = 0; gi < gHeaders.length; gi++) {
      if (gHeaders[gi].indexOf('retention') !== -1 && gHeaders[gi].indexOf('type') !== -1) { gTypeCol = gi; break; }
    }
    
    
    var srcGroupIds = null, tgtGroupIds = null;
    
    for (var r = 1; r < gData.length; r++) {
      var name = String(gData[r][gNameCol] || '').trim();
      var rate = gRateCol >= 0 ? String(gData[r][gRateCol] || '').trim() : '';
      var rType = gTypeCol >= 0 ? String(gData[r][gTypeCol] || '').trim().toLowerCase() : 'week';
      var rawGroup = String(gData[r][gGroupCol] || '').trim();
      var nameLower = name.toLowerCase();
      if (rType !== filterType) continue;
      
      // Match source
      var isSrcType = isMom ? (nameLower.indexOf('active') !== -1) : (nameLower.indexOf('ftd') !== -1);
      if (isSrcType && rate === srcLabel) {
        srcGroupIds = parseGroupIdsFromRaw(rawGroup);
      }
      // Match target (always ACTIVE)
      if (nameLower.indexOf('active') !== -1 && rate === tgtLabel) {
        tgtGroupIds = parseGroupIdsFromRaw(rawGroup);
      }
    }
    
    if (!srcGroupIds) return { error: 'Source group not found for: ' + srcLabel };
    if (!tgtGroupIds) return { error: 'Target group not found for: ' + tgtLabel };
    
    // 2. Read GENERAL DASHBOARD
    var gdSheet = ss.getSheetByName('GENERAL DASHBOARD');
    if (!gdSheet) return { error: 'GENERAL DASHBOARD not found' };
    
    var gdData = gdSheet.getDataRange().getValues();
    var gdH = gdData[0].map(function(h) { return String(h).trim().toLowerCase(); });
    
    var eIdx = gdH.indexOf('email');
    var cIdx = gdH.indexOf('country');
    var grpIdx = gdH.indexOf('groups');
    var disIdx = gdH.indexOf('disabled');
    var fnIdx = gdH.indexOf('first_name');
    var lnIdx = gdH.indexOf('last_name');
    var tagIdx = gdH.indexOf('tags');
    
    // Find deposit/financial columns
    var depSumIdx = -1, cashSumIdx = -1, depCntIdx = -1, inoutIdx = -1, stagIdx = -1;
    for (var h = 0; h < gdH.length; h++) {
      if (gdH[h].indexOf('deposit_sum') !== -1 && gdH[h].indexOf('promo') === -1 && depSumIdx === -1) depSumIdx = h;
      if (gdH[h].indexOf('cashout_sum') !== -1 && cashSumIdx === -1) cashSumIdx = h;
      if (gdH[h] === 'lifetime_deposit_count_total' || gdH[h] === 'deposit_count_total') depCntIdx = h;
      if (gdH[h] === 'inout' || gdH[h] === 'in_out') inoutIdx = h;
      if (gdH[h] === 'stag') stagIdx = h;
    }
    
    var trafficMapping = getTrafficTypeMapping();
    
    // Build player data
    function playerFromRow(row) {
      var stag = stagIdx !== -1 ? String(row[stagIdx] || '') : '';
      var tType = '', tDir = '', tSrc = '';
      if (stag) {
        var info = trafficMapping[stag.split('_')[0]];
        if (info && typeof info === 'object') { tType = info.type || ''; tDir = info.direction || ''; tSrc = info.source || ''; }
        else if (info) tType = String(info);
      }
      var depS = depSumIdx !== -1 ? Number(row[depSumIdx]) || 0 : 0;
      var cashS = cashSumIdx !== -1 ? Number(row[cashSumIdx]) || 0 : 0;
      return {
        id: String(row[eIdx] || '').trim().toLowerCase(),
        email: eIdx !== -1 ? String(row[eIdx] || '') : '',
        country: cIdx !== -1 ? String(row[cIdx] || '') : '',
        status: disIdx !== -1 ? String(row[disIdx] || 'none') : 'none',
        tags: tagIdx !== -1 ? String(row[tagIdx] || '') : '',
        trafficType: tType, trafficDirection: tDir, trafficSource: tSrc,
        actualDeposits: depCntIdx !== -1 ? Number(row[depCntIdx]) || 0 : 0,
        depositSum: depS,
        cashoutSum: cashS,
        inout: inoutIdx !== -1 ? Number(row[inoutIdx]) || 0 : (depS - cashS)
      };
    }
    
    // Find source and target players
    var srcPlayers = {};  // email -> row data
    var tgtEmails = {};
    
    for (var p = 1; p < gdData.length; p++) {
      var email = eIdx !== -1 ? String(gdData[p][eIdx] || '').trim().toLowerCase() : '';
      if (!email) continue;
      var pGroups = grpIdx !== -1 ? parseGroupIdsFromRaw(String(gdData[p][grpIdx] || '')) : [];
      
      var inSrc = groupIdMatch(pGroups, srcGroupIds);
      var inTgt = groupIdMatch(pGroups, tgtGroupIds);
      
      if (inSrc) srcPlayers[email] = gdData[p];
      if (inTgt) tgtEmails[email] = true;
    }
    
    var achieved = [];
    var dropped = [];
    
    for (var email in srcPlayers) {
      var pData = playerFromRow(srcPlayers[email]);
      if (tgtEmails[email]) {
        achieved.push(pData);
      } else {
        dropped.push(pData);
      }
    }
    
    return {
      achieved: achieved,
      dropped: dropped,
      week: srcLabel + ' → ' + tgtLabel,
      range: 'Retention V2',
      total: Object.keys(srcPlayers).length
    };
  } catch(e) {
    return { error: e.message };
  }
}

function getTrafficTypeMapping() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var generalSheet = ss.getSheetByName('GENERAL INFO');
  
  if (!generalSheet) {
    Logger.log('GENERAL INFO sheet not found');
    return {};
  }
  
  var data = generalSheet.getDataRange().getValues();
  var headers = data[0];
  
  var stagIdx = -1, typeIdx = -1, dirIdx = -1, srcIdx = -1;
  
  for (var i = 0; i < headers.length; i++) {
    var h = String(headers[i]).toLowerCase().trim();
    if (h === 'stag') stagIdx = i;
    if (h === 'type') typeIdx = i;
    if (h === 'direction') dirIdx = i;
    if (h === 'source') srcIdx = i;
  }
  
  if (stagIdx === -1 || typeIdx === -1) {
    Logger.log('STAG or TYPE column not found in GENERAL INFO');
    return {};
  }
  
  var mapping = {};
  
  for (var i = 1; i < data.length; i++) {
    var stag = String(data[i][stagIdx] || '').trim();
    var type = String(data[i][typeIdx] || '').trim();
    var direction = dirIdx !== -1 ? String(data[i][dirIdx] || '').trim() : '';
    var source = srcIdx !== -1 ? String(data[i][srcIdx] || '').trim() : '';
    
    if (stag && type) {
      mapping[stag] = {
        type: type,
        direction: direction,
        source: source
      };
    }
  }
  
  Logger.log('Traffic mapping from GENERAL INFO: ' + Object.keys(mapping).length + ' stags');
  return mapping;
}

function extractMonthNumber(sheetName) {
  var months = {
    'january': 1, 'jan': 1,
    'february': 2, 'feb': 2,
    'march': 3, 'mar': 3,
    'april': 4, 'apr': 4,
    'may': 5,
    'june': 6, 'jun': 6,
    'july': 7, 'jul': 7,
    'august': 8, 'aug': 8,
    'september': 9, 'sep': 9, 'sept': 9,
    'october': 10, 'oct': 10,
    'november': 11, 'nov': 11,
    'december': 12, 'dec': 12
  };
  
  var name = sheetName.toLowerCase();
  for (var month in months) {
    if (name.indexOf(month) !== -1) {
      return months[month];
    }
  }
  return 0;
}

function extractMonthName(sheetName) {
  var months = ['January', 'February', 'March', 'April', 'May', 'June', 
                'July', 'August', 'September', 'October', 'November', 'December'];
  var monthNum = extractMonthNumber(sheetName);
  return monthNum > 0 ? months[monthNum - 1] : sheetName;
}

function getRetentionData() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  
  var ftdSheets = [];
  var activeSheets = [];
  
  var weekPattern = /^\d{2}\.\d{2}\s*-\s*\d{2}\.\d{2}/;
  
  sheets.forEach(function(sheet) {
    var name = sheet.getName();
    if (weekPattern.test(name)) return;
    
    if (name.indexOf('FTD') !== -1 && name.indexOf('ACTIVE') === -1) {
      ftdSheets.push(sheet);
    } else if (name.indexOf('ACTIVE') !== -1) {
      activeSheets.push(sheet);
    }
  });
  
  ftdSheets.sort(function(a, b) { return sheets.indexOf(a) - sheets.indexOf(b); });
  activeSheets.sort(function(a, b) { return sheets.indexOf(a) - sheets.indexOf(b); });
  
  Logger.log('=== getRetentionData ===');
  Logger.log('FTD sheets: ' + ftdSheets.map(function(s) { return s.getName(); }).join(', '));
  Logger.log('ACTIVE sheets: ' + activeSheets.map(function(s) { return s.getName(); }).join(', '));
  
  var result = { months: [], rows: [] };
  
  activeSheets.forEach(function(sheet) {
    var monthName = extractMonthName(sheet.getName());
    result.months.push(monthName);
  });
  
  ftdSheets.forEach(function(ftdSheet, ftdIdx) {
    var ftdName = ftdSheet.getName();
    var ftdMonth = extractMonthName(ftdName);
    
    var ftdData = getSheetData(ftdSheet);
    var ftdCount = ftdData.length;
    var ftdPlayerIds = ftdData.map(function(p) { return p.id; });
    
    Logger.log('FTD "' + ftdName + '": ' + ftdCount + ' players, sample IDs: ' + ftdPlayerIds.slice(0, 3).join(', '));
    
    var row = { month: ftdMonth, ftdCount: ftdCount, retention: [] };
    
    for (var i = ftdIdx; i < activeSheets.length; i++) {
      var activeSheet = activeSheets[i];
      var activeData = getSheetData(activeSheet);
      
      var retainedCount = 0;
      ftdPlayerIds.forEach(function(ftdId) {
        var found = activeData.some(function(p) { return p.id === ftdId; });
        if (found) retainedCount++;
      });
      
      // Debug: log if 0 retained but both sheets have data
      if (retainedCount === 0 && ftdCount > 0 && activeData.length > 0) {
        Logger.log('⚠️ 0 retained: "' + ftdName + '" (' + ftdCount + ' players) vs "' + activeSheet.getName() + '" (' + activeData.length + ' players)');
        Logger.log('  FTD IDs sample: ' + ftdPlayerIds.slice(0, 3).join(', '));
        Logger.log('  ACTIVE IDs sample: ' + activeData.slice(0, 3).map(function(p) { return p.id; }).join(', '));
      }
      
      row.retention.push({
        count: retainedCount,
        pct: ftdCount > 0 ? retainedCount / ftdCount : 0
      });
    }
    
    result.rows.push(row);
  });
  
  return result;
}

function getRetentionMoMData() {
