function getPlayerContacts() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('PLAYER_CONTACTS');
    if (!sheet) return { success: true, contacts: {} };
    var data = sheet.getDataRange().getValues();
    var contacts = {};
    for (var i = 1; i < data.length; i++) {
      var email = String(data[i][0] || '').trim().toLowerCase();
      if (!email) continue;
      // Parse date — Google Sheets may return Date object or string
      var rawDate = data[i][1];
      var lastDate = '';
      if (rawDate instanceof Date && !isNaN(rawDate.getTime())) {
        lastDate = Utilities.formatDate(rawDate, 'Europe/Kiev', 'yyyy-MM-dd');
      } else if (rawDate) {
        var s = String(rawDate).trim();
        // Already YYYY-MM-DD?
        if (/^\d{4}-\d{2}-\d{2}/.test(s)) {
          lastDate = s.slice(0, 10);
        } else {
          // Try to parse and reformat
          var d = new Date(s);
          if (!isNaN(d.getTime())) lastDate = Utilities.formatDate(d, 'Europe/Kiev', 'yyyy-MM-dd');
        }
      }
      var history = [];
      try { history = JSON.parse(String(data[i][2] || '[]')); } catch(e) { history = []; }
      // Sanitize history entries
      history = history.map(function(h) {
        if (h instanceof Date && !isNaN(h.getTime())) return Utilities.formatDate(h, 'Europe/Kiev', 'yyyy-MM-dd');
        var hs = String(h).trim();
        if (/^\d{4}-\d{2}-\d{2}/.test(hs)) return hs.slice(0,10);
        var hd = new Date(hs); return (!isNaN(hd.getTime())) ? Utilities.formatDate(hd,'Europe/Kiev','yyyy-MM-dd') : null;
      }).filter(function(h){ return h && h.length === 10; });
      // If history empty but lastDate exists — reconstruct
      if (!history.length && lastDate) history = [lastDate];
      // Sort newest first
      history.sort(function(a,b){ return b > a ? 1 : b < a ? -1 : 0; });
      if (history.length) lastDate = history[0];
      contacts[email] = { lastDate: lastDate, history: history };
    }
    return { success: true, contacts: contacts };
  } catch(e) { return { error: e.message }; }
}

