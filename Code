      var role    = roleIdx    >= 0 ? String(data[i][roleIdx]    || '').trim() : '';
      users.push({ email: email, name: manager || email.split('@')[0], role: role });
    }
    return { success: true, users: users };
  } catch(e) { return { error: e.message }; }
}

