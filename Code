    // Create sheet if not exists
    if (!sheet) {
      sheet = ss.insertSheet('BONUS CATEGORIES');
      sheet.getRange('A1').setValue('Bonus Name');
      sheet.getRange('B1').setValue('Category');
      sheet.getRange('D1').setValue('Category Options');
