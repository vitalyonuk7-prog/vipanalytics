// =============================================
// REAL-TIME POLLING — Change Summary
// =============================================
function getChangeSummary() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var summary = {};

    // Onboarding assignments checksum (most active)
    var asgnSheet = ss.getSheetByName('ONBOARDING_ASSIGNMENTS');
    if (asgnSheet) {
      var asgnData = asgnSheet.getRange(2,1).getValue();
      summary.ob_asgn_len = String(asgnData).length;
      summary.ob_asgn_hash = Utilities.computeDigest(
        Utilities.DigestAlgorithm.MD5,
        String(asgnData).slice(0, 2000)
      ).slice(0,4).map(function(b){ return (b < 0 ? b+256 : b).toString(16).padStart(2,'0'); }).join('');
    }

    // Onboarding plans checksum
    var planSheet = ss.getSheetByName('ONBOARDING_PLANS');
    if (planSheet) {
      var planData = planSheet.getRange(2,1).getValue();
      summary.ob_plans_len = String(planData).length;
    }

    // QA results count
    var qaSheet = ss.getSheetByName('QA_RESULTS');
    if (qaSheet) summary.qa_rows = qaSheet.getLastRow();

    // Timetable
    var ttSheet = ss.getSheetByName('TIMETABLE');
    if (ttSheet) summary.tt_rows = ttSheet.getLastRow();

    summary.ts = new Date().getTime();
    return { success: true, summary: summary };
  } catch(e) {
    return { error: e.message };
  }
}

