      }
    }
    subject = subject.replace(/\{month\}/g, moName).replace(/\{year\}/g, moYear).replace(/\{name\}/g, mgrName);
    bodyText = bodyText.replace(/\{month\}/g, moName).replace(/\{year\}/g, moYear).replace(/\{name\}/g, mgrName);
    var pdfHtml = '<!DOCTYPE html><html><head><meta charset="utf-8"><style>';
    pdfHtml += 'body{font-family:Arial,Helvetica,sans-serif;margin:20px;color:#1e293b;font-size:12px;line-height:1.5} td{vertical-align:top} table{border-collapse:collapse}';
    pdfHtml += '</style></head><body>' + htmlContent + '</body></html>';
    var blob = Utilities.newBlob(pdfHtml, 'text/html', 'report.html').getAs('application/pdf');
    blob.setName('Quality_Report_' + mgrName.replace(/[^a-zA-Z0-9]/g,'_') + '_' + moName + '_' + moYear + '.pdf');
    GmailApp.sendEmail(mgrEmail, subject, bodyText.replace(/\n/g, '\n'), {
      htmlBody: '<div style="font-family:Arial,sans-serif;font-size:14px;color:#333;line-height:1.6">' + bodyText.replace(/\n/g, '<br>') + '</div>',
      attachments: [blob]
    });
    // Track sent status
    var settingsSheet = ss.getSheetByName('QA_SETTINGS');
    if (!settingsSheet) settingsSheet = ss.insertSheet('QA_SETTINGS');
    var key = 'pdf_sent_' + month;
    var sData = settingsSheet.getDataRange().getValues();
    var found = false;
    for (var si = 0; si < sData.length; si++) {
      if (String(sData[si][0]).trim() === key) {
        var list = []; try { list = JSON.parse(String(sData[si][1])); } catch(e) {}
        var entry = list.find(function(x) { return x.email === mgrEmail; });
        if (entry) { entry.sent_at = new Date().toISOString(); entry.sent_by = Session.getActiveUser().getEmail() || ''; }
        else list.push({ email: mgrEmail, sent_at: new Date().toISOString(), sent_by: Session.getActiveUser().getEmail() || '' });
        settingsSheet.getRange(si + 1, 2).setValue(JSON.stringify(list));
        found = true; break;
      }
    }
    if (!found) {
      settingsSheet.appendRow([key, JSON.stringify([{ email: mgrEmail, sent_at: new Date().toISOString(), sent_by: Session.getActiveUser().getEmail() || '' }])]);
    }
    return { success: true, to: mgrEmail };
  } catch(e) { return { error: e.message }; }
}

