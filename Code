function decideTimetableRequest(id, decision, decidedBy) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('TIMETABLE_REQUESTS');
    if (!sheet) return { error: 'Sheet not found' };
    var data = sheet.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][0]) === id) {
        sheet.getRange(i+1, 9).setValue(decision);  // Status
        sheet.getRange(i+1,11).setValue(decidedBy||'');
        sheet.getRange(i+1,12).setValue(new Date().toLocaleString('uk-UA'));
        return { success: true };
      }
    }
    return { error: 'Request not found' };
  } catch(e) { return { error: e.message }; }
}
