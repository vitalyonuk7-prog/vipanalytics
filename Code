// ==========================================
// BONUS ISSUE HISTORY
// ==========================================
function getBonusIssueHistory() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var histSheet = ss.getSheetByName('Bonus Issue History');
    if (!histSheet) return { error: 'Sheet "Bonus Issue History" not found' };

    var histData = histSheet.getDataRange().getValues();
    if (histData.length < 2) return { success: true, rows: [], stages: [] };

    var hdr = histData[0].map(function(h){ return String(h).trim(); });
    function col(name) { return hdr.indexOf(name); }

    var idxStage    = col('Stage');
    var idxAmount   = col('Amount');
    var idxCurrency = col('Currency');
    var idxReceived = col('Date received');
    var idxUpdated  = col('Updated at');
    var idxExpiry   = col('Expiry date');

    if (idxStage < 0 || idxAmount < 0 || idxCurrency < 0) {
      return { error: 'Missing required columns. Found: ' + hdr.join(', ') };
    }

    var rateMap = buildEurRateMap_(ss);
    var stagesSet = {};
    var rows = []; // raw day-level rows

    function fmtDate(d) {
      if (!d) return null;
      var dt = d instanceof Date ? d : new Date(String(d));
      if (isNaN(dt.getTime())) return null;
      return dt.getFullYear() + '-' + String(dt.getMonth()+1).padStart(2,'0') + '-' + String(dt.getDate()).padStart(2,'0');
    }

    for (var i = 1; i < histData.length; i++) {
      var row      = histData[i];
      var stage    = String(row[idxStage]   || '').trim();
      var amount   = parseFloat(row[idxAmount] || 0) || 0;
      var currency = String(row[idxCurrency] || '').trim().toUpperCase();
      if (!stage) continue;
      stagesSet[stage] = true;

      var dRec = idxReceived >= 0 ? fmtDate(row[idxReceived]) : null;
      var dUpd = idxUpdated  >= 0 ? fmtDate(row[idxUpdated])  : null;
      var dExp = idxExpiry   >= 0 ? fmtDate(row[idxExpiry])   : null;

      // Compute EUR amounts using rate from whichever date is available
      function eurForDate(dateStr) {
        if (!dateStr) return 0;
        var moKey = dateStr.slice(0, 7);
        var rate  = (currency !== 'EUR' && currency !== '') ? getEurRate_(rateMap, moKey, currency) : 1;
        return Math.round(amount * rate * 100) / 100;
      }

      rows.push({
        stage:    stage,
        received: dRec,
        updated:  dUpd,
        expiry:   dExp,
        eurRec:   dRec ? eurForDate(dRec) : 0,
        eurUpd:   dUpd ? eurForDate(dUpd) : 0,
        eurExp:   dExp ? eurForDate(dExp) : 0
      });
    }

    var stageOrder = ['Lost','Won','Active','Not activated','Canceled','Expired'];
    var stages = stageOrder.filter(function(s){ return stagesSet[s]; });
    Object.keys(stagesSet).forEach(function(s){ if (stageOrder.indexOf(s) < 0) stages.push(s); });

    return { success: true, rows: rows, stages: stages };
  } catch(e) {
    return { error: e.message };
  }
}

function buildEurRateMap_(ss) {
  // rateMap[YYYY-MM][CURRENCY] = avgRate
  var rateMap = {};
  try {
    var sheets = ['BONUS REPORT [MONTHLY]', 'BONUS REPORT [DAILY]'];
    sheets.forEach(function(sName) {
      var sheet = ss.getSheetByName(sName);
      if (!sheet) return;
      var data = sheet.getDataRange().getValues();
      if (data.length < 2) return;
      var h = data[0].map(function(x){ return String(x).trim(); });
      var cPeriod = h.indexOf('Period');
      var cCur    = h.indexOf('Currency');
      var cTotal  = h.indexOf('Total');
      var cEur    = h.indexOf('Total in EUR');
      if (cPeriod < 0 || cCur < 0 || cTotal < 0 || cEur < 0) return;
      for (var i = 1; i < data.length; i++) {
        var rawPeriod = data[i][cPeriod];
        var cur       = String(data[i][cCur] || '').trim().toUpperCase();
        var total     = parseFloat(data[i][cTotal]) || 0;
        var eur       = parseFloat(data[i][cEur]) || 0;
        if (!cur || cur === 'EUR' || total === 0 || eur === 0) continue;
        var d = rawPeriod instanceof Date ? rawPeriod : new Date(String(rawPeriod));
        if (isNaN(d.getTime())) continue;
        var moKey = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
        if (!rateMap[moKey]) rateMap[moKey] = {};
        if (!rateMap[moKey][cur]) rateMap[moKey][cur] = { sum: 0, eurSum: 0 };
        rateMap[moKey][cur].sum    += total;
        rateMap[moKey][cur].eurSum += eur;
      }
    });
    // Convert to rates
    Object.keys(rateMap).forEach(function(mo) {
      Object.keys(rateMap[mo]).forEach(function(cur) {
        var e = rateMap[mo][cur];
        rateMap[mo][cur] = e.sum > 0 ? e.eurSum / e.sum : 1;
      });
    });
  } catch(e) { Logger.log('buildEurRateMap error: ' + e.message); }
  return rateMap;
}

function getEurRate_(rateMap, moKey, currency) {
  if (!rateMap) return 1;
  // Exact month match
  if (rateMap[moKey] && rateMap[moKey][currency]) return rateMap[moKey][currency];
  // Find closest prior month
  var keys = Object.keys(rateMap).filter(function(k){ return k <= moKey; }).sort();
  for (var i = keys.length - 1; i >= 0; i--) {
    if (rateMap[keys[i]][currency]) return rateMap[keys[i]][currency];
  }
  // Find any month for this currency
  var anyKeys = Object.keys(rateMap).sort();
  for (var j = 0; j < anyKeys.length; j++) {
    if (rateMap[anyKeys[j]][currency]) return rateMap[anyKeys[j]][currency];
  }
  return 1;
}

function getIsoWeek_(date) {
  var d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  var dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
  var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
  return { year: d.getUTCFullYear(), week: Math.ceil((((d - yearStart) / 86400000) + 1) / 7) };
}

