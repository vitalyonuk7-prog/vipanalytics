function getProfilingCompletionByManager() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName('PROFILING') || ss.getSheetByName('[PROFILING]');
    if (!sheet) return { success: true, managers: {}, debug: 'PROFILING sheet not found' };
    
    // Load MANAGER mapping (tag-based)
    var mgrMap = getManagerMapping();
    var tagToMgr = mgrMap.tagToManager || {};
    if (!Object.keys(tagToMgr).length) return { success: true, managers: {}, debug: 'No MANAGER mapping found' };
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return { success: true, managers: {}, debug: 'Sheet empty' };
    
    var headers = data[0].map(function(h) { return String(h).trim(); });
    var headersLower = headers.map(function(h) { return h.toLowerCase(); });
    
    // Find tags column
    var tagsCol = -1;
    for (var ti = 0; ti < headersLower.length; ti++) {
      if (headersLower[ti] === 'tags' || headersLower[ti] === 'tag') { tagsCol = ti; break; }
    }
    if (tagsCol === -1) return { success: true, managers: {}, debug: 'No tags column. Headers: ' + headers.join(' | ') };
    
    // Find VIP confirmation date column
    var vipDateCol = -1;
    for (var vi = 0; vi < headersLower.length; vi++) {
      if (headersLower[vi].indexOf('vip confirm') !== -1 || headersLower[vi] === 'vip_confirmation_date') { vipDateCol = vi; break; }
    }
    
    // Skip system columns
    var skipCols = {};
    headersLower.forEach(function(h, i) {
      if (h === 'tags' || h === 'tag' || h === 'last_webhook_at' || h === '_last_webhook_at' || h === '' || h === 'photo' || h === 'id') skipCols[i] = true;
    });
    
    // Load TYPE mapping for player type detection
    var typeMap = getTypeMapping();
    var tagToType = typeMap.tagToType || {};
    
    var now = new Date();
    var oneMonthAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
    var result = {};
    
    for (var i = 1; i < data.length; i++) {
      var tagsRaw = data[i][tagsCol];
      var playerTags = [];
      if (tagsRaw) {
        var ts = String(tagsRaw).trim();
        if (ts.charAt(0) === '[') { try { playerTags = JSON.parse(ts); } catch(e) { playerTags = [ts]; } }
        else if (ts) { playerTags = ts.split(',').map(function(t) { return t.trim(); }); }
      }
      playerTags = playerTags.map(function(t) { return String(t).toLowerCase().trim().replace(/"/g, ''); });
      
      var playerMgr = null;
      for (var pt = 0; pt < playerTags.length; pt++) {
        if (tagToMgr[playerTags[pt]]) { playerMgr = tagToMgr[playerTags[pt]]; break; }
      }
      if (!playerMgr) continue;
      
      // Detect player type
      var playerType = 'UNKNOWN';
      for (var tt = 0; tt < playerTags.length; tt++) {
        if (tagToType[playerTags[tt]]) { playerType = tagToType[playerTags[tt]]; break; }
      }
      
      var mgrKey = playerMgr.toLowerCase();
      if (!result[mgrKey]) result[mgrKey] = { name: playerMgr, total: 0, filled: 0, players: 0, playersFull: 0, totalOld: 0, filledOld: 0, playersOld: 0, playersFullOld: 0, cols: {}, types: {} };
      
      // Per-type stats
      if (!result[mgrKey].types[playerType]) result[mgrKey].types[playerType] = { total: 0, filled: 0, players: 0, totalOld: 0, filledOld: 0, playersOld: 0, cols: {} };
      
      var isOld = false;
      if (vipDateCol >= 0) {
        var vDate = data[i][vipDateCol];
        if (vDate instanceof Date) { isOld = vDate <= oneMonthAgo; }
        else if (vDate) { var parsed = new Date(String(vDate)); if (!isNaN(parsed.getTime())) isOld = parsed <= oneMonthAgo; }
      }
      
      var pT = 0, pF = 0;
      for (var ci = 0; ci < headers.length; ci++) {
        if (skipCols[ci]) continue;
        pT++;
        var colName = headers[ci];
        if (!result[mgrKey].cols[colName]) result[mgrKey].cols[colName] = { total: 0, filled: 0, totalOld: 0, filledOld: 0 };
        if (!result[mgrKey].types[playerType].cols[colName]) result[mgrKey].types[playerType].cols[colName] = { total: 0, filled: 0, totalOld: 0, filledOld: 0 };
        result[mgrKey].cols[colName].total++;
        result[mgrKey].types[playerType].cols[colName].total++;
        var val = data[i][ci];
        var isFilled = val !== undefined && val !== null && val !== '' && String(val).trim() !== '';
        if (isFilled) { pF++; result[mgrKey].cols[colName].filled++; result[mgrKey].types[playerType].cols[colName].filled++; }
        if (isOld) { result[mgrKey].cols[colName].totalOld++; result[mgrKey].types[playerType].cols[colName].totalOld++; if (isFilled) { result[mgrKey].cols[colName].filledOld++; result[mgrKey].types[playerType].cols[colName].filledOld++; } }
      }
      result[mgrKey].total += pT;
      result[mgrKey].filled += pF;
      result[mgrKey].players++;
      if (pT > 0 && pF / pT >= 0.8) result[mgrKey].playersFull++;
      // Type stats
      result[mgrKey].types[playerType].total += pT;
      result[mgrKey].types[playerType].filled += pF;
      result[mgrKey].types[playerType].players++;
      if (isOld) {
        result[mgrKey].totalOld += pT; result[mgrKey].filledOld += pF; result[mgrKey].playersOld++;
        if (pT > 0 && pF / pT >= 0.8) result[mgrKey].playersFullOld++;
        result[mgrKey].types[playerType].totalOld += pT;
        result[mgrKey].types[playerType].filledOld += pF;
        result[mgrKey].types[playerType].playersOld++;
      }
    }
    
    return { success: true, managers: result, debug: 'Tags col: ' + headers[tagsCol] + '. Mgrs: ' + Object.keys(result).length + '. Players matched: ' + Object.keys(result).reduce(function(s,k){return s+result[k].players;},0) };
  } catch(e) { return { error: e.toString() }; }
}

