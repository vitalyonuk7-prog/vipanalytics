function getVocabulary() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var vocabSheet = ss.getSheetByName('VOCABULARY');
    
    if (!vocabSheet) {
      Logger.log('VOCABULARY sheet not found - using empty vocabulary');
