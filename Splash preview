// ==========================================
// TRAFFIC ANALYTICS
// ==========================================
var trafficMode = 'monthly'; // monthly | weekly
var trafficGroupBy = 'trafficType'; // trafficType | trafficSource | trafficDirection
var trafficChart = null;
var trafficPlayersCache = {}; // period → { achieved: [], dropped: [] }
var trafficFilters = { periods: [], types: [] };
var trafficAllPeriods = [];
var trafficAllTypes = [];

function populateTrafficFilters() {
  var periods = [];
  if (trafficMode === 'monthly' && retentionData && retentionData.months) {
    periods = retentionData.months.slice();
  } else if (trafficMode === 'weekly' && weeklyRetentionData && weeklyRetentionData.weeks) {
    periods = weeklyRetentionData.weeks.slice();
  }
  trafficAllPeriods = periods;
  if (trafficFilters.periods.length === 0) trafficFilters.periods = periods.slice();
  
  // Period checkboxes
  var periodHtml = '';
  periods.forEach(function(p) {
    var checked = trafficFilters.periods.includes(p);
    periodHtml += '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (checked ? '#667eea' : '#f1f5f9') + ';color:' + (checked ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.2s">';
    periodHtml += '<input type="checkbox" ' + (checked ? 'checked' : '') + ' onchange="toggleTrafficFilter(\'periods\',\'' + p.replace(/'/g, "\\'") + '\')" style="display:none">' + p + '</label>';
  });
  document.getElementById('trafficPeriodChecks').innerHTML = periodHtml;
  
  // Collect types from retention players
  var typesSet = new Set();
  retentionPlayersCellMap.forEach(function(cellData) {
    if (!cellData) return;
    [].concat(cellData.achieved || [], cellData.dropped || []).forEach(function(p) {
      var type = getPlayerTypeFromTags(getEffectiveTags(p));
      if (type && type !== 'UNKNOWN') typesSet.add(type);
    });
  });
  trafficAllTypes = [...typesSet].sort();
  
  // Type checkboxes
  var typeHtml = '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (trafficFilters.types.length === 0 ? '#667eea' : '#f1f5f9') + ';color:' + (trafficFilters.types.length === 0 ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600"><input type="checkbox" ' + (trafficFilters.types.length === 0 ? 'checked' : '') + ' onchange="toggleTrafficFilterAll(\'types\')" style="display:none">All</label>';
  trafficAllTypes.forEach(function(t) {
    var checked = trafficFilters.types.includes(t);
    typeHtml += '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (checked ? '#667eea' : '#f1f5f9') + ';color:' + (checked ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.2s">';
    typeHtml += '<input type="checkbox" ' + (checked ? 'checked' : '') + ' onchange="toggleTrafficFilter(\'types\',\'' + t.replace(/'/g, "\\'") + '\')" style="display:none">' + t + '</label>';
  });
  document.getElementById('trafficTypeChecks').innerHTML = typeHtml;
  updateTrafficFilterBadge();
}

function toggleTrafficFilter(filterType, value) {
  var idx = trafficFilters[filterType].indexOf(value);
  if (idx > -1) trafficFilters[filterType].splice(idx, 1);
  else trafficFilters[filterType].push(value);
  renderTrafficAnalytics();
}

function toggleTrafficFilterAll(filterType) {
  trafficFilters[filterType] = [];
  renderTrafficAnalytics();
}

function updateTrafficFilterBadge() {
  var badge = document.getElementById('trafficFilterBadge');
  if (!badge) return;
  var count = 0;
  if (trafficFilters.periods.length > 0 && trafficFilters.periods.length < trafficAllPeriods.length) count++;
  if (trafficFilters.types.length > 0) count++;
  badge.style.display = count > 0 ? 'inline' : 'none';
  if (count > 0) badge.textContent = count + ' active';
}

function trafficPlayerMatchesFilter(player) {
  if (trafficFilters.types.length > 0) {
    var type = getPlayerTypeFromTags(getEffectiveTags(player));
    if (!trafficFilters.types.includes(type)) return false;
  }
  return true;
}

function switchTrafficMode(mode) {
  trafficMode = mode;
  trafficFilters.periods = []; // reset periods for new mode
  document.getElementById('trafficMonthlyBtn').classList.toggle('active', mode === 'monthly');
  document.getElementById('trafficWeeklyBtn').classList.toggle('active', mode === 'weekly');
  renderTrafficAnalytics();
}

function switchTrafficGroup(group) {
  trafficGroupBy = group;
  document.getElementById('trafficGroupType').classList.toggle('active', group === 'trafficType');
  document.getElementById('trafficGroupSource').classList.toggle('active', group === 'trafficSource');
  document.getElementById('trafficGroupDirection').classList.toggle('active', group === 'trafficDirection');
  renderTrafficAnalytics();
}

function getTrafficData() {
  trafficPlayersCache = {};
  var periods = [];
  var periodData = {};
  var selectedPeriods = trafficFilters.periods;
  var hasTypeFilter = trafficFilters.types.length > 0;
  
  if (trafficMode === 'monthly' && retentionData && retentionData.rows) {
    var months = retentionData.months || [];
    // Filter periods
    periods = selectedPeriods.length > 0 ? months.filter(function(m) { return selectedPeriods.includes(m); }) : months.slice();
    
    retentionData.rows.forEach(function(row, rowIdx) {
      var ftdMonth = row.month;
      if (!ftdMonth || !periods.includes(ftdMonth)) return;
      
      periodData[ftdMonth] = {};
      
      var lastActiveMonth = null;
      for (var i = months.length - 1; i >= rowIdx; i--) {
        var cellKey = normCellKey(ftdMonth + '|' + months[i]);
        if (retentionPlayersCellMap.has(cellKey)) { lastActiveMonth = months[i]; break; }
      }
      if (!lastActiveMonth) return;
      
      var lastCellData = retentionPlayersCellMap.get(normCellKey(ftdMonth + '|' + lastActiveMonth));
      if (!lastCellData) return;
      
      var achieved = (lastCellData.achieved || []).filter(function(p) { return !hasTypeFilter || trafficPlayerMatchesFilter(p); });
      var dropped = (lastCellData.dropped || []).filter(function(p) { return !hasTypeFilter || trafficPlayerMatchesFilter(p); });
      trafficPlayersCache[ftdMonth] = { achieved: achieved, dropped: dropped };
      
      [].concat(achieved, dropped).forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (!periodData[ftdMonth][g]) periodData[ftdMonth][g] = { ftd: 0, active: 0, dropped: 0 };
        periodData[ftdMonth][g].ftd++;
      });
      achieved.forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (periodData[ftdMonth][g]) periodData[ftdMonth][g].active++;
      });
      dropped.forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (periodData[ftdMonth][g]) periodData[ftdMonth][g].dropped++;
      });
    });
    
  } else if (trafficMode === 'weekly' && weeklyRetentionData && weeklyRetentionData.rows) {
    var weeks = weeklyRetentionData.weeks || [];
    periods = selectedPeriods.length > 0 ? weeks.filter(function(w) { return selectedPeriods.includes(w); }) : weeks.slice();
    
    weeklyRetentionData.rows.forEach(function(row, rowIdx) {
      var ftdWeek = row.week;
      if (!ftdWeek || !periods.includes(ftdWeek)) return;
      
      periodData[ftdWeek] = {};
      
      var lastActiveWeek = null;
      for (var i = weeks.length - 1; i >= rowIdx; i--) {
        var cellKey = normCellKey(ftdWeek + '|' + weeks[i]);
        if (retentionPlayersCellMap.has(cellKey)) { lastActiveWeek = weeks[i]; break; }
      }
      if (!lastActiveWeek) return;
      
      var lastCellData = retentionPlayersCellMap.get(normCellKey(ftdWeek + '|' + lastActiveWeek));
      if (!lastCellData) return;
      
      var achieved = (lastCellData.achieved || []).filter(function(p) { return !hasTypeFilter || trafficPlayerMatchesFilter(p); });
      var dropped = (lastCellData.dropped || []).filter(function(p) { return !hasTypeFilter || trafficPlayerMatchesFilter(p); });
      trafficPlayersCache[ftdWeek] = { achieved: achieved, dropped: dropped };
      
      [].concat(achieved, dropped).forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (!periodData[ftdWeek][g]) periodData[ftdWeek][g] = { ftd: 0, active: 0, dropped: 0 };
        periodData[ftdWeek][g].ftd++;
      });
      achieved.forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (periodData[ftdWeek][g]) periodData[ftdWeek][g].active++;
      });
      dropped.forEach(function(p) {
        var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
        if (periodData[ftdWeek][g]) periodData[ftdWeek][g].dropped++;
      });
    });
  }
  
  var allGroups = new Set();
  Object.values(periodData).forEach(function(groups) {
    Object.keys(groups).forEach(function(g) { allGroups.add(g); });
  });
  
  return { periods: periods, groups: [...allGroups].sort(), data: periodData };
}

function renderTrafficAnalytics() {
  if (!retentionCellsLoaded) {
