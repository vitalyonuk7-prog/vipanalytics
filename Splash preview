function renderDashQuickStats(){if(!vipData||!vipData.metrics)return;var activeTab=window.currentDashboardTab||'';const sums=vipData.metrics.sums;const vocabulary=vipData.vocabulary||{};const grid=document.getElementById('dashQuickStats');if(!grid)return;

