}

function sortBonusPieModal(key) {
  if(_modalSort.key === key) _modalSort.dir = _modalSort.dir==='asc'?'desc':'asc';
  else { _modalSort.key = key; _modalSort.dir = key==='label'?'asc':'desc'; }
  renderBonusPieModalContent();
}

function renderBonusPieModalContent() {
  var pieIdx = window._pieModalIdx;
  var pies = window._bonusPieConfigs;
  var byType = window._bonusPieData;
  var p = pies[pieIdx];
  var tc = getBonusTypeColors();
  var items = Object.keys(byType).map(function(t){return{label:t,value:byType[t][p.key]};}).filter(function(i){return i.value>0;});
  var total = items.reduce(function(a,i){return a+i.value;},0);
  items.forEach(function(i){ i.pct = total>0?(i.value/total)*100:0; });
  
  var sk = _modalSort.key, sd = _modalSort.dir;
  items.sort(function(a,b){
    var va=a[sk],vb=b[sk];
    if(typeof va==='string') return sd==='asc'?va.localeCompare(vb):vb.localeCompare(va);
    return sd==='asc'?va-vb:vb-va;
  });
  
  var thS = 'padding:12px;color:#fff;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;cursor:pointer;user-select:none';
  var html = '<div style="display:flex;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center" id="bonusPieModal" onclick="if(event.target.id===\'bonusPieModal\')this.style.display=\'none\'">';
