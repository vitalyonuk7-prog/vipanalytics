function getPlayerType(player) {
  if (!player) return '';
  // 1. Try dashboardGroups (for VIP dashboard context)
  var groups = window.dashboardGroups || [];
  if (groups.length > 0 && typeof dynamicTabsData !== 'undefined') {
    for (var g = 0; g < groups.length; g++) {
      var gd = dynamicTabsData[groups[g].id];
      if (!gd || !gd.allPlayers) continue;
      var gPlayers = [].concat(gd.allPlayers.vip || [], gd.allPlayers.silentVip || []);
      for (var j = 0; j < gPlayers.length; j++) {
        if ((player.email && gPlayers[j].email === player.email) || (player.id && gPlayers[j].id === player.id)) return groups[g].displayName;
      }
    }
  }
  // 2. Try TYPE sheet mapping (for profiling context)
  if (player.tags && player.tags.length > 0 && typeof getPlayerTypeFromTags === 'function') {
    var mapped = getPlayerTypeFromTags(player.tags);
    if (mapped && mapped !== 'UNKNOWN') return mapped;
  }
  // 3. Hardcoded fallback
  if (player.tags && Array.isArray(player.tags)) {
    for (var i = 0; i < player.tags.length; i++) {
      var tag = String(player.tags[i] || '').toLowerCase();
      if (tag.indexOf('ann_pre_vip') !== -1) return 'PRE-VIP';
      if (tag.indexOf('ann_vip') !== -1) return 'VIP';
      if (tag.indexOf('pre_ann') !== -1) return 'SILENT PRE-VIP';
      if (tag.indexOf('ann') !== -1) return 'SILENT VIP';
    }
  }
  return '';
}

function getTypeTotalGroup(typeName) {
  // 1. Use typeToTotal direct mapping (most reliable)
  var t2t = window.typeToTotal || {};
  if (t2t[typeName]) return t2t[typeName];
  
  // 2. Check totalGroups values
  var tg = window.totalGroups || {};
  for (var grpName in tg) {
    if (tg[grpName].indexOf(typeName) !== -1) return grpName;
  }
  
  // 3. Match via dashboardGroups: displayName→id→totalGroups
  var groups = window.dashboardGroups || [];
  for (var i = 0; i < groups.length; i++) {
    if (groups[i].displayName === typeName) {
      // Check typeToTotal by id
      if (t2t[groups[i].id]) return t2t[groups[i].id];
      // Check totalGroups by id
      for (var grpName2 in tg) {
        if (tg[grpName2].indexOf(groups[i].id) !== -1) return grpName2;
      }
    }
  }
  
  return typeName;
}
