  grid.className = 'fav-slots-grid';
  grid.id = 'favSlotsGrid';
  box.appendChild(grid);
  
  var email = player.data.email || player.data.Email || '';
  
  // Always reset state for new player
  favSlotsState.email = email;
  favSlotsState.slots = [];
