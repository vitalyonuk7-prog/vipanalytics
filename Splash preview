      google.script.run
        .withSuccessHandler(function(data) {
          console.log('✅ Player Profiling data preloaded');
          
          if (!data) {
            console.error('❌ Backend returned null/undefined');
            profilingData.allPlayers = [];
            profilingData.managers = [];
            profilingData.fieldConfig = {};
            resolve();
            return;
          }
          
          // ✅ Store MANAGER mapping
          if (data.managerMapping) {
            console.log('📊 Raw managerMapping from backend:', JSON.stringify(data.managerMapping).substring(0, 500));
            tagToManagerMap = data.managerMapping.tagToManager || {};
            managerMapping = data.managerMapping.managerMapping || {};
            console.log('📊 Manager mapping:', Object.keys(managerMapping), 'Tags:', Object.keys(tagToManagerMap));
          } else {
            console.warn('⚠️ No managerMapping in backend response!');
          }
          
          // ✅ Wrap flat player list
          profilingData.allPlayers = wrapProfilingPlayers(data.players || []);
          console.log('📊 Loaded ' + profilingData.allPlayers.length + ' players');
          
          // ✅ Build managers list from MANAGER sheet mapping
          profilingData.managers = Object.keys(managerMapping).sort();
          console.log('📊 Managers from MANAGER sheet:', profilingData.managers);
          
          profilingData.fieldConfig = data.fieldConfig || {};
          profilingData.attentionRules = data.attentionRules || [];
          
          // ✅ Fill missing tags from VIP data
          fillProfilingTagsFromVIP();
          
          resolve();
        })
        .withFailureHandler(function(error) {
          console.error('❌ Failed to load Player Profiling:', error);
          profilingData.allPlayers = [];
          profilingData.managers = [];
          profilingData.fieldConfig = {};
          resolve();
        })
        .getPlayerProfilingData();
    } else {
