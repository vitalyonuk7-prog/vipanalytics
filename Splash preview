function populateAdFilters() {
  // Types from tagToTypeMap
  var types = {};
  if (window.dashboardTagMap) {
    Object.values(window.dashboardTagMap).forEach(function(d) {
      var t = getPlayerTypeFromTags(d.tags);
      if (t && t !== 'UNKNOWN') types[t] = true;
    });
  }
  
  var managers = {};
  if (window.dashboardTagMap) {
    Object.values(window.dashboardTagMap).forEach(function(d) {
      var m = resolveManagerFromTags(d.tags);
      if (m) managers[m] = true;
    });
  }
  
  // Countries
  var countries = {};
  if (window.dashboardTagMap) {
    Object.values(window.dashboardTagMap).forEach(function(d) {
      if (d.country) countries[d.country] = true;
    });
  }
  
  function fill(id, vals) {
    var sel = document.getElementById(id);
    if (!sel) return;
    var cur = sel.value;
    var opts = '<option value="">All</option>';
    Object.keys(vals).sort().forEach(function(v) { opts += '<option value="' + v + '">' + v + '</option>'; });
    sel.innerHTML = opts;
    sel.value = cur;
  }
  fill('adTypeFilter', types);
  fill('adCountryFilter', countries);
  fill('adManagerFilter', managers);
}

function buildActiveDaysData() {
  if (!window.paymentsRawData || !window.paymentsRawData.length) return {};
  
  var typeF = document.getElementById('adTypeFilter').value;
  var countryF = document.getElementById('adCountryFilter').value;
  var managerF = document.getElementById('adManagerFilter').value;
  
  // Step 1: Count successful deposits per player per day of week
  var playerDays = {}; // email → { days: [0..6], totalDeps, totalAmount }
  
  window.paymentsRawData.forEach(function(r) {
    if (!r.success || !r.email) return;
    var email = r.email.trim().toLowerCase();
    
    if (!playerDays[email]) {
      playerDays[email] = { days: [0, 0, 0, 0, 0, 0, 0], totalDeps: 0, totalAmount: 0 };
    }
    
    var pd = playerDays[email];
    pd.totalDeps++;
    pd.totalAmount += (r.amount || 0);
    
    var dt = r.createdAt ? new Date(r.createdAt) : null;
    if (dt && !isNaN(dt.getTime())) {
      pd.days[dt.getDay()]++;
    }
  });
  
  // Step 2: Enrich from Dashboard, apply filters, rank days
  var players = {};
  Object.keys(playerDays).forEach(function(email) {
    var pd = playerDays[email];
    if (pd.totalDeps < 2) return;
    
    var dash = window.dashboardTagMap && window.dashboardTagMap[email];
    var tags = dash ? dash.tags : null;
    var type = getPlayerTypeFromTags(tags);
    var manager = resolveManagerFromTags(tags);
    var country = dash ? dash.country : '';
    
    // Apply filters
    if (typeF && type !== typeF) return;
    if (countryF && country !== countryF) return;
    if (managerF && manager !== managerF) return;
    
    // Rank days
    var dayRanks = [0,1,2,3,4,5,6].map(function(d) { return { day: d, count: pd.days[d] }; });
    dayRanks.sort(function(a, b) { return b.count - a.count || a.day - b.day; });
    
    var prob = {};
    dayRanks.forEach(function(dr, idx) {
      if (dr.count === 0) prob[dr.day] = 'none';
      else if (idx < 2) prob[dr.day] = 'high';
      else if (idx < 5) prob[dr.day] = 'medium';
      else prob[dr.day] = 'low';
    });
    
    var depSum = dash ? dash.depositSum : pd.totalAmount;
    var cashSum = dash ? dash.cashoutSum : 0;
    var io = dash ? dash.inout : depSum;
    var lastDep = dash ? dash.lastTimeDeposit : '';
    
    players[email] = {
      email: email,
      name: dash ? dash.name : '',
      country: country,
      manager: manager,
      type: type,
      currency: dash ? dash.currency : '',
      totalDeps: dash ? dash.depositCount : pd.totalDeps,
      depositSum: depSum,
      cashoutSum: cashSum,
      inout: io,
      avgDep: (dash ? dash.depositCount : pd.totalDeps) > 0 ? Math.round(depSum / (dash ? dash.depositCount : pd.totalDeps)) : 0,
      lastDep: lastDep,
      days: pd.days,
      probability: prob
    };
  });
  
  return players;
}

function adSetSort(key) {
  if (adSort.key === key) adSort.dir = adSort.dir === 'desc' ? 'asc' : 'desc';
  else { adSort.key = key; adSort.dir = 'desc'; }
  renderActiveDays();
}

function parseLastDep(val) {
  if (!val) return null;
  // Unix timestamp (seconds)
  var n = Number(val);
  if (n > 1e9 && n < 2e10) return new Date(n * 1000);
  // Unix millis
  if (n > 1e12) return new Date(n);
  // String date
  var d = new Date(val);
  return isNaN(d.getTime()) ? null : d;
}

