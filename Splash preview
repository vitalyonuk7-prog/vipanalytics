function resolveManagerFromTags(tags) {
  if (!tags) return '';
  var m = getPlayerManagerFromTags(tags);
  if (m) return m;
  var tagsArr = Array.isArray(tags) ? tags :
    (typeof tags === 'string' && tags.trim().startsWith('[')) ?
      (function(){ try { return JSON.parse(tags); } catch(e) { return tags.split(',').map(function(t){return t.trim()}); } })() :
    typeof tags === 'string' ? tags.split(',').map(function(t){return t.trim()}) : [];
  return getPlayerManager({ tags: tagsArr });
}

