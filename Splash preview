  if (email) {
    favSlotsState.loading = true;
    addBtn.disabled = true;
    addBtn.style.opacity = '0.5';
    grid.innerHTML = '<div class="fav-slot-empty">Loading favourites...</div>';
    google.script.run
      .withSuccessHandler(function(slots) {
