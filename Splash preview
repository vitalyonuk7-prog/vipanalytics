function renderBonusCategoryList(names) {
  var search = (document.getElementById('bonusCatSearch').value||'').toLowerCase();
  var filtered = names.filter(function(n){
    if(search && n.toLowerCase().indexOf(search)===-1) return false;
    if(bonusCatFilter==='assigned') return !!bonusCatMapping[n];
    if(bonusCatFilter==='unassigned') return !bonusCatMapping[n];
    return true;
  });
  
  // Sort: uncategorized first
  filtered.sort(function(a,b){
    var ca = bonusCatMapping[a]||'', cb = bonusCatMapping[b]||'';
    if(!ca && cb) return -1;
    if(ca && !cb) return 1;
    return a.localeCompare(b);
  });
  
  var assigned = 0, unassigned = 0;
  names.forEach(function(n){ if(bonusCatMapping[n]) assigned++; else unassigned++; });
  
  var statsEl = document.getElementById('bonusCatStats');
  if(statsEl) statsEl.innerHTML = '<span style="color:#10b981">✓ '+assigned+'</span> / <span style="color:#f59e0b">○ '+unassigned+'</span> / Total: '+names.length;
  
  var btnEl = document.getElementById('bonusCatFilterBtns');
  if(btnEl){
    var filters = [{k:'all',l:'All'},{k:'assigned',l:'Assigned'},{k:'unassigned',l:'Unassigned'}];
    var bh='';
    filters.forEach(function(f){
      var active = bonusCatFilter===f.k;
      bh+='<button onclick="bonusCatFilter=\''+f.k+'\';renderBonusCategoryList(window._bonusCatNames)" style="padding:4px 12px;border-radius:6px;border:1.5px solid '+(active?'#667eea':'#e2e8f0')+';background:'+(active?'#667eea':'#fff')+';color:'+(active?'#fff':'#64748b')+';font-size:11px;font-weight:700;cursor:pointer">'+f.l+'</button>';
    });
    btnEl.innerHTML=bh;
  }
  
  var container = document.getElementById('bonusCategoryListWrap');
  if(filtered.length===0){
    container.innerHTML='<div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px">No bonus names found</div>';
    return;
  }
  
  var optionsHtml = '<option value="">— Select —</option>';
  bonusCatOptions.forEach(function(c){ optionsHtml += '<option value="'+c+'">'+c+'</option>'; });
  
  // Bulk assign bar
  var html = '<div style="display:flex;gap:8px;align-items:center;padding:12px 0;border-bottom:1px solid #e2e8f0;position:sticky;top:0;background:#fff;z-index:1">';
  html += '<label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;font-weight:700;color:#64748b"><input type="checkbox" id="bonusCatSelectAll" onchange="toggleAllBonusCatCheckboxes(this.checked)" style="accent-color:#667eea"> Select all</label>';
  html += '<div style="flex:1"></div>';
  html += '<select id="bonusBulkCatSelect" style="padding:6px 10px;border:1.5px solid #e2e8f0;border-radius:6px;font-size:12px;font-weight:600">'+optionsHtml+'</select>';
  html += '<button onclick="bulkAssignBonusCategory()" style="padding:6px 14px;border-radius:6px;border:none;background:#667eea;color:#fff;font-size:12px;font-weight:700;cursor:pointer">Assign Selected</button>';
  html += '<span id="bonusCatSelectedCount" style="font-size:11px;color:#94a3b8;font-weight:600">0 selected</span>';
  html += '</div>';
  
  html += '<table style="width:100%;border-collapse:collapse">';
  html += '<thead><tr style="background:linear-gradient(135deg,#667eea,#764ba2)"><th style="padding:8px;width:30px"></th><th style="padding:8px 12px;color:#fff;font-size:11px;font-weight:700;text-transform:uppercase;text-align:left;border-radius:0">Bonus Name</th><th style="padding:8px 12px;color:#fff;font-size:11px;font-weight:700;text-transform:uppercase;text-align:left;width:200px">Category</th></tr></thead><tbody>';
  
  filtered.forEach(function(name, i){
    var cat = bonusCatMapping[name]||'';
    var bg = i%2===0?'#fff':'#f8fafc';
    var dot = cat ? '●' : '○';
    var dotClr = cat ? '#10b981' : '#e2e8f0';
    html += '<tr style="background:'+bg+'">';
    html += '<td style="padding:6px 8px;border-bottom:1px solid #f1f5f9;text-align:center"><input type="checkbox" class="bonusCatCb" data-name="'+name.replace(/"/g,'&quot;')+'" onchange="updateBonusCatSelectedCount()" style="accent-color:#667eea"></td>';
    html += '<td style="padding:6px 12px;border-bottom:1px solid #f1f5f9;font-size:13px;font-weight:600;color:#1e293b"><span style="color:'+dotClr+';margin-right:6px">'+dot+'</span>'+name+'</td>';
    html += '<td style="padding:4px 12px;border-bottom:1px solid #f1f5f9"><select onchange="assignBonusCategory(\''+name.replace(/'/g,"\\'")+'\',this.value,this)" style="width:100%;padding:5px 8px;border:1.5px solid '+(cat?'#10b98140':'#e2e8f0')+';border-radius:6px;font-size:11px;font-weight:600;color:#1e293b;background:'+(cat?'#10b98108':'#fff')+';cursor:pointer">'+optionsHtml.replace('value="'+cat+'"','value="'+cat+'" selected')+'</select></td>';
