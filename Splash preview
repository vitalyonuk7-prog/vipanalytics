/**
 * Upload player photo to Google Drive
 */
function uploadPlayerPhoto(player) {
  var input = document.createElement('input');
  input.type = 'file';
  input.accept = 'image/*';
  
  input.onchange = function(e) {
    var file = e.target.files[0];
    if (!file) return;
    
    if (file.size > 10 * 1024 * 1024) {
      showToast('❌ File too large! Max 10MB');
      return;
    }
    if (!file.type.startsWith('image/')) {
      showToast('❌ Please select an image file');
      return;
    }
    
    showToast('📤 Processing photo...');
    
    var reader = new FileReader();
    reader.onload = function(event) {
      var fullDataUrl = event.target.result;
      
      // ✅ INSTANT: Show photo immediately from local file
      updatePlayerAvatars(player, fullDataUrl);
      
      // Resize image via canvas to fit google.script.run limits
      var img = new Image();
      img.onload = function() {
        var maxSize = 300;
        var w = img.width, h = img.height;
        if (w > maxSize || h > maxSize) {
          if (w > h) { h = Math.round(h * maxSize / w); w = maxSize; }
          else { w = Math.round(w * maxSize / h); h = maxSize; }
        }
        var canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        var ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, w, h);
        var resizedDataUrl = canvas.toDataURL('image/jpeg', 0.7);
        var base64Data = resizedDataUrl.split(',')[1];
        
        console.log('Photo resized: ' + img.width + 'x' + img.height + ' → ' + w + 'x' + h + ', base64 length: ' + base64Data.length);
        showToast('📤 Uploading to Drive...');
        
        var playerEmail = player.data.email || player.data['EMAIL [PREV]'] || player.data['email [prev]'] || '';
        console.log('Uploading photo for email:', playerEmail);
        
        google.script.run
          .withSuccessHandler(function(photoUrl) {
            showToast('✅ Photo uploaded!');
            console.log('Photo URL:', photoUrl);
            
            // Update player data
            player.data.photo = photoUrl;
            var keys = Object.keys(player.data);
            for (var i = 0; i < keys.length; i++) {
              if (keys[i].toLowerCase().indexOf('upload') !== -1) player.data[keys[i]] = photoUrl;
            }
            
            // Update avatars with Drive URL
            updatePlayerAvatars(player, photoUrl);
            
            // Update allPlayers for grid cards
            if (profilingData && profilingData.allPlayers) {
              var em = playerEmail.toLowerCase();
              profilingData.allPlayers.forEach(function(p) {
                var pEm = (p.data.email || p.data['EMAIL [PREV]'] || '').toLowerCase();
                if (pEm === em) {
                  p.data.photo = photoUrl;
                  Object.keys(p.data).forEach(function(k) {
                    if (k.toLowerCase().indexOf('upload') !== -1) p.data[k] = photoUrl;
                  });
                }
              });
            }
            renderProfilingPlayers();
          })
          .withFailureHandler(function(error) {
            console.error('Upload error:', error);
            showToast('❌ Upload failed: ' + (error.message || error));
          })
          .uploadPlayerPhoto(playerEmail, base64Data, file.name);
      };
      img.onerror = function() { showToast('❌ Cannot read image'); };
      img.src = fullDataUrl;
    };
    reader.readAsDataURL(file);
  };
  input.click();
}

