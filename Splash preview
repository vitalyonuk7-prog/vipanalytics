function getPlayerFinance(p) {
  // Try Dashboard data first (most accurate), fallback to player fields
  var email = (p.email || p.id || '').trim().toLowerCase();
  var dash = (email && window.dashboardTagMap && window.dashboardTagMap[email]) ? window.dashboardTagMap[email] : null;
  return {
    depositSum: dash ? dash.depositSum : (p.depositSum || 0),
    cashoutSum: dash ? dash.cashoutSum : (p.cashoutSum || 0),
    inout: dash ? dash.inout : (p.inout || 0),
    depositCount: dash ? dash.depositCount : (p.depositCount || p.actualDeposits || 0)
  };
}

function renderTrafficFinance(td) {
  var table = document.getElementById('traffic-finance-table');
  if (!table) return;
  
  if (td.groups.length === 0) {
    table.innerHTML = '<tr><td style="padding:20px;text-align:center;color:#94a3b8">No data</td></tr>';
    return;
  }
  
  var groupFin = {};
  td.groups.forEach(function(g) { groupFin[g] = { players: 0, depSum: 0, cashSum: 0, inout: 0, depCount: 0 }; });
  
  Object.keys(trafficPlayersCache).forEach(function(period) {
    var cache = trafficPlayersCache[period];
    [].concat(cache.achieved || [], cache.dropped || []).forEach(function(p) {
      var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
      if (!groupFin[g]) return;
      var fin = getPlayerFinance(p);
      groupFin[g].players++;
      groupFin[g].depSum += fin.depositSum;
      groupFin[g].cashSum += fin.cashoutSum;
      groupFin[g].inout += fin.inout;
      groupFin[g].depCount += fin.depositCount;
    });
  });
  
  var sorted = Object.keys(groupFin).sort(function(a, b) { return groupFin[b].depSum - groupFin[a].depSum; });
  
  var totP = 0, totDep = 0, totCash = 0, totIO = 0, totDC = 0;
  sorted.forEach(function(g) { var f = groupFin[g]; totP += f.players; totDep += f.depSum; totCash += f.cashSum; totIO += f.inout; totDC += f.depCount; });
  
  function fm(n) { return Math.round(n).toLocaleString(); }
  function fmD(n) { return '$' + Math.round(n).toLocaleString(); }
  function ioC(v) { return v >= 0 ? '#059669' : '#dc2626'; }
  function cl(group) { return ' style="cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')"'; }
  
  var html = '<thead><tr>';
  html += '<th class="row-header" style="min-width:140px">Traffic</th>';
  html += '<th>Players</th><th>Deposits $</th><th>Cashouts $</th><th>In/Out $</th><th>Avg Dep/Player</th><th>Dep Count</th><th>Avg Deps/Player</th>';
  html += '</tr></thead><tbody>';
  
  // Total row
  var tc = cl('TOTAL');
  html += '<tr style="background:#f8fafc;font-weight:700">';
  html += '<td class="row-header" style="color:#1e293b;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">TOTAL</td>';
  html += '<td' + tc + '>' + fm(totP) + '</td>';
  html += '<td style="color:#059669;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + fmD(totDep) + '</td>';
  html += '<td style="color:#dc2626;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + fmD(totCash) + '</td>';
  html += '<td style="color:' + ioC(totIO) + ';font-weight:800;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + fmD(totIO) + '</td>';
  html += '<td' + tc + '>' + (totP > 0 ? fmD(Math.round(totDep / totP)) : '$0') + '</td>';
  html += '<td' + tc + '>' + fm(totDC) + '</td>';
  html += '<td' + tc + '>' + (totP > 0 ? (totDC / totP).toFixed(1) : '0') + '</td>';
  html += '</tr>';
  
  sorted.forEach(function(g) {
    var f = groupFin[g];
    var avgDep = f.players > 0 ? Math.round(f.depSum / f.players) : 0;
    var avgDeps = f.players > 0 ? f.depCount / f.players : 0;
    var gc = cl(g);
    
    html += '<tr>';
    html += '<td class="row-header"' + gc + '>' + g + '</td>';
    html += '<td' + gc + '>' + fm(f.players) + '</td>';
    html += '<td style="color:#059669;cursor:pointer" onclick="openTrafficModal(\'' + g.replace(/'/g,"\\'") + '\',\'ALL\')">' + fmD(f.depSum) + '</td>';
    html += '<td style="color:#dc2626;cursor:pointer" onclick="openTrafficModal(\'' + g.replace(/'/g,"\\'") + '\',\'ALL\')">' + fmD(f.cashSum) + '</td>';
    html += '<td style="color:' + ioC(f.inout) + ';font-weight:700;cursor:pointer" onclick="openTrafficModal(\'' + g.replace(/'/g,"\\'") + '\',\'ALL\')">' + fmD(f.inout) + '</td>';
    html += '<td' + gc + '>' + fmD(avgDep) + '</td>';
    html += '<td' + gc + '>' + fm(f.depCount) + '</td>';
    html += '<td' + gc + '>' + avgDeps.toFixed(1) + '</td>';
    html += '</tr>';
  });
  
  html += '</tbody>';
  table.innerHTML = html;
}

function renderTrafficSummary(td) {
  var totalFtd = 0, totalActive = 0, totalDropped = 0;
  
  Object.values(td.data).forEach(function(groups) {
    Object.values(groups).forEach(function(d) {
      totalFtd += d.ftd;
      totalActive += d.active;
      totalDropped += d.dropped;
    });
  });
  
  var dropRate = totalFtd > 0 ? (totalDropped / totalFtd * 100).toFixed(1) : '0.0';
  var activeRate = totalFtd > 0 ? (totalActive / totalFtd * 100).toFixed(1) : '0.0';
  
  var html = '';
  html += '<div style="background:linear-gradient(135deg,#667eea,#764ba2);border-radius:16px;padding:20px;color:#fff"><div style="font-size:12px;opacity:0.8">Total FTD</div><div style="font-size:28px;font-weight:800">' + totalFtd.toLocaleString() + '</div></div>';
  html += '<div style="background:linear-gradient(135deg,#10b981,#059669);border-radius:16px;padding:20px;color:#fff"><div style="font-size:12px;opacity:0.8">Active</div><div style="font-size:28px;font-weight:800">' + totalActive.toLocaleString() + '</div><div style="font-size:12px;opacity:0.8">' + activeRate + '% of FTD</div></div>';
  html += '<div style="background:linear-gradient(135deg,#ef4444,#dc2626);border-radius:16px;padding:20px;color:#fff"><div style="font-size:12px;opacity:0.8">Dropped</div><div style="font-size:28px;font-weight:800">' + totalDropped.toLocaleString() + '</div><div style="font-size:12px;opacity:0.8">' + dropRate + '% of FTD</div></div>';
  html += '<div style="background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:16px;padding:20px;color:#fff"><div style="font-size:12px;opacity:0.8">Traffic Groups</div><div style="font-size:28px;font-weight:800">' + td.groups.length + '</div><div style="font-size:12px;opacity:0.8">' + td.periods.length + ' periods</div></div>';
  
  document.getElementById('trafficSummaryCards').innerHTML = html;
}

function renderTrafficChart(td) {
  var canvas = document.getElementById('trafficChart');
  if (!canvas || typeof Chart === 'undefined') return;
  var ctx = canvas.getContext('2d');
  
  // Aggregate totals per group across all periods
  var groupTotals = {};
  td.groups.forEach(function(g) { groupTotals[g] = { ftd: 0, active: 0, dropped: 0 }; });
  
  Object.values(td.data).forEach(function(groups) {
    Object.keys(groups).forEach(function(g) {
      groupTotals[g].ftd += groups[g].ftd;
      groupTotals[g].active += groups[g].active;
      groupTotals[g].dropped += groups[g].dropped;
    });
  });
  
  // Sort by drop rate descending
  var sorted = Object.keys(groupTotals).sort(function(a, b) {
    var rA = groupTotals[a].ftd > 0 ? groupTotals[a].dropped / groupTotals[a].ftd : 0;
    var rB = groupTotals[b].ftd > 0 ? groupTotals[b].dropped / groupTotals[b].ftd : 0;
    return rB - rA;
  });
  
  var labels = sorted;
  var activeData = sorted.map(function(g) { return groupTotals[g].active; });
  var droppedData = sorted.map(function(g) { return groupTotals[g].dropped; });
  
  if (trafficChart) trafficChart.destroy();
  
  trafficChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'Active',
          data: activeData,
          backgroundColor: 'rgba(16,185,129,0.8)',
          borderRadius: 4
        },
        {
          label: 'Dropped',
          data: droppedData,
          backgroundColor: 'rgba(239,68,68,0.8)',
          borderRadius: 4
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'top' },
        datalabels: { display: false }
      },
      scales: {
        x: { stacked: true, grid: { display: false } },
        y: { stacked: true, grid: { color: '#f1f5f9' }, ticks: { precision: 0 } }
      }
    }
  });
}

function openTrafficModal(group, period) {
  // group = traffic group name or 'TOTAL', period = month/week or 'ALL'
  var modal = document.getElementById('modal');
  var title = group === 'TOTAL' ? 'All Traffic' : group;
  if (period !== 'ALL') title += ' • ' + period;
  document.getElementById('modalTitle').textContent = '🚦 ' + title;
  modal.classList.add('open');
  
  var achieved = [], dropped = [];
  
  if (period === 'ALL') {
    // Merge all periods
    Object.keys(trafficPlayersCache).forEach(function(p) {
      var c = trafficPlayersCache[p];
      achieved = achieved.concat(c.achieved || []);
      dropped = dropped.concat(c.dropped || []);
    });
  } else {
    var c = trafficPlayersCache[period];
    if (c) {
      achieved = (c.achieved || []).slice();
      dropped = (c.dropped || []).slice();
    }
  }
  
  // Filter by group if not TOTAL
  if (group !== 'TOTAL') {
    achieved = achieved.filter(function(p) {
      return ((p[trafficGroupBy] || '').trim() || 'Unknown') === group;
    });
    dropped = dropped.filter(function(p) {
      return ((p[trafficGroupBy] || '').trim() || 'Unknown') === group;
    });
  }
  
  var data = {
    achieved: achieved,
    dropped: dropped,
    total: achieved.length + dropped.length,
    totalAchieved: achieved.length,
    totalDropped: dropped.length
  };
  
  currentModalData = data;
  currentFilteredData = data;
  renderModalContent(data);
}

function renderTrafficTable(td) {
