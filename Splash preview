    var decimalRtp = rtpVal >= 1 ? rtpVal / 100 : rtpVal;
    inputs[field.a1] = decimalRtp;
    chosen.innerHTML = '✓ ' + g.provider + ' — ' + g.slot + ' (' + g.rtpPct + '%) <span class="bc-chosen-x" title="Clear">✕</span>';
