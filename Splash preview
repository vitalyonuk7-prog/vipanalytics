  var hasAnyIcon = false;
  
  function findData(searchKeys) {
    var keys = Object.keys(player.data);
    var skip = ['—', '-', '–', 'n/a', 'N/A', 'none', 'None', 'null', 'undefined'];
    // Exact match first
    for (var s = 0; s < searchKeys.length; s++) {
      var term = searchKeys[s].toLowerCase();
      for (var k = 0; k < keys.length; k++) {
        if (keys[k].toLowerCase() === term) {
          var v = player.data[keys[k]];
          if (v && String(v).trim() !== '' && skip.indexOf(String(v).trim()) === -1) return v;
        }
