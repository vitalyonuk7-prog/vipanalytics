function deduplicatePlayers(players){const seen=new Map();players.forEach(p=>{if(!seen.has(p.id)){seen.set(p.id,p)}});return Array.from(seen.values())}

// Modal sort state
window._modalSort = { key: null, dir: 'asc', section: null };
window._modalAchieved = [];
window._modalDropped = [];
window._modalHasFilters = false;
window._modalData = null;

function _mStatus(p){
  var d=getDashboardPlayerData(p);
  if(d){var s=String(d.status||'none').toLowerCase();return(s==='none'||s===''||s==='false')?'Active':'Disabled';}
  var s=String(p.status||'none').toLowerCase();
  return(s==='none'||s===''||s==='false'||s==='active')?'Active':'Disabled';
}
function _mType(p){return getPlayerTypeFromTags(getEffectiveTags(p))||'-';}
function _mFin(p){
  var d=getDashboardPlayerData(p);
  if(d){var dp=Number(d.depositSum)||0,cs=Number(d.cashoutSum)||0;return{dep:dp,cash:cs,io:Number(d.inout)||(dp-cs)};}
  return{dep:Number(p.depositSum)||0,cash:Number(p.cashoutSum)||0,io:Number(p.inout)||0};
}
function _mSortVal(p,k){
  if(k==='email')return(p.email||'').toLowerCase();
  if(k==='country')return(p.country||'').toLowerCase();
  if(k==='status')return _mStatus(p);
  if(k==='type')return _mType(p);
  if(k==='manager')return(getManager(getEffectiveTags(p))||'').toLowerCase();
  if(k==='deposits')return _mFin(p).dep;
  if(k==='cashouts')return _mFin(p).cash;
  if(k==='inout')return _mFin(p).io;
  if(k==='trafficType')return(p.trafficType||'').toLowerCase();
  if(k==='trafficSource')return(p.trafficSource||'').toLowerCase();
  if(k==='trafficDirection')return(p.trafficDirection||'').toLowerCase();
  return'';
}

function sortModalCol(section,key){
  var s=window._modalSort;
  if(s.key===key&&s.section===section)s.dir=s.dir==='asc'?'desc':'asc';
  else{s.key=key;s.dir='asc';s.section=section;}
  _renderModalInner();
}

function renderModalContent(data){
  window._modalData=data;
  window._modalAchieved=deduplicatePlayers(data.achieved||[]);
  window._modalDropped=deduplicatePlayers(data.dropped||[]);
  window._modalHasFilters=data.totalAchieved!==window._modalAchieved.length||data.totalDropped!==window._modalDropped.length;
  window._modalSort={key:null,dir:'asc',section:null};
  _renderModalInner();
}

function _renderModalInner(){
  var ach=window._modalAchieved,drp=window._modalDropped,hf=window._modalHasFilters,data=window._modalData,st=window._modalSort;
  var all=[].concat(ach,drp);
  
  var html='<div class="analytics-section"><div class="analytics-title">\u{1F4CA} Analytics'+(hf?' (Filtered)':'')+'</div><div class="pies-grid">';
  if(all.length>0){
    html+=createPieCard('Countries','c1',groupBy(all,function(p){return p.country||'Unknown'}));
    html+=createPieCard('Status','c2',groupBy(all,function(p){return _mStatus(p)}));
    html+=createPieCard('Achievement','c3',[{label:'Achieved',value:ach.length},{label:'Dropped',value:drp.length}]);
  }
  html+='</div></div>';
  
  var cols=[
    {k:'email',l:'Email'},{k:'country',l:'Country'},{k:'status',l:'Status'},
    {k:'type',l:'Type'},{k:'trafficType',l:'Traffic'},{k:'trafficSource',l:'Source'},
    {k:'trafficDirection',l:'Direction'},{k:'deposits',l:'Deposits'},{k:'cashouts',l:'Cashouts'},
    {k:'inout',l:'Inout'},{k:null,l:''}
  ];
  
  function mkH(sec){
    var h='';
    cols.forEach(function(c){
      var sty='font-weight:700;font-size:10px;text-transform:uppercase;padding:6px 3px;white-space:nowrap;user-select:none';
      if(!c.k){h+='<div style="'+sty+'">'+c.l+'</div>';return;}
      var act=st.key===c.k&&st.section===sec;
      var arr=act?(st.dir==='asc'?' \u2191':' \u2193'):'';
      h+='<div style="'+sty+';cursor:pointer;color:'+(act?'#667eea':'#475569')+'" onclick="sortModalCol(\''+sec+'\',\''+c.k+'\')">'+c.l+arr+'</div>';
    });
    return h;
  }
  
  function fm(v){if(!v&&v!==0)return'-';return'\u20AC'+Number(v).toLocaleString('en',{maximumFractionDigits:0});}
  function fi(v){if(!v&&v!==0)return'-';var n=Number(v);return'<span style="color:'+(n>=0?'#10b981':'#ef4444')+';font-weight:700">\u20AC'+n.toLocaleString('en',{maximumFractionDigits:0})+'</span>';}
  
  function isProf(p){
    if(!window.vipAllPlayers)return false;
    var a=[].concat(window.vipAllPlayers.vip||[],window.vipAllPlayers.silentVip||[]);
    var em=(p.email||'').toLowerCase();
    return a.some(function(v){return v.email&&v.email.toLowerCase()===em;});
  }
  
  function rRow(p){
    var em=p.email||p.id||'N/A',stat=_mStatus(p),sc=stat==='Active'?'#10b981':'#ef4444';
    var tp=_mType(p),mg=getManager(getEffectiveTags(p))||'',fn=_mFin(p),pr=isProf(p);
    var r='<div class="player-row" style="cursor:pointer" onclick="openPlayerCardFromModal(\''+escapeHtml(p.id||'')+'\',\''+escapeHtml(em)+'\')">';
    r+='<div class="player-email">'+escapeHtml(em)+'<span class="copy-icon" onclick="event.stopPropagation();copyToClipboard(\''+escapeHtml(em)+'\')">\u{1F4CB}</span></div>';
    r+='<div>'+escapeHtml(p.country||'-')+'</div>';
    r+='<div><span style="padding:2px 6px;border-radius:5px;background:'+sc+'18;color:'+sc+';font-weight:700;font-size:10px">'+stat+'</span></div>';
    r+='<div style="font-size:10px;font-weight:700;color:#667eea">'+escapeHtml(tp)+(mg?' <span style="color:#94a3b8;font-weight:400">('+escapeHtml(mg)+')</span>':'')+'</div>';
    r+='<div style="font-size:10px;color:#475569">'+escapeHtml(p.trafficType||'-')+'</div>';
    r+='<div style="font-size:10px;color:#475569">'+escapeHtml(p.trafficSource||'-')+'</div>';
    r+='<div style="font-size:10px;color:#475569">'+escapeHtml(p.trafficDirection||'-')+'</div>';
    r+='<div style="font-variant-numeric:tabular-nums;font-size:11px">'+fm(fn.dep)+'</div>';
    r+='<div style="font-variant-numeric:tabular-nums;font-size:11px">'+fm(fn.cash)+'</div>';
    r+='<div style="font-variant-numeric:tabular-nums;font-size:11px">'+fi(fn.io)+'</div>';
    r+='<div style="display:flex;gap:3px;align-items:center">';
    r+='<a href="'+createBackofficeLink(p.id)+'" target="_blank" class="player-link" onclick="event.stopPropagation()" style="font-size:11px">Open</a>';
    if(pr)r+='<button onclick="event.stopPropagation();goToPlayerProfiling(\''+escapeHtml(em)+'\')" style="padding:1px 5px;border-radius:4px;border:1px solid #a78bfa;background:#a78bfa18;color:#7c3aed;font-size:9px;font-weight:700;cursor:pointer">VIP</button>';
    r+='</div></div>';
    return r;
  }
  
  function doSort(list,sec){
    if(!st.key||st.section!==sec)return list;
    return list.slice().sort(function(a,b){
      var va=_mSortVal(a,st.key),vb=_mSortVal(b,st.key);
      if(typeof va==='number'&&typeof vb==='number')return st.dir==='asc'?va-vb:vb-va;
      return st.dir==='asc'?String(va).localeCompare(String(vb)):String(vb).localeCompare(String(va));
    });
  }
  
  html+='<div class="players-section"><div class="section-header"><div class="section-title">\u2705 Achieved</div><div class="section-count">'+ach.length+(hf?' / '+data.totalAchieved:'')+'</div></div>';
  if(ach.length>0){
    html+='<div class="players-list"><div class="player-row" style="font-weight:700;background:#f8fafc;border-bottom:2px solid #667eea;cursor:default">'+mkH('achieved')+'</div>';
    doSort(ach,'achieved').forEach(function(p){html+=rRow(p);});
    html+='</div>';
  }else{html+='<div style="padding:20px;text-align:center;color:#64748b">No players</div>';}
  html+='</div>';
  
  html+='<div class="players-section"><div class="section-header"><div class="section-title">\u274C Dropped</div><div class="section-count">'+drp.length+(hf?' / '+data.totalDropped:'')+'</div></div>';
  if(drp.length>0){
    html+='<div class="players-list"><div class="player-row" style="font-weight:700;background:#fef2f2;border-bottom:2px solid #ef4444;cursor:default">'+mkH('dropped')+'</div>';
    doSort(drp,'dropped').forEach(function(p){html+=rRow(p);});
    html+='</div>';
  }else{html+='<div style="padding:20px;text-align:center;color:#64748b">All achieved!</div>';}
  html+='</div>';
  
  document.getElementById('modalBody').innerHTML=html;
  setTimeout(function(){
