/**
 * Build email→tags map from Dashboard players for cross-tab tag enrichment
 */
function buildDashboardTagMap(players) {
  var map = {};
  var count = 0;
  players.forEach(function(p) {
    var email = (p.email || '').trim().toLowerCase();
    if (email) {
      var dep = Number(p.lifetime_deposit_sum_total || p.deposit_sum_total || 0);
      var cash = Number(p.lifetime_cashout_sum_total || p.cashout_sum_total || 0);
      var io = Number(p.inout || p.in_out || 0) || (dep - Math.abs(cash));
      var depCount = Number(p.lifetime_deposit_count_total || p.deposit_count_total || 0);
      map[email] = {
        tags: p.tags,
        status: p.disabled || p.status || 'none',
        depositSum: dep,
        cashoutSum: Math.abs(cash),
        inout: io,
        depositCount: depCount,
        lastTimeDeposit: p.last_time_deposit || p.lastTimeDeposit || p['last time deposit'] || p.last_deposit || p.lastDeposit || p['last deposit date'] || '',
        country: p.country || '',
        name: p.name || p.player || '',
        currency: p.currency || ''
      };
      count++;
    }
  });
  window.dashboardTagMap = map;
  console.log('🗺️ Dashboard tag map built:', count, 'players');
  // ✅ Re-enrich payments data if it was already loaded before dashboardTagMap
  if (window.paymentsDataLoaded && window.paymentsRawData && window.paymentsRawData.length) {
    enrichPaymentsWithPlayerType();
    populatePaymentsFilters();
    console.log('🔄 Payments re-enriched with fresh dashboardTagMap');
  }
}

