function pcBuildWeeks() {
  var wm = {};
  window.pcPlayerRows.forEach(function(r) {
    if (!r.finishedAt) return;
    var ds = r.finishedAt.substring(0,10), p = ds.split('-'), d = new Date(+p[0], p[1]-1, +p[2]);
    if (isNaN(d)) return;
    var dy = d.getDay(), df = dy === 0 ? -6 : 1 - dy, mn = new Date(d); mn.setDate(d.getDate() + df);
    var wk = mn.getFullYear() + '-' + String(mn.getMonth()+1).padStart(2,'0') + '-' + String(mn.getDate()).padStart(2,'0');
    if (!wm[wk]) wm[wk] = []; wm[wk].push(r);
  });
  var sk = Object.keys(wm).sort().reverse();
  window.pcWeeks = sk.map(function(mk) {
    var p = mk.split('-'), mn = new Date(+p[0], p[1]-1, +p[2]), su = new Date(mn); su.setDate(mn.getDate()+6);
    return { key: mk, label: pmDF(mn) + ' — ' + pmDF(su), rows: wm[mk] };
  });
  window.pcWeekIdx = 0;
}

