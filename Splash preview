  if (!filters[filterKey]) { console.warn('⚠️ Unknown filterKey:', filterKey); return; }
  
  if(checked){
    if(!filters[filterKey].includes(value)){
      filters[filterKey].push(value);
    }
  }else{
    filters[filterKey]=filters[filterKey].filter(v=>v!==value);
