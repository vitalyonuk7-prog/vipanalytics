var bonusCatMapping = {};
var bonusCatOptions = [];
var bonusCatFilter = 'all';
var bonusCatLoaded = false;
var bonusCategoryPieChart = null;

function preloadBonusCategories() {
  return new Promise(function(resolve) {
    google.script.run
      .withSuccessHandler(function(result) {
        if(result && !result.error){
          bonusCatMapping = result.mapping || {};
          bonusCatOptions = result.categoryOptions || [];
          bonusCatLoaded = true;
          updateBonusCatBadge();
        }
        resolve();
      })
      .withFailureHandler(function(){ resolve(); })
      .getBonusCategories();
  });
}

function getUniqueBonusNames() {
  var names = {};
  ['monthly','weekly','daily'].forEach(function(m){
    var d = bonusRawData[m];
    if(!d||!d.rows) return;
    d.rows.forEach(function(r){
      if(r.title && r.title.indexOf('Strategy total')===-1 && r.title.indexOf('Aggregated')===-1 && r.type) names[r.title] = true;
    });
  });
  return Object.keys(names).sort();
}

function updateBonusCatBadge() {
  var badge = document.getElementById('bonusCatBadge');
  if(!badge) return;
  var names = getUniqueBonusNames();
  var count = 0;
  names.forEach(function(n){ if(!bonusCatMapping[n]) count++; });
  if(count > 0){
    badge.style.display = 'block';
    badge.textContent = count;
  } else {
    badge.style.display = 'none';
  }
}

function renderBonusCategoryPie(filtered) {
  var section = document.getElementById('bonusCategoryPieSection');
  if(!section) return;
  if(!bonusCatLoaded || bonusCatOptions.length === 0){ section.style.display='none'; return; }
  
  // Group by category with bonus details
  var byCategory = {};
  var bonusesByCat = {};
  filtered.forEach(function(r){
    var cat = bonusCatMapping[r.title] || 'Uncategorized';
    if(!byCategory[cat]) { byCategory[cat] = 0; bonusesByCat[cat] = {}; }
    byCategory[cat] += r.totalInEUR || 0;
    if(!bonusesByCat[cat][r.title]) bonusesByCat[cat][r.title] = {totalInEUR:0,countIssued:0,betsEUR:0};
    bonusesByCat[cat][r.title].totalInEUR += r.totalInEUR||0;
    bonusesByCat[cat][r.title].countIssued += r.countIssued||0;
    bonusesByCat[cat][r.title].betsEUR += r.betsEUR||0;
  });
  window._bonusesByCat = bonusesByCat;
  window._bonusCatTotals = byCategory;
  
  var items = Object.keys(byCategory).map(function(k){return{label:k,value:byCategory[k]};}).filter(function(i){return i.value>0;});
  items.sort(function(a,b){return b.value-a.value;});
  if(items.length === 0){ section.style.display='none'; return; }
  
  section.style.display = 'block';
  var total = items.reduce(function(a,i){return a+i.value;},0);
  var palette = ['#667eea','#f472b6','#34d399','#fbbf24','#a78bfa','#fb923c','#22d3ee','#ef4444','#6366f1','#14b8a6','#ec4899','#f59e0b'];
  var labels = items.map(function(i){return i.label;});
  var values = items.map(function(i){return i.value;});
  var colors = labels.map(function(l,i){return palette[i%palette.length];});
  window._bonusCatColors = {};
  labels.forEach(function(l,i){ window._bonusCatColors[l] = colors[i]; });
  
  var canvas = document.getElementById('bonusCategoryPie');
  if(!canvas) return;
  if(bonusCategoryPieChart) bonusCategoryPieChart.destroy();
  bonusCategoryPieChart = new Chart(canvas.getContext('2d'),{
    type:'doughnut',
    data:{labels:labels,datasets:[{data:values,backgroundColor:colors,borderWidth:2,borderColor:'#fff'}]},
    options:{responsive:true,maintainAspectRatio:true,cutout:'55%',onClick:function(e,els){
      if(els.length>0){ var idx=els[0].index; openBonusCatDetailModal(labels[idx]); }
    },plugins:{legend:{display:false},datalabels:{display:false},
      tooltip:{callbacks:{label:function(c){var pct=total?((c.raw/total)*100).toFixed(1):0;return c.label+': €'+c.raw.toLocaleString('en',{maximumFractionDigits:0})+' ('+pct+'%)';}}}}}
  });
  
  var lh='';
  items.forEach(function(item,i){
    var pct=total?((item.value/total)*100).toFixed(1):0;
    lh+='<div style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:4px 8px;border-radius:6px;transition:background 0.15s" onclick="openBonusCatDetailModal(\''+item.label.replace(/'/g,"\\'")+'\')" onmouseover="this.style.background=\'#f1f5f9\'" onmouseout="this.style.background=\'transparent\'">';
    lh+='<span style="width:12px;height:12px;border-radius:4px;background:'+colors[i]+';flex-shrink:0"></span>';
    lh+='<span style="font-weight:700;color:#1e293b;font-size:14px;min-width:120px">'+item.label+'</span>';
    lh+='<span style="font-weight:800;color:#475569;font-size:13px">€'+item.value.toLocaleString('en',{maximumFractionDigits:0})+'</span>';
    lh+='<span style="color:#94a3b8;font-size:12px;font-weight:600">('+pct+'%)</span></div>';
  });
  document.getElementById('bonusCategoryPieLegend').innerHTML=lh;
}

