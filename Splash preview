function pmTabClick(filter) {
  var tabs = document.querySelectorAll('.pm-t');
  tabs.forEach(function(t) { t.style.borderBottomColor = 'transparent'; t.style.color = '#94a3b8'; });
  
  window._pmTypeFilter = filter === 'all' ? null : filter;
  
  if (filter === 'all') {
    tabs[0].style.borderBottomColor = '#667eea'; tabs[0].style.color = '#667eea';
  } else if (filter.indexOf('type:') === 0) {
    var typeName = filter.substring(5);
    tabs.forEach(function(t) { if (t.getAttribute('data-type') === typeName) { t.style.borderBottomColor = '#667eea'; t.style.color = '#667eea'; } });
  }
  
  var filtered = window._pmDrillData;
  if (window._pmTypeFilter && window._pmTypeFilter.indexOf('type:') === 0) {
    var tv = window._pmTypeFilter.substring(5);
    filtered = filtered.filter(function(p) { return (p.type||'—') === tv; });
  }
  pmRenderDrillTable(filtered);
}

function pmDrillSort(col) {
  if (window._pmSortCol === col) { window._pmSortDir = window._pmSortDir === 'desc' ? 'asc' : 'desc'; }
  else { window._pmSortCol = col; window._pmSortDir = 'desc'; }
  // Re-apply current filter
  var filtered = window._pmDrillData;
  if (window._pmTypeFilter && window._pmTypeFilter.indexOf('type:') === 0) {
    var tv = window._pmTypeFilter.substring(5);
    filtered = filtered.filter(function(p) { return (p.type||'—') === tv; });
  }
  pmRenderDrillTable(filtered);
}

function pmRenderDrillTable(data) {
  var el = document.getElementById('pmDrillContent');
  if (!el) return;
  var sc = window._pmSortCol || 'count', sd = window._pmSortDir || 'desc';
  
  var sorted = data.slice().sort(function(a, b) {
    var va, vb;
    if (sc === 'count') { va = a.count; vb = b.count; }
    else if (sc === 'amount') { va = a.totalAmt; vb = b.totalAmt; }
    else if (sc === 'success') { va = a.successCount; vb = b.successCount; }
    else if (sc === 'failed') { va = a.failedCount; vb = b.failedCount; }
    else if (sc === 'email') { va = (a.email||'').toLowerCase(); vb = (b.email||'').toLowerCase(); }
    else if (sc === 'type') { va = (a.type||'').toLowerCase(); vb = (b.type||'').toLowerCase(); }
    else if (sc === 'manager') { va = (a.manager||'').toLowerCase(); vb = (b.manager||'').toLowerCase(); }
    else if (sc === 'country') { va = (a.country||'').toLowerCase(); vb = (b.country||'').toLowerCase(); }
    else { va = a.count; vb = b.count; }
    if (va < vb) return sd === 'asc' ? -1 : 1;
    if (va > vb) return sd === 'asc' ? 1 : -1;
    return 0;
  });
  
  function thS(col) {
    var active = sc === col;
    return 'position:sticky;top:0;z-index:2;background:#667eea;padding:12px 10px;font-weight:700;color:' + (active ? '#fff' : 'rgba(255,255,255,0.8)') + ';font-size:11px;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;cursor:pointer;user-select:none';
  }
  function arrow(col) { return sc===col?(sd==='asc'?' ▲':' ▼'):''; }
  
  var h = '<table style="width:100%;border-collapse:collapse;font-size:13px"><thead><tr>';
  h += '<th style="text-align:left;' + thS('email') + ';border-radius:8px 0 0 0" onclick="pmDrillSort(\'email\')">Email' + arrow('email') + '</th>';
  h += '<th style="text-align:center;' + thS('type') + '" onclick="pmDrillSort(\'type\')">Type' + arrow('type') + '</th>';
  h += '<th style="text-align:center;' + thS('manager') + '" onclick="pmDrillSort(\'manager\')">Manager' + arrow('manager') + '</th>';
  h += '<th style="text-align:center;' + thS('country') + '" onclick="pmDrillSort(\'country\')">Country' + arrow('country') + '</th>';
  h += '<th style="text-align:center;' + thS('success') + '" onclick="pmDrillSort(\'success\')">✅' + arrow('success') + '</th>';
  h += '<th style="text-align:center;' + thS('failed') + '" onclick="pmDrillSort(\'failed\')">❌' + arrow('failed') + '</th>';
  h += '<th style="text-align:center;' + thS('count') + '" onclick="pmDrillSort(\'count\')">Total' + arrow('count') + '</th>';
  h += '<th style="text-align:right;' + thS('amount') + ';border-radius:0 8px 0 0" onclick="pmDrillSort(\'amount\')">Success Amount' + arrow('amount') + '</th>';
  h += '</tr></thead><tbody>';
  sorted.forEach(function(p) {
    var amts = Object.keys(p.byCur).sort().map(function(c) { return pmFmt(p.byCur[c]) + ' ' + c; }).join(', ');
    var rate = p.count > 0 ? ((p.successCount / p.count) * 100).toFixed(0) : '0';
    h += '<tr style="border-bottom:1px solid #f1f5f9;cursor:pointer;transition:background 0.1s" onmouseover="this.style.background=\'#f8fafc\'" onmouseout="this.style.background=\'\'" onclick="pmOpenPlayer(\'' + p.email.replace(/'/g,"\\'") + '\')">';
    h += '<td style="padding:10px;font-weight:600;color:#667eea">' + p.email + '</td>';
    h += '<td style="padding:10px;text-align:center"><span style="font-size:11px;padding:2px 8px;border-radius:10px;background:#f1f5f9;font-weight:600">' + (p.type || '—') + '</span></td>';
    h += '<td style="padding:10px;text-align:center;font-size:12px">' + (p.manager || '—') + '</td>';
    h += '<td style="padding:10px;text-align:center;font-size:12px">' + (typeof getFlag==='function'?getFlag(p.country):'') + ' ' + (p.country || '—') + '</td>';
    h += '<td style="padding:10px;text-align:center;font-weight:700;color:#10b981">' + p.successCount + '</td>';
    h += '<td style="padding:10px;text-align:center;font-weight:600;color:#ef4444">' + p.failedCount + '</td>';
    h += '<td style="padding:10px;text-align:center;font-weight:700">' + p.count + ' <span style="font-size:10px;color:'+pmRC(rate)+'">(' + rate + '%)</span></td>';
    h += '<td style="padding:10px;text-align:right;font-size:12px;font-weight:600">' + amts + '</td></tr>';
  });
  h += '</tbody></table>';
  el.innerHTML = h;
}

