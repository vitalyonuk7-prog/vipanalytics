  html += '<h2 style="margin:0;font-size:20px;font-weight:800;color:#1e293b">'+p.title+'</h2>';
  html += '<button onclick="document.getElementById(\'bonusPieModal\').style.display=\'none\'" style="background:none;border:none;font-size:28px;color:#64748b;cursor:pointer">×</button></div>';
  html += '<div style="padding:24px"><table style="width:100%;border-collapse:collapse">';
  html += '<thead><tr style="background:linear-gradient(135deg,#667eea,#764ba2)">';
