// ===== WEEKLY CHART =====
function buildPmWeeks(filtered) {
  var wm = {};
  filtered.forEach(function(r) {
    if (!r.finishedAt) return;
    var ds = r.finishedAt.substring(0,10), ps = ds.split('-');
    var d = new Date(parseInt(ps[0]),parseInt(ps[1])-1,parseInt(ps[2]));
    if (isNaN(d.getTime())) return;
    var dy = d.getDay(), df = dy===0?-6:1-dy;
    var m = new Date(d); m.setDate(d.getDate()+df);
    var wk = m.getFullYear()+'-'+String(m.getMonth()+1).padStart(2,'0')+'-'+String(m.getDate()).padStart(2,'0');
    if (!wm[wk]) wm[wk] = [];
    wm[wk].push(r);
  });
  var sk = Object.keys(wm).sort().reverse();
  window.pmWeeks = sk.map(function(mk) {
    var p = mk.split('-'), m = new Date(parseInt(p[0]),parseInt(p[1])-1,parseInt(p[2]));
    var s = new Date(m); s.setDate(m.getDate()+6);
    return { key:mk, label:pmDF(m)+' — '+pmDF(s), rows:wm[mk] };
  });
  window.pmWeekIndex = 0;
}
function pmDF(d) { return String(d.getDate()).padStart(2,'0')+'.'+String(d.getMonth()+1).padStart(2,'0'); }

function pmWeekNav(dir) {
  if (window.pmLifetimeMode) return;
  var n = window.pmWeekIndex - dir;
  if (n < 0) n = 0; if (n >= window.pmWeeks.length) n = window.pmWeeks.length - 1;
  window.pmWeekIndex = n;
  renderPmWeeklyChart();
}

function pmToggleLifetime() {
  window.pmLifetimeMode = !window.pmLifetimeMode;
  var btn = document.getElementById('pmLifetimeBtn');
  btn.style.background = window.pmLifetimeMode ? 'linear-gradient(135deg,#667eea,#764ba2)' : '#fff';
  btn.style.color = window.pmLifetimeMode ? '#fff' : '#64748b';
  btn.style.borderColor = window.pmLifetimeMode ? 'transparent' : '#e2e8f0';
