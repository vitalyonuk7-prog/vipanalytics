  // Group by status
  var groups = {};
  KANBAN_COLS.forEach(function(c) { groups[c.id] = []; });
  listsData.forEach(function(list) {
    var s = list.status || 'backlog';
    if (!groups[s]) s = 'backlog';
    groups[s].push(list);
