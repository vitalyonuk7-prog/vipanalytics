  html += '<button onclick="this.closest(\'#bonusBarDetailModal\').remove()" style="background:none;border:none;font-size:28px;color:#64748b;cursor:pointer;line-height:1">×</button></div>';
  html += '<div style="overflow-y:auto;flex:1;padding:0 24px 24px">';
  html += '<table style="width:100%;border-collapse:collapse;margin-top:12px">';
  html += '<thead><tr style="background:linear-gradient(135deg,#667eea,#764ba2)">';
  html += '<th style="text-align:left;'+thS+';border-radius:8px 0 0 0" onclick="sortBarDetailModal(\'type\')">Type'+arrow('type')+'</th>';
  html += '<th style="text-align:left;'+thS+'" onclick="sortBarDetailModal(\'title\')">Title'+arrow('title')+'</th>';
  html += '<th style="text-align:right;'+thS+'" onclick="sortBarDetailModal(\'metricVal\')">'+metricLabel+arrow('metricVal')+'</th>';
