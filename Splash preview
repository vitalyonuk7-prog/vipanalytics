    h += '<td style="text-align:center;padding:5px;font-weight:600">'+ct+'</td>';
    h += '<td style="text-align:center;padding:5px;font-weight:700;color:'+pmRC(cr)+'">'+cr+'%</td>';
    h += '<td style="text-align:right;padding:5px;font-weight:600">'+pmFmt(d.a)+' '+c+'</td></tr>';
