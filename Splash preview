function pmAgg(rows) {
  var s=0,f=0,bc={};
  rows.forEach(function(r) {
    if (r.success) { s++; if(!bc[r.currency])bc[r.currency]={s:0,f:0,a:0}; bc[r.currency].s++; bc[r.currency].a+=r.amount; }
    else { f++; if(!bc[r.currency])bc[r.currency]={s:0,f:0,a:0}; bc[r.currency].f++; }
  });
  return {s:s,f:f,t:s+f,r:s+f>0?((s/(s+f))*100).toFixed(1):'0.0',bc:bc};
}
function pmRC(r) { var v=parseFloat(r); return v>=70?'#10b981':v>=40?'#f59e0b':'#ef4444'; }

function pmCurTable(bc) {
  var h = '<table style="width:100%;border-collapse:collapse;font-size:12px">';
  h += '<tr style="color:#64748b;font-weight:700"><td style="padding:5px 10px">Currency</td><td style="text-align:center;padding:5px">Success</td><td style="text-align:center;padding:5px">Failed</td><td style="text-align:center;padding:5px">Total</td><td style="text-align:center;padding:5px">Rate</td><td style="text-align:right;padding:5px">Amount</td></tr>';
  Object.keys(bc).sort().forEach(function(c) {
    var d=bc[c], ct=d.s+d.f, cr=ct>0?((d.s/ct)*100).toFixed(1):'0.0';
    h += '<tr style="border-top:1px solid #f1f5f9"><td style="padding:5px 10px;font-weight:700">'+c+'</td>';
    h += '<td style="text-align:center;padding:5px;color:#10b981;font-weight:600">'+d.s+'</td>';
