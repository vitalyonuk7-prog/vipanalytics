function bulkAssignBonusCategory(){
  var cat = document.getElementById('bonusBulkCatSelect').value;
  if(!cat){ showToast('Select a category first'); return; }
  var cbs = document.querySelectorAll('.bonusCatCb:checked');
  if(cbs.length===0){ showToast('Select bonus names first'); return; }
  
  var names = [];
  cbs.forEach(function(cb){ names.push(cb.dataset.name); });
  
  var done = 0, total = names.length;
  showToast('⏳ Assigning '+total+' bonuses...');
  
  names.forEach(function(name){
    bonusCatMapping[name] = cat; // optimistic update
    google.script.run
      .withSuccessHandler(function(){ done++; if(done>=total){ showToast('✅ '+total+' bonuses assigned to "'+cat+'"'); renderBonusCategoryList(window._bonusCatNames); }})
      .withFailureHandler(function(){ done++; })
      .saveBonusCategory(name, cat);
  });
  renderBonusCategoryList(window._bonusCatNames); // immediate UI update
}

function filterBonusCategoryList(){
  if(window._bonusCatNames) renderBonusCategoryList(window._bonusCatNames);
}

function assignBonusCategory(name, category, selectEl){
  selectEl.style.opacity='0.5';
  bonusCatMapping[name] = category; // optimistic
  google.script.run
    .withSuccessHandler(function(r){
      selectEl.style.opacity='1';
      if(r.success){
        selectEl.style.borderColor = category ? '#10b98140' : '#e2e8f0';
        selectEl.style.background = category ? '#10b98108' : '#fff';
        var tr = selectEl.closest('tr');
        var dot = tr.querySelector('td:nth-child(2) span');
        if(dot){ dot.style.color = category?'#10b981':'#e2e8f0'; dot.textContent = category?'●':'○'; }
        var statsEl = document.getElementById('bonusCatStats');
        if(statsEl && window._bonusCatNames){
          var a=0,u=0; window._bonusCatNames.forEach(function(n){if(bonusCatMapping[n])a++;else u++;});
          statsEl.innerHTML='<span style="color:#10b981">✓ '+a+'</span> / <span style="color:#f59e0b">○ '+u+'</span> / Total: '+window._bonusCatNames.length;
        }
      } else { showToast('Error: '+(r.error||'Unknown')); bonusCatMapping[name]=''; }
    })
    .withFailureHandler(function(e){ selectEl.style.opacity='1'; showToast('Error: '+e); bonusCatMapping[name]=''; })
    .saveBonusCategory(name, category);
}

