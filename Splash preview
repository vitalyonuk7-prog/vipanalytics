function renderLists() {
  var empty = document.getElementById('listsEmpty');
  var container = document.getElementById('listsContainer');
  if (!container) return;
  if (listsData.length === 0) { if (empty) empty.style.display = 'block'; container.innerHTML = ''; return; }
