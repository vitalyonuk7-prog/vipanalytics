function filterDepositData(baseData, filters) {
  if (!baseData) return baseData;
  
  // Need playersCellMap with at least FTD cells loaded
  if (playersCellMap.size === 0) {
    console.log('⚠️ filterDepositData: playersCellMap empty, returning baseData');
    return baseData;
  }
  
  console.log('🔍 filterDepositData called:', { filters, months: baseData.months });
  
  // ✅ Parse deposit range string into {min, max}
  function parseRange(range) {
    if (range === 'FTD') return {min: 1, max: null};
    if (range.indexOf('-') !== -1) {
      var parts = range.split('-');
      return {min: parseInt(parts[0]), max: parseInt(parts[1])};
    }
    if (range.indexOf('+') !== -1) return {min: parseInt(range), max: null};
    return {min: 0, max: null};
  }
  
  // ✅ Build depositCountMap: playerKey → depositCount
  // Key = email (preferred) or id (fallback)
  // Priority: 1) Dashboard (lifetime_deposit_count_total)
  //           2) ACTIVE sheets newest→oldest (from playersCellMap FTD cells)
  var depositCountMap = {};
  
  function playerKey(p) {
    return ((p.email || p.playerId || p.id || '').trim().toLowerCase()) || null;
  }
  
  // Step 1: Fill from ACTIVE sheets oldest→newest (so newer overwrites older)
  baseData.months.forEach(function(month) {
    var cellData = playersCellMap.get(month + '|FTD');
    if (!cellData) return;
    var players = [].concat(cellData.achieved || [], cellData.dropped || []);
    players.forEach(function(p) {
      var key = playerKey(p);
      if (key) {
        var dc = p.actualDeposits || p.depositCount || 0;
        if (!depositCountMap[key] || dc > depositCountMap[key]) {
          depositCountMap[key] = dc;
        }
      }
    });
  });
  
  // Step 2: Override with Dashboard data (most authoritative, latest snapshot)
  if (window.dashboardTagMap) {
    Object.keys(window.dashboardTagMap).forEach(function(email) {
      var dc = window.dashboardTagMap[email].depositCount;
      if (dc > 0) depositCountMap[email] = dc;
    });
  }
  
  console.log('📊 depositCountMap built:', Object.keys(depositCountMap).length, 'players');
  
  // ✅ Get ALL FTD players from cell map (achieved + dropped)
  function getFtdPlayers(month) {
    var cellData = playersCellMap.get(month + '|FTD');
    if (!cellData) return [];
    if (Array.isArray(cellData)) return cellData;
    return [].concat(cellData.achieved || [], cellData.dropped || []);
  }
  
  var result = { months: baseData.months, rows: [] };
  
  baseData.rows.forEach(function(rowData) {
    var newRow = { range: rowData.range, cells: [] };
    var parsed = parseRange(rowData.range);
    
    baseData.months.forEach(function(month) {
      // 1. Get FTD players for this month
      var ftdPlayers = getFtdPlayers(month);
      
      // 2. Apply filters (type, manager, traffic, country)
      var filteredFtd = ftdPlayers.filter(function(p) { return matchesDepositFilters(p, filters); });
      var ftdCount = filteredFtd.length;
      
      if (rowData.range === 'FTD') {
        newRow.cells.push({count: ftdCount, pct: ftdCount > 0 ? 1.0 : 0});
        return;
      }
      
      // 3. For each filtered FTD player, get deposit count from map
      var count = 0;
      filteredFtd.forEach(function(p) {
        var key = playerKey(p);
        var depCount = key ? (depositCountMap[key] || 0) : 0;
        // Check if deposit count matches range
        var inRange = parsed.max === null ? depCount >= parsed.min : (depCount >= parsed.min && depCount <= parsed.max);
        if (inRange) count++;
      });
      
      var pct = ftdCount > 0 ? count / ftdCount : 0;
      newRow.cells.push({count: count, pct: pct});
    });
    
    result.rows.push(newRow);
  });
  
  console.log('✅ filterDepositData complete');
  return result;
}
