var ppCalViewMode = 'week';
var ppCalDate = new Date();
ppCalDate.setHours(0,0,0,0);

function renderProfilingCalendar() {
  var container = document.getElementById('profilingPlayersContainer');
  if (!container) return;
  container.style.display = 'block';
  container.style.gridTemplateColumns = '';

  var today = ppTodayStr();
  var mNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var dNames = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  // Build map: dateStr -> [players]
  var dateMap = {};
  var managerName = profilingData.activeManager;
  var managerTags = managerMapping[managerName] || [];
  var players = (profilingData.allPlayers || []).filter(function(p) {
    if (!managerTags.length) return false;
    var pt = (p.tags || []).map(function(t){ return String(t).toLowerCase().trim(); });
    return pt.some(function(t){ return managerTags.indexOf(t) !== -1; });
  });

  players.forEach(function(p) {
    var email = (p.data.email || '').toLowerCase();
    var info = playerContactsCache[email];
    if (!info) return;
    // Use lastDate, fallback to first history entry; sanitize to YYYY-MM-DD
    var raw = info.lastDate || (info.history && info.history.length ? info.history[0] : null);
    if (!raw) return;
    var d = String(raw).slice(0, 10);
    if (d.length !== 10 || d[4] !== '-') return; // basic sanity check
    // Sync lastDate in cache so future renders are consistent
    if (!info.lastDate || info.lastDate !== d) info.lastDate = d;
    if (!dateMap[d]) dateMap[d] = [];
    dateMap[d].push(p);
  });

  // Controls
  var html = '<div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap">';
  html += '<button onclick="ppCalNav(-1)" style="padding:7px 14px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-size:13px;font-weight:700;border-radius:8px;cursor:pointer">◀</button>';
  html += '<button onclick="ppCalNav(1)" style="padding:7px 14px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-size:13px;font-weight:700;border-radius:8px;cursor:pointer">▶</button>';
  html += '<button onclick="ppCalGoToday()" style="padding:7px 14px;border:1.5px solid #e2e8f0;background:#fff;color:#6366f1;font-size:12px;font-weight:700;border-radius:8px;cursor:pointer">Today</button>';
  html += '<div style="display:flex;border:1.5px solid #e2e8f0;border-radius:8px;overflow:hidden">';
  var modeLabels = {day:'📅 Month', week:'📆 Weeks', month:'📊 Year'};
  ['day','week','month'].forEach(function(m) {
    html += '<button onclick="ppCalSetView(this)" data-mode="' + m + '" style="padding:7px 14px;border:none;background:' + (ppCalViewMode===m?'#667eea':'#fff') + ';color:' + (ppCalViewMode===m?'#fff':'#64748b') + ';font-size:12px;font-weight:700;cursor:pointer">' + modeLabels[m] + '</button>';
  });
  html += '</div></div>';

  if (ppCalViewMode === 'week') html += ppCalRenderWeek(dateMap, today, mNames, dNames);
  else if (ppCalViewMode === 'month') html += ppCalRenderMonth(dateMap, today, mNames, dNames);
  else html += ppCalRenderDay(dateMap, today, mNames, dNames);

  container.innerHTML = html;

  // Wire all calendar bubbles via event delegation
  container.querySelectorAll('.pp-cal-bubble').forEach(function(el) {
    el.onmouseenter = function(){ this.style.transform='scale(1.12)'; };
    el.onmouseleave = function(){ this.style.transform='scale(1)'; };
    el.onclick = function(e) {
      e.stopPropagation();
      ppCalShowPlayers(decodeURIComponent(this.dataset.ppemails), this.dataset.ppdate);
    };
  });

  // Wire day-view player cards
  if (ppCalViewMode === 'day') {
    var dk = ppCalDk(ppCalDate);
    var dayPlayers = dateMap[dk] || [];
    var dayGrid = document.getElementById('ppCalDayGrid');
    if (dayGrid && dayPlayers.length) {
      dayPlayers.forEach(function(p) {
        var name = p.data.name || p.data.email || '?';
        var em = p.data.email || '';
        var card = document.createElement('div');
        card.style.cssText = 'padding:12px 14px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;cursor:pointer;transition:all 0.15s';
        card.onmouseover = function(){ this.style.borderColor='#667eea'; this.style.background='#eef2ff'; };
        card.onmouseout  = function(){ this.style.borderColor='#e2e8f0'; this.style.background='#f8fafc'; };
        card.onclick = function(){ ppCalOpenModal(em); };
        card.innerHTML = '<div style="font-weight:800;font-size:13px;color:#1e293b">' + name + '</div><div style="font-size:11px;color:#94a3b8;margin-top:2px">' + em + '</div>';
        dayGrid.appendChild(card);
      });
    }
  }
}

function ppCalNav(dir) {
  if (ppCalViewMode === 'week') {
    // Navigate by month
    ppCalDate.setMonth(ppCalDate.getMonth() + dir);
    ppCalDate.setDate(1);
  } else if (ppCalViewMode === 'day') {
    // Navigate by month (day mode shows a whole month calendar)
    ppCalDate.setMonth(ppCalDate.getMonth() + dir);
    ppCalDate.setDate(1);
  } else {
    // Month mode: navigate by year
    ppCalDate.setFullYear(ppCalDate.getFullYear() + dir);
    ppCalDate.setMonth(0); ppCalDate.setDate(1);
  }
  renderProfilingCalendar();
}

function ppCalGoToday() {
  ppCalDate = new Date(); ppCalDate.setHours(0,0,0,0);
  renderProfilingCalendar();
}

function ppCalDates() {
  // Returns dates for current month (used by day and week modes)
  var dates = [];
  var d2 = new Date(ppCalDate.getFullYear(), ppCalDate.getMonth(), 1);
  var end = new Date(ppCalDate.getFullYear(), ppCalDate.getMonth()+1, 0);
  var sd = d2.getDay(); d2.setDate(d2.getDate()+(sd===0?-6:1-sd));
  while(d2<=end||d2.getDay()!==1){dates.push(new Date(d2));d2.setDate(d2.getDate()+1);if(dates.length>42)break;}
  return dates;
}


