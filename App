    h += '<div style="margin-left:auto;text-align:center;background:rgba(255,255,255,0.2);padding:10px 20px;border-radius:12px"><div style="font-size:10px;opacity:0.8;font-weight:700">TOTAL BONUS</div><div style="font-size:28px;font-weight:900">$' + totalBonus.toFixed(0) + '</div>';
    if (kpiBonus > 0) h += '<span style="font-size:10px;opacity:0.7">KPI $' + kpiBonus.toFixed(0) + '</span> ';
    if (qaBonus > 0) h += '<span style="font-size:10px;opacity:0.7">QA $' + qaBonus.toFixed(0) + '</span>';
    h += '</div>';
  }
  h += '</div>';
  
