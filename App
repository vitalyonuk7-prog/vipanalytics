function openRv2Modal(srcLabel, tgtLabel) {
  var isMom = rv2Type === 'mom';
  var modal = document.getElementById('modal');
  document.getElementById('modalTitle').textContent = srcLabel + (isMom ? ' ACTIVE' : ' FTD') + ' → ' + tgtLabel + ' ACTIVE';
  modal.classList.add('open');
  
  var mode = rv2CurrentMode();
  var data = rv2Data[mode];
  if (!data || !data.srcEmails || !data.activeEmails || !data.playerDetails) {
    document.getElementById('modalBody').innerHTML = '<div class="err">No data available</div>';
    return;
  }
  
  var isWeekly = rv2Mode === 'weekly';
  var periods = isWeekly ? (data.weeks || []) : (data.months || []);
  
  // srcIdx = row index (FTD groups), tgtIdx = column index (ACTIVE groups)
  var srcIdx = -1, tgtIdx = -1;
  for (var i = 0; i < data.rows.length; i++) {
    var rowLabel = isWeekly ? data.rows[i].week : data.rows[i].month;
    if (rowLabel === srcLabel) { srcIdx = i; break; }
  }
  for (var i = 0; i < periods.length; i++) {
    if (periods[i] === tgtLabel) { tgtIdx = i; break; }
  }
  
  if (srcIdx === -1 || tgtIdx === -1 || !data.srcEmails[srcIdx] || !data.activeEmails[tgtIdx]) {
    document.getElementById('modalBody').innerHTML = '<div class="err">Period not found (src=' + srcIdx + ' tgt=' + tgtIdx + ')</div>';
    return;
  }
  
  var pd = data.playerDetails;
  var activeSet = {};
  data.activeEmails[tgtIdx].forEach(function(e) { activeSet[e] = true; });
  
  // Apply filters if active
  var srcEmails = data.srcEmails[srcIdx];
  if (rv2HasActiveFilters()) {
    srcEmails = srcEmails.filter(function(e) { return rv2PlayerPassesFilter(e, pd); });
  }
  
  var achieved = [], dropped = [];
  srcEmails.forEach(function(e) {
    var player = buildPlayerFromDetails(e, pd);
    if (activeSet[e]) achieved.push(player);
    else dropped.push(player);
  });
  
  var modalData = { achieved: achieved, dropped: dropped, total: srcEmails.length, totalAchieved: achieved.length, totalDropped: dropped.length };
  currentModalData = modalData;
  currentFilteredData = modalData;
  renderModalContent(modalData);
}

