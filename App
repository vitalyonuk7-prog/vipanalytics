function bsParseCSV(text) {
  var lines = text.split(/\r?\n/);
  if (lines.length < 2) return [];
  // Handle quoted fields
  function parseLine(line) {
    var result = []; var field = ''; var inQuote = false;
    for (var i = 0; i < line.length; i++) {
      var c = line[i];
      if (c === '"') { inQuote = !inQuote; }
      else if ((c === ',' || c === '\t' || c === ';') && !inQuote) { result.push(field.trim()); field = ''; }
      else { field += c; }
    }
    result.push(field.trim());
    return result;
  }
  var headers = parseLine(lines[0]).map(function(h) { return h.toLowerCase().replace(/[^a-z0-9_]/g, '_'); });
  var rows = [];
  for (var i = 1; i < lines.length; i++) {
    if (!lines[i].trim()) continue;
    var vals = parseLine(lines[i]);
    var obj = {};
    headers.forEach(function(h, idx) { obj[h] = vals[idx] || ''; });
    rows.push(obj);
  }
  return rows;
}

function bsLoadCSV(input, type) {
  var file = input.files[0]; if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    var rows = bsParseCSV(e.target.result);
    if (type === 'games') bsReplay.games = rows;
    else bsReplay.balances = rows;
    bsRender();
  };
  reader.readAsText(file);
}

function bsStartReplay() {
  if (!bsReplay.games.length) return;
  bsReplay.deposit = parseFloat(document.getElementById('bsRepDeposit').value) || 100;
  bsReplay.bonusPct = parseFloat(document.getElementById('bsRepBonusPct').value) || 100;
  bsReplay.wagerX = parseFloat(document.getElementById('bsRepWagerX').value) || 35;
  
  // Build merged array from games CSV
  var g = bsReplay.games;
  // Sort by id or created_at
  g.sort(function(a, b) {
    var aid = parseInt(a.id) || 0; var bid = parseInt(b.id) || 0;
    return aid - bid;
  });
  
  // Build balance lookup from balances CSV (Reference = game id)
  var balMap = {};
  bsReplay.balances.forEach(function(b) {
    var ref = b.reference || '';
    if (!balMap[ref]) balMap[ref] = [];
    balMap[ref].push(b);
  });
  
  // Merge with proper real/bonus tracking
  bsReplay.merged = [];
  var dep = bsReplay.deposit;
  var bonusInit = dep * bsReplay.bonusPct / 100;
  var trackReal = dep;
  var trackBonus = bonusInit;
  
  g.forEach(function(row) {
    var gameId = row.id || '';
    var balRows = balMap[gameId] || [];
    
    // From balance CSV: sum real and bonus parts
    var totalBonusAmt = 0;
    var totalAmt = 0;
    balRows.forEach(function(b) {
      totalAmt += parseFloat(b.amount) || 0;
      totalBonusAmt += parseFloat(b.bonus_amount) || 0;
    });
    var totalRealAmt = totalAmt - totalBonusAmt;
    
    var balBefore = parseFloat(row.balance_before) || 0;
    var balAfter = parseFloat(row.balance_after) || 0;
    var betSum = parseFloat(row.bets_sum) || 0;
    var payoff = parseFloat(row.payoffs_sum) || 0;
    var profit = parseFloat(row.profit) || 0;
    var title = row.title || '';
    var bonusIssue = row.bonus_issue || '';
    
    var realBefore = trackReal;
    var bonusBefore = trackBonus;
    
    // Apply changes from balance entries
    trackReal += totalRealAmt;
    trackBonus += totalBonusAmt;
    
    // Clamp
    if (trackReal < 0) { trackBonus += trackReal; trackReal = 0; }
    if (trackBonus < 0) { trackReal += trackBonus; trackBonus = 0; }
    trackReal = Math.round(trackReal * 100) / 100;
    trackBonus = Math.round(trackBonus * 100) / 100;
    
    bsReplay.merged.push({
      gameId: gameId,
      title: title,
      balBefore: balBefore,
      balAfter: balAfter,
      betSum: betSum,
      payoff: payoff,
      profit: profit,
      bonusAmount: totalBonusAmt,
      realAmount: totalRealAmt,
      bonusIssue: bonusIssue,
      realBefore: realBefore,
      bonusBefore: bonusBefore,
      realAfter: trackReal,
      bonusBalAfter: trackBonus
    });
  });
  
  bsReplay.idx = 0;
  bsReplay.loaded = true;
  bsReplay.playing = false;
  bsRender();
}

function bsReplaySeek(val) {
  bsReplay.idx = parseInt(val) || 0;
  bsRender();
}

function bsReplayStep(n) {
  bsReplay.idx = Math.max(0, Math.min(bsReplay.merged.length - 1, bsReplay.idx + n));
  bsRender();
}

function bsReplayPlay() {
  if (bsReplay.playing) return;
  bsReplay.playing = true;
  bsRender();
  bsReplay.timer = setInterval(function() {
    if (bsReplay.idx < bsReplay.merged.length - 1) {
      bsReplay.idx++;
      bsRender();
    } else {
      bsReplayPause();
    }
  }, bsReplay.speed);
}

function bsReplayPause() {
  bsReplay.playing = false;
  clearInterval(bsReplay.timer);
  bsRender();
}

function bsReplaySpeed(sp) {
  bsReplay.speed = sp;
  if (bsReplay.playing) {
    clearInterval(bsReplay.timer);
    bsReplay.timer = setInterval(function() {
      if (bsReplay.idx < bsReplay.merged.length - 1) {
        bsReplay.idx++;
        bsRender();
      } else { bsReplayPause(); }
    }, sp);
  }
  bsRender();
}

