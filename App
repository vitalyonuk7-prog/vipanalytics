function pSmsCalcChars(text) {
  var eEl=document.getElementById('pSmsEncoding'), cEl=document.getElementById('pSmsCharCount'),
      sEl=document.getElementById('pSmsSegments'), bEl=document.getElementById('pSmsProgressBar'),
      wEl=document.getElementById('pSmsWarning');
  if (!eEl) return;
  if (!text) {
    eEl.textContent='GSM-7'; eEl.style.color='#10b981';
    cEl.textContent='0/160'; sEl.textContent='0'; sEl.style.color='#10b981';
    bEl.style.width='0%'; if(wEl) wEl.style.display='none'; return;
  }
  var gsm=isGSM7(text), cc, sl, ml, segs;
  if(gsm){cc=countGSM7(text);sl=160;ml=153;eEl.textContent='GSM-7';eEl.style.color='#10b981';}
  else{cc=text.length;sl=70;ml=67;eEl.textContent='UCS-2';eEl.style.color='#f59e0b';}
  segs=cc<=sl?(cc>0?1:0):Math.ceil(cc/ml);
  cEl.textContent=cc+'/'+(segs<=1?sl:ml*segs);
  sEl.textContent=String(segs); sEl.style.color=segs<=1?'#10b981':segs<=3?'#f59e0b':'#ef4444';
  bEl.style.width=Math.min(100,(cc/sl)*100)+'%';
  bEl.style.background=segs<=1?'linear-gradient(90deg,#10b981,#059669)':segs<=3?'linear-gradient(90deg,#f59e0b,#d97706)':'linear-gradient(90deg,#ef4444,#dc2626)';
  if(wEl){wEl.style.display=(!gsm||segs>1)?'block':'none';wEl.textContent=!gsm?'⚠️ Unicode → 70 chars/seg':'📦 '+segs+' segments';}
}

function pSmsUpdateBtn() {
  var text = '';
  if (_pSmsData.mode === 'new') { text = (document.getElementById('pSmsText').value || '').trim(); }
  else { text = (document.getElementById('pSmsTplPreview').value || '').trim(); }
  pSmsCalcChars(text);
  var ok = _pSmsData.phone && _pSmsData.selectedLocale && text.length > 0;
  var btn = document.getElementById('pSmsSendBtn');
  btn.disabled = !ok; btn.style.opacity = ok ? '1' : '0.5';
}

