<!-- Bonus Category Modal -->
<div id="bonusCategoryModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center" onclick="if(event.target.id==='bonusCategoryModal')closeBonusCategoryModal()">
<div style="background:#fff;border-radius:16px;max-width:900px;width:95%;max-height:90vh;box-shadow:0 20px 60px rgba(0,0,0,0.3);display:flex;flex-direction:column">
<div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:2px solid #e2e8f0">
<h2 style="margin:0;font-size:20px;font-weight:800;color:#1e293b">🏷️ Bonus Categories</h2>
<div style="display:flex;gap:10px;align-items:center">
<button onclick="openAddCategoryModal()" style="padding:8px 16px;border-radius:8px;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-size:12px;font-weight:700;cursor:pointer">+ New Category</button>
<button onclick="closeBonusCategoryModal()" style="background:none;border:none;font-size:28px;color:#64748b;cursor:pointer;line-height:1">×</button>
</div>
</div>
<div style="padding:16px 24px;border-bottom:1px solid #e2e8f0;display:flex;gap:12px;align-items:center;flex-wrap:wrap">
<input type="text" id="bonusCatSearch" placeholder="Search bonus name..." oninput="filterBonusCategoryList()" style="padding:8px 14px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;flex:1;min-width:200px">
<div id="bonusCatFilterBtns" style="display:flex;gap:6px;flex-wrap:wrap"></div>
<div id="bonusCatStats" style="font-size:12px;color:#64748b;font-weight:600"></div>
</div>
<div style="padding:0 24px 24px;overflow-y:auto;flex:1" id="bonusCategoryListWrap"></div>
</div>
</div>

<!-- Add Category Sub-Modal -->
<div id="addCategorySubModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:10001;align-items:center;justify-content:center" onclick="if(event.target.id==='addCategorySubModal')this.style.display='none'">
<div style="background:#fff;border-radius:16px;max-width:400px;width:90%;padding:32px;box-shadow:0 20px 60px rgba(0,0,0,0.4)">
<h3 style="margin:0 0 20px;font-size:18px;font-weight:800;color:#1e293b">Create New Category</h3>
<input type="text" id="newCategoryInput" placeholder="Category name..." style="width:100%;padding:12px 16px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px;font-weight:600;margin-bottom:12px;box-sizing:border-box" onkeydown="if(event.key==='Enter')saveBonusCategoryOption()">
<div id="existingCatsList" style="margin-bottom:16px"></div>
<div style="display:flex;gap:10px;justify-content:flex-end">
<button onclick="document.getElementById('addCategorySubModal').style.display='none'" style="padding:10px 20px;border-radius:8px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-weight:700;cursor:pointer;font-size:13px">Cancel</button>
<button onclick="saveBonusCategoryOption()" style="padding:10px 20px;border-radius:8px;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-weight:700;cursor:pointer;font-size:13px">Create</button>
</div>
</div>
</div>

<!-- Contact Tracker -->
<div class="ct-fab" id="ctFab" onclick="ctToggle()" title="Contact Tracker">✏️</div>
<div class="ct-panel" id="ctPanel">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
    <div style="font-size:13px;font-weight:800;color:#1e293b">✏️ Contact Tracker</div>
    <button onclick="ctReset()" style="padding:3px 8px;border:1px solid #e2e8f0;border-radius:6px;background:#fff;color:#94a3b8;font-size:10px;font-weight:700;cursor:pointer" title="Clear all marks">🗑️ Clear</button>
  </div>
  <div style="font-size:10px;color:#94a3b8;margin-bottom:8px">Select emoji, then click any player:</div>
  <div class="ct-emoji-grid" id="ctEmojiGrid"></div>
  <div class="ct-stats" id="ctStats">No contacts marked</div>
</div>
<!-- Player SMS Modal -->
<div id="playerSmsModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:99999;align-items:center;justify-content:center" onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#fff;border-radius:16px;padding:28px;max-width:520px;width:92%;box-shadow:0 20px 60px rgba(0,0,0,0.2);animation:fadeInScale 0.2s ease;max-height:85vh;overflow-y:auto">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
      <span style="font-size:28px">💬</span>
      <div><div style="font-weight:800;font-size:16px;color:#1e293b">Send SMS</div><div id="pSmsPlayerInfo" style="font-size:12px;color:#64748b;margin-top:2px"></div></div>
    </div>
    <div id="pSmsNoPhone" style="display:none;background:#fef2f2;border:1.5px solid #fca5a5;border-radius:10px;padding:12px;margin-bottom:12px;font-size:13px;color:#dc2626;font-weight:700">🚫 No phone number — cannot send SMS</div>
    <div id="pSmsForm">
      <div style="margin-bottom:12px">
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;display:block;margin-bottom:6px">Mode</label>
        <div style="display:flex;gap:8px">
          <button id="pSmsModeNew" onclick="pSmsSetMode('new')" class="metric-btn active" style="padding:8px 16px;font-size:12px">✏️ Write New</button>
          <button id="pSmsModeTemplate" onclick="pSmsSetMode('template')" class="metric-btn" style="padding:8px 16px;font-size:12px">📋 Template</button>
        </div>
      </div>
      <div id="pSmsNewPanel">
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;display:block;margin-bottom:6px">Locale</label>
        <div id="pSmsLocaleButtons" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px"></div>
        <textarea id="pSmsText" placeholder="Type message..." rows="4" class="sms-locale-input" style="margin-bottom:6px" oninput="pSmsCalcChars(this.value);pSmsUpdateBtn()"></textarea>
      </div>
      <div id="pSmsTplPanel" style="display:none">
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;display:block;margin-bottom:6px">Template</label>
        <select id="pSmsTplSelect" onchange="pSmsTplChanged()" style="width:100%;padding:10px 14px;border:2px solid #e2e8f0;border-radius:10px;font-size:13px;font-weight:600;font-family:inherit;outline:none;box-sizing:border-box;cursor:pointer;margin-bottom:10px"><option value="">— choose —</option></select>
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;display:block;margin-bottom:6px">Locale</label>
        <div id="pSmsTplLocaleButtons" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px"></div>
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;display:block;margin-bottom:6px">Message <span style="font-weight:500;color:#94a3b8">(editable)</span></label>
        <textarea id="pSmsTplPreview" rows="4" class="sms-locale-input" style="width:100%;padding:12px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:13px;color:#1e293b;min-height:70px;margin-bottom:6px;box-sizing:border-box;resize:vertical;font-family:inherit;white-space:pre-wrap;background:#f8fafc" oninput="pSmsCalcChars(this.value);pSmsUpdateBtn()"></textarea>
      </div>
      <!-- Char counter -->
      <div id="pSmsCharBar" style="display:flex;gap:16px;align-items:center;padding:8px 12px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;margin-bottom:12px">
        <div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Encoding</div><div id="pSmsEncoding" style="font-size:13px;font-weight:800;color:#10b981">GSM-7</div></div>
        <div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Chars</div><div id="pSmsCharCount" style="font-size:13px;font-weight:800;color:#1e293b">0/160</div></div>
        <div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Segments</div><div id="pSmsSegments" style="font-size:13px;font-weight:800;color:#10b981">0</div></div>
        <div style="flex:1"><div style="height:4px;background:#e2e8f0;border-radius:2px;overflow:hidden"><div id="pSmsProgressBar" style="height:100%;width:0%;background:linear-gradient(90deg,#10b981,#059669);border-radius:2px;transition:width 0.2s"></div></div><div id="pSmsWarning" style="display:none;font-size:10px;font-weight:600;color:#f59e0b;margin-top:3px"></div></div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button onclick="document.getElementById('playerSmsModal').style.display='none'" style="padding:10px 20px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-size:13px;font-weight:700;border-radius:10px;cursor:pointer">Cancel</button>
        <button id="pSmsSendBtn" onclick="pSmsSend()" disabled style="padding:10px 24px;border:none;background:linear-gradient(135deg,#10b981,#059669);color:#fff;font-size:13px;font-weight:700;border-radius:10px;cursor:pointer;opacity:0.5">📤 Send</button>
      </div>
      <div id="pSmsSendStatus" style="text-align:center;margin-top:6px;font-size:12px;font-weight:600"></div>
    </div>
  </div>
</div>
</body>
</html>
