  h += '<th style="text-align:center;' + thS('country') + '" onclick="pmDrillSort(\'country\')">Country' + arrow('country') + '</th>';
  h += '<th style="text-align:center;' + thS('success') + '" onclick="pmDrillSort(\'success\')">✅' + arrow('success') + '</th>';
  h += '<th style="text-align:center;' + thS('failed') + '" onclick="pmDrillSort(\'failed\')">❌' + arrow('failed') + '</th>';
  h += '<th style="text-align:center;' + thS('count') + '" onclick="pmDrillSort(\'count\')">Total' + arrow('count') + '</th>';
  h += '<th style="text-align:right;' + thS('amount') + ';border-radius:0 8px 0 0" onclick="pmDrillSort(\'amount\')">Success Amount' + arrow('amount') + '</th>';
  h += '</tr></thead><tbody>';
  sorted.forEach(function(p) {
    var amts = Object.keys(p.byCur).sort().map(function(c) { return pmFmt(p.byCur[c]) + ' ' + c; }).join(', ');
    var rate = p.count > 0 ? ((p.successCount / p.count) * 100).toFixed(0) : '0';
    h += '<tr style="border-bottom:1px solid #f1f5f9;cursor:pointer;transition:background 0.1s" onmouseover="this.style.background=\'#f8fafc\'" onmouseout="this.style.background=\'\'" onclick="pmOpenPlayer(\'' + p.email.replace(/'/g,"\\'") + '\')">';
    h += '<td style="padding:10px;font-weight:600;color:#667eea">' + p.email + '</td>';
    h += '<td style="padding:10px;text-align:center"><span style="font-size:11px;padding:2px 8px;border-radius:10px;background:#f1f5f9;font-weight:600">' + (p.type || '—') + '</span></td>';
    h += '<td style="padding:10px;text-align:center;font-size:12px">' + (p.manager || '—') + '</td>';
    h += '<td style="padding:10px;text-align:center;font-size:12px">' + (typeof getFlag==='function'?getFlag(p.country):'') + ' ' + (p.country || '—') + '</td>';
    h += '<td style="padding:10px;text-align:center;font-weight:700;color:#10b981">' + p.successCount + '</td>';
    h += '<td style="padding:10px;text-align:center;font-weight:600;color:#ef4444">' + p.failedCount + '</td>';
