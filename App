.upd-msg{font-size:12px;font-weight:700;text-align:center;margin-top:8px;min-height:18px}

/* Admin Panel Overlay */
.admin-overlay{background:linear-gradient(135deg,#fef2f2 0%,#fff7ed 35%,#f5f3ff 65%,#eff6ff 100%);display:none;justify-content:center;align-items:flex-start;padding:16px 20px;overflow-y:auto;min-height:100%}
.admin-overlay.active{display:flex}
.admin-panel{width:100%;max-width:1100px}
.admin-topbar{display:flex;align-items:center;justify-content:space-between;padding:22px 32px;background:linear-gradient(135deg,#1e293b,#334155);border-radius:24px;margin-bottom:16px;box-shadow:0 8px 32px rgba(30,41,59,0.2)}
.admin-topbar-title{font-size:20px;font-weight:900;color:#fff;display:flex;align-items:center;gap:12px}
.admin-topbar-close{display:none}
.admin-tabs{display:flex;gap:6px;margin-bottom:16px;overflow-x:auto;padding-bottom:4px}
.admin-tab{padding:10px 18px;border-radius:10px;border:1.5px solid #e2e8f0;background:#fff;font-size:12px;font-weight:800;cursor:pointer;transition:all 0.2s;color:#64748b;white-space:nowrap}
.admin-tab.active{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-color:transparent;box-shadow:0 4px 12px rgba(102,126,234,0.3)}
.admin-card{background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 16px rgba(0,0,0,0.06);border:1px solid #e2e8f0}
.admin-card-title{font-size:16px;font-weight:900;color:#1e293b;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.admin-table{width:100%;border-collapse:collapse;font-size:13px}
.admin-table th{padding:12px 14px;text-align:left;font-weight:700;color:#475569;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;background:#f8fafc;border-bottom:2px solid #e2e8f0}
.admin-table td{padding:10px 14px;border-bottom:1px solid #f1f5f9;vertical-align:middle}
.admin-table tr:hover td{background:#fafbff}
.admin-table input[type="text"],.admin-table input[type="email"],.admin-table select{padding:6px 10px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600;font-family:inherit;outline:none}
.admin-table input:focus,.admin-table select:focus{border-color:#667eea}
.admin-btn-sm{padding:6px 12px;border:none;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;transition:all 0.2s}
.admin-btn-danger{background:#fee2e2;color:#dc2626}.admin-btn-danger:hover{background:#fecaca}
.admin-btn-action{background:#ede9fe;color:#7c3aed}.admin-btn-action:hover{background:#ddd6fe}
.admin-btn-add{padding:10px 20px;border:none;border-radius:10px;background:linear-gradient(135deg,#059669,#047857);color:#fff;font-size:13px;font-weight:800;cursor:pointer;box-shadow:0 4px 12px rgba(5,150,105,0.3);transition:all 0.2s}
.admin-btn-add:hover{transform:translateY(-1px)}
/* Roles - card layout */
.rm-card{background:#fff;border:1.5px solid #e2e8f0;border-radius:16px;overflow:hidden;transition:box-shadow 0.2s}
.rm-card:hover{box-shadow:0 4px 16px rgba(0,0,0,0.06)}
.rm-card-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #f1f5f9}
.rm-role-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:10px;font-size:14px;font-weight:800;letter-spacing:-0.2px}
.rm-role-badge.admin{background:linear-gradient(135deg,#fef2f2,#fff1f2);color:#dc2626;border:1.5px solid #fecaca}
