// ── Total progress summary for an assignment ──
function obTotalProgress(asgn, plan) {
  if (!plan) return null;
  var days = plan.days||[];
  var total = days.length;
  var closed = Object.keys(asgn.daysClosed||{}).length;
  var rv = Object.values(asgn.dayRatings||{});
  var avgR = rv.length ? rv.reduce(function(s,v){return s+v;},0)/rv.length : 0;
  var testT=0, testM=0;
  days.forEach(function(day,di){
    (day.tests||[]).forEach(function(t,ti){
      var k=(day.id||di)+'_t'+ti;
      if((asgn.testScores||{})[k]!==undefined) testT+=Number((asgn.testScores||{})[k])||0;
      if(t.maxScore) testM+=Number(t.maxScore)||0;
    });
  });
  var pct = total ? Math.round(closed/total*100) : 0;

  var bar = document.createElement('div');
  bar.style.cssText = 'padding:12px 18px;background:linear-gradient(135deg,#f8fafc,#f1f5f9);border:1.5px solid #e2e8f0;border-radius:12px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:16px';

  // Progress ring
  var sz=44,sw=4,r=(sz-sw)/2,circ=2*Math.PI*r,dash=circ*pct/100;
  var ringC=pct===100?'#10b981':'#6366f1';
  var ringDiv=document.createElement('div');ringDiv.style.cssText='position:relative;width:'+sz+'px;height:'+sz+'px;flex-shrink:0';
  ringDiv.innerHTML='<svg width="'+sz+'" height="'+sz+'" viewBox="0 0 '+sz+' '+sz+'" style="position:absolute;top:0;left:0"><circle cx="'+sz/2+'" cy="'+sz/2+'" r="'+r+'" fill="none" stroke="#e2e8f0" stroke-width="'+sw+'"/><circle cx="'+sz/2+'" cy="'+sz/2+'" r="'+r+'" fill="none" stroke="'+ringC+'" stroke-width="'+sw+'" stroke-linecap="round" stroke-dasharray="'+dash.toFixed(1)+' '+(circ-dash).toFixed(1)+'" transform="rotate(-90 '+sz/2+' '+sz/2+')"/></svg><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:'+ringC+'">'+pct+'%</div>';
  bar.appendChild(ringDiv);

  var stats=document.createElement('div');stats.style.cssText='display:flex;gap:14px;flex-wrap:wrap;align-items:center';
  function stat(val,lbl,color){var d=document.createElement('div');d.style.cssText='text-align:center';var v=obEl('div','font-size:16px;font-weight:900;color:'+(color||'#1e293b'),val);var l=obEl('div','font-size:9px;color:#94a3b8;text-transform:uppercase;margin-top:1px',lbl);d.appendChild(v);d.appendChild(l);return d;}
  stats.appendChild(stat(closed+'/'+total,'closed','#10b981'));
  if (avgR>0) {
    var sr=document.createElement('div');sr.style.cssText='text-align:center';
    var starsD=document.createElement('div');
    for(var i=1;i<=5;i++){var sp=document.createElement('span');sp.textContent=i<=Math.round(avgR)?'★':'☆';sp.style.cssText='color:'+(i<=avgR?'#f59e0b':'#d1d5db')+';font-size:14px';starsD.appendChild(sp);}
    sr.appendChild(starsD);
    sr.appendChild(obEl('div','font-size:9px;color:#94a3b8;text-transform:uppercase;margin-top:1px','avg score'));
    stats.appendChild(sr);
  }
  if (testM>0) stats.appendChild(stat(testT+'/'+testM,'test pts','#6366f1'));
  bar.appendChild(stats);
  return bar;
}

// ── Calculate onboarding day dates based on manager's timetable schedule ──
function obCalcWorkingDayDates(userEmail, startDate, numDays) {
  // Returns array of date strings (YYYY-MM-DD) for each onboarding day
  // skipping non-working days based on timetable assignment
  var result = [];
  if (!numDays) return result;

  // Find timetable assignment for this user
  var ttAsgn = null;
  if (ttData && ttData.assignments) {
    ttAsgn = ttData.assignments.find(function(a) {
      return (a.managerEmail||'').toLowerCase() === (userEmail||'').toLowerCase();
    });
  }

  var current = new Date(startDate + 'T12:00:00');
  var maxDays = numDays * 14; // safety limit (2 weeks per day max)
  var counted = 0;

  for (var i = 0; i < maxDays && result.length < numDays; i++) {
    var isWorking = true;

    if (ttAsgn) {
      var shift = ttGetShiftForDate(ttAsgn, current);
      isWorking = !!shift;
    } else {
      // No timetable — skip Sat/Sun by default
      var dow = current.getDay();
      isWorking = dow !== 0 && dow !== 6;
    }

    if (isWorking) {
      var y = current.getFullYear();
      var m = String(current.getMonth()+1).padStart(2,'0');
      var d = String(current.getDate()).padStart(2,'0');
      result.push(y+'-'+m+'-'+d);
    }
    current.setDate(current.getDate() + 1);
  }

