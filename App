// ── Linkify text — makes URLs clickable ──
function obLinkify(text) {
  var div = document.createElement('div');
  div.style.cssText = 'white-space:pre-wrap;word-break:break-word';
  var urlRegex = /(https?:\/\/[^\s<>"']+)/g;
  var parts = text.split(urlRegex);
  parts.forEach(function(part) {
    if (urlRegex.test(part)) {
      var a = document.createElement('a');
      a.href = part; a.target = '_blank'; a.rel = 'noopener';
      a.textContent = part;
      a.style.cssText = 'color:#6366f1;text-decoration:underline;word-break:break-all';
