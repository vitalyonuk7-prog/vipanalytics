function ppDeleteContact(email, idx) {
  var info = playerContactsCache[email];
  if (!info || !info.history) return;
  // Instant remove
  info.history.splice(idx, 1);
  info.lastDate = info.history.length ? info.history[0] : null;
  
  // ── Instant UI updates ──
  var histEl = document.getElementById('ppContactHistoryList');
  if (histEl) ppFillHistoryContainer(histEl, info.history, email);
  
