function ctDoSaveList() {
  var input = document.getElementById('ctSaveListInput');
  if (!input) return;
  var name = (input.value || '').trim();
  if (!name) { input.style.borderColor = '#ef4444'; return; }
  var players = ctBuildPlayersArray();
  input.disabled = true;
  // Optimistic
  var tempId = 'list_' + Date.now();
  listsData.push({ id: tempId, name: name, players: players, priority: 3, comments: '', status: 'todo', created: 'just now' });
  var sm = document.getElementById('ctSummaryModal');
  if (sm) sm.style.display = 'none';
  ctShowSuccessBanner('✅ List "' + name + '" saved — ' + players.length + ' players');
