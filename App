function appRefresh() {
  var icon = document.getElementById('topRefreshIcon');
  var btn  = document.getElementById('topRefreshBtn');

  if (btn) btn.disabled = true;
  if (icon) {
    icon.style.transition = 'transform 0.7s ease';
    icon.style.transform  = 'rotate(360deg)';
    setTimeout(function(){
      icon.style.transition = 'none'; icon.style.transform = 'rotate(0deg)';
      setTimeout(function(){ icon.style.transition = 'transform 0.7s ease'; }, 50);
    }, 720);
  }

  _rtLastSummary = {};

  var activeView = document.querySelector('.content.active');
  var viewId = activeView ? activeView.id : '';

  // ── Service tools: always refresh ALL of them ──
  var jobs = [];

  // 1. Onboarding
  jobs.push(new Promise(function(res){
    google.script.run.withSuccessHandler(function(r){ if(r&&r.plans) obPlans=r.plans; res(); }).withFailureHandler(res).getOnboardingPlans();
  }));
  jobs.push(new Promise(function(res){
    google.script.run.withSuccessHandler(function(r){ if(r&&r.assignments) obAssignments=r.assignments; res(); }).withFailureHandler(res).getOnboardingAssignments();
  }));

  // 2. QA
  if (typeof preloadQaData === 'function') jobs.push(preloadQaData().catch(function(){}));

  // 3. Timetable
  jobs.push(new Promise(function(res){
    google.script.run.withSuccessHandler(function(r){ if(r&&r.success) ttData=r.data||{teams:[],shifts:[]}; res(); }).withFailureHandler(res).getTimetableData();
  }));

  // 4. SMS
  if (typeof preloadSmsData === 'function') jobs.push(preloadSmsData());

  // 5. QA KPI board
  jobs.push(new Promise(function(res){ var c=0; function ck(){if(++c>=2)res();}
    google.script.run.withSuccessHandler(function(r){kpiTemplates=r||[];ck();}).withFailureHandler(ck).getKpiTemplates();
    google.script.run.withSuccessHandler(function(r){kpiResults=r||[];ck();}).withFailureHandler(ck).getKpiResults();
  }));

  // 6. Admin (if loaded)
  if (adminPanelData) loadAdminPanelData(true);

  // 7. Contacts/player data (profiling contacts)
  jobs.push(new Promise(function(res){
    google.script.run.withSuccessHandler(function(r){
      if(r&&r.contacts){ playerContactsCache=r.contacts; playerContactsCacheLoaded=true; }
      res();
    }).withFailureHandler(res).getPlayerContacts();
  }));

  // ── Re-render current view after all loaded ──
  Promise.all(jobs).then(function() {
    if (btn) btn.disabled = false;
    obShowTopBtn();

    // Re-render whichever service view is active
    if (viewId.indexOf('onboarding') !== -1) {
      var c2 = document.getElementById('obMainContent');
      if (c2) {
        if (obMyAssignment) obRenderUserPlanPage(c2);
        else if (obTutorAssignments.length) obRenderTutorPage(c2);
        else if (window._userRole === 'admin') qaRenderOnboarding(c2);
      }
    } else if (viewId.indexOf('timetable') !== -1) {
      if (typeof ttRenderPage === 'function') ttRenderPage();
    } else if (viewId.indexOf('qa_board') !== -1) {
      if (typeof qaRenderPage === 'function') qaRenderPage();
    } else if (viewId.indexOf('sms_tool') !== -1) {
      if (typeof renderSmsTool === 'function') renderSmsTool();
    } else if (viewId.indexOf('kpi_board') !== -1) {
      if (typeof renderKpiBoardPage === 'function') renderKpiBoardPage();
    }

    showToast('✅ Refreshed');
  }).catch(function() {
    if (btn) btn.disabled = false;
    showToast('⚠️ Refresh failed');
  });
}


