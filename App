    var bgColors = data.map(function(v, i) {
      var grad = ctx.createLinearGradient(0, 0, 0, 220);
      var pair = gradients[i % gradients.length];
      grad.addColorStop(0, pair[0]); grad.addColorStop(1, pair[1]);
      return grad;
    });
    if (canvas._chart) canvas._chart.destroy();
    canvas._chart = new Chart(canvas, { type: 'bar', data: { labels: labels, datasets: [{ data: data, backgroundColor: bgColors, borderRadius: 6, borderSkipped: false }] }, options: { responsive: true, maintainAspectRatio: false, layout: { padding: { top: 25 } }, plugins: { legend: { display: false }, datalabels: { anchor: 'end', align: 'top', formatter: function(v) { return v || ''; }, color: '#1e293b', font: { weight: 'bold', size: 12 } } }, scales: { y: { beginAtZero: true, grace: '10%', grid: { color: '#f1f5f9' }, ticks: { stepSize: 1 } }, x: { grid: { display: false }, ticks: { font: { weight: 'bold', size: 10 } } } } } });
