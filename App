    vipAllPlayers.vip.forEach(function(p) { allPlayers.push(p); });
  }
  if (vipAllPlayers.silentVip && Array.isArray(vipAllPlayers.silentVip)) {
    vipAllPlayers.silentVip.forEach(function(p) { allPlayers.push(p); });
  }
  if (window.dynamicTabsData) {
    Object.keys(dynamicTabsData).forEach(function(gid) {
      var td = dynamicTabsData[gid];
      if (td && td.allPlayers) {
        (td.allPlayers.vip || []).forEach(function(p) { allPlayers.push(p); });
        (td.allPlayers.silentVip || []).forEach(function(p) { allPlayers.push(p); });
      }
    });
  }
  
  var enrichment = closureEnrichment || { reasons: {}, manualData: {} };
  var reasons = enrichment.reasons || {};
  var manualData = enrichment.manualData || {};
  
  var result = [];
  var seen = {};
  
  allPlayers.forEach(function(p) {
    var rawDisabled = p.disabled;
    if (rawDisabled === false || rawDisabled === true) rawDisabled = String(rawDisabled);
    var status = String(rawDisabled || '').trim().toLowerCase();
    if (!status || status === 'none' || status === 'false') return;
    
    var id = String(p.id || '').trim();
    if (!id || seen[id]) return;
    seen[id] = true;
    
    var email = String(p.email || '').trim();
    var emailLower = email.toLowerCase();
    var type = p.vipType || p.dashboardType || p._sourceSheet || 'Unknown';
    
    var inout = 0;
    if (p.lifetime_inout !== undefined) inout = Number(p.lifetime_inout) || 0;
    else if (p.inout !== undefined) inout = Number(p.inout) || 0;
    else {
      var dep = Number(p.lifetime_deposit_sum_total || p.deposit_sum_total || 0);
      var cash = Number(p.lifetime_cashout_sum_total || p.cashout_sum_total || 0);
      inout = dep - cash;
    }
    
    var manual = manualData[id] || {};
    
    result.push({
      id: id,
      email: email,
      type: type,
      status: String(rawDisabled || ''),
      closureReason: reasons[emailLower] || '',
      inout: inout,
      closureDate: manual.closureDate || '',
      reopeningDate: manual.reopeningDate || '',
      manager: manual.manager || '',
      notes: manual.notes || '',
      trafficType: p.trafficType || '',
      trafficSource: p.trafficSource || '',
      trafficDirection: p.trafficDirection || ''
    });
  });
  
  return result;
}

