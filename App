  var h = '<div style="margin-top:12px;padding:14px 18px;border-radius:12px;border:1.5px solid ' + (belowMin ? '#fca5a5' : '#86efac') + ';background:' + (belowMin ? '#fef2f2' : '#f0fdf4') + '">';
