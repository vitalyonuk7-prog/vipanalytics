// ── Manual day unlock (admin) ──
function obRenderUnlockPanel(container, asgn, plan, onSave) {
  var days = plan ? (plan.days||[]) : [];
  var manualUnlocks = asgn.manualUnlocks || {};

  container.innerHTML = '';
  container.appendChild(obEl('div','font-size:12px;font-weight:800;color:#1e293b;margin-bottom:10px','🔓 Manual Day Unlocks'));

  var grid = document.createElement('div'); grid.style.cssText='display:flex;flex-wrap:wrap;gap:6px';
  days.forEach(function(day, di) {
    var natural = obIsDayUnlocked(asgn, di);
    var manualOn = !!manualUnlocks[day.id||di];
    var unlocked = natural || manualOn;

    var pill = document.createElement('div');
    pill.style.cssText = 'display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:8px;border:1.5px solid '+(unlocked?'#86efac':'#e2e8f0')+';background:'+(unlocked?'#f0fdf4':'#fff')+';font-size:11px;font-weight:700;color:'+(unlocked?'#059669':'#64748b');

    var label = obEl('span','','D'+(di+1)+(natural?' 📅':'')); 
    pill.appendChild(label);

    if (!natural) {
      var tog = document.createElement('button');
      tog.style.cssText = 'padding:2px 8px;border:none;background:'+(manualOn?'linear-gradient(135deg,#10b981,#059669)':'#f1f5f9')+';color:'+(manualOn?'#fff':'#94a3b8')+';font-size:10px;font-weight:700;border-radius:5px;cursor:pointer';
      tog.textContent = manualOn ? '🔓 ON' : '🔒 OFF';
      tog.onclick = (function(key) { return function() {
        if (!asgn.manualUnlocks) asgn.manualUnlocks={};
        if (asgn.manualUnlocks[key]) delete asgn.manualUnlocks[key];
        else asgn.manualUnlocks[key] = obKyivToday();
        onSave(); obRenderUnlockPanel(container, asgn, plan, onSave);
      }; })(day.id||di);
      pill.appendChild(tog);
    } else if (manualOn) {
      var offBtn = document.createElement('button');
      offBtn.style.cssText='padding:2px 8px;border:none;background:#fee2e2;color:#ef4444;font-size:10px;font-weight:700;border-radius:5px;cursor:pointer';
