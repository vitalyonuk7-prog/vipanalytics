function pmRenderDrillTable(data) {
  var el = document.getElementById('pmDrillContent');
  if (!el) return;
  var sc = window._pmSortCol || 'count', sd = window._pmSortDir || 'desc';
  
  var sorted = data.slice().sort(function(a, b) {
    var va, vb;
    if (sc === 'count') { va = a.count; vb = b.count; }
    else if (sc === 'amount') { va = a.totalAmt; vb = b.totalAmt; }
    else if (sc === 'success') { va = a.successCount; vb = b.successCount; }
    else if (sc === 'failed') { va = a.failedCount; vb = b.failedCount; }
    else if (sc === 'email') { va = (a.email||'').toLowerCase(); vb = (b.email||'').toLowerCase(); }
    else if (sc === 'type') { va = (a.type||'').toLowerCase(); vb = (b.type||'').toLowerCase(); }
    else if (sc === 'manager') { va = (a.manager||'').toLowerCase(); vb = (b.manager||'').toLowerCase(); }
    else if (sc === 'country') { va = (a.country||'').toLowerCase(); vb = (b.country||'').toLowerCase(); }
    else { va = a.count; vb = b.count; }
    if (va < vb) return sd === 'asc' ? -1 : 1;
    if (va > vb) return sd === 'asc' ? 1 : -1;
    return 0;
  });
  
  function thS(col) {
    var active = sc === col;
