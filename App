function ttDoSwap(ai) {
  var teamAs = (ttData.assignments||[]).filter(function(a){return a.teamId===ttSelectedTeam;});
  var others = teamAs.filter(function(a,i){return i!==ai;});
  var otherIdx = parseInt(document.getElementById('ttSwapWith').value);
  var fromDate = document.getElementById('ttSwapFrom').value;
  var toDate = document.getElementById('ttSwapTo').value;
  var a1 = teamAs[ai]; var a2 = others[otherIdx];
  if (!a1||!a2) return;
  if (!toDate) {
    // Permanent swap: exchange shiftIds and startDates
    var tmpShift = a1.shiftId; var tmpStart = a1.startDate;
    a1.shiftId = a2.shiftId; a1.startDate = fromDate;
    a2.shiftId = tmpShift; a2.startDate = fromDate;
    a1.exceptions = []; a2.exceptions = [];
  } else {
    // Range swap: add exceptions for each day in range
    var d = new Date(fromDate + 'T00:00:00');
    var end = new Date(toDate + 'T00:00:00');
    while (d <= end) {
      var dk = ttDateKey(d);
      ttSetExceptionDirect(a1, dk, 'shift', a2.shiftId);
      ttSetExceptionDirect(a2, dk, 'shift', a1.shiftId);
      d.setDate(d.getDate()+1);
    }
  }
  document.getElementById('ttSwapModal').style.display = 'none';
  ttSaveData(); ttRenderPage();
  showToast('✅ Shifts swapped');
}

function ttSetExceptionDirect(asgn, dateKey, type, shiftId) {
  if (!asgn.exceptions) asgn.exceptions = [];
  var idx = asgn.exceptions.findIndex(function(e){return e.date===dateKey;});
  var ex = { date: dateKey, type: type, shiftId: shiftId };
  if (idx>=0) asgn.exceptions[idx]=ex; else asgn.exceptions.push(ex);
}

