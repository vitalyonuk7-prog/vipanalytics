 */
function getGenderIcon(gender) {
  if (!gender) return '👤';
  
  const g = String(gender).toLowerCase();
  if (g === 'm' || g === 'male') return '👨';
  if (g === 'f' || g === 'female') return '👩';
  return '👤';
}

/**
