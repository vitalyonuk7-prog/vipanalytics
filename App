function fetchYouTubeTitle(videoId, el) {
  try {
    var url = 'https://noembed.com/embed?url=https://www.youtube.com/watch?v=' + videoId;
    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data && data.title) el.textContent = data.title;
      })
      .catch(function() {});
  } catch(e) {}
}

