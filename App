  myQaAll.forEach(function(r) { allMonths[r.month] = true; });
  myKpiAll.forEach(function(r) { allMonths[r.month] = true; });
  var months = Object.keys(allMonths).sort().reverse();
  
  var selMonth = qcSelectedMonth || (months.length ? months[0] : qcCurMonth());
  var myQa = myQaAll.find(function(r) { return r.month === selMonth; });
  var myKpi = myKpiAll.find(function(r) { return r.month === selMonth; });
  
  var qaScore = myQa ? parseFloat(myQa.score) || 0 : null;
  var kpiScore = myKpi ? parseFloat(myKpi.score) || 0 : null;
  var qaTpl = myQa ? qaTemplates.find(function(t) { return t.name === myQa.template_name; }) : null;
  var kpiTpl = myKpi ? kpiTemplates.find(function(t) { return t.name === myKpi.template_name; }) : null;
  
  // Bonus calc
  var qaBonus = 0, kpiBonus = 0;
  if (qaTpl && qaTpl.bonus && qaTpl.bonus.enabled && qaScore !== null) {
    qaBonus = (qaTpl.bonus.minPct > 0 && qaScore < qaTpl.bonus.minPct) ? 0 : (qaTpl.bonus.amount * qaScore / 100);
  }
  if (kpiTpl && kpiTpl.bonus && kpiTpl.bonus.enabled && kpiScore !== null) {
    kpiBonus = (kpiTpl.bonus.minPct > 0 && kpiScore < kpiTpl.bonus.minPct) ? 0 : (kpiTpl.bonus.amount * kpiScore / 100);
  }
  var totalBonus = qaBonus + kpiBonus;
  
  var h = '<div style="display:flex;gap:20px">';
