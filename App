// --- Determine player type/manager from tags ---
// --- Shared tag parser (handles JSON array, comma-separated, single tag) ---
function parseTags(raw) {
  if (!raw || raw === '' || raw === '[]') return [];
  if (Array.isArray(raw)) return raw.map(function(t){ return String(t).trim().toLowerCase(); }).filter(function(t){ return t !== ''; });
  var s = String(raw).trim();
  if (s === '') return [];
  if (s.charAt(0) === '[') {
    try {
      var arr = JSON.parse(s.replace(/'/g, '"'));
      return arr.map(function(t){ return String(t).trim().toLowerCase(); }).filter(function(t){ return t !== ''; });
    } catch(e) {}
  }
  return s.split(',').map(function(t){ return t.trim().toLowerCase().replace(/["'\[\]]/g, ''); }).filter(function(t){ return t !== ''; });
}

function rv2GetPlayerType(details) {
  if (!details || !details.tags) return '';
  if (typeof tagToTypeMap === 'undefined' || !tagToTypeMap || Object.keys(tagToTypeMap).length === 0) return '';
  var tags = parseTags(details.tags);
  for (var i = 0; i < tags.length; i++) {
    if (tagToTypeMap[tags[i]]) return tagToTypeMap[tags[i]];
  }
  return '';
}

function rv2GetPlayerManager(details) {
  if (!details || !details.tags) return '';
  if (typeof vipManagerMapping === 'undefined' || !vipManagerMapping || Object.keys(vipManagerMapping).length === 0) return '';
  var tags = parseTags(details.tags);
  for (var i = 0; i < tags.length; i++) {
    if (vipManagerMapping[tags[i]]) return vipManagerMapping[tags[i]];
  }
  return '';
}

// --- Check if player passes filters ---
function rv2PlayerPassesFilter(email, playerDetails) {
  var details = playerDetails[email];
  if (!details) return false;
  
  // Country
  if (rv2Filters.country.length > 0) {
    if (rv2Filters.country.indexOf(details.country) === -1) return false;
  }
  // Traffic Type
  if (rv2Filters.trafficType.length > 0) {
    if (rv2Filters.trafficType.indexOf(details.trafficType) === -1) return false;
  }
  // Type (from tags)
  if (rv2Filters.type.length > 0) {
    var pType = rv2GetPlayerType(details);
    if (rv2Filters.type.indexOf(pType) === -1) return false;
  }
  // Manager (from tags)
  if (rv2Filters.manager.length > 0) {
    var pManager = rv2GetPlayerManager(details);
    if (rv2Filters.manager.indexOf(pManager) === -1) return false;
  }
  return true;
}

function rv2HasActiveFilters() {
  return Object.values(rv2Filters).some(function(arr) { return arr && arr.length > 0; });
}

// --- Recalculate matrix with filters applied to BOTH src and active ---
function getRv2FilteredRows() {
  var mode = rv2CurrentMode();
  var data = rv2Data[mode];
  if (!data) return null;
  
  var hasFilters = rv2HasActiveFilters();
  if (!hasFilters || !data.srcEmails || !data.activeEmails || !data.playerDetails) {
    return data.rows;  // Return original pre-calculated rows
  }
  
  var isWeekly = rv2Mode === 'weekly';
  var isMom = rv2Type === 'mom';
  var pd = data.playerDetails;
  
  // Filter src and active email arrays
  var filteredSrc = data.srcEmails.map(function(emails) {
    return emails.filter(function(e) { return rv2PlayerPassesFilter(e, pd); });
  });
  var filteredActive = data.activeEmails.map(function(emails) {
    return emails.filter(function(e) { return rv2PlayerPassesFilter(e, pd); });
  });
  
  // Build active sets for fast lookup
  var activeSets = filteredActive.map(function(emails) {
    var set = {};
    emails.forEach(function(e) { set[e] = true; });
    return set;
  });
  
  // Recalculate rows
  var periods = isWeekly ? (data.weeks || []) : (data.months || []);
  var newRows = [];
  
  filteredSrc.forEach(function(srcEmails, srcIdx) {
    var label = data.rows[srcIdx] ? (isWeekly ? data.rows[srcIdx].week : data.rows[srcIdx].month) : '';
    var row = isWeekly
      ? { week: label, ftdCount: srcEmails.length, retention: [] }
      : { month: label, ftdCount: srcEmails.length, retention: [] };
    
    if (isWeekly) {
      for (var i = 0; i < activeSets.length; i++) {
        if (i < srcIdx) { row.retention.push({ count: 0, pct: 0 }); continue; }
        var retained = 0;
        srcEmails.forEach(function(e) { if (activeSets[i][e]) retained++; });
        row.retention.push({ count: retained, pct: srcEmails.length > 0 ? retained / srcEmails.length : 0 });
      }
    } else {
      for (var i = srcIdx; i < activeSets.length; i++) {
        var retained = 0;
        srcEmails.forEach(function(e) { if (activeSets[i][e]) retained++; });
        row.retention.push({ count: retained, pct: srcEmails.length > 0 ? retained / srcEmails.length : 0 });
      }
    }
    newRows.push(row);
  });
  
  return newRows;
}

// --- Metric Selector ---
function renderRv2MetricSelector() {
  var data = rv2Data[rv2CurrentMode()];
  if (!data || !data.rows || data.rows.length === 0) return;
  var container = document.getElementById('rv2MetricSelector');
  container.innerHTML = '';
  var isWeekly = rv2Mode === 'weekly';
  var maxOffset = Math.max.apply(null, data.rows.map(function(r) { return r.retention ? r.retention.length : 0; }));
  var label = isWeekly ? 'Week' : 'Month';
  
  for (var i = 0; i < maxOffset; i++) {
    (function(idx) {
      var btn = document.createElement('button');
      btn.className = 'metric-btn' + (idx === rv2CurrentOffset ? ' active' : '');
      btn.textContent = label + ' +' + idx;
      btn.onclick = function() {
        rv2CurrentOffset = idx;
        container.querySelectorAll('.metric-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        renderRv2Chart();
      };
      container.appendChild(btn);
    })(i);
  }
}

// --- Bar Chart ---
function renderRv2Chart() {
  var data = rv2Data[rv2CurrentMode()];
  if (!data || !data.rows || data.rows.length === 0) return;
  if (typeof Chart === 'undefined') return;
  var canvas = document.getElementById('rv2Chart');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  if (!ctx) return;
  
  var rows = getRv2FilteredRows() || [];
  var isWeekly = rv2Mode === 'weekly';
  var isMom = rv2Type === 'mom';
  var labels = [], chartData = [], colors = [];
  var gradients = [['#667eea','#764ba2'],['#f093fb','#f5576c'],['#4facfe','#00f2fe'],['#43e97b','#38f9d7'],['#fa709a','#fee140'],['#30cfd0','#330867'],['#a8edea','#fed6e3'],['#ff9a9e','#fecfef'],['#ffecd2','#fcb69f'],['#ff6e7f','#bfe9ff'],['#e0c3fc','#8ec5fc'],['#f093fb','#f5576c']];
  var ci = 0;
  
  rows.forEach(function(row, rowIdx) {
    var retIdx = isWeekly ? (rowIdx + rv2CurrentOffset) : rv2CurrentOffset;
    if (!row.retention || retIdx >= row.retention.length) return;
    if (isWeekly && retIdx < rowIdx) return;
    var cell = row.retention[isWeekly ? retIdx : rv2CurrentOffset];
    var pct = cell ? cell.pct : 0;
    var label = isWeekly ? row.week : row.month;
    labels.push(label + (isMom ? ' ACT' : ' FTD'));
    chartData.push(parseFloat((pct * 100).toFixed(2)));
    var grad = ctx.createLinearGradient(0, 0, 0, 400);
    var cp = gradients[ci % gradients.length];
    grad.addColorStop(0, cp[0]);
    grad.addColorStop(1, cp[1]);
    colors.push(grad);
    ci++;
  });
  
  if (rv2ChartObj) rv2ChartObj.destroy();
  var periodLabel = isWeekly ? 'Week' : 'Month';
  rv2ChartObj = new Chart(canvas, {
    type: 'bar',
    data: { labels: labels, datasets: [{ label: 'Retention (' + periodLabel + ' +' + rv2CurrentOffset + ')', data: chartData, backgroundColor: colors, borderRadius: 8 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      layout: { padding: { top: 30, bottom: 10 } },
      plugins: {
        legend: { display: false },
        datalabels: { anchor: 'end', align: 'top', formatter: function(v) { return v.toFixed(1) + '%'; }, color: '#1e293b', font: { weight: 'bold', size: 12 } }
      },
      scales: {
        y: { beginAtZero: true, max: 100, grace: '10%', ticks: { callback: function(v) { return v + '%'; } }, grid: { color: '#f1f5f9' } },
        x: { grid: { display: false } }
      }
    }
  });
}

// --- Table ---
function renderRv2Table() {
  var mode = rv2CurrentMode();
  var data = rv2Data[mode];
  if (!data) return;
  
  var isWeekly = rv2Mode === 'weekly';
  var isMom = rv2Type === 'mom';
  var periods = isWeekly ? (data.weeks || []) : (data.months || []);
  var rows = getRv2FilteredRows() || [];
  
  if (periods.length === 0 || rows.length === 0) {
    document.getElementById('rv2-table').innerHTML = '<tr><td style="text-align:center;padding:40px;color:#94a3b8">No data for this mode</td></tr>';
    return;
  }
  
  var maxOffset = 0;
  rows.forEach(function(r) { if (r.retention && r.retention.length > maxOffset) maxOffset = r.retention.length; });
  
  var html = '<thead><tr><th class="row-header">' + (isMom ? 'Active' : 'FTD') + ' ' + (isWeekly ? 'Week' : 'Month') + ' ↓ / Active →</th>';
  periods.forEach(function(p) { html += '<th>' + p + '</th>'; });
  html += '</tr></thead><tbody>';
  
  rows.forEach(function(row, rowIdx) {
    var label = isWeekly ? row.week : row.month;
    html += '<tr><td class="row-header">' + label + (isMom ? ' ACTIVE' : ' FTD') + '<br><span style="font-size:10px;color:#94a3b8">' + row.ftdCount + ' players</span></td>';
    
    periods.forEach(function(p, colIdx) {
      if (isWeekly && colIdx < rowIdx) {
        html += '<td><span class="cell" style="background:#f8fafc;color:#cbd5e1;cursor:default">—</span></td>';
      } else {
        var retIdx = isWeekly ? colIdx : (colIdx - rowIdx);
        if (retIdx < 0) {
          html += '<td><span class="cell" style="background:#f8fafc;color:#cbd5e1;cursor:default">—</span></td>';
          return;
        }
        var cellData = row.retention && retIdx >= 0 && retIdx < row.retention.length ? row.retention[isWeekly ? colIdx : retIdx] : null;
        if (cellData) {
          var count = cellData.count || 0;
          var pct = cellData.pct || 0;
          var retOffset = isWeekly ? (colIdx - rowIdx) : retIdx;
          var bg = retentionHeatmapColor(pct, retOffset, maxOffset);
          var fg = getTextColor(bg);
          var display = rv2ShowPct ? (pct * 100).toFixed(1) + '%' : count;
          html += '<td><span class="cell" style="background:' + bg + ';color:' + fg + ';cursor:pointer" data-rv2-src="' + label + '" data-rv2-tgt="' + p + '">' + display + '</span></td>';
        } else {
          html += '<td><span class="cell" style="background:#f8fafc;color:#cbd5e1;cursor:default">—</span></td>';
        }
      }
    });
    html += '</tr>';
  });
  
  html += '</tbody>';
  document.getElementById('rv2-table').innerHTML = html;
  
  document.getElementById('rv2-table').querySelectorAll('.cell[data-rv2-src]').forEach(function(cell) {
    cell.onclick = function() { openRv2Modal(cell.dataset.rv2Src, cell.dataset.rv2Tgt); };
  });
}

