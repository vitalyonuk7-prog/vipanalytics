function qaSaveLive(){
  var failures=window._qaFailures||[];var td=0;
  failures.forEach(function(f){if(f.level!=='warning')td+=parseFloat(f.pct)||0;});
  var score=Math.max(0,100-td);
  var savedMonth=window._qaLiveMonth;
  var params={manager:window._qaLiveMgr,month:savedMonth,template_name:window._qaLiveTplName,score:score,failures_json:JSON.stringify(failures),created_by:window._userNickname||window._userManager||window._userEmail||''};
  
  // Optimistic: update results immediately
  var existing=false;
  qaResults.forEach(function(r,i){if(r.manager===params.manager&&r.month===params.month){qaResults[i]={manager:params.manager,month:params.month,template_name:params.template_name,score:String(score),failures_json:params.failures_json,created_at:new Date().toLocaleString(),created_by:params.created_by};existing=true;}});
  if(!existing){qaResults.push({manager:params.manager,month:params.month,template_name:params.template_name,score:String(score),failures_json:params.failures_json,created_at:new Date().toLocaleString(),created_by:params.created_by});}
  qaActiveMonth=savedMonth;
  qaRenderPage();
  showToast('\uD83D\uDCBE Saving...');
  
  // Save in background
  google.script.run.withSuccessHandler(function(r){
    if(r&&r.success){showToast('\u2705 Saved!');}
    else{showToast('\u274C '+(r?r.error:'Error'));}
  }).withFailureHandler(function(e){showToast('\u274C '+e);}).saveQaResult(params);
}

