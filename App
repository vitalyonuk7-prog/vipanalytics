    var data = kpiDataByTab[tabName];
    if (!data || !data.months || !metricKey) return 0;
    var sum = 0;
    if (ymKeys.length === 0) {
      data.months.forEach(function(m) { sum += (m.monthly[metricKey] || m.sumWeeks[metricKey] || 0); });
    } else {
      ymKeys.forEach(function(ym) {
        for (var i = 0; i < data.months.length; i++) {
          if (data.months[i].ym === ym) { sum += (data.months[i].monthly[metricKey] || data.months[i].sumWeeks[metricKey] || 0); break; }
        }
      });
    }
    return sum;
  }
  
  function buildCircle(pct, numVal, denomVal, denomLabel, circleColor) {
    var sz = 160, cr = 66, sw = 9;
    var circ = 2 * Math.PI * cr;
    var disp = Math.min(Math.abs(pct), 100);
    var coff = circ - (disp / 100) * circ;
    var ccx = sz / 2;
    var isNeg = pct < 0;
    var h = '<div style="position:relative;width:' + sz + 'px;height:' + sz + 'px">';
    h += '<svg width="' + sz + '" height="' + sz + '" viewBox="0 0 ' + sz + ' ' + sz + '">';
    h += '<circle cx="' + ccx + '" cy="' + ccx + '" r="' + cr + '" fill="none" stroke="#f1f5f9" stroke-width="' + sw + '"/>';
    h += '<circle cx="' + ccx + '" cy="' + ccx + '" r="' + cr + '" fill="none" stroke="' + circleColor + '" stroke-width="' + sw + '" stroke-linecap="round" stroke-dasharray="' + circ.toFixed(1) + '" stroke-dashoffset="' + coff.toFixed(1) + '" transform="rotate(-90 ' + ccx + ' ' + ccx + ')" style="transition:stroke-dashoffset 0.6s ease"/>';
    h += '</svg>';
    h += '<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center">';
    h += '<div style="font-size:22px;font-weight:900;color:' + (isNeg ? '#dc2626' : circleColor) + ';line-height:1">' + pct.toFixed(1) + '%</div>';
    h += '<div style="margin-top:6px;background:' + circleColor + '14;border:1.5px solid ' + circleColor + '30;border-radius:20px;padding:2px 10px;display:flex;align-items:center;gap:3px">';
    h += '<span style="font-size:10px;font-weight:700;color:' + circleColor + '">\u20ac' + Math.round(numVal).toLocaleString() + '</span>';
    h += '<span style="font-size:9px;font-weight:600;color:#94a3b8">/ ' + denomLabel + '</span>';
    h += '</div></div></div>';
    return h;
  }
  
  // ---- BDI ----
  var depRows = filtered.filter(function(r) { return r.type && r.type.toLowerCase().indexOf('deposit') !== -1; });
  var bonusIssued = 0;
  depRows.forEach(function(r) { bonusIssued += (r.countIssued || 0); });
  var totalDepCount = sumKpiMetric(totalTab, depCountKey);
  var bdiPct = totalDepCount > 0 ? (bonusIssued / totalDepCount) * 100 : 0;
  
  section.style.display = 'flex';
  
  var bdiCol = bdiPct > 50 ? '#dc2626' : bdiPct > 30 ? '#f59e0b' : '#059669';
  circleEl.innerHTML = buildCircle(bdiPct, bonusIssued, totalDepCount, Math.round(totalDepCount).toLocaleString() + ' deps', bdiCol);
  
  // ---- VIP Bonus Rate ----
  if (!vipBlock || !vipCirclesEl || !totalVipTab) {
    if (vipBlock) vipBlock.style.display = 'none';
    var dvd = document.getElementById('bonusVipDivider');
    if (dvd) dvd.style.display = 'none';
    return;
  }
  
  var vipData = kpiDataByTab[totalVipTab];
  if (!vipData || !vipData.metrics) { vipBlock.style.display = 'none'; return; }
  
  // Sum VIP BONUSES category from ALL bonus data using category mapping
  var allRows = bonusRawData.monthly ? bonusRawData.monthly.rows || [] : [];
  var vipBonusRows = allRows.filter(function(r) {
    var cat = bonusCatMapping[r.title] || '';
    return cat.toUpperCase().indexOf('VIP BONUS') !== -1;
  });
  // Also filter by same periods as bonus report
  if (ymKeys.length > 0) {
    vipBonusRows = vipBonusRows.filter(function(r) {
      var d = new Date(String(r.period).trim());
      if (isNaN(d.getTime())) return true;
      var pk = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
      return allBonusPeriods[pk];
    });
  }
  var vipBonusSum = 0;
  vipBonusRows.forEach(function(r) { vipBonusSum += (r.totalInEUR || 0); });
  
