// ── Kyiv time helpers ──
function obKyivToday() {
  var now = new Date();
  var kyiv = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Kiev' }));
  var y = kyiv.getFullYear(), m = String(kyiv.getMonth()+1).padStart(2,'0'), d = String(kyiv.getDate()).padStart(2,'0');
  return y + '-' + m + '-' + d;
}
function obDateAdd(dateStr, days) {
  var d = new Date(dateStr + 'T12:00:00');
  d.setDate(d.getDate() + days);
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}
function obIsDayUnlocked(asgn, di) {
  if (!asgn.startDate) return false;
  // Check manual unlock first
  var plan = obPlans.find(function(p){ return p.id===asgn.planId; });
  var day = plan && plan.days && plan.days[di];
  var dayKey = (day && day.id) ? day.id : di;
  if (asgn.manualUnlocks && asgn.manualUnlocks[dayKey]) return true;
  // Use custom schedule if available, else sequential
  var dayDate = (asgn.daySchedule && asgn.daySchedule[di]) ? asgn.daySchedule[di] : obDateAdd(asgn.startDate, di);
  return obKyivToday() >= dayDate;
}
function obDayDate(asgn, di) {
  if (!asgn.startDate) return '';
  if (asgn.daySchedule && asgn.daySchedule[di]) return asgn.daySchedule[di];
  return obDateAdd(asgn.startDate, di);
}
function obFmtDate(d) {
  if (!d) return '';
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var parts = d.split('-');
  return parseInt(parts[2]) + ' ' + months[parseInt(parts[1])-1];
}

function obDayLabel(di, asgn) {
  // Returns "D1 · 24 Mar" if asgn provided, else "D1"
  var base = 'D' + (di + 1);
  if (!asgn || !asgn.startDate) return base;
  var date = obDayDate(asgn, di);
  return base + ' · ' + obFmtDate(date);
}

