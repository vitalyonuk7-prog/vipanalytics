    html += '<td><input type="date" class="' + reopeningDateClass + '" value="' + (p.reopeningDate || '') + '" onchange="saveClosureFieldUI(\'' + p.id + '\',\'' + p.email.replace(/'/g, "\\'") + '\',\'reopening_date\',this.value,this)"></td>';
