  function inp(val,ph){ var i=document.createElement('input'); i.value=val||''; i.placeholder=ph||''; i.style.cssText='width:100%;padding:9px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box'; i.onfocus=function(){this.style.borderColor='#6366f1';};i.onblur=function(){this.style.borderColor='#e2e8f0';}; return i; }

  var nameI=inp(ch.name,'Full name'); body.appendChild(fRow('Name',nameI));
  var nickI=inp(ch.nickname,'@username'); body.appendChild(fRow('Nickname',nickI));
  var roleI=inp(ch.role,'e.g. VIP Manager'); body.appendChild(fRow('Role / Position',roleI));
  var emailI=inp(ch.email,'email@company.com'); body.appendChild(fRow('Email',emailI));
  var phoneI=inp(ch.phone,'+380...'); body.appendChild(fRow('Phone',phoneI));
  var photoI=inp(ch.photoUrl,'https://...image.jpg'); body.appendChild(fRow('Photo URL',photoI));
  var albumI=inp(ch.photoAlbum,'https://photos.google.com/...'); body.appendChild(fRow('Photo Album URL',albumI));

  // Socials
  var socInputs={};
  body.appendChild(chEl('div','font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-top:4px','Messengers & Social'));
  var socGrid=document.createElement('div'); socGrid.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:8px';
  CHARS_SOCIALS.forEach(function(s){
    var si=inp(ch[s.key]||'', s.placeholder);
    socInputs[s.key]=si;
    socGrid.appendChild(fRow(s.icon+' '+s.label,si));
  });
  body.appendChild(socGrid);

  // Tags
  var tagsI=inp((ch.tags||[]).join(', '),'tag1, tag2, tag3'); body.appendChild(fRow('Tags (comma separated)',tagsI));

  // TOV sections
  body.appendChild(chEl('div','font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-top:4px','💬 TOV Sections'));
  var tovContainer=document.createElement('div');
  var tovSections=JSON.parse(JSON.stringify(ch.tov||[]));

  function renderTovSections(){
    tovContainer.innerHTML='';
    tovSections.forEach(function(sec,si){
      var row=document.createElement('div'); row.style.cssText='border:1.5px solid #e2e8f0;border-radius:10px;padding:10px 12px;margin-bottom:8px;background:#fafafa';
      var titleR=document.createElement('div'); titleR.style.cssText='display:flex;gap:6px;margin-bottom:7px';
      var tI=inp(sec.title,'Section title'); tI.style.flex='1';
      tI.oninput=function(){tovSections[si].title=this.value;};
      var delS=chBtn('×','padding:4px 9px;border:1.5px solid #fca5a5;background:#fef2f2;color:#ef4444;font-size:12px;font-weight:700;border-radius:6px;cursor:pointer',function(){tovSections.splice(si,1);renderTovSections();});
      titleR.appendChild(tI); titleR.appendChild(delS); row.appendChild(titleR);
      var ta=document.createElement('textarea'); ta.style.cssText='width:100%;padding:8px 10px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px;font-family:inherit;outline:none;resize:vertical;min-height:70px;box-sizing:border-box';
      ta.placeholder='Content...'; ta.value=sec.content||'';
      ta.oninput=function(){tovSections[si].content=this.value;};
      row.appendChild(ta); tovContainer.appendChild(row);
    });
    var addSecBtn=chBtn('+ Add TOV Section','width:100%;padding:7px;border:1.5px dashed #c7d2fe;background:#eef2ff;color:#6366f1;font-size:12px;font-weight:700;border-radius:8px;cursor:pointer',function(){tovSections.push({title:'',content:''});renderTovSections();});
    tovContainer.appendChild(addSecBtn);
  }
  renderTovSections();
  body.appendChild(tovContainer);

  // Save button
  var saveBtn=chBtn('💾 Save Character','width:100%;padding:12px;border:none;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;font-size:14px;font-weight:800;border-radius:10px;cursor:pointer;margin-top:8px',function(){
    ch.name=nameI.value.trim(); ch.nickname=nickI.value.trim(); ch.role=roleI.value.trim();
    ch.email=emailI.value.trim(); ch.phone=phoneI.value.trim();
    ch.photoUrl=photoI.value.trim(); ch.photoAlbum=albumI.value.trim();
    ch.tags=tagsI.value.split(',').map(function(t){return t.trim();}).filter(Boolean);
    ch.tov=tovSections;
    CHARS_SOCIALS.forEach(function(s){ ch[s.key]=socInputs[s.key].value.trim(); });
    if (isNew) charsData.push(ch);
    else { var idx=charsData.findIndex(function(x){return x.id===ch.id;}); if(idx>=0) charsData[idx]=ch; }
    saveBtn.disabled=true; saveBtn.textContent='⏳ Saving...';
    google.script.run
      .withSuccessHandler(function(r){
        saveBtn.disabled=false; saveBtn.textContent='💾 Save Character';
        if(r&&r.success){ modal.style.display='none'; showToast('✅ Saved!'); charsRenderGrid(document.getElementById('charsMainContent')); }
        else showToast('❌ '+(r?r.error:'Save failed'));
      })
      .withFailureHandler(function(e){ saveBtn.disabled=false; saveBtn.textContent='💾 Save Character'; showToast('❌ '+e); })
      .saveCharacters(charsData);
  });
  body.appendChild(saveBtn);
  box.appendChild(body);
  modal.appendChild(box);
}

function charsDelete(id) {
  charsData=charsData.filter(function(c){return c.id!==id;});
  google.script.run.withSuccessHandler(function(){ showToast('✅ Deleted'); charsRenderGrid(document.getElementById('charsMainContent')); }).withFailureHandler(function(){}).saveCharacters(charsData);
}

// Tiny helpers
function chEl(tag,css,text){var e=document.createElement(tag);if(css)e.style.cssText=css;if(text!=null)e.textContent=text;return e;}
function chBtn(label,css,fn){var b=document.createElement('button');b.textContent=label;if(css)b.style.cssText=css;b.onclick=fn;return b;}


</script>

