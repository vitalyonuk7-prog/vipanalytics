function kpiSaveCard() {
  var tpl = kpiTemplates.find(function(t) { return t.name === window._kpiEditTpl; });
  if (!tpl) return;
  var month = document.getElementById('kpiEditMonthInp').value;
  var goals = []; var totalWeight = 0; var totalScore = 0;
  document.querySelectorAll('.kpi-goal-inp').forEach(function(inp) {
    var bi = parseInt(inp.dataset.bi); var gi = parseInt(inp.dataset.gi);
    var goal = tpl.blocks[bi] && tpl.blocks[bi].goals[gi];
    var weight = goal ? (parseFloat(goal.weight) || 1) : 1;
    if (inp.dataset.type === 'pct') {
      var v = Math.min(100, Math.max(0, parseFloat(inp.value) || 0));
      goals.push({ bi: bi, gi: gi, value: v }); totalWeight += weight; totalScore += v * weight;
    } else {
      goals.push({ bi: bi, gi: gi, value: inp.checked }); totalWeight += weight; totalScore += (inp.checked ? 100 : 0) * weight;
    }
  });
  var score = totalWeight > 0 ? totalScore / totalWeight : 0;
  var result = { manager: window._kpiEditMgr, month: month, template_name: window._kpiEditTpl, score: score.toFixed(1), goals_json: JSON.stringify(goals) };
  var existing = kpiResults.findIndex(function(r) { return r.manager === result.manager && r.month === month; });
  if (existing >= 0) kpiResults[existing] = result; else kpiResults.push(result);
  kpiActiveMonth = month; kpiRenderPage();
  showToast('\u2705 KPI Card saved');
  google.script.run.withFailureHandler(function(e) { showToast('\u274C ' + e); }).saveKpiResult(result);
}

