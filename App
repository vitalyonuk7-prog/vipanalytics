  (ttData.shifts||[]).forEach(function(s,i){ shiftColorMap[s.id] = shColors[i%shColors.length]; });
  var teamAssignments = (ttData.assignments||[]).filter(function(a){ return a.teamId === ttSelectedTeam; });
  var today = ttDateKey(new Date());
  var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var dayNames = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  if (ttViewMode === 'month') {
    ttRenderMonthGrid(container, teamAssignments, shiftColorMap, today, monthNames, dayNames);
  } else if (ttViewMode === 'day') {
