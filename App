function renderKpiTabs(){
  const container=document.getElementById('kpiTabs');
  container.innerHTML='';
  
  const groups = window.kpiGroups || {};
  const allTabs = Object.keys(kpiDataByTab);
  
  // Build group structure
  var grouped = {};
  var ungrouped = [];
  allTabs.forEach(function(tab) {
    var g = groups[tab];
    if (g) {
      if (!grouped[g]) grouped[g] = [];
      grouped[g].push(tab);
    } else {
      ungrouped.push(tab);
    }
  });
  
  var groupNames = Object.keys(grouped);
  var hasGroups = groupNames.length > 0;
  
  // Sort: TOTAL first, then alphabetical
  function totalFirst(a, b) {
    var aT = a.toUpperCase().indexOf('TOTAL') !== -1 ? 0 : 1;
    var bT = b.toUpperCase().indexOf('TOTAL') !== -1 ? 0 : 1;
    if (aT !== bT) return aT - bT;
    return a.localeCompare(b);
  }
  groupNames.sort(totalFirst);
  ungrouped.sort(totalFirst);
  Object.keys(grouped).forEach(function(g) { grouped[g].sort(totalFirst); });
  
  // Determine current group from current tab
  if (hasGroups && !window.kpiCurrentGroup) {
    window.kpiCurrentGroup = groups[kpiCurrentTab] || null;
  }
  
  // Main row: merge groups + ungrouped, sort together
  var mainItems = [];
  groupNames.forEach(function(g) { mainItems.push({ type: 'group', name: g }); });
  ungrouped.forEach(function(t) { mainItems.push({ type: 'tab', name: t }); });
  mainItems.sort(function(a, b) { return totalFirst(a.name, b.name); });
  
  var mainRow = document.createElement('div');
  mainRow.style.cssText = 'display:flex;gap:8px;flex-wrap:wrap;align-items:center';
  
  mainItems.forEach(function(item) {
    if (item.type === 'group') {
      var g = item.name;
      var isActive = g === window.kpiCurrentGroup;
      var btn = document.createElement('div');
      btn.className = 'kpi-tab' + (isActive ? ' active' : '');
      btn.textContent = g;
      btn.onclick = function() {
        window.kpiCurrentGroup = g;
        switchKpiTab(grouped[g][0]);
      };
      mainRow.appendChild(btn);
    } else {
      var tab = item.name;
      var isActive = tab === kpiCurrentTab && !window.kpiCurrentGroup;
      var btn = document.createElement('div');
      btn.className = 'kpi-tab' + (isActive ? ' active' : '');
      btn.textContent = tab;
      btn.onclick = function() { window.kpiCurrentGroup = null; switchKpiTab(tab); };
      mainRow.appendChild(btn);
    }
  });
  
  // Compare button
  var compareBtn = document.createElement('div');
  compareBtn.className = 'kpi-tab compare-tab';
  compareBtn.textContent = '🔄 Compare';
  compareBtn.style.marginLeft = 'auto';
  compareBtn.onclick = function() {
    document.querySelectorAll('.kpi-tab').forEach(function(b) { b.classList.remove('active'); });
    compareBtn.classList.add('active');
    document.getElementById('kpiNormalView').style.display = 'none';
    document.getElementById('kpiCompareView').style.display = 'block';
    if (!window.compareInitialized) { initCompareView(); window.compareInitialized = true; }
  };
  mainRow.appendChild(compareBtn);
  container.appendChild(mainRow);
  
  // Subtabs row (only if current group has >1 subtabs)
  if (hasGroups && window.kpiCurrentGroup && grouped[window.kpiCurrentGroup] && grouped[window.kpiCurrentGroup].length > 1) {
    var subRow = document.createElement('div');
    subRow.style.cssText = 'display:flex;gap:4px;flex-wrap:wrap;margin-top:8px;padding:6px 8px;background:#f8fafc;border-radius:10px';
    
    grouped[window.kpiCurrentGroup].forEach(function(tab) {
      var isActive = tab === kpiCurrentTab;
      var btn = document.createElement('div');
      btn.style.cssText = 'padding:7px 16px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;' +
        (isActive ? 'background:#fff;color:#667eea;box-shadow:0 1px 4px rgba(0,0,0,0.08);font-weight:700' : 'background:transparent;color:#64748b');
      btn.textContent = tab;
      btn.onmouseover = function() { if (!isActive) this.style.color = '#667eea'; };
      btn.onmouseout = function() { if (!isActive) this.style.color = '#64748b'; };
      btn.onclick = function() { switchKpiTab(tab); };
      subRow.appendChild(btn);
    });
    container.appendChild(subRow);
  }
}

function switchKpiTab(tab) {
  kpiCurrentTab = tab;
