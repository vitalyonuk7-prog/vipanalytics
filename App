function qaSaveTemplate(){
  qaSyncBlockData();
  var name=(document.getElementById('qaTemplateName').value||'').trim();
  if(!name){document.getElementById('qaTemplateName').style.borderColor='#ef4444';return;}
  var thresholds={
    green:parseInt(document.getElementById('qaThrGreen').value)||90,
    yellow:parseInt(document.getElementById('qaThrYellow').value)||70,
    orange:parseInt(document.getElementById('qaThrOrange').value)||50
  };
  var bonus={
    enabled:document.getElementById('qaBonusCb').checked,
    amount:parseFloat(document.getElementById('qaBonusAmount').value)||0,
    minPct:parseFloat(document.getElementById('qaBonusMinPct').value)||0
  };
  var adEl = document.getElementById('qaAppealDeadline');
  var admEl = document.getElementById('qaAppealDeadlineMonth');
  var appeal_deadline = adEl ? parseInt(adEl.value) || 10 : 10;
  var appeal_deadline_month = admEl ? admEl.value : 'next';
  var template={name:name,blocks:_qaBlocks,thresholds:thresholds,bonus:bonus,appeal_deadline:appeal_deadline,appeal_deadline_month:appeal_deadline_month};
