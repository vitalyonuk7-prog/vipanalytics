    allPlayersList.forEach(function(player){
      var manager = getPlayerManager(player);
      if(manager) managersSet.add(manager);
    });
  });
  
  var managers = Array.from(managersSet).sort();
  
  if(managers.length === 0){
    submenu.innerHTML = '';
