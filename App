var _ppDirtyTimer = null;
function markProfilingDirty() {
  window._profilingDirty = true;
  // Auto-save after 800ms debounce
  clearTimeout(_ppDirtyTimer);
  _ppDirtyTimer = setTimeout(function() {
    if (window._profilingDirty && profilingData.selectedPlayer) {
      saveProfilingPlayerSilent(profilingData.selectedPlayer);
    }
  }, 800);
  // Show floating save bar for table view
  if (profilingData.viewMode === 'table') {
    showTableSaveBar();
  }
}

