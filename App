function adminUpdateUserUI(row, field, value) {
  if (value === '__new__') return;
  var params = { row: row };
  params[field] = value;

  // Optimistic: update local data immediately
  if (adminPanelData) {
    adminPanelData.users.forEach(function(u){ if(u._row===row) u[field]=value; });
  }

  // Visual feedback on the element that triggered
  var targetEl = event && event.target ? event.target : null;
  if (targetEl) { targetEl.style.borderColor = '#f59e0b'; targetEl.style.background = '#fffbeb'; }

  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        if (targetEl) {
          targetEl.style.borderColor = '#10b981'; targetEl.style.background = '#f0fdf4';
          setTimeout(function(){ targetEl.style.borderColor = '#e2e8f0'; targetEl.style.background = ''; }, 1200);
        }
        if (field === 'role') renderRolesMatrix();
      } else {
        if (targetEl) { targetEl.style.borderColor = '#ef4444'; targetEl.style.background = '#fef2f2'; }
        showToast('❌ ' + (result ? result.error : 'Save failed'));
      }
    })
    .withFailureHandler(function(err) {
      if (targetEl) { targetEl.style.borderColor = '#ef4444'; targetEl.style.background = '#fef2f2'; }
      showToast('❌ ' + err);
    })
    .adminUpdateUser(params);
}

