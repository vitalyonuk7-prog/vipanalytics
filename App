  h += '<div style="flex:1;min-width:0">';
  
  // Summary bar
  h += '<div style="background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:16px;padding:20px 24px;color:#fff;margin-bottom:20px;display:flex;align-items:center;gap:20px;flex-wrap:wrap">';
