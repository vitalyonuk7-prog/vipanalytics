function getPlayerChannels(email) {
  var channels = [];
  if (!email) return channels;
  email = email.toLowerCase().trim();

  // Find profiling player
  var pp = null;
  if (typeof profilingData !== 'undefined' && profilingData.players && profilingData.fieldConfig) {
    for (var pi = 0; pi < profilingData.players.length; pi++) {
      var pd = profilingData.players[pi].data || {};
      var keys = Object.keys(pd);
      for (var ki = 0; ki < keys.length; ki++) {
        if (String(pd[keys[ki]] || '').toLowerCase().trim() === email) {
          pp = profilingData.players[pi];
          break;
        }
      }
      if (pp) break;
    }
  }

  // Social links [ICON]
  if (pp && profilingData.fieldConfig && typeof getSocialLinks === 'function') {
    try {
      getSocialLinks(pp, profilingData.fieldConfig).forEach(function(l) {
        channels.push({ platform: l.platform, url: l.url, icon: l.icon, label: '' });
      });
    } catch(e) {}
  }
  // Big icon links [BICON] - BO, JIRA, Intercom
  if (pp && profilingData.fieldConfig && typeof getBigIconLinks === 'function') {
    try {
      getBigIconLinks(pp, profilingData.fieldConfig).forEach(function(l) {
        channels.push({ platform: l.platform, url: l.url, icon: l.icon, label: l.platform });
      });
    } catch(e) {}
  }

  // Fallback BO from VIP data
  if (!channels.some(function(c) { return c.platform === 'BO' || c.platform === 'Backoffice'; })) {
    var playerId = null;
    // Try allVipPlayers
    if (typeof allVipPlayers !== 'undefined' && allVipPlayers) {
      for (var vi = 0; vi < allVipPlayers.length; vi++) {
        if ((allVipPlayers[vi].email || '').toLowerCase().trim() === email) {
          playerId = allVipPlayers[vi].id;
          break;
        }
      }
    }
    if (playerId) {
      channels.push({ platform: 'BO', url: createBackofficeLink(playerId), icon: 'fas fa-user-shield', label: 'BO' });
    }
  }
  return channels;
}

