  if (myKpi) {
    window._qcViewMode = true;
    h += '<div style="margin-bottom:16px">' + kpiRenderCardDetail(myKpi).replace(/<button[^>]*onclick[^>]*>[^<]*<\/button>/g, '') + '</div>';
  }
  
  // QA Card (with appeal buttons)
  if (myQa) {
    window._qcViewMode = true;
    h += qaRenderScorecardDetail(myQa, false);
  }
  
  if (!myQa && !myKpi) h += '<div style="text-align:center;padding:40px;color:#94a3b8;background:#fff;border:1.5px solid #e2e8f0;border-radius:14px">No cards for ' + qaFmtMonth(selMonth) + '</div>';
  
  h += '</div>';
  
  // Right - month circles
  h += '<div style="width:80px;flex-shrink:0;display:flex;flex-direction:column;gap:8px;align-items:center">';
  h += '<div style="font-size:10px;font-weight:800;color:#94a3b8;text-transform:uppercase;margin-bottom:4px">MONTHS</div>';
  months.forEach(function(m) {
    var isActive = m === selMonth;
    var mQa = myQaAll.find(function(r) { return r.month === m; });
    var mKpi = myKpiAll.find(function(r) { return r.month === m; });
    var avg = 0; var cnt = 0;
    if (mQa) { avg += parseFloat(mQa.score) || 0; cnt++; }
    if (mKpi) { avg += parseFloat(mKpi.score) || 0; cnt++; }
    avg = cnt > 0 ? avg / cnt : 0;
    var cc = avg >= 80 ? '#10b981' : avg >= 50 ? '#f59e0b' : '#ef4444';
    h += '<div data-m="' + m + '" class="qc-month-btn" style="width:60px;height:60px;border-radius:50%;background:' + (isActive ? cc : '#f8fafc') + ';border:2px solid ' + (isActive ? cc : '#e2e8f0') + ';display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all 0.2s" onmouseover="this.style.borderColor=\'' + cc + '\'" onmouseout="this.style.borderColor=\'' + (isActive ? cc : '#e2e8f0') + '\'">';
    h += '<div style="font-size:12px;font-weight:900;color:' + (isActive ? '#fff' : cc) + '">' + avg.toFixed(0) + '%</div>';
    h += '<div style="font-size:8px;font-weight:700;color:' + (isActive ? 'rgba(255,255,255,0.8)' : '#94a3b8') + '">' + qaFmtMonth(m).split(' ')[0] + '</div>';
