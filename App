  h += '<span style="font-size:20px;font-weight:900;color:' + (belowMin ? '#ef4444' : '#10b981') + '">$' + bonusEarned.toFixed(0) + '</span></div>';
  h += '<div style="height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden"><div style="height:100%;width:' + Math.min(100, score) + '%;background:' + (belowMin ? '#ef4444' : '#10b981') + ';border-radius:3px"></div></div>';
  h += '<div style="font-size:10px;color:#94a3b8;margin-top:4px">' + score.toFixed(1) + '% of $' + bn.amount + (bn.minPct > 0 ? ' \u2022 Min: ' + bn.minPct + '%' : '') + '</div>';
  if (belowMin) {
    h += '<div style="margin-top:8px;padding:8px 12px;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;font-size:10px;color:#991b1b;line-height:1.5"><strong>\u26A0\uFE0F Warning!</strong> Score below minimum threshold (' + bn.minPct + '%). Bonus: <b>$0</b>.<br><em>Attention! High risk of performance decline! If the month closes with this score — the manager may be placed on a 3-month probationary period — at management\'s discretion.</em></div>';
