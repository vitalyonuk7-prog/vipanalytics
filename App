function qaDrawMgrChart(mgrRes){
  var canvas=document.getElementById('qaMgrChart');if(!canvas)return;
  var ctx=canvas.getContext('2d');
  var gradients=[['#667eea','#764ba2'],['#f093fb','#f5576c'],['#4facfe','#00f2fe'],['#43e97b','#38f9d7'],['#fa709a','#fee140'],['#30cfd0','#330867'],['#a8edea','#fed6e3'],['#ff9a9e','#fecfef'],['#e0c3fc','#8ec5fc']];
  var labels=mgrRes.map(function(r){return qaFmtMonth(r.month);});
  var data=mgrRes.map(function(r){return parseFloat(r.score)||0;});
  var bgColors=data.map(function(s,i){
    var grad=ctx.createLinearGradient(0,0,0,250);
    var pair=gradients[i%gradients.length];
    grad.addColorStop(0,pair[0]);grad.addColorStop(1,pair[1]);
    return grad;
  });
  if(canvas._chart)canvas._chart.destroy();
  canvas._chart=new Chart(canvas,{type:'bar',data:{labels:labels,datasets:[{data:data,backgroundColor:bgColors,borderRadius:8,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,layout:{padding:{top:30}},plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',formatter:function(v){return v?v.toFixed(1)+'%':'';},color:'#1e293b',font:{weight:'bold',size:12}}},scales:{y:{beginAtZero:true,max:100,grace:'5%',grid:{color:'#f1f5f9'},ticks:{callback:function(v){return v+'%';}}},x:{grid:{display:false},ticks:{font:{weight:'bold',size:11}}}}}});
}

