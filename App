// ---- GSM-7 ----
var GSM7_CHARS = '@\u00a3$\u00a5\u00e8\u00e9\u00f9\u00ec\u00f2\u00c7\n\u00d8\u00f8\r\u00c5\u00e5\u0394_\u03a6\u0393\u039b\u03a9\u03a0\u03a8\u03a3\u0398\u039e \u00c6\u00e6\u00df\u00c9 !"#\u00a4%&\'()*+,-./0123456789:;<=>?\u00a1ABCDEFGHIJKLMNOPQRSTUVWXYZ\u00c4\u00d6\u00d1\u00dc\u00a7\u00bfabcdefghijklmnopqrstuvwxyz\u00e4\u00f6\u00f1\u00fc\u00e0';
var GSM7_EXT = '^{}\\[~]|\u20ac';
function isGSM7(t){for(var i=0;i<t.length;i++){if(GSM7_CHARS.indexOf(t[i])===-1&&GSM7_EXT.indexOf(t[i])===-1)return false;}return true;}
function countGSM7(t){var c=0;for(var i=0;i<t.length;i++)c+=GSM7_EXT.indexOf(t[i])!==-1?2:1;return c;}

function smsUpdateCalc(text) {
  var eEl=document.getElementById('smsEncoding'),cEl=document.getElementById('smsCharCount'),sEl=document.getElementById('smsSegments'),bEl=document.getElementById('smsProgressBar'),wEl=document.getElementById('smsWarning');
  if(!text){eEl.textContent='GSM-7';cEl.textContent='0/160';sEl.textContent='0';bEl.style.width='0%';bEl.style.background='linear-gradient(90deg,#10b981,#059669)';wEl.style.display='none';smsUpdateSendBtn();return;}
  var gsm=isGSM7(text),cc,sl,ml,segs;
  if(gsm){cc=countGSM7(text);sl=160;ml=153;eEl.textContent='GSM-7';eEl.style.color='#10b981';}else{cc=text.length;sl=70;ml=67;eEl.textContent='UCS-2';eEl.style.color='#f59e0b';}
  segs=cc<=sl?(cc>0?1:0):Math.ceil(cc/ml);
  cEl.textContent=cc+'/'+(segs<=1?sl:ml*segs);sEl.textContent=String(segs);
  sEl.style.color=segs<=1?'#10b981':segs<=3?'#f59e0b':'#ef4444';
  bEl.style.width=Math.min(100,(cc/sl)*100)+'%';
  bEl.style.background=segs<=1?'linear-gradient(90deg,#10b981,#059669)':segs<=3?'linear-gradient(90deg,#f59e0b,#d97706)':'linear-gradient(90deg,#ef4444,#dc2626)';
  wEl.style.display=(!gsm||segs>1)?'block':'none';
  wEl.textContent=!gsm?'\u26a0\ufe0f Unicode \u2192 70 chars/seg':'\ud83d\udce6 '+segs+' segments';
  smsUpdateSendBtn();
}

