/**
 * Robust country finder from any data object
 */
function findPlayerCountry(data) {
  if (!data) return '';
  var skip = ['—', '-', '–', 'n/a', 'N/A', 'none', 'None', 'null', 'undefined', ''];
  // Direct keys first
  if (data.country && skip.indexOf(String(data.country).trim()) === -1) return String(data.country).trim();
  if (data.COUNTRY && skip.indexOf(String(data.COUNTRY).trim()) === -1) return String(data.COUNTRY).trim();
  if (data.Country && skip.indexOf(String(data.Country).trim()) === -1) return String(data.Country).trim();
  // Search all keys containing 'country'
  var keys = Object.keys(data);
  for (var i = 0; i < keys.length; i++) {
    if (keys[i].toLowerCase().indexOf('country') !== -1) {
      var v = String(data[keys[i]] || '').trim();
      if (v && v.length <= 5 && skip.indexOf(v) === -1) return v;
    }
  }
  return '';
}

/**
