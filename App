function bulkAssignBonusCategory(){
  var cat = document.getElementById('bonusBulkCatSelect').value;
  if(!cat){ showToast('Select a category first'); return; }
  var cbs = document.querySelectorAll('.bonusCatCb:checked');
  if(cbs.length===0){ showToast('Select bonus names first'); return; }
  
  var names = [];
  cbs.forEach(function(cb){ names.push(cb.dataset.name); });
  
  var done = 0, total = names.length;
  showToast('⏳ Assigning '+total+' bonuses...');
  
  names.forEach(function(name){
    bonusCatMapping[name] = cat; // optimistic update
    google.script.run
      .withSuccessHandler(function(){ done++; if(done>=total){ showToast('✅ '+total+' bonuses assigned to "'+cat+'"'); renderBonusCategoryList(window._bonusCatNames); }})
      .withFailureHandler(function(){ done++; })
      .saveBonusCategory(name, cat);
  });
  renderBonusCategoryList(window._bonusCatNames); // immediate UI update
}

function filterBonusCategoryList(){
