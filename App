function ttOpenLunchModal(ai, dateKey) {
  // ai = assignment index, dateKey = specific date (or null for default)
  var asgn = ttData.assignments[ai];
  if (!asgn) return;
  var myEmail = (window._userEmail||'').toLowerCase();
  var isAdmin = window._userRole === 'admin';
  var isOwn = asgn.managerEmail.toLowerCase() === myEmail;
  if (!isAdmin && !isOwn) return;

  // Get current lunch for this date (or default)
  var lunchOverrides = asgn.lunchOverrides || {};
  var defaultLunch = asgn.defaultLunch || '13:00';
  var currentLunch = dateKey ? (lunchOverrides[dateKey] || defaultLunch) : defaultLunch;

  var modal = document.getElementById('ttLunchModal');
  if (!modal) {
    modal = document.createElement('div'); modal.id = 'ttLunchModal';
    modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:10010;display:flex;align-items:center;justify-content:center;padding:16px';
    modal.onclick = function(e){ if(e.target===this) this.style.display='none'; };
    document.body.appendChild(modal);
  }
  modal.innerHTML = ''; modal.style.display = 'flex';

  var box = document.createElement('div');
  box.style.cssText = 'background:#fff;border-radius:18px;max-width:360px;width:100%;overflow:hidden;box-shadow:0 16px 50px rgba(0,0,0,0.25)';

  // Header
  var hdr = document.createElement('div');
  hdr.style.cssText = 'padding:14px 18px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:space-between;border-radius:18px 18px 0 0';
  hdr.innerHTML = '<div style="font-size:15px;font-weight:900;color:#fff">🍽️ Lunch Break</div>';
  var closeX = document.createElement('button');
  closeX.textContent='×'; closeX.style.cssText='background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:17px;width:30px;height:30px;border-radius:6px;cursor:pointer';
  closeX.onclick=function(){ modal.style.display='none'; };
  hdr.appendChild(closeX); box.appendChild(hdr);

  var body = document.createElement('div');
  body.style.cssText = 'padding:18px';

  var mgrName = asgn.managerEmail.split('@')[0];

  if (!dateKey) {
    // Setting DEFAULT lunch for all shifts
    body.appendChild(ttLunchEl('div','font-size:12px;color:#64748b;margin-bottom:14px',
      '⚙️ Set default lunch time for <b>'+mgrName+'</b> — applies to all working days'));
  } else {
    body.appendChild(ttLunchEl('div','font-size:12px;color:#64748b;margin-bottom:14px',
      '📅 Override lunch for <b>'+mgrName+'</b> on <b>'+dateKey+'</b>'));
  }

  // Build slots within shift hours
  var sh = (ttData.shifts||[]).find(function(s){ return s.id===asgn.shiftId; });
  var shStart = sh && sh.startTime ? sh.startTime : '09:00';
  var shEnd   = sh && sh.endTime   ? sh.endTime   : '18:00';
  function toMins(t){ var p=t.split(':'); var h=parseInt(p[0]); return (h===0?24:h)*60+parseInt(p[1]||0); }
  function fromMins(m){ return String(Math.floor(m/60)%24).padStart(2,'0')+':'+String(m%60).padStart(2,'0'); }
  var dur = parseInt(asgn.lunchDuration||60);
  var sMin = toMins(shStart) + 60;
  var eMin = toMins(shEnd) - dur - 30;
  var slots = [];
  for (var m = sMin; m <= eMin; m += 30) slots.push(fromMins(m));
  if (!slots.length) slots = ['12:00','12:30','13:00','13:30','14:00'];

  // Duration selector (needed for slot labels and save)
  var durSel = document.createElement('select');
  durSel.style.cssText = 'padding:7px 10px;border:1.5px solid #fde68a;border-radius:8px;font-size:12px;font-family:inherit;outline:none;margin-bottom:12px;width:100%';
  [['30 min','30'],['45 min','45'],['60 min','60'],['90 min','90']].forEach(function(d){
    var o=document.createElement('option'); o.value=d[1]; o.textContent=d[0];
    if (String(asgn.lunchDuration||'60')===d[1]) o.selected=true;
    durSel.appendChild(o);
  });
  // When duration changes, rebuild slots
  durSel.onchange = function() {
    dur = parseInt(this.value);
    eMin = toMins(shEnd) - dur - 30;
    slots = [];
    for (var m2 = sMin; m2 <= eMin; m2 += 30) slots.push(fromMins(m2));
    if (!slots.length) slots = ['12:00','12:30','13:00'];
    rebuildSlots();
  };

  body.appendChild(ttLunchEl('div','font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:6px','Duration'));
  body.appendChild(durSel);

  var timePicker = document.createElement('input');
  timePicker.type = 'time'; timePicker.value = currentLunch;
  timePicker.style.cssText = 'display:none'; // hidden — set via slots or custom
  body.appendChild(timePicker);

  // Quick pick label
  body.appendChild(ttLunchEl('div','font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:8px',
    'Quick pick · '+shStart+'–'+shEnd));

  var slotGrid = document.createElement('div');
  slotGrid.style.cssText = 'display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px';

  function lunchEnd(start) {
    var d2=parseInt(durSel.value||60);
    return fromMins(toMins(start)+d2);
  }

  function rebuildSlots() {
    slotGrid.innerHTML = '';
    slots.forEach(function(s) {
      var isOn = s === timePicker.value;
      var btn = document.createElement('button');
      btn.textContent = s + ' – ' + lunchEnd(s);
      btn.style.cssText = 'padding:6px 10px;border-radius:7px;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;' +
        'border:1.5px solid '+(isOn?'#f59e0b':'#e2e8f0')+';background:'+(isOn?'#fffbeb':'#fff')+';color:'+(isOn?'#d97706':'#64748b');
      btn.onclick = (function(val){ return function(){
        timePicker.value = val;
        slotGrid.querySelectorAll('button').forEach(function(b){ b.style.borderColor='#e2e8f0'; b.style.background='#fff'; b.style.color='#64748b'; });
        this.style.borderColor='#f59e0b'; this.style.background='#fffbeb'; this.style.color='#d97706';
        customI.value = val;
      }; })(s);
      slotGrid.appendChild(btn);
    });
  }
  body.appendChild(slotGrid);

  // Custom time input
  body.appendChild(ttLunchEl('div','font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:6px','Custom time'));
  var customI = document.createElement('input'); customI.type='time'; customI.value=currentLunch;
  customI.style.cssText='width:100%;padding:9px 12px;border:1.5px solid #e2e8f0;border-radius:9px;font-size:14px;font-weight:700;font-family:inherit;outline:none;box-sizing:border-box;margin-bottom:14px';
  customI.onfocus=function(){this.style.borderColor='#f59e0b';};
  customI.onblur=function(){this.style.borderColor='#e2e8f0';};
  customI.oninput=function(){ timePicker.value=this.value; };
  body.appendChild(customI);

  // Sync timePicker → customI
  timePicker.value = currentLunch;
  customI.value = currentLunch;

  rebuildSlots();

  // Buttons
  var btnRow = document.createElement('div'); btnRow.style.cssText='display:flex;gap:8px';

  // Apply to all / Apply to this day
  if (dateKey) {
    btnRow.appendChild(ttLunchBtn('Apply to this day','flex:1;padding:10px;border:none;background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;font-size:12px;font-weight:800;border-radius:9px;cursor:pointer', function(){
      if (!asgn.lunchOverrides) asgn.lunchOverrides={};
      asgn.lunchOverrides[dateKey] = timePicker.value;
      asgn.lunchDuration = durSel.value;
      ttSaveData(); modal.style.display='none'; showToast('🍽️ Lunch set for '+dateKey); ttRenderGrid(document.getElementById('ttGridContainer'));
    }));
    btnRow.appendChild(ttLunchBtn('Set as default','flex:1;padding:10px;border:1.5px solid #f59e0b;background:#fffbeb;color:#d97706;font-size:12px;font-weight:800;border-radius:9px;cursor:pointer', function(){
      asgn.defaultLunch = timePicker.value;
      asgn.lunchDuration = durSel.value;
      ttSaveData(); modal.style.display='none'; showToast('🍽️ Default lunch updated for '+mgrName); ttRenderGrid(document.getElementById('ttGridContainer'));
    }));
  } else {
    btnRow.appendChild(ttLunchBtn('Save Default Lunch','flex:1;padding:10px;border:none;background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;font-size:12px;font-weight:800;border-radius:9px;cursor:pointer', function(){
      asgn.defaultLunch = timePicker.value;
      asgn.lunchDuration = durSel.value;
      ttSaveData(); modal.style.display='none'; showToast('🍽️ Default lunch set: '+timePicker.value+' ('+durSel.value+'m)'); ttRenderGrid(document.getElementById('ttGridContainer'));
    }));
  }

  if (dateKey && (asgn.lunchOverrides||{})[dateKey]) {
    btnRow.appendChild(ttLunchBtn('Clear override','padding:10px 12px;border:1.5px solid #fca5a5;background:#fef2f2;color:#ef4444;font-size:11px;font-weight:700;border-radius:9px;cursor:pointer', function(){
      delete asgn.lunchOverrides[dateKey];
      ttSaveData(); modal.style.display='none'; showToast('↩️ Override removed'); ttRenderGrid(document.getElementById('ttGridContainer'));
    }));
  }

  body.appendChild(btnRow);
  box.appendChild(body);
  modal.appendChild(box);
}

function ttLunchEl(tag,css,html){ var e=document.createElement(tag); if(css)e.style.cssText=css; if(html)e.innerHTML=html; return e; }
function ttLunchBtn(label,css,fn){ var b=document.createElement('button'); b.textContent=label; if(css)b.style.cssText=css; b.onclick=fn; return b; }

function ttLunchEndTime(startTime, durMins) {
  if (!startTime) return '';
  var p = startTime.split(':');
  var total = parseInt(p[0])*60 + parseInt(p[1]||0) + parseInt(durMins||60);
  return String(Math.floor(total/60)%24).padStart(2,'0') + ':' + String(total%60).padStart(2,'0');
}
function ttGetLunchTime(asgn, dateKey) {
  if (!asgn) return null;
  var lunchOverrides = asgn.lunchOverrides || {};
  return lunchOverrides[dateKey] || asgn.defaultLunch || null;
}



