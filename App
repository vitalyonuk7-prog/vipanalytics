function formatUnixTimestamp(timestamp) {
  if (!timestamp || timestamp === 0 || timestamp === '0') return '—';
  
  // Якщо це вже строка з датою (містить дефіс або слеш)
  if (typeof timestamp === 'string' && (timestamp.includes('-') || timestamp.includes('/'))) {
    return timestamp;
  }
  
  // Конвертуємо в число
  var ts = parseInt(timestamp);
  if (isNaN(ts)) return timestamp;
  
  // Unix timestamp в мілісекундах (якщо менше 10000000000, то це секунди)
  var date = ts < 10000000000 ? new Date(ts * 1000) : new Date(ts);
  
  // Перевірка чи дата валідна
  if (isNaN(date.getTime())) return timestamp;
  
  // Форматуємо дату
  var year = date.getFullYear();
  var month = String(date.getMonth() + 1).padStart(2, '0');
  var day = String(date.getDate()).padStart(2, '0');
  var hours = String(date.getHours()).padStart(2, '0');
  var minutes = String(date.getMinutes()).padStart(2, '0');
  
  return day + '.' + month + '.' + year + ' ' + hours + ':' + minutes;
}

