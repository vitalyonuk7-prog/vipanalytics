function filterClosureTable() {
  if (!closureData) return;
  
  var search = (document.getElementById('closureSearch').value || '').toLowerCase().trim();
  var statusFilter = document.getElementById('closureStatusFilter').value;
  var reasonFilter = document.getElementById('closureReasonFilter').value;
  var managerFilter = document.getElementById('closureManagerFilter').value;
  
  var filtered = closureData.filter(function(p) {
    if (statusFilter && p.status !== statusFilter) return false;
    var reason = p.closureReason || 'Not specified';
    if (reasonFilter && reason !== reasonFilter) return false;
    var mgr = p.manager || 'Not assigned';
    if (managerFilter && mgr !== managerFilter) return false;
    if (search) {
      var haystack = (p.email + ' ' + p.status + ' ' + p.closureReason + ' ' + p.type + ' ' + p.manager).toLowerCase();
      if (haystack.indexOf(search) === -1) return false;
    }
    return true;
  });
  
  var tbody = document.getElementById('closureTableBody');
  if (filtered.length === 0) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;color:#94a3b8">No closed players found</td></tr>';
    return;
  }
  
  // Sort: no closure date first (green), then by closure date descending (newest→oldest)
  filtered.sort(function(a, b) {
    var aHasDate = a.closureDate ? 1 : 0;
    var bHasDate = b.closureDate ? 1 : 0;
    if (aHasDate !== bHasDate) return aHasDate - bHasDate; // no date first
    if (a.closureDate && b.closureDate) return b.closureDate.localeCompare(a.closureDate); // newest first
    return b.inout - a.inout; // among no-date: by inout desc
  });
  
  var statusColorMap = { 'disabled-by-manager': '#f59e0b', 'disabled': '#ef4444', 'closed': '#ef4444', 'self-excluded': '#8b5cf6', 'self_excluded': '#8b5cf6', 'blocked': '#dc2626', 'frozen': '#3b82f6' };
  var isAdmin = window._userRole === 'admin';
  var currentUser = window._userManager || window._userEmail || '';
  
  // Build manager select options HTML
  var mgrOptsHtml = '<option value="">—</option><option value="Support">Support</option><option value="User">User</option>';
  closureAppUsers.forEach(function(u) {
    mgrOptsHtml += '<option value="' + u.replace(/"/g, '&quot;') + '">' + u + '</option>';
  });
  
  // Build reason select options HTML
  var reasonOptsHtml = '<option value="">—</option>';
  window._clReasonOpts.forEach(function(r) {
    reasonOptsHtml += '<option value="' + r.replace(/"/g, '&quot;') + '">' + r + '</option>';
  });
  
  var html = '';
  filtered.forEach(function(p) {
    var boLink = p.id ? 'https://backoffice.slotornado-bivu.com/backend/players/' + String(p.id).replace('slotornado:', '').trim() : '#';
    var statusColor = statusColorMap[p.status.toLowerCase()] || '#64748b';
    var inoutColor = p.inout >= 0 ? '#10b981' : '#ef4444';
    var inoutSign = p.inout >= 0 ? '+' : '';
    var noDate = !p.closureDate;
    var trClass = noDate ? ' class="cl-no-date"' : '';
    
    var closureDateClass = p.closureDate ? 'cl-date-input has-value' : 'cl-date-input';
    var reopeningDateClass = p.reopeningDate ? 'cl-date-input has-value' : 'cl-date-input';
    
    // Reason <select>
    var reasonClass = p.closureReason ? 'cl-select has-value' : 'cl-select';
    var reasonSelectHtml = '<select class="' + reasonClass + '" onchange="saveClosureReasonUI(\'' + p.id + '\',\'' + p.email.replace(/'/g, "\\'") + '\',this.value,this)">' + reasonOptsHtml + '</select>';
    
    // Manager <select> — non-admin can only select themselves
    var mgrClass = p.manager ? 'cl-select has-value' : 'cl-select';
    var mgrSelectHtml;
    if (isAdmin) {
      mgrSelectHtml = '<select class="' + mgrClass + '" onchange="saveClosureFieldUI(\'' + p.id + '\',\'' + p.email.replace(/'/g, "\\'") + '\',\'manager\',this.value,this)">' + mgrOptsHtml + '</select>';
    } else {
      mgrSelectHtml = '<select class="' + mgrClass + '" onchange="saveClosureFieldUI(\'' + p.id + '\',\'' + p.email.replace(/'/g, "\\'") + '\',\'manager\',this.value,this)">';
      mgrSelectHtml += '<option value="">—</option>';
      mgrSelectHtml += '<option value="Support">Support</option>';
      mgrSelectHtml += '<option value="User">User</option>';
      if (currentUser) mgrSelectHtml += '<option value="' + currentUser.replace(/"/g, '&quot;') + '">' + currentUser + '</option>';
      mgrSelectHtml += '</select>';
    }
    
    var escapedId = p.id.replace(/"/g, '&quot;');
    
    html += '<tr' + trClass + '>';
    html += '<td class="cl-email" title="' + p.email + '">' + p.email + '</td>';
    html += '<td><span style="font-size:11px;font-weight:600;color:#475569">' + p.type + '</span></td>';
    html += '<td><span class="cl-status" style="background:' + statusColor + '20;color:' + statusColor + '">' + p.status + '</span></td>';
    html += '<td class="cl-reason" data-pid="' + escapedId + '">' + reasonSelectHtml + '</td>';
    html += '<td data-pid="' + escapedId + '">' + mgrSelectHtml + '</td>';
    html += '<td class="cl-inout" style="color:' + inoutColor + '">' + inoutSign + '€' + Math.abs(p.inout).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '</td>';
