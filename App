var momRetentionCellsLoaded = false;
var momRetentionCellsLoading = false;

function loadAllRetentionMoMPlayersForFilters(){
  if(momRetentionCellsLoaded || momRetentionCellsLoading) return Promise.resolve();
  momRetentionCellsLoading = true;
  return new Promise((resolve)=>{
    const requests=[];
    // Monthly MoM
    if(momRetentionData&&momRetentionData.rows){
      momRetentionData.rows.forEach((row,rowIdx)=>{
        const cohortMonth=row.month;
        for(let i=rowIdx;i<momRetentionData.months.length;i++){
          requests.push({cohortMonth:cohortMonth,activeMonth:momRetentionData.months[i],type:'monthly'});
        }
      });
    }
    // Weekly MoM
    if(momWeeklyRetentionData&&momWeeklyRetentionData.rows){
      momWeeklyRetentionData.rows.forEach((row,rowIdx)=>{
        const cohortWeek=row.week;
        for(let i=rowIdx;i<momWeeklyRetentionData.weeks.length;i++){
          requests.push({cohortWeek:cohortWeek,activeWeek:momWeeklyRetentionData.weeks[i],type:'weekly'});
        }
      });
    }
    if(requests.length===0){momRetentionCellsLoaded=true;momRetentionCellsLoading=false;resolve();return}
    const BATCH_SIZE=5;let batchIndex=0;
    console.log('📥 Loading ALL MoM retention cells:',requests.length,'total');
    function loadNextBatch(){
      const start=batchIndex*BATCH_SIZE;const end=Math.min(start+BATCH_SIZE,requests.length);
      if(start>=requests.length){
        console.log('✅ All MoM retention cells loaded');
        momRetentionCellsLoaded=true;momRetentionCellsLoading=false;
        // Re-render if filters active
        var hasActiveFilters=Object.values(retentionFilters).some(arr=>arr&&arr.length>0);
        if(hasActiveFilters&&retentionType==='mom'){
          console.log('🔄 Re-rendering MoM retention with filters after cells loaded');
          if(retentionMode==='monthly'){renderRetentionChart();renderRetentionTable()}
          else{renderWeeklyRetentionChart();renderWeeklyRetentionTable()}
        }
        resolve();return;
      }
      const batch=requests.slice(start,end);let batchCompleted=0;let timeoutId;
      console.log('⏳ MoM batch',batchIndex+1,'/',Math.ceil(requests.length/BATCH_SIZE));
      timeoutId=setTimeout(function(){if(batchCompleted<batch.length){batchIndex++;loadNextBatch()}},15000);
      batch.forEach(req=>{
        if(req.type==='monthly'){
          const k='mom:'+req.cohortMonth+'|'+req.activeMonth;
          google.script.run.withSuccessHandler(function(data){
            retentionPlayersCellMap.set(normCellKey(k),data);
            batchCompleted++;if(batchCompleted===batch.length){clearTimeout(timeoutId);batchIndex++;setTimeout(loadNextBatch,500)}
          }).withFailureHandler(function(error){
            console.error('❌ MoM cell failed:',k,error);
            batchCompleted++;if(batchCompleted===batch.length){clearTimeout(timeoutId);batchIndex++;setTimeout(loadNextBatch,500)}
          }).getCellPlayersRetentionMoM({ftdMonth:req.cohortMonth,activeMonth:req.activeMonth});
        }else{
          const k='mom:'+req.cohortWeek+'|'+req.activeWeek;
          google.script.run.withSuccessHandler(function(data){
            retentionPlayersCellMap.set(normCellKey(k),data);
            batchCompleted++;if(batchCompleted===batch.length){clearTimeout(timeoutId);batchIndex++;setTimeout(loadNextBatch,500)}
          }).withFailureHandler(function(error){
            console.error('❌ MoM weekly cell failed:',k,error);
            batchCompleted++;if(batchCompleted===batch.length){clearTimeout(timeoutId);batchIndex++;setTimeout(loadNextBatch,500)}
          }).getCellPlayersRetentionWeeklyMoM({ftdWeek:req.cohortWeek,activeWeek:req.activeWeek});
        }
      });
    }
    loadNextBatch();
  });
}

