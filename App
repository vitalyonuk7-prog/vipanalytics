function renderTrafficChart(td) {
  var canvas = document.getElementById('trafficChart');
  if (!canvas || typeof Chart === 'undefined') return;
  var ctx = canvas.getContext('2d');
  
  // Aggregate totals per group across all periods
  var groupTotals = {};
  td.groups.forEach(function(g) { groupTotals[g] = { ftd: 0, active: 0, dropped: 0 }; });
  
  Object.values(td.data).forEach(function(groups) {
    Object.keys(groups).forEach(function(g) {
      groupTotals[g].ftd += groups[g].ftd;
      groupTotals[g].active += groups[g].active;
      groupTotals[g].dropped += groups[g].dropped;
    });
  });
  
  // Sort by drop rate descending
  var sorted = Object.keys(groupTotals).sort(function(a, b) {
    var rA = groupTotals[a].ftd > 0 ? groupTotals[a].dropped / groupTotals[a].ftd : 0;
    var rB = groupTotals[b].ftd > 0 ? groupTotals[b].dropped / groupTotals[b].ftd : 0;
    return rB - rA;
  });
  
  var labels = sorted;
  var activeData = sorted.map(function(g) { return groupTotals[g].active; });
  var droppedData = sorted.map(function(g) { return groupTotals[g].dropped; });
  
  if (trafficChart) trafficChart.destroy();
  
  trafficChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'Active',
          data: activeData,
          backgroundColor: 'rgba(16,185,129,0.8)',
          borderRadius: 4
        },
        {
          label: 'Dropped',
          data: droppedData,
          backgroundColor: 'rgba(239,68,68,0.8)',
          borderRadius: 4
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'top' },
        datalabels: { display: false }
      },
      scales: {
        x: { stacked: true, grid: { display: false } },
        y: { stacked: true, grid: { color: '#f1f5f9' }, ticks: { precision: 0 } }
      }
    }
  });
}

function openTrafficModal(group, period) {
  // group = traffic group name or 'TOTAL', period = month/week or 'ALL'
  var modal = document.getElementById('modal');
  var title = group === 'TOTAL' ? 'All Traffic' : group;
  if (period !== 'ALL') title += ' • ' + period;
  document.getElementById('modalTitle').textContent = '🚦 ' + title;
  modal.classList.add('open');
  
  var achieved = [], dropped = [];
  
  if (period === 'ALL') {
    // Merge all periods
    Object.keys(trafficPlayersCache).forEach(function(p) {
      var c = trafficPlayersCache[p];
      achieved = achieved.concat(c.achieved || []);
      dropped = dropped.concat(c.dropped || []);
    });
  } else {
    var c = trafficPlayersCache[period];
    if (c) {
      achieved = (c.achieved || []).slice();
      dropped = (c.dropped || []).slice();
    }
  }
  
  // Filter by group if not TOTAL
  if (group !== 'TOTAL') {
    achieved = achieved.filter(function(p) {
      return ((p[trafficGroupBy] || '').trim() || 'Unknown') === group;
    });
    dropped = dropped.filter(function(p) {
      return ((p[trafficGroupBy] || '').trim() || 'Unknown') === group;
    });
  }
  
  var data = {
    achieved: achieved,
    dropped: dropped,
    total: achieved.length + dropped.length,
    totalAchieved: achieved.length,
    totalDropped: dropped.length
  };
  
  currentModalData = data;
  currentFilteredData = data;
  renderModalContent(data);
}

function renderTrafficTable(td) {
  var table = document.getElementById('traffic-table');
  if (!table) return;
  
  if (td.groups.length === 0) {
    table.innerHTML = '<tr><td style="padding:40px;text-align:center;color:#64748b">No traffic data available</td></tr>';
    return;
  }
  
  // Aggregate per group across all periods + per period
  var groupTotals = {};
  td.groups.forEach(function(g) { groupTotals[g] = { ftd: 0, active: 0, dropped: 0 }; });
  Object.values(td.data).forEach(function(groups) {
    Object.keys(groups).forEach(function(g) {
      groupTotals[g].ftd += groups[g].ftd;
      groupTotals[g].active += groups[g].active;
      groupTotals[g].dropped += groups[g].dropped;
    });
  });
  
  // Sort by FTD count descending
  var sortedGroups = td.groups.sort(function(a, b) { return groupTotals[b].ftd - groupTotals[a].ftd; });
  
  var html = '<thead><tr>';
  html += '<th class="row-header" style="min-width:140px">Traffic</th>';
  html += '<th>FTD</th><th>Active</th><th>Dropped</th><th>Drop %</th><th>Drop/Active</th>';
  
  // Per-period columns
  td.periods.forEach(function(p) {
    html += '<th>' + p + '<br><span style="font-size:10px;font-weight:400;opacity:0.7">Drop %</span></th>';
  });
  html += '</tr></thead><tbody>';
  
  // Total row
  var allFtd = 0, allActive = 0, allDropped = 0;
  Object.values(groupTotals).forEach(function(d) { allFtd += d.ftd; allActive += d.active; allDropped += d.dropped; });
  html += '<tr style="background:#f8fafc;font-weight:700">';
  html += '<td class="row-header" style="color:#1e293b;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">TOTAL</td>';
  html += '<td style="cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + allFtd + '</td>';
  html += '<td style="color:#059669;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + allActive + '</td>';
  html += '<td style="color:#dc2626;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + allDropped + '</td>';
  html += '<td><span class="cell" style="background:' + dropRateColor(allFtd > 0 ? allDropped/allFtd : 0) + ';color:#fff;padding:6px 12px;min-width:60px;cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + (allFtd > 0 ? (allDropped/allFtd*100).toFixed(1) : '0.0') + '%</span></td>';
  html += '<td style="cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'ALL\')">' + (allActive > 0 ? (allDropped/allActive*100).toFixed(1) : '0.0') + '%</td>';
  td.periods.forEach(function(p) {
    var pFtd = 0, pDrop = 0;
    Object.values(td.data[p] || {}).forEach(function(d) { pFtd += d.ftd; pDrop += d.dropped; });
    var pRate = pFtd > 0 ? (pDrop/pFtd*100).toFixed(1) : '-';
    html += '<td style="cursor:pointer" onclick="openTrafficModal(\'TOTAL\',\'' + p.replace(/'/g,"\\'") + '\')">' + pRate + (pRate !== '-' ? '%' : '') + '</td>';
  });
  html += '</tr>';
  
  // Group rows
  sortedGroups.forEach(function(group) {
    var t = groupTotals[group];
    var dropPct = t.ftd > 0 ? t.dropped / t.ftd : 0;
    var dropVsActive = t.active > 0 ? (t.dropped / t.active * 100).toFixed(1) : '∞';
    
    html += '<tr>';
    html += '<td class="row-header" style="cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + group + '</td>';
    html += '<td style="cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + t.ftd + '</td>';
    html += '<td style="color:#059669;cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + t.active + '</td>';
    html += '<td style="color:#dc2626;cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + t.dropped + '</td>';
    html += '<td><span class="cell" style="background:' + dropRateColor(dropPct) + ';color:#fff;padding:6px 12px;min-width:60px;cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + (dropPct*100).toFixed(1) + '%</span></td>';
    html += '<td style="cursor:pointer" onclick="openTrafficModal(\'' + group.replace(/'/g,"\\'") + '\',\'ALL\')">' + dropVsActive + '%</td>';
    
    // Per-period
    td.periods.forEach(function(p) {
      var pd = (td.data[p] && td.data[p][group]) || null;
      var safeGroup = group.replace(/'/g,"\\'");
      var safePeriod = p.replace(/'/g,"\\'");
      if (pd && pd.ftd > 0) {
        var pRate = (pd.dropped / pd.ftd * 100).toFixed(1);
        html += '<td><span class="cell" style="background:' + dropRateColor(pd.dropped/pd.ftd) + ';color:#fff;padding:6px 10px;min-width:50px;cursor:pointer" onclick="openTrafficModal(\'' + safeGroup + '\',\'' + safePeriod + '\')">' + pRate + '%</span></td>';
      } else {
        html += '<td style="color:#cbd5e1">—</td>';
      }
    });
    
    html += '</tr>';
  });
  
  html += '</tbody>';
  table.innerHTML = html;
}

function dropRateColor(rate) {
  // 0% = green, 50% = yellow, 100% = red
  var r = Math.round(Math.min(255, rate * 2 * 239));
  var g = Math.round(Math.max(0, (1 - rate * 1.5) * 185));
  var b = Math.round(50);
  return 'rgb(' + r + ',' + g + ',' + b + ')';
}

