function renderTotalPies(){
  var container=document.getElementById('dashTotalPies');
  if(!container)return;
  var groups=window.dashboardGroups||[];
  // Aggregate pie data across all tabs
  var aggregated={};
  groups.forEach(function(g){
    var td=dynamicTabsData[g.id];
    if(!td||!td.metrics||!td.metrics.pies)return;
    var vocab=td.vocabulary||{};
    Object.keys(vocab).forEach(function(id){
      if(vocab[id].type!=='dash pie')return;
      var pd=td.metrics.pies[id];
      if(!pd)return;
      var dist=pd.total||{};
      if(!aggregated[id])aggregated[id]={name:vocab[id].name||id,data:{}};
      Object.keys(dist).forEach(function(k){
        aggregated[id].data[k]=(aggregated[id].data[k]||0)+(dist[k]||0);
      });
    });
  });
  // If no aggregated data from dynamicTabsData, use current vipData
  if(Object.keys(aggregated).length===0&&vipData&&vipData.metrics&&vipData.metrics.pies){
    var vocab=vipData.vocabulary||{};
    Object.keys(vocab).forEach(function(id){
      if(vocab[id].type!=='dash pie')return;
      var pd=vipData.metrics.pies[id];
      if(!pd)return;
      var dist=pd.total||{};
      if(Object.keys(dist).length>0){aggregated[id]={name:vocab[id].name||id,data:dist}}
    });
  }
  var pieKeys=Object.keys(aggregated);
  if(pieKeys.length===0){container.innerHTML='';return}
  var h='<div class="dash-total-pies-title">🌍 Total Distribution (all tabs)</div><div class="dash-pies">';
  pieKeys.forEach(function(id){
    var m=aggregated[id];
    var canvasId='tpie_'+id.replace(/[^a-z0-9]/gi,'_');
    h+='<div class="dash-pie-card"><div class="dash-pie-title">'+m.name+'</div><div class="dash-pie-canvas"><canvas id="'+canvasId+'"></canvas></div><div class="dash-pie-legend" id="'+canvasId+'_legend"></div></div>';
  });
  h+='</div>';
  container.innerHTML=h;
  setTimeout(function(){
    pieKeys.forEach(function(id){
      var canvasId='tpie_'+id.replace(/[^a-z0-9]/gi,'_');
      renderDashPieChart(canvasId,aggregated[id].data);
    });
  },150);
}
function renderDashQuickStats(){if(!vipData||!vipData.metrics)return;var activeTab=window.currentDashboardTab||'';const sums=vipData.metrics.sums;const vocabulary=vipData.vocabulary||{};const grid=document.getElementById('dashQuickStats');if(!grid)return;

// Period suffix mapping
var periodSuffix={lifetime:'lifetime','30':'last_30','90':'last_90','7':'last_7','1':'previous_day'};
var curSuffix=periodSuffix[currentPeriod]||'lifetime';
var periodLabel={lifetime:'Lifetime','30':'30 Days','90':'90 Days','7':'7 Days','1':'1 Day'}[currentPeriod]||'Lifetime';

// Filter metrics to only current period
var depCards=[],cashCards=[],inoutCards=[];
function makeCard(id,m,icon,color){
  var v=0;if(currentVIPTab==='total')v=m.total||0;else if(currentVIPTab==='vip')v=m.vip||0;else v=m.silentVip||0;
  if(id.indexOf('cashout')!==-1&&currentPeriod!=='lifetime')v=Math.abs(v);
  var mType=(m.type==='dash sum'||id.indexOf('sum')!==-1)?'currency':'number';
  var fmt=mType==='currency'?'€'+Math.abs(v).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:0}):Math.round(v).toLocaleString();
  var maxV=Math.max(Math.abs(m.total||0),Math.abs(m.vip||0),Math.abs(m.silentVip||0),1);
  var pct=Math.min(100,Math.abs(v)/maxV*100);
  var pctHtml='';
  var dashTab=window.currentDashboardTab||'';
  var isGrandTotal=dashTab==='__DASH_TOTAL__';
  var isTypeTotalTab=dashTab.indexOf('__DASH_TG__:')===0;
  
  if(currentVIPTab!=='total'){
    // Subtype pill (VIP / SILENT VIP): % of group total (m.total)
    var denom=Math.abs(m.total||0);
    if(denom>0){
      var p=Math.round(Math.abs(v)/denom*100);
      pctHtml='<div style="font-size:13px;font-weight:800;color:'+color+';margin-top:2px">'+p+'%</div>';
    }
  } else if(isTypeTotalTab){
    // Type-total "All" tab: % of grand total
    var gt=window._grandMetricTotals;
    if(gt&&gt[id]>0){
      var p=Math.round(Math.abs(v)/gt[id]*100);
      pctHtml='<div style="font-size:13px;font-weight:800;color:'+color+';margin-top:2px">'+p+'%</div>';
    }
  } else if(!isGrandTotal){
    // Individual type tab: % of parent type-group total
    var tgt=window._typeGroupMetricTotals;
    var tgIds=window._typeGroupIds||[];
    if(tgt&&tgt[id]>0&&tgIds.indexOf(dashTab)!==-1){
      var p=Math.round(Math.abs(v)/tgt[id]*100);
      pctHtml='<div style="font-size:13px;font-weight:800;color:'+color+';margin-top:2px">'+p+'%</div>';
    }
  }
  return'<div class="dash-stat" data-metric-id="'+id+'" data-metric-name="'+(m.name||id)+'" data-metric-type="'+mType+'" onclick="openMetricModalFromCard(this)"><div class="dash-stat-icon">'+icon+'</div><div class="dash-stat-val">'+fmt+'</div><div class="dash-stat-name">'+(m.name||id)+'</div>'+pctHtml+'<div class="dash-stat-bar"><div class="dash-stat-bar-fill" style="width:'+pct+'%;background:'+color+'"></div></div></div>';
}

var depIcons=['💰','📥','💵','🏦','📈'];var depColors=['#10b981','#667eea','#059669','#0d9488','#34d399'];
var cashIcons=['💸','📤','🔻','📉','💳'];var cashColors=['#ef4444','#f59e0b','#dc2626','#f97316','#fb923c'];
var di=0,ci=0;

// Collect metrics then sort: sum first, count second
var depRaw=[],cashRaw=[];
Object.keys(sums).forEach(function(id){
  var m=sums[id];if(!m)return;
  var idL=id.toLowerCase();
  if(curSuffix==='lifetime'){
    if(idL.indexOf('lifetime')===-1&&(idL.indexOf('last_')!==-1||idL.indexOf('previous_')!==-1))return;
  }else{
    if(idL.indexOf(curSuffix)===-1)return;
  }
  var nameL=(m.name||'').toLowerCase();
  var order=idL.indexOf('sum')!==-1?0:1;
  if(idL.indexOf('deposit')!==-1||nameL.indexOf('deposit')!==-1){
    depRaw.push({id:id,m:m,order:order});
  }else if(idL.indexOf('cashout')!==-1||nameL.indexOf('cashout')!==-1){
    cashRaw.push({id:id,m:m,order:order});
  }
});
depRaw.sort(function(a,b){return a.order-b.order});
cashRaw.sort(function(a,b){return a.order-b.order});

depRaw.forEach(function(r){
  depCards.push(makeCard(r.id,r.m,depIcons[di%depIcons.length],depColors[di%depColors.length]));di++
});
cashRaw.forEach(function(r){
  cashCards.push(makeCard(r.id,r.m,cashIcons[ci%cashIcons.length],cashColors[ci%cashColors.length]));ci++
});

// Build Inout card for current period only
var depId=getMetricIdForPeriod('deposit_sum',currentPeriod);var cashId=getMetricIdForPeriod('cashout_sum',currentPeriod);
var depM=sums[depId];var cashM=sums[cashId];
if(depM&&cashM){
  var dv=0,cv=0;
  if(currentVIPTab==='total'){dv=depM.total||0;cv=cashM.total||0}else if(currentVIPTab==='vip'){dv=depM.vip||0;cv=cashM.vip||0}else{dv=depM.silentVip||0;cv=cashM.silentVip||0}
  if(currentPeriod!=='lifetime')cv=Math.abs(cv);
  var io=dv-cv;var sign=io>=0?'+':'-';var clr=io>=0?'#10b981':'#ef4444';
  var ioPctHtml='';
  var dashTab2=window.currentDashboardTab||'';
  var isGrandTotal2=dashTab2==='__DASH_TOTAL__';
  var isTypeTotalTab2=dashTab2.indexOf('__DASH_TG__:')===0;
  if(currentVIPTab!=='total'){
    var totalIo=(depM.total||0)-Math.abs(cashM.total||0);
    if(Math.abs(totalIo)>0){
      var ioP=Math.round(Math.abs(io)/Math.abs(totalIo)*100);
      ioPctHtml='<div style="font-size:13px;font-weight:800;color:'+clr+';margin-top:2px">'+ioP+'%</div>';
    }
  } else if(isTypeTotalTab2){
    var gt=window._grandMetricTotals;
    if(gt&&gt[depId]>0&&gt[cashId]>0){
      var grandIo=gt[depId]-gt[cashId];
      if(Math.abs(grandIo)>0){
        var ioP=Math.round(Math.abs(io)/Math.abs(grandIo)*100);
        ioPctHtml='<div style="font-size:13px;font-weight:800;color:'+clr+';margin-top:2px">'+ioP+'%</div>';
      }
    }
  } else if(!isGrandTotal2){
    var tgt=window._typeGroupMetricTotals;
    var tgIds=window._typeGroupIds||[];
    if(tgt&&tgt[depId]>0&&tgt[cashId]>0&&tgIds.indexOf(dashTab2)!==-1){
      var tgIo=tgt[depId]-tgt[cashId];
      if(Math.abs(tgIo)>0){
        var ioP=Math.round(Math.abs(io)/Math.abs(tgIo)*100);
        ioPctHtml='<div style="font-size:13px;font-weight:800;color:'+clr+';margin-top:2px">'+ioP+'%</div>';
      }
    }
  }
  inoutCards.push('<div class="dash-stat" style="cursor:default"><div class="dash-stat-icon">💱</div><div class="dash-stat-val" style="color:'+clr+'">'+sign+'€'+Math.abs(io).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:0})+'</div><div class="dash-stat-name">Inout '+periodLabel+'</div>'+ioPctHtml+'<div class="dash-stat-bar"><div class="dash-stat-bar-fill" style="width:100%;background:'+clr+'"></div></div></div>');
}

