function getManager(tags){
  if(!tags)return'';
  
  // ✅ Use dynamic vipManagerMapping from MANAGER sheet
  if(vipManagerMapping && Object.keys(vipManagerMapping).length > 0) {
    var tagsArray = [];
    if(Array.isArray(tags)) {
      tagsArray = tags;
