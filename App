// ===== DRILL-DOWN MODAL =====
function pmShowDrill(title, rows) {
  var modal = document.getElementById('pmPlayersModal');
  if (!rows || !rows.length) { return; }
  document.getElementById('pmModalTitle').textContent = title + ' (' + rows.length + ')';
  // Aggregate by email
  var byEmail = {};
  rows.forEach(function(r) {
    if (!byEmail[r.email]) {
      // ✅ Get manager from dashboardTagMap tags
      var mgr = '—';
      var emailLc = (r.email || '').toLowerCase();
      if (window.dashboardTagMap && window.dashboardTagMap[emailLc]) {
        var tags = window.dashboardTagMap[emailLc].tags;
        if (tags && typeof getManager === 'function') mgr = getManager(tags) || '—';
      }
      byEmail[r.email] = { email:r.email, type:r.playerType||r.type||'—', manager:mgr, country:r.country||'—', count:0, successCount:0, failedCount:0, byCur:{}, totalAmt:0 };
    }
    byEmail[r.email].count++;
    if (r.success) {
      byEmail[r.email].successCount++;
      // ✅ Only sum successful deposit amounts
      if (!byEmail[r.email].byCur[r.currency]) byEmail[r.email].byCur[r.currency] = 0;
      byEmail[r.email].byCur[r.currency] += r.amount;
      byEmail[r.email].totalAmt += r.amount;
    } else {
      byEmail[r.email].failedCount++;
    }
  });
  window._pmDrillData = Object.values(byEmail);
  window._pmSortCol = 'count'; window._pmSortDir = 'desc';
  window._pmTypeFilter = null;
  
  document.getElementById('pmModalBody').innerHTML = '<div id="pmTypeTabs" style="margin-bottom:12px"></div><div id="pmDrillContent"></div>';
  pmBuildTypeTabs();
  pmRenderDrillTable(window._pmDrillData);
  modal.style.display = 'flex';
}
function pmBuildTypeTabs() {
  var container = document.getElementById('pmTypeTabs');
  if (!container || !window._pmDrillData) return;
  var data = window._pmDrillData;
  var typeMap = {};
  data.forEach(function(p) {
    var t = p.playerType || p.type || '—';
    if (!typeMap[t]) typeMap[t] = 0; typeMap[t]++;
  });
  var typeNames = Object.keys(typeMap).sort();
  if (typeNames.length <= 1) { container.innerHTML = ''; return; }
  
  var h = '<div style="display:flex;gap:0;border-bottom:2px solid #e2e8f0;overflow-x:auto">';
  h += '<button onclick="pmTabClick(\'all\')" class="pm-t" style="padding:10px 18px;border:none;background:transparent;font-weight:700;font-size:13px;cursor:pointer;border-bottom:3px solid #667eea;color:#667eea;white-space:nowrap">All (' + data.length + ')</button>';
  typeNames.forEach(function(t) {
    h += '<button onclick="pmTabClick(\'type:' + t.replace(/'/g,"\\'") + '\')" class="pm-t" data-type="' + t + '" style="padding:10px 18px;border:none;background:transparent;font-weight:700;font-size:13px;cursor:pointer;border-bottom:3px solid transparent;color:#94a3b8;white-space:nowrap">' + t + ' (' + typeMap[t] + ')</button>';
  });
  h += '</div>';
  container.innerHTML = h;
}

function pmTabClick(filter) {
  var tabs = document.querySelectorAll('.pm-t');
  tabs.forEach(function(t) { t.style.borderBottomColor = 'transparent'; t.style.color = '#94a3b8'; });
  
  window._pmTypeFilter = filter === 'all' ? null : filter;
  
  if (filter === 'all') {
    tabs[0].style.borderBottomColor = '#667eea'; tabs[0].style.color = '#667eea';
  } else if (filter.indexOf('type:') === 0) {
    var typeName = filter.substring(5);
    tabs.forEach(function(t) { if (t.getAttribute('data-type') === typeName) { t.style.borderBottomColor = '#667eea'; t.style.color = '#667eea'; } });
  }
  
  var filtered = window._pmDrillData;
  if (window._pmTypeFilter && window._pmTypeFilter.indexOf('type:') === 0) {
    var tv = window._pmTypeFilter.substring(5);
    filtered = filtered.filter(function(p) { return (p.type||'—') === tv; });
  }
  pmRenderDrillTable(filtered);
}

function pmDrillSort(col) {
  if (window._pmSortCol === col) { window._pmSortDir = window._pmSortDir === 'desc' ? 'asc' : 'desc'; }
  else { window._pmSortCol = col; window._pmSortDir = 'desc'; }
  // Re-apply current filter
  var filtered = window._pmDrillData;
  if (window._pmTypeFilter && window._pmTypeFilter.indexOf('type:') === 0) {
    var tv = window._pmTypeFilter.substring(5);
    filtered = filtered.filter(function(p) { return (p.type||'—') === tv; });
  }
