function qcSendPdf(email, month) {
  if (!confirm('Send Quality Report PDF to ' + email + '?')) return;
  showToast('Generating PDF and sending...');
  
  // Generate report HTML
  var html = qcGenerateReportHtml(email, month);
  
  // Get email settings
  var subject = (_qcEmailSettings && _qcEmailSettings.subject) ? _qcEmailSettings.subject : 'Quality Report — {month} {year}';
  var body = (_qcEmailSettings && _qcEmailSettings.body) ? _qcEmailSettings.body : 'Dear {name},\n\nPlease find attached your Quality Report for {month} {year}.\n\nBest regards,\nQA Department';
  
  // If settings not loaded, load them first
  if (!_qcEmailSettings) {
    google.script.run.withSuccessHandler(function(r) {
      if (r && r.success) _qcEmailSettings = r;
      qcDoSendPdf(email, month, html);
    }).getQualityEmailSettings();
  } else {
    qcDoSendPdf(email, month, html);
  }
