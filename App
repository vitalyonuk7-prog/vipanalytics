  var players = window._uniAllPlayers || [];
  
  var typeMap = {};
  players.forEach(function(p) {
    var t = (window._uniMode === 'metric') ? (p.vipType || 'Unknown') : (getPlayerType(p) || 'Unknown');
    if (!typeMap[t]) typeMap[t] = [];
