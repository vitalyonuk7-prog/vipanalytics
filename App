function bsStart() {
  bs.deposit = parseFloat(document.getElementById('bsDeposit').value) || 100;
  bs.bonusPct = parseFloat(document.getElementById('bsBonusPct').value) || 100;
  bs.bet = parseFloat(document.getElementById('bsBet').value) || 1;
  bs.wagerX = parseFloat(document.getElementById('bsWagerX').value) || 35;
  bs.rtp = parseFloat(document.getElementById('bsRtp').value) || 96;
  bs.volatility = document.getElementById('bsVolatility').value || 'medium';
  bs.minMult = parseFloat(document.getElementById('bsMinMult').value) || 0;
  bs.maxMult = parseFloat(document.getElementById('bsMaxMult').value) || 50;
  if (bs.minMult > bs.maxMult) bs.maxMult = bs.minMult + 1;
  bs.realBal = bs.deposit;
  bs.bonusBal = bs.deposit * bs.bonusPct / 100;
  bs.initTotal = bs.realBal + bs.bonusBal;
  bs.wagerReq = bs.bonusBal * bs.wagerX;
  bs.wager = 0;
  bs.spins = 0;
  bs.log = [];
  bs.started = true;
  for (var r = 0; r < 3; r++) for (var c = 0; c < 3; c++) bs.reels[r][c] = Math.floor(Math.random() * BS_SYMBOLS.length);
  bsRender();
}

function bsReset() { bs.started = false; bsRender(); }

function bsChangeBet(delta) {
  bs.bet = Math.max(0.1, Math.round((bs.bet + delta) * 100) / 100);
  bsRender();
}

function bsSpin() {
  if (bs.spinning) return;
  var totalBal = bs.realBal + bs.bonusBal;
  if (totalBal < bs.bet) return;
  
  bs.spinning = true;
  bs.spins++;
  
  // Determine source (Softswiss):
  // 1. If total > initial total → excess is in bonus → bet from bonus first
  // 2. If total <= initial and real > 0 → bet from real
  // 3. If real = 0 → bet from bonus
  var source = 'real';
  var betFromReal = 0, betFromBonus = 0;
  var totalNow = bs.realBal + bs.bonusBal;
  var overflow = totalNow - bs.initTotal;
  
  if (overflow > 0 && bs.bonusBal > 0) {
    // We have overflow above initial — bet from bonus (overflow portion)
    var fromBonus = Math.min(bs.bet, overflow, bs.bonusBal);
    betFromBonus = fromBonus;
    bs.bonusBal -= fromBonus;
    if (fromBonus < bs.bet) {
      betFromReal = bs.bet - fromBonus;
      bs.realBal -= betFromReal;
      source = 'mixed';
    } else {
      source = 'bonus';
    }
  } else if (bs.realBal >= bs.bet) {
    betFromReal = bs.bet;
    bs.realBal -= bs.bet;
    source = 'real';
  } else if (bs.realBal > 0) {
    betFromReal = bs.realBal;
    betFromBonus = bs.bet - bs.realBal;
    bs.realBal = 0;
    bs.bonusBal -= betFromBonus;
    source = 'mixed';
  } else {
    betFromBonus = bs.bet;
    bs.bonusBal -= bs.bet;
    source = 'bonus';
  }
  bs.wager += bs.bet;
  
  // Generate outcome using RTP + volatility
  var winMult = bsGenMult();
  var winAmount = Math.round(bs.bet * winMult * 100) / 100;
  
  // Set reels visually based on outcome
  for (var r = 0; r < 3; r++) for (var c = 0; c < 3; c++) bs.reels[r][c] = Math.floor(Math.random() * BS_SYMBOLS.length);
  if (winMult >= 15) {
    // 3x match for big wins
    var s = Math.floor(Math.random() * BS_SYMBOLS.length);
    bs.reels[1][0] = s; bs.reels[1][1] = s; bs.reels[1][2] = s;
  } else if (winMult >= 2) {
    // 2x match for medium wins
    var s = Math.floor(Math.random() * BS_SYMBOLS.length);
    var pos = Math.random() < 0.5 ? 0 : 1;
    bs.reels[1][pos] = s; bs.reels[1][pos + 1] = s;
  }
  // else: all random = no match (loss or tiny win)
  
  // Softswiss win crediting:
  // Real bet → wins to real (capped at deposit), overflow to bonus
  // Bonus bet → wins to bonus only
  // Mixed bet → proportional, real part capped
  var bonusPart = 0;
  if (winAmount > 0) {
    if (source === 'bonus') {
      // Full bonus bet → all wins to bonus
      bs.bonusBal += winAmount;
      bonusPart = winAmount;
    } else if (source === 'mixed') {
      // Split proportionally
      var realRatio = betFromReal / bs.bet;
      var winToReal = winAmount * realRatio;
      var winToBonus = winAmount - winToReal;
      bs.realBal += winToReal;
      if (bs.realBal > bs.deposit) {
        var ov = bs.realBal - bs.deposit;
        bs.realBal = bs.deposit;
        winToBonus += ov;
      }
      bs.bonusBal += winToBonus;
      bonusPart = winToBonus;
    } else {
      // Full real bet → wins to real, capped at deposit
      bs.realBal += winAmount;
      if (bs.realBal > bs.deposit) {
        var ov = bs.realBal - bs.deposit;
        bs.realBal = bs.deposit;
        bs.bonusBal += ov;
        bonusPart = ov;
      }
    }
  }
  
  // Calculate bonus part of bet (for Softswiss-style display)
  var betBonusPart = betFromBonus;
  
  // Log entry
  var mid = bs.reels[1];
  bs.log.push({
    spin: bs.spins,
    symbols: BS_SYMBOLS[mid[0]] + ' ' + BS_SYMBOLS[mid[1]] + ' ' + BS_SYMBOLS[mid[2]],
    bet: bs.bet,
    win: winAmount,
    mult: winMult,
    source: source === 'mixed' ? 'real+bonus' : source,
    betBonusPart: betBonusPart,
    winBonusPart: bonusPart,
    realAfter: bs.realBal,
    bonusAfter: bs.bonusBal
  });
  
  bs.spinning = false;
  bsRender();
}

// RTP-based multiplier generator
function bsGenMult() {
  var rtp = bs.rtp / 100;
  var r = Math.random();
  
  // Tier tables: [cumProb, multLow, multHigh]
  var tiers = {
    low:       [[0.40,0,0],[0.65,0.2,0.8],[0.82,0.8,1.5],[0.93,1.5,3],[0.98,3,6],[1.0,6,12]],
    medium:    [[0.60,0,0],[0.73,0.3,1.0],[0.84,1.0,2.5],[0.92,2.5,6],[0.97,6,15],[1.0,15,30]],
    high:      [[0.75,0,0],[0.83,0.5,1.5],[0.90,1.5,4],[0.95,4,10],[0.98,10,25],[1.0,25,50]],
    very_high: [[0.85,0,0],[0.90,0.5,2],[0.94,2,5],[0.97,5,15],[0.99,15,50],[1.0,50,100]]
  };
  
  var t = tiers[bs.volatility] || tiers.medium;
  var baseMult = 0;
  for (var i = 0; i < t.length; i++) {
    if (r <= t[i][0]) {
      baseMult = t[i][1] + Math.random() * (t[i][2] - t[i][1]);
      break;
    }
  }
  
  // Calculate base expected value for scaling
  var baseEV = 0; var prevCum = 0;
  for (var i = 0; i < t.length; i++) {
    var prob = t[i][0] - prevCum;
    baseEV += prob * (t[i][1] + t[i][2]) / 2;
    prevCum = t[i][0];
  }
  
  // Scale to target RTP
  var mult = baseEV > 0 ? baseMult * (rtp / baseEV) : 0;
  
  // Clamp to min/max settings
  if (mult > 0 && mult < bs.minMult) mult = bs.minMult;
  mult = Math.min(bs.maxMult, mult);
  
  return Math.round(mult * 100) / 100;
}

