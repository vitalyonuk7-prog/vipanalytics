    window.pmSelectedCurrency = curKeys[0] || '';
  }
  var amtStr = window.pmSelectedCurrency ? pmFmt(window.pmAmtByCur[window.pmSelectedCurrency]) + ' ' + window.pmSelectedCurrency : '0.00';

  // Build currency selector pills
