function renderAdminUsers() {
  if (!adminPanelData) return;
  var users = adminPanelData.users;
  var allRoles = adminPanelData.allRoles.length > 0 ? adminPanelData.allRoles : ['admin', 'user'];
  
  var html = '';
  users.forEach(function(u) {
    html += '<tr>';
    html += '<td style="font-weight:700">' + (u.email || '') + '</td>';
    html += '<td><select onchange="adminUpdateUserUI(' + u._row + ',\'role\',this.value)" style="padding:6px 10px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600">';
    allRoles.forEach(function(r) {
      html += '<option value="' + r + '"' + (r === (u.role || '').toLowerCase() ? ' selected' : '') + '>' + r + '</option>';
    });
    html += '<option value="__new__">+ new role...</option></select></td>';
    html += '<td><input type="text" value="' + (u.manager || '') + '" style="width:100px" onchange="adminUpdateUserUI(' + u._row + ',\'manager\',this.value)"></td>';
    html += '<td><input type="text" value="' + (u.nickname || '') + '" style="width:100px" onchange="adminUpdateUserUI(' + u._row + ',\'nickname\',this.value)"></td>';
    html += '<td style="font-family:monospace;font-weight:700;color:#64748b;letter-spacing:1px">' + (u.password || '—') + ' <button class="admin-btn-sm admin-btn-action" onclick="adminResetPwUI(' + u._row + ',this)" style="margin-left:6px">🔄</button></td>';
    html += '<td style="text-align:center"><button class="admin-btn-sm admin-btn-danger" onclick="adminDeleteUserUI(' + u._row + ',\'' + (u.email || '').replace(/'/g, "\\'") + '\')">🗑️</button></td>';
    html += '</tr>';
  });
  
  document.getElementById('adminUsersBody').innerHTML = html || '<tr><td colspan="6" style="text-align:center;padding:30px;color:#94a3b8">No users</td></tr>';
  
  // Handle "new role" selection
  document.querySelectorAll('#adminUsersBody select').forEach(function(sel) {
    sel.addEventListener('change', function() {
      if (this.value === '__new__') {
        var newRole = prompt('Enter new role name:');
        if (newRole && newRole.trim()) {
          newRole = newRole.trim().toLowerCase();
          if (allRoles.indexOf(newRole) === -1) allRoles.push(newRole);
          adminPanelData.allRoles = allRoles;
          var opt = document.createElement('option');
          opt.value = newRole; opt.textContent = newRole; opt.selected = true;
          this.insertBefore(opt, this.lastElementChild);
          this.dispatchEvent(new Event('change'));
        } else {
          this.value = this.querySelector('[selected]') ? this.querySelector('[selected]').value : allRoles[0];
        }
      }
    });
  });
}

