function adminDeleteUserUI(row, email) {
  // Instant optimistic remove
  var removed = null;
  if (adminPanelData) {
    adminPanelData.users = adminPanelData.users.filter(function(u){
      if (u._row === row) { removed = u; return false; }
      return true;
    });
  }
  renderAdminUsers(); renderRolesMatrix();
  // Show toast with undo
  var undone = false;
  showToast('🗑️ ' + email + ' removed · <b style="cursor:pointer;text-decoration:underline" onclick="adminUndoDelete()">Undo</b>', 4000);
  window._adminDeleteUndo = { row: row, email: email, user: removed };
  // Commit after delay
  setTimeout(function() {
    if (undone || !window._adminDeleteUndo || window._adminDeleteUndo.row !== row) return;
    window._adminDeleteUndo = null;
    google.script.run.withFailureHandler(function(e){ showToast('❌ Delete failed: '+e); }).adminDeleteUser({ row: row });
  }, 4200);
}

function adminUndoDelete() {
  if (!window._adminDeleteUndo) return;
  var u = window._adminDeleteUndo.user;
  if (u && adminPanelData) { adminPanelData.users.push(u); adminPanelData.users.sort(function(a,b){ return a._row-b._row; }); }
  window._adminDeleteUndo = null;
  renderAdminUsers(); renderRolesMatrix();
  showToast('↩️ Undone');
}

// ===== ROLES MATRIX =====
function renderRolesMatrix() {
  if (!adminPanelData) { console.warn('renderRolesMatrix: no data'); return; }
  
  var pages = adminPanelData.pages || [];
  var roleNames = adminPanelData.allRoles || [];
  var rolePerms = adminPanelData.rolePermissions || {};
  
  var wrap = document.getElementById('rolesCardsWrap');
  var html = '';
  
  roleNames.forEach(function(roleName) {
    var perms = rolePerms[roleName] || {};
    var isAdmin = (roleName === 'admin');
    var badgeClass = isAdmin ? 'admin' : (roleName === 'user' ? 'user' : 'other');
    var icon = isAdmin ? '👑' : '👤';
    
    html += '<div class="rm-card">';
    html += '<div class="rm-card-header">';
    html += '<div class="rm-role-badge ' + badgeClass + '">' + icon + ' ' + roleName + '</div>';
    
    if (!isAdmin) {
      html += '<div class="rm-header-actions">';
      html += '<button class="rm-header-btn" onclick="rmToggleAll(\'' + roleName + '\',true)">✅ All</button>';
      html += '<button class="rm-header-btn" onclick="rmToggleAll(\'' + roleName + '\',false)">⬜ None</button>';
      if (roleName !== 'user') {
        html += '<button class="rm-header-btn" style="color:#ef4444;border-color:#fecaca" onclick="deleteRoleUI(\'' + roleName + '\')">🗑️</button>';
      }
      html += '</div>';
    }
    html += '</div>';
    
    if (isAdmin) {
      html += '<div class="rm-admin-note">🔓 Admin has full access to all pages</div>';
    }
    
    html += '<div class="rm-card-body">';
    pages.forEach(function(p) {
      var checked = (perms[p.id] !== false) ? ' checked' : '';
      var disabled = isAdmin ? ' disabled' : '';
      var itemClass = isAdmin ? ' disabled' : '';
      
      html += '<label class="rm-perm-item' + itemClass + '">';
      html += '<div class="rm-perm-icon">' + p.icon + '</div>';
      html += '<div class="rm-perm-name">' + p.name + '</div>';
      html += '<div class="rm-toggle">';
      html += '<input type="checkbox" class="roles-check" data-role="' + roleName + '" data-page="' + p.id + '"' + checked + disabled + '>';
      html += '<div class="rm-toggle-track"></div>';
      html += '<div class="rm-toggle-thumb"></div>';
      html += '</div>';
      html += '</label>';
    });
    html += '</div></div>';
  });
  
  wrap.innerHTML = html;
}

function rmToggleAll(roleName, state) {
  document.querySelectorAll('.roles-check[data-role="' + roleName + '"]:not(:disabled)').forEach(function(cb) {
    cb.checked = state;
  });
}

function addNewRoleUI() {
  document.getElementById('newRoleNameInput').value = '';
