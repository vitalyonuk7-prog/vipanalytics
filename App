}

function getMonday(d) {
  var dt = new Date(d);
  var day = dt.getDay();
  var diff = day === 0 ? -6 : 1 - day;
  dt.setDate(dt.getDate() + diff);
  return dt;
}

function fmtDate(d) {
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}

function renderClosureDateCharts(closureDates, reopenDates) {
  clDateState.closure.allDates = closureDates;
  clDateState.reopen.allDates = reopenDates;
  clDateState.closure.offset = 0;
  clDateState.reopen.offset = 0;
  renderSingleDateChart('closure');
  renderSingleDateChart('reopen');
}

function renderSingleDateChart(type) {
  var st = clDateState[type];
  var allDates = st.allDates || {};
  var canvasId = type === 'closure' ? 'closureDateChart' : 'closureReopenChart';
  var labelId = type === 'closure' ? 'clDateClosureLabel' : 'clDateReopenLabel';
  var chartVar = type === 'closure' ? 'closureChartDate' : 'closureChartReopen';
  var colors = type === 'closure' ? ['#667eea','#764ba2','#4facfe','#43e97b','#f093fb','#fa709a','#30cfd0'] : ['#10b981','#059669','#34d399','#6ee7b7','#a7f3d0','#047857','#065f46'];
  
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  
  // Destroy old chart
  if (type === 'closure' && closureChartDate) { closureChartDate.destroy(); closureChartDate = null; }
  if (type === 'reopen' && closureChartReopen) { closureChartReopen.destroy(); closureChartReopen = null; }
  
  var labels = [], data = [], rangeLabel = '';
  
  if (st.mode === 'week') {
    var now = new Date();
    var monday = getMonday(now);
    monday.setDate(monday.getDate() + st.offset * 7);
    var sunday = new Date(monday);
    sunday.setDate(sunday.getDate() + 6);
    
    rangeLabel = String(monday.getDate()).padStart(2,'0') + '.' + String(monday.getMonth()+1).padStart(2,'0') + ' — ' + String(sunday.getDate()).padStart(2,'0') + '.' + String(sunday.getMonth()+1).padStart(2,'0') + '.' + sunday.getFullYear();
    
    var dayNames = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    for (var i = 0; i < 7; i++) {
      var d = new Date(monday);
      d.setDate(d.getDate() + i);
      var key = fmtDate(d);
      labels.push(dayNames[i] + ' ' + String(d.getDate()).padStart(2,'0') + '.' + String(d.getMonth()+1).padStart(2,'0'));
      data.push(allDates[key] || 0);
    }
  } else if (st.mode === 'month') {
    var now2 = new Date();
    var targetMonth = now2.getMonth() + st.offset;
    var targetYear = now2.getFullYear();
    while (targetMonth < 0) { targetMonth += 12; targetYear--; }
    while (targetMonth > 11) { targetMonth -= 12; targetYear++; }
    
    var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    rangeLabel = monthNames[targetMonth] + ' ' + targetYear;
    
    var daysInMonth = new Date(targetYear, targetMonth + 1, 0).getDate();
    for (var i = 1; i <= daysInMonth; i++) {
      var key = targetYear + '-' + String(targetMonth+1).padStart(2,'0') + '-' + String(i).padStart(2,'0');
      labels.push(String(i));
      data.push(allDates[key] || 0);
    }
  } else if (st.mode === 'weeks') {
    // Compare weeks: aggregate all dates into Mon-Sun weeks
    rangeLabel = 'Comparison by Weeks';
    var weekBuckets = {};
    var allKeys = Object.keys(allDates).sort();
    allKeys.forEach(function(dateStr) {
      var d = new Date(dateStr + 'T00:00:00');
      var mon = getMonday(d);
      var sun = new Date(mon); sun.setDate(sun.getDate() + 6);
      var wKey = fmtDate(mon);
      var wLabel = String(mon.getDate()).padStart(2,'0') + '.' + String(mon.getMonth()+1).padStart(2,'0') + '–' + String(sun.getDate()).padStart(2,'0') + '.' + String(sun.getMonth()+1).padStart(2,'0');
      if (!weekBuckets[wKey]) weekBuckets[wKey] = { label: wLabel, count: 0 };
      weekBuckets[wKey].count += allDates[dateStr];
    });
    var sortedWeeks = Object.keys(weekBuckets).sort();
    sortedWeeks.forEach(function(wk) {
      labels.push(weekBuckets[wk].label);
      data.push(weekBuckets[wk].count);
    });
  } else if (st.mode === 'months') {
    // Compare months: aggregate all dates into calendar months
    rangeLabel = 'Comparison by Months';
    var monthBuckets = {};
    var shortMonths = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    Object.keys(allDates).forEach(function(dateStr) {
      var parts = dateStr.split('-');
      var mKey = parts[0] + '-' + parts[1];
      var mIdx = parseInt(parts[1], 10) - 1;
      var mLabel = shortMonths[mIdx] + ' ' + parts[0];
      if (!monthBuckets[mKey]) monthBuckets[mKey] = { label: mLabel, count: 0 };
      monthBuckets[mKey].count += allDates[dateStr];
    });
    var sortedMonths = Object.keys(monthBuckets).sort();
    sortedMonths.forEach(function(mk) {
      labels.push(monthBuckets[mk].label);
      data.push(monthBuckets[mk].count);
    });
  }
  
  var labelEl = document.getElementById(labelId);
  if (labelEl) labelEl.textContent = rangeLabel;
  
  var hasData = data.some(function(v) { return v > 0; });
  if (!hasData) {
    canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
    if (labelEl) labelEl.textContent = rangeLabel + '  (no data)';
    return;
  }
  
  var maxVal = Math.max.apply(null, data);
  
  var chart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        data: data,
        backgroundColor: labels.map(function(_, i) { return colors[i % colors.length]; }),
        borderRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      layout: { padding: { top: 20 } },
      plugins: {
        legend: { display: false },
        datalabels: {
          anchor: 'end',
          align: 'top',
          font: { weight: 'bold', size: 10 },
          color: '#1e293b',
          formatter: function(v) { return v > 0 ? v : ''; }
        }
      },
      scales: {
        y: { beginAtZero: true, max: maxVal + Math.ceil(maxVal * 0.3) + 1, ticks: { stepSize: 1 }, grid: { color: '#f1f5f9' } },
        x: { grid: { display: false }, ticks: { font: { size: (st.mode === 'month' || st.mode === 'weeks') ? 9 : st.mode === 'months' ? 10 : 11 }, maxRotation: st.mode === 'weeks' ? 45 : 0 } }
      }
    }
  });
  
  if (type === 'closure') closureChartDate = chart;
  else closureChartReopen = chart;
}

