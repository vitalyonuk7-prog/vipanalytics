function injectCalculatedKpiMetrics() {
  var depPatterns = ['total deposit amount', 'deposit amount', 'deposits amount', 'total deposits', 'deposit sum', 'deposits sum', 'total deposit'];
  var coPatterns = ['cashouts sum', 'cashout sum', 'cashouts amount', 'cashout amount', 'total cashouts', 'total cashout', 'cashout'];
  
  function findMetric(metrics, patterns) {
    var metricsLower = {};
    metrics.forEach(function(m) { metricsLower[m.toLowerCase().trim()] = m; });
    for (var i = 0; i < patterns.length; i++) {
      if (metricsLower[patterns[i]]) return metricsLower[patterns[i]];
    }
    // Fuzzy: find first metric containing keyword
    for (var j = 0; j < metrics.length; j++) {
      var ml = metrics[j].toLowerCase();
      if (ml.indexOf('deposit') !== -1 && (ml.indexOf('amount') !== -1 || ml.indexOf('sum') !== -1 || ml.indexOf('total') !== -1) && ml.indexOf('count') === -1 && ml.indexOf('#') === -1 && ml.indexOf('number') === -1) return metrics[j];
    }
    return null;
  }
  function findCashout(metrics) {
    for (var j = 0; j < metrics.length; j++) {
      var ml = metrics[j].toLowerCase();
      if (ml.indexOf('cashout') !== -1 && (ml.indexOf('amount') !== -1 || ml.indexOf('sum') !== -1 || ml.indexOf('total') !== -1)) return metrics[j];
    }
    for (var j = 0; j < metrics.length; j++) {
      if (metrics[j].toLowerCase().indexOf('cashout') !== -1) return metrics[j];
    }
    return null;
  }
  
  Object.keys(kpiDataByTab).forEach(function(tab) {
    var tabData = kpiDataByTab[tab];
    var depKey = findMetric(tabData.metrics, depPatterns);
    var coKey = findCashout(tabData.metrics);
    
    if (!depKey || !coKey) {
      console.log('KPI calc: skipping tab "' + tab + '" — deposit:"' + depKey + '" cashout:"' + coKey + '"');
      return;
    }
    console.log('KPI calc: tab "' + tab + '" deposit="' + depKey + '" cashout="' + coKey + '"');
    
    var inoutName = '📊 Inout (€)';
    var outRateName = '📊 Out Rate (%)';
    
    // Add to metrics list
    if (tabData.metrics.indexOf(inoutName) === -1) tabData.metrics.push(inoutName);
    if (tabData.metrics.indexOf(outRateName) === -1) tabData.metrics.push(outRateName);
    
    // Calculate for each period
    tabData.months.forEach(function(m) {
      var dep = m.monthly[depKey] || m.sumWeeks[depKey] || 0;
      var co = m.monthly[coKey] || m.sumWeeks[coKey] || 0;
      m.monthly[inoutName] = dep - co;
      m.sumWeeks[inoutName] = dep - co;
      m.monthly[outRateName] = dep > 0 ? (co / dep) * 100 : 0;
      m.sumWeeks[outRateName] = dep > 0 ? (co / dep) * 100 : 0;
      
      m.weeks.forEach(function(w) {
        var wDep = w.weekly[depKey] || 0;
        var wCo = w.weekly[coKey] || 0;
        w.weekly[inoutName] = wDep - wCo;
        w.weekly[outRateName] = wDep > 0 ? (wCo / wDep) * 100 : 0;
      });
    });
    
    // Mark nonZero
    if (tabData.nonZero) {
      tabData.nonZero[inoutName] = true;
      tabData.nonZero[outRateName] = true;
    }
  });
  
  // Set format hints
  metricFormats['📊 Inout (€)'] = 'eur';
  metricFormats['📊 Out Rate (%)'] = '%';
  metricFormats['📊 Bonus Rate/Dep (%)'] = '%';
  
  // Inject Bonus Rate/Dep (%) = Bonuses CS / Total deposit amount × 100
  Object.keys(kpiDataByTab).forEach(function(tab) {
    var tabData = kpiDataByTab[tab];
    var metrics = tabData.metrics;
    var depKey = findMetric(metrics, depPatterns);
    
    // Find Bonuses CS metric
    var bonusKey = null;
    for (var bi = 0; bi < metrics.length; bi++) {
      var ml = metrics[bi].toLowerCase();
      if (ml.indexOf('bonus') !== -1 && (ml.indexOf('cs') !== -1 || ml.indexOf('sum') !== -1 || ml.indexOf('amount') !== -1 || ml.indexOf('total') !== -1)) {
        bonusKey = metrics[bi]; break;
      }
    }
    if (!bonusKey) {
      for (var bi2 = 0; bi2 < metrics.length; bi2++) {
        if (metrics[bi2].toLowerCase().indexOf('bonus') !== -1) { bonusKey = metrics[bi2]; break; }
      }
    }
    
    if (!depKey || !bonusKey) return;
    
    var brName = '📊 Bonus Rate/Dep (%)';
    if (metrics.indexOf(brName) === -1) metrics.push(brName);
    
    tabData.months.forEach(function(m) {
      var dep = m.monthly[depKey] || m.sumWeeks[depKey] || 0;
      var bon = m.monthly[bonusKey] || m.sumWeeks[bonusKey] || 0;
      m.monthly[brName] = dep > 0 ? (bon / dep) * 100 : 0;
      m.sumWeeks[brName] = dep > 0 ? (bon / dep) * 100 : 0;
      
      m.weeks.forEach(function(w) {
        var wDep = w.weekly[depKey] || 0;
        var wBon = w.weekly[bonusKey] || 0;
        w.weekly[brName] = wDep > 0 ? (wBon / wDep) * 100 : 0;
      });
    });
    
    if (tabData.nonZero) tabData.nonZero[brName] = true;
    console.log('KPI calc: tab "' + tab + '" Bonus Rate/Dep: bonus="' + bonusKey + '" dep="' + depKey + '"');
  });
}

