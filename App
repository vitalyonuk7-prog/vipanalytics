function toggleBonusPeriodFilter(period) {
  if(period === 'ALL'){
    if(!bonusSelectedPeriods){
      // Was all selected → deselect all
      bonusSelectedPeriods = [];
    } else {
      // Not all selected → select all
      bonusSelectedPeriods = null;
    }
  } else {
    if(!bonusSelectedPeriods){
      // Was all - now deselect one: select all except clicked
      var data = bonusRawData[bonusMode];
      if(!data||!data.rows) return;
      var all = [];
      data.rows.forEach(function(r){ var p=formatBonusPeriod(r.period); if(all.indexOf(p)===-1)all.push(p); });
      bonusSelectedPeriods = all.filter(function(p){return p!==period;});
    } else {
      var idx = bonusSelectedPeriods.indexOf(period);
      if(idx===-1) bonusSelectedPeriods.push(period);
      else bonusSelectedPeriods.splice(idx,1);
    }
  }
  renderBonusReport();
}

function renderBonusBarChart(periodGroups, periodOrder) {
  var canvas = document.getElementById('bonusBarChart');
  if(!canvas || typeof Chart==='undefined') return;
  var numKeys = ['countIssued','totalInEUR','countCancelled','countWagerDone','depositEUR','betsEUR','countActive'];
  var key = bonusChartMetric;
  window._bonusBarPeriodGroups = periodGroups;
  window._bonusBarPeriodOrder = periodOrder;
  
  var labels = [], values = [], colors = [];
  var gradients = [['#667eea','#764ba2'],['#f093fb','#f5576c'],['#4facfe','#00f2fe'],['#43e97b','#38f9d7'],['#fa709a','#fee140'],['#30cfd0','#330867'],['#a8edea','#fed6e3'],['#ff9a9e','#fecfef'],['#ffecd2','#fcb69f'],['#ff6e7f','#bfe9ff'],['#e0c3fc','#8ec5fc']];
  var ctx = canvas.getContext('2d');
  
  periodOrder.forEach(function(p, i){
    var group = periodGroups[p];
    if(!group) return;
    var tot = 0;
    group.forEach(function(r){ tot += r[key]||0; });
    labels.push(p);
    values.push(tot);
    var grad = ctx.createLinearGradient(0,0,0,300);
    var pair = gradients[i % gradients.length];
    grad.addColorStop(0, pair[0]);
    grad.addColorStop(1, pair[1]);
    colors.push(grad);
  });
  
  if(bonusBarChart) bonusBarChart.destroy();
  var colLabel = BONUS_ALL_COLS.find(function(c){return c.key===key;});
  bonusBarChart = new Chart(ctx, {
    type:'bar',
    data:{labels:labels,datasets:[{label:(colLabel?colLabel.label:key),data:values,backgroundColor:colors,borderRadius:8,barPercentage:0.6}]},
    options:{responsive:true,maintainAspectRatio:false,layout:{padding:{top:30}},
      onClick:function(e,els){ if(els.length>0){ var idx=els[0].index; openBonusBarDetailModal(labels[idx]); } },
      plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',color:'#1e293b',font:{weight:'bold',size:11},formatter:function(v){var isCount=bonusChartMetric.indexOf('count')===0;return isCount?v.toLocaleString():'€'+v.toLocaleString('en',{maximumFractionDigits:0});}}},
      scales:{y:{beginAtZero:true,grace:'10%',grid:{color:'#f1f5f9'},ticks:{font:{weight:'600'},color:'#64748b',callback:function(v){return numKeys.indexOf(key)!==-1&&key.indexOf('count')===0?v.toLocaleString():'€'+v.toLocaleString();}}},
        x:{grid:{display:false},ticks:{font:{weight:'600',size:10},color:'#64748b'}}}
    }
  });
}

var _barDetailSort = { key: null, dir: 'desc' };

