  h += '<div style="background:#fff;border:1.5px solid #e2e8f0;border-radius:14px;padding:16px;margin:12px 0"><canvas id="qaFDChart" height="200" style="max-height:200px;width:100%"></canvas></div>';

  // Who makes it
  if (!filterMgr) {
    var mgrSorted = Object.keys(mgrData).map(function(k) { return { name: k, count: mgrData[k] }; }).sort(function(a, b) { return b.count - a.count; });
    if (mgrSorted.length) {
      h += '<div style="font-size:12px;font-weight:800;color:#1e293b;margin:12px 0 8px">\uD83D\uDC64 Who makes this failure</div>';
      h += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
      mgrSorted.forEach(function(m) {
        h += '<div style="padding:6px 12px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:8px;font-size:12px"><span style="font-weight:700;color:#1e293b">' + m.name + '</span> <span style="color:#667eea;font-weight:800">' + m.count + 'x</span></div>';
      });
      h += '</div>';
    }
  }

  // Total
  var total = 0; months.forEach(function(m) { total += monthData[m] || 0; });
