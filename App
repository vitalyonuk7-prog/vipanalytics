function convertTimezone() {
  var timeVal = document.getElementById('homeTzConvTime').value;
  var container = document.getElementById('homeTzConvResults');
  if (!timeVal) {
    container.innerHTML = '<div style="text-align:center;color:#94a3b8;font-size:12px;padding:12px">Select time above</div>';
    return;
  }
  var fromTz = document.getElementById('homeTzConvFrom').value;
  var parts = timeVal.split(':');
  var inputH = parseInt(parts[0]), inputM = parseInt(parts[1] || 0);

  // Build a reference date in the source timezone
  // Use today's date to respect DST
  var today = new Date();
  var refStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0') + 'T' + String(inputH).padStart(2,'0') + ':' + String(inputM).padStart(2,'0') + ':00';

  // Get UTC offset of source timezone for today
  var probe = new Date(refStr + 'Z');
  // Find the offset: format the probe as if it's in fromTz, parse back
  var srcFormatted = probe.toLocaleString('en-US', { timeZone: fromTz, year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
  // Parse srcFormatted to get the "local" time that corresponds to probe (UTC)
  // We need the inverse: given local time in fromTz, find UTC
  // Iterative approach: guess UTC, check result
  var guessUTC = new Date(refStr + 'Z');
  for (var iter = 0; iter < 3; iter++) {
    var localInSrc = new Date(guessUTC.toLocaleString('en-US', { timeZone: fromTz }));
    var targetLocal = new Date(refStr);
    var diff = targetLocal - localInSrc;
    guessUTC = new Date(guessUTC.getTime() + diff);
  }
  var utcTime = guessUTC;

  // Get source day for comparison
  var srcDay = new Date(utcTime.toLocaleString('en-US', { timeZone: fromTz })).getDate();

  var html = '';
  tzConvZones.forEach(function(z) {
    var isSource = z.tz === fromTz;
    var converted = utcTime.toLocaleString('en-GB', { timeZone: z.tz, hour: '2-digit', minute: '2-digit', hour12: false });
    var targetDay = new Date(utcTime.toLocaleString('en-US', { timeZone: z.tz })).getDate();
    var dayDiff = targetDay - srcDay;
    var dayLabel = '';
    if (dayDiff > 0) dayLabel = '<span class="home-tz-conv-day">+1d</span>';
    else if (dayDiff < 0) dayLabel = '<span class="home-tz-conv-day">-1d</span>';

    // Calculate hour offset from source
    var srcDateObj = new Date(utcTime.toLocaleString('en-US', { timeZone: fromTz }));
    var tgtDateObj = new Date(utcTime.toLocaleString('en-US', { timeZone: z.tz }));
    var offsetH = Math.round((tgtDateObj - srcDateObj) / 3600000);
    var offsetStr = '';
    if (!isSource) {
      offsetStr = '<span class="home-tz-conv-diff">' + (offsetH >= 0 ? '+' : '') + offsetH + 'h</span>';
    }

    html += '<div class="home-tz-conv-row' + (isSource ? ' tz-source' : '') + '">';
    html += '<span class="home-tz-conv-zone">' + z.flag + ' ' + z.label + '</span>';
    html += '<span class="home-tz-conv-val">' + converted + offsetStr + dayLabel + '</span>';
    html += '</div>';
  });
  container.innerHTML = html;
}

