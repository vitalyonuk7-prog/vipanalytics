    <div class="sidebar-subtitle">Filter conversion data</div>
    <button class="close-sidebar-btn" onclick="closeDv2FilterSidebar()">×</button>
  </div>
  
  <div class="sidebar-body">
    <div class="sidebar-filter-group">
      <div class="sidebar-filter-label"><span>📋</span><span>Type</span></div>
      <input type="text" class="sidebar-filter-search" placeholder="🔍 Search types..." id="dv2TypeSearch">
      <div class="sidebar-filter-list" id="dv2TypeFilters"></div>
    </div>
    <div class="sidebar-filter-group">
      <div class="sidebar-filter-label"><span>👤</span><span>Manager</span></div>
      <input type="text" class="sidebar-filter-search" placeholder="🔍 Search managers..." id="dv2ManagerSearch">
      <div class="sidebar-filter-list" id="dv2ManagerFilters"></div>
    </div>
    <div class="sidebar-filter-group">
      <div class="sidebar-filter-label"><span>🎯</span><span>Traffic Type</span></div>
      <input type="text" class="sidebar-filter-search" placeholder="🔍 Search traffic..." id="dv2TrafficSearch">
      <div class="sidebar-filter-list" id="dv2TrafficFilters"></div>
    </div>
    <div class="sidebar-filter-group">
      <div class="sidebar-filter-label"><span>🌍</span><span>Country</span></div>
      <input type="text" class="sidebar-filter-search" placeholder="🔍 Search countries..." id="dv2CountrySearch">
      <div class="sidebar-filter-list" id="dv2CountryFilters"></div>
    </div>
  </div>
  
  <div class="sidebar-footer">
    <button class="sidebar-btn-apply" onclick="applyDv2Filters()">✅ Apply Filters</button>
    <button class="sidebar-btn-clear" onclick="clearDv2Filters()">🔄 Clear All</button>
  </div>
</div>

