  kpi += pmKpiCard('❌', 'Failed Deposits', fC.toLocaleString(), '#ef4444', 'rgba(239,68,68,0.08)', function() { pmShowDrill('Failed Deposits', filtered.filter(function(r){return !r.success;})); });
  kpi += pmKpiCard('📊', 'Acceptance Rate', rate + '%', '#667eea', 'rgba(102,126,234,0.08)');
  kpi += '<div onclick="pmShowDrill(\'Success Amount — ' + window.pmSelectedCurrency + '\', getFilteredPayments().filter(function(r){return r.success && r.currency===\'' + window.pmSelectedCurrency + '\';}))" style="background:rgba(245,158,11,0.08);border:1px solid #f59e0b22;border-radius:16px;padding:20px;cursor:pointer;transition:all 0.2s" onmouseover="this.style.transform=\'translateY(-2px)\';this.style.boxShadow=\'0 4px 16px rgba(245,158,11,0.2)\'" onmouseout="this.style.transform=\'\';this.style.boxShadow=\'\'">' +
    '<div style="display:flex;align-items:center;gap:12px"><div style="width:44px;height:44px;background:#f59e0b18;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">💰</div>' +
    '<div style="min-width:0"><div style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:2px">Success Amount</div>' +
    '<div style="font-size:22px;font-weight:900;color:#f59e0b">' + amtStr + '</div></div></div>' +
    '<div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:0">' + curPills + '</div></div>';

  document.getElementById('pmKpiCards').innerHTML = kpi;

  buildPmWeeks(filtered);
  renderPmWeeklyChart();
  renderPmAnalyticsChart(filtered);
  renderPmBreakdown(filtered);
  renderPmBonusAnalytics(filtered);
}

