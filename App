// ---- CARD COMPLETION ----
var _qaCompletionData = null;
var _qaCompletionLoading = false;

function qaRenderCardCompletion(c) {
  var h = '<div style="font-size:16px;font-weight:800;color:#1e293b;margin-bottom:6px">\uD83D\uDCCA Card Completion</div>';
  h += '<div style="font-size:12px;color:#94a3b8;margin-bottom:16px">Player profile fill rate per manager</div>';

  if (!_qaCompletionData && !_qaCompletionLoading) {
    _qaCompletionLoading = true;
    c.innerHTML = h + '<div style="text-align:center;padding:40px;color:#94a3b8">\u23F3 Loading...</div>';
    google.script.run.withSuccessHandler(function(r) {
      _qaCompletionLoading = false;
      _qaCompletionData = (r && r.success) ? r.managers : {};
      window._qaCompDebug = r ? r.debug : '';
      qaRenderCardCompletion(c);
    }).withFailureHandler(function(e) { _qaCompletionLoading = false; c.innerHTML = h + '<div style="color:#ef4444;padding:20px">Error: ' + e + '</div>'; }).getProfilingCompletionByManager();
    return;
  }
  if (_qaCompletionLoading) return;

  var data = _qaCompletionData || {};
  var entries = [];
  var usedDataKeys = {};

  // Match ACCESS users to PROFILING managers
  qaAllUsers.forEach(function(u) {
    var mgrName = (u.manager || '').toLowerCase();
    if (!mgrName) return;
    // Find matching key in data
    var matchedKey = null;
    Object.keys(data).forEach(function(key) {
      if (matchedKey) return;
      if (key === mgrName) matchedKey = key;
      else if (data[key].name && data[key].name.toLowerCase() === mgrName) matchedKey = key;
    });
    if (matchedKey && !usedDataKeys[matchedKey]) {
      var d = data[matchedKey];
      var team = '-';
      qaTeams.forEach(function(t) { qaTeamMembers(t).forEach(function(m) { if (m.email === u.email) team = t.name; }); });
      entries.push({ user: u, team: team, data: d, pct: d.total > 0 ? Math.round(d.filled / d.total * 100) : 0, pctOld: d.totalOld > 0 ? Math.round(d.filledOld / d.totalOld * 100) : null });
      usedDataKeys[matchedKey] = true;
    }
  });

  // Also try matching by nickname
  qaAllUsers.forEach(function(u) {
    var nick = (u.nickname || '').toLowerCase();
    if (!nick) return;
    Object.keys(data).forEach(function(key) {
      if (usedDataKeys[key]) return;
      if (key === nick || (data[key].name && data[key].name.toLowerCase() === nick)) {
        var d = data[key];
        var team = '-';
        qaTeams.forEach(function(t) { qaTeamMembers(t).forEach(function(m) { if (m.email === u.email) team = t.name; }); });
        entries.push({ user: u, team: team, data: d, pct: d.total > 0 ? Math.round(d.filled / d.total * 100) : 0, pctOld: d.totalOld > 0 ? Math.round(d.filledOld / d.totalOld * 100) : null });
        usedDataKeys[key] = true;
      }
    });
  });

  // Show any remaining unmatched PROFILING managers
  Object.keys(data).forEach(function(key) {
    if (usedDataKeys[key]) return;
    var d = data[key];
