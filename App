// ---- PERIOD HELPERS ----
var qaChartPeriod = 'lifetime'; // 'YYYY-MM' | 'YYYY-Q1' | 'YYYY' | 'lifetime'

function qaGetMonthsForPeriod(period) {
  var all = qaAllMonths();
  if (!period || period === 'lifetime') return all;
  if (period.indexOf('-Q') !== -1) {
    var parts = period.split('-Q');
    var y = parts[0]; var q = parseInt(parts[1]);
    var qMonths = { 1: ['01','02','03'], 2: ['04','05','06'], 3: ['07','08','09'], 4: ['10','11','12'] };
    var ms = (qMonths[q] || []).map(function(m) { return y + '-' + m; });
    return all.filter(function(m) { return ms.indexOf(m) !== -1; });
  }
  if (period.length === 4) return all.filter(function(m) { return m.indexOf(period) === 0; });
  return all.filter(function(m) { return m === period; });
}

function qaGetPeriodOptions() {
  var months = qaAllMonths();
  var opts = [];
  var years = {}; var quarters = {};
  months.forEach(function(m) {
    opts.push({ value: m, label: qaFmtMonth(m) });
    var y = m.split('-')[0]; var mo = parseInt(m.split('-')[1]);
    years[y] = true;
    var q = Math.ceil(mo / 3);
    quarters[y + '-Q' + q] = true;
  });
  var result = [];
  months.forEach(function(m) { result.push({ value: m, label: qaFmtMonth(m), type: 'month' }); });
  Object.keys(quarters).sort().forEach(function(q) { result.push({ value: q, label: q, type: 'quarter' }); });
  Object.keys(years).sort().forEach(function(y) { result.push({ value: y, label: y, type: 'year' }); });
  result.push({ value: 'lifetime', label: 'Lifetime', type: 'lifetime' });
  return result;
}

function qaRenderPeriodSelector(containerId) {
  var opts = qaGetPeriodOptions();
  var h = '<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:14px">';
  opts.forEach(function(o) {
    var active = qaChartPeriod === o.value;
    var bg = o.type === 'month' ? '#667eea' : o.type === 'quarter' ? '#8b5cf6' : o.type === 'year' ? '#f59e0b' : '#10b981';
    if (active) {
      h += '<button data-period="' + o.value + '" class="qa-period-btn" style="padding:5px 12px;border:none;background:' + bg + ';color:#fff;font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">' + o.label + '</button>';
    } else {
      h += '<button data-period="' + o.value + '" class="qa-period-btn" style="padding:5px 12px;border:1.5px solid #e2e8f0;background:#fff;color:#64748b;font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">' + o.label + '</button>';
    }
  });
  h += '</div>';
  return h;
}

function qaAttachPeriodClicks(container, callback) {
  container.querySelectorAll('.qa-period-btn').forEach(function(b) {
    b.onclick = function() { qaChartPeriod = this.dataset.period; callback(); };
  });
}

function qaCalcAvgForPeriod(email, period) {
  var months = qaGetMonthsForPeriod(period);
  var scores = [];
  months.forEach(function(m) {
    var r = qaResults.find(function(x) { return x.manager === email && x.month === m; });
    if (r) scores.push(parseFloat(r.score) || 0);
  });
  return scores.length ? scores.reduce(function(a, b) { return a + b; }, 0) / scores.length : null;
}

