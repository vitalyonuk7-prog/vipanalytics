  var typeNames = Object.keys(typeMap).sort();
  if (typeNames.length <= 1) { container.innerHTML = ''; return; }
  
  var h = '<div style="display:flex;gap:0;border-bottom:2px solid #e2e8f0;overflow-x:auto">';
