// REAL-TIME POLLING ENGINE
// =============================================
var _rtPollTimer   = null;
var _rtLastSummary = {};
var _rtPollActive  = false;
var _rtPollInterval = 6000; // 6 seconds

function rtStartPolling() {
  if (_rtPollTimer) return; // already running
  _rtPollActive = true;
  _rtDoPoll();
}

function rtStopPolling() {
  _rtPollActive = false;
  if (_rtPollTimer) { clearTimeout(_rtPollTimer); _rtPollTimer = null; }
}

function rtDoPoll() {
  if (!_rtPollActive || !window._userEmail) return;
  google.script.run
    .withSuccessHandler(function(r) {
      if (r && r.success) rtHandleChanges(r.summary);
      _rtPollTimer = setTimeout(rtDoPoll, _rtPollInterval);
    })
    .withFailureHandler(function() {
      _rtPollTimer = setTimeout(rtDoPoll, _rtPollInterval * 2);
    })
    .getChangeSummary();
}
// alias for internal use
function _rtDoPoll() { rtDoPoll(); }

function rtHandleChanges(summary) {
  var changed = [];

  // Check onboarding assignments
  if (_rtLastSummary.ob_asgn_hash !== undefined &&
      (summary.ob_asgn_hash !== _rtLastSummary.ob_asgn_hash ||
       summary.ob_asgn_len  !== _rtLastSummary.ob_asgn_len)) {
    changed.push('ob_asgn');
  }

  // Check onboarding plans
  if (_rtLastSummary.ob_plans_len !== undefined &&
      summary.ob_plans_len !== _rtLastSummary.ob_plans_len) {
    changed.push('ob_plans');
  }

  // Check QA
  if (_rtLastSummary.qa_rows !== undefined &&
      summary.qa_rows !== _rtLastSummary.qa_rows) {
    changed.push('qa');
  }

  // Check Timetable
  if (_rtLastSummary.tt_rows !== undefined &&
      summary.tt_rows !== _rtLastSummary.tt_rows) {
    changed.push('tt');
  }

  // Remember last
  _rtLastSummary = summary;

  if (!changed.length) return;

  // Apply changes
  if (changed.indexOf('ob_asgn') !== -1) {
    google.script.run
      .withSuccessHandler(function(r) {
        if (r && r.assignments) {
          obAssignments = r.assignments;
          rtRefreshObView();
        }
      })
      .withFailureHandler(function(){})
      .getOnboardingAssignments();
  }

  if (changed.indexOf('ob_plans') !== -1) {
    google.script.run
      .withSuccessHandler(function(r) {
        if (r && r.plans) {
          obPlans = r.plans;
          rtRefreshObView();
        }
      })
      .withFailureHandler(function(){})
      .getOnboardingPlans();
  }

  if (changed.indexOf('qa') !== -1 && typeof preloadQaData === 'function') {
    preloadQaData().catch(function(){});
    var activeView = document.querySelector('.content.active');
    if (activeView && activeView.id.indexOf('qa') !== -1) {
      if (typeof qaRenderPage === 'function') qaRenderPage();
    }
  }

  if (changed.indexOf('tt') !== -1) {
    google.script.run
      .withSuccessHandler(function(r) {
        if (r && r.success) {
          ttData = r.data || { teams:[], shifts:[] };
          var activeView = document.querySelector('.content.active');
          if (activeView && activeView.id.indexOf('timetable') !== -1) {
            if (typeof ttRenderPage === 'function') ttRenderPage();
          }
        }
      })
      .withFailureHandler(function(){})
      .getTimetableData();
  }
}

function rtRefreshObView() {
  // Update top button visibility
  if (typeof obShowTopBtn === 'function') obShowTopBtn();

  // If on onboarding view, re-render
  var activeView = document.querySelector('.content.active');
  if (activeView && activeView.id === 'onboarding-view') {
    var c = document.getElementById('obMainContent');
    if (!c) return;
