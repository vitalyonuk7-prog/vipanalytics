    badge.textContent = pct + '%';
  });
  // Update side panel - rebuild it
  var sidePanel = document.querySelector('[data-completion-panel]');
  if (!sidePanel) return;
  var totalPct = calcTotalCompletion(sections, player);
  var sz=64;var sw=5;var rr=(sz-sw)/2;var circ=2*Math.PI*rr;var dash=circ*totalPct/100;var gap2=circ-dash;
  var cc=completionColor(totalPct);
  var h='<div style="text-align:center"><svg width="'+sz+'" height="'+sz+'" viewBox="0 0 '+sz+' '+sz+'"><circle cx="'+sz/2+'" cy="'+sz/2+'" r="'+rr+'" fill="none" stroke="#e2e8f0" stroke-width="'+sw+'"/><circle cx="'+sz/2+'" cy="'+sz/2+'" r="'+rr+'" fill="none" stroke="'+cc+'" stroke-width="'+sw+'" stroke-linecap="round" stroke-dasharray="'+dash.toFixed(1)+' '+gap2.toFixed(1)+'" transform="rotate(-90 '+sz/2+' '+sz/2+')" style="transition:stroke-dasharray 0.4s"/></svg><div style="margin-top:-'+(sz/2+8)+'px;position:relative;font-size:16px;font-weight:900;color:'+cc+'">'+totalPct+'%</div><div style="font-size:8px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-top:'+(sz/2-10)+'px">TOTAL</div></div>';
  sectionNames.forEach(function(sn) {
