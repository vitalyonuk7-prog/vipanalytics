  var optionsHtml = '<option value="">— Select —</option>';
  bonusCatOptions.forEach(function(c){ optionsHtml += '<option value="'+c+'">'+c+'</option>'; });
  
  // Bulk assign bar
  var html = '<div style="display:flex;gap:8px;align-items:center;padding:12px 0;border-bottom:1px solid #e2e8f0;position:sticky;top:0;background:#fff;z-index:1">';
  html += '<label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;font-weight:700;color:#64748b"><input type="checkbox" id="bonusCatSelectAll" onchange="toggleAllBonusCatCheckboxes(this.checked)" style="accent-color:#667eea"> Select all</label>';
  html += '<div style="flex:1"></div>';
