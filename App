    teamMap[e.team].totalOld += e.data.totalOld; teamMap[e.team].filledOld += e.data.filledOld;
    teamMap[e.team].count++;
  });
  h += '<div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:20px">';
  Object.keys(teamMap).forEach(function(tn) {
    var tm = teamMap[tn]; var tp = tm.total > 0 ? Math.round(tm.filled / tm.total * 100) : 0;
    var tpO = tm.totalOld > 0 ? Math.round(tm.filledOld / tm.totalOld * 100) : null;
