function closeAddRoleModal() {
  document.getElementById('addRoleModal').classList.remove('show');
}

function confirmAddRole() {
  var input = document.getElementById('newRoleNameInput');
  var roleName = input.value.trim().toLowerCase().replace(/[^a-z0-9_]/g, '');
  var msg = document.getElementById('addRoleMsg');
  
  if (!roleName) { msg.style.color = '#ef4444'; msg.textContent = 'Please enter a valid role name'; input.focus(); return; }
  
  if (adminPanelData && adminPanelData.allRoles && adminPanelData.allRoles.indexOf(roleName) !== -1) {
    msg.style.color = '#ef4444'; msg.textContent = 'Role "' + roleName + '" already exists!'; return;
  }
  
  msg.style.color = '#64748b'; msg.textContent = 'Creating...';
  
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        msg.style.color = '#10b981';
        msg.textContent = '✅ Created!';
        // Optimistic local update
        if (adminPanelData) {
          if (adminPanelData.allRoles.indexOf(roleName) === -1) adminPanelData.allRoles.push(roleName);
          if (!adminPanelData.rolePermissions[roleName]) {
            var perms = {};
            (adminPanelData.pages || []).forEach(function(p) { perms[p.id] = true; });
            adminPanelData.rolePermissions[roleName] = perms;
          }
          renderRolesMatrix();
          renderAdminUsers();
        }
        setTimeout(function() { closeAddRoleModal(); }, 500);
      } else {
        msg.style.color = '#ef4444';
        msg.textContent = '❌ ' + (result ? result.error : 'Unknown error');
      }
    })
    .withFailureHandler(function(err) { msg.style.color = '#ef4444'; msg.textContent = '❌ ' + err; })
    .adminAddRole(roleName);
}

function deleteRoleUI(roleName) {
  if (!confirm('Delete role "' + roleName + '"? Users with this role will need reassignment.')) return;
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        // Optimistic local update
        if (adminPanelData) {
          var idx = adminPanelData.allRoles.indexOf(roleName);
          if (idx !== -1) adminPanelData.allRoles.splice(idx, 1);
          delete adminPanelData.rolePermissions[roleName];
          renderRolesMatrix();
          renderAdminUsers();
        }
      } else {
        alert('Error: ' + (result ? result.error : 'Unknown'));
      }
    })
    .withFailureHandler(function(err) { alert('Error: ' + err); })
    .adminDeleteRole(roleName);
}

// Enter key on modal input
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && document.getElementById('addRoleModal').classList.contains('show')) {
    confirmAddRole();
  }
  if (e.key === 'Escape' && document.getElementById('addRoleModal').classList.contains('show')) {
    closeAddRoleModal();
  }
});

function saveRolesUI() {
  var msg = document.getElementById('rolesSaveMsg');
  if (!msg) { showToast('Saving...'); }
  else { msg.style.color = '#64748b'; msg.textContent = 'Saving...'; }
  
  var checks = document.querySelectorAll('.roles-check');
  var permissions = {};
  checks.forEach(function(cb) {
    var roleName = cb.dataset.role;
    var pageId = cb.dataset.page;
    if (!roleName || !pageId) return;
    if (!permissions[roleName]) permissions[roleName] = {};
    permissions[roleName][pageId] = cb.checked;
  });
  
  console.log('💾 Saving role permissions:', JSON.stringify(permissions));
  
  google.script.run
    .withSuccessHandler(function(result) {
      console.log('💾 Save result:', JSON.stringify(result));
      if (result && result.success) {
        if (msg) { msg.style.color = '#10b981'; msg.textContent = '✅ Permissions saved!'; }
        showToast('✅ Permissions saved!');
        setTimeout(function() { if (msg) msg.textContent = ''; }, 3000);
        // Update local data
        Object.keys(permissions).forEach(function(rn) {
          if (!adminPanelData.rolePermissions[rn]) adminPanelData.rolePermissions[rn] = {};
          Object.keys(permissions[rn]).forEach(function(pid) {
            adminPanelData.rolePermissions[rn][pid] = permissions[rn][pid];
          });
        });
      } else {
        var err = result ? result.error : 'Unknown error';
        if (msg) { msg.style.color = '#ef4444'; msg.textContent = '❌ ' + err; }
        showToast('❌ ' + err);
      }
    })
    .withFailureHandler(function(err) {
      console.error('💾 Save failed:', err);
      if (msg) { msg.style.color = '#ef4444'; msg.textContent = '❌ ' + err; }
      showToast('❌ ' + err);
    })
    .saveRolePermissions({ permissions: permissions });
}

