  var tPlayers = playersKey ? getMetricVal(sd.totalTab, ym, playersKey) : 0;
  var tBets = betsKey ? getMetricVal(sd.totalTab, ym, betsKey) : 0;

  function fE(v) { return '€' + Math.round(v).toLocaleString(); }
  function fN(v) { return Math.round(v).toLocaleString(); }
  function pct(v, t) { return t ? ((v / t) * 100).toFixed(1) + '%' : '\u2014'; }

  // ---- KPI CARDS ----
  var cards = [
    { icon: '\ud83d\udcb0', label: 'Total Deposits', val: fE(tDep), color: '#059669' },
