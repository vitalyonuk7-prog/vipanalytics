    if (!r || !r.success) showToast('Error: ' + (r ? r.error : ''));
  }).unlockKpiResult({manager: manager, month: month});
}

// Delete QA Scorecard
function qaDeleteScorecard(manager, month) {
  if (!confirm('Delete scorecard for ' + qaFmtMonth(month) + '?')) return;
