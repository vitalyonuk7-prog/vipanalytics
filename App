function qcDoSendPdf(email, month, html) {
  var subject = (_qcEmailSettings && _qcEmailSettings.subject) ? _qcEmailSettings.subject : 'Quality Report — {month} {year}';
  var body = (_qcEmailSettings && _qcEmailSettings.body) ? _qcEmailSettings.body : 'Dear {name},\n\nPlease find attached your Quality Report for {month} {year}.\n\nBest regards,\nQA Department';
  
  google.script.run.withSuccessHandler(function(r) {
    if (r && r.success) {
      showToast('✅ Sent to ' + r.to);
      // Update local sent cache
      if (!_qcPdfSent[month]) _qcPdfSent[month] = [];
      var existing = _qcPdfSent[month].find(function(x) { return x.email === email; });
      if (existing) { existing.sent_at = new Date().toISOString(); }
      else _qcPdfSent[month].push({ email: email, sent_at: new Date().toISOString(), sent_by: window._userEmail || '' });
      qcRenderPage();
    } else showToast('❌ ' + (r ? r.error : 'Error'));
  }).withFailureHandler(function(e) { showToast('❌ ' + e); }).sendQualityPdfEmail({
    manager: email, month: month, html: html, subject: subject, body: body
  });
}

