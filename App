function saveBonusCategoryOption(){
  var input = document.getElementById('newCategoryInput');
  var name = input.value.trim();
  if(!name){ showToast('Enter a category name'); return; }
  input.disabled = true;
  google.script.run
    .withSuccessHandler(function(r){
      input.disabled = false;
      if(r.success){
        bonusCatOptions.push(name);
        bonusCatOptions.sort();
        document.getElementById('addCategorySubModal').style.display='none';
        showToast('✅ Category "'+name+'" created');
        if(window._bonusCatNames) renderBonusCategoryList(window._bonusCatNames);
      } else { showToast('Error: '+(r.error||'Unknown')); }
    })
    .withFailureHandler(function(e){ input.disabled=false; showToast('Error: '+e); })
    .addBonusCategoryOption(name);
}

function deleteBonusCategoryOption(name){
  if(!confirm('Delete category "'+name+'"? All bonuses assigned to it will be unassigned.')) return;
  google.script.run
    .withSuccessHandler(function(r){
      if(r.success){
        var idx = bonusCatOptions.indexOf(name);
        if(idx!==-1) bonusCatOptions.splice(idx,1);
        Object.keys(bonusCatMapping).forEach(function(k){ if(bonusCatMapping[k]===name) bonusCatMapping[k]=''; });
        showToast('🗑️ Category "'+name+'" deleted');
        openAddCategoryModal();
        if(window._bonusCatNames) renderBonusCategoryList(window._bonusCatNames);
      } else { showToast('Error: '+(r.error||'Unknown')); }
    })
    .withFailureHandler(function(e){ showToast('Error: '+e); })
    .removeBonusCategoryOption(name);
}

