function pieTabClick(filter) {
  var tabs = document.querySelectorAll('.pie-t');
  tabs.forEach(function(t) { t.style.borderBottomColor = 'transparent'; t.style.color = '#94a3b8'; });
  
  if (filter === 'all') {
    window._pieTypeFilter = null;
    tabs[0].style.borderBottomColor = '#667eea'; tabs[0].style.color = '#667eea';
  } else if (filter.indexOf('type:') === 0) {
