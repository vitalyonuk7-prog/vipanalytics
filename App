<div id="loginScreen">
<div class="login-bg">
  <div class="orb"></div>
  <div class="orb"></div>
  <div class="orb"></div>
</div>
<div class="login-card">
  <div class="login-logo">🌪️</div>
  <div class="login-title">Slotornado</div>
  <div class="login-sub">Analytics Suite</div>
  <form class="login-form" id="loginForm" onsubmit="doLogin();return false;">
    <div class="login-field">
      <label for="loginEmail">Email</label>
      <input type="email" id="loginEmail" name="username" placeholder="your@email.com" autocomplete="username" autofocus>
    </div>
    <div class="login-field">
      <label for="loginPassword">Password</label>
      <input type="password" id="loginPassword" name="password" placeholder="Enter password" autocomplete="current-password">
    </div>
    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:rgba(255,255,255,0.5);font-weight:600;margin-bottom:12px;user-select:none">
      <input type="checkbox" id="loginRemember" checked style="width:16px;height:16px;accent-color:#667eea;cursor:pointer"> Remember me
    </label>
    <button type="submit" class="login-btn" id="loginBtn">Sign In</button>
    <div class="login-error" id="loginError"></div>
  </form>
</div>
</div>

<script>
// Login script - auto-fill from server-stored credentials
(function() {
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    google.script.run
      .withSuccessHandler(function(result) {
        if (result && result.success && result.email) {
          document.getElementById('loginEmail').value = result.email;
          document.getElementById('loginPassword').value = result.password || '';
          console.log('✅ Credentials auto-filled from server');
          // Auto-login if both fields filled
          if (result.email && result.password) {
            setTimeout(function() { doLogin(); }, 300);
          }
        }
      })
      .withFailureHandler(function() {})
      .getRememberMe();
  }
})();

function doLogin() {
  var email = document.getElementById('loginEmail').value.trim().toLowerCase();
  var password = document.getElementById('loginPassword').value.trim();
  var errEl = document.getElementById('loginError');
  var btn = document.getElementById('loginBtn');
  
  if (!email || !password) { errEl.textContent = 'Enter email and password'; return; }
  
  errEl.textContent = '';
  btn.disabled = true;
  btn.textContent = 'Signing in...';
  
  console.log('🔐 Attempting login for:', email);
  
  if (typeof google === 'undefined' || !google.script || !google.script.run) {
    errEl.textContent = 'App not connected. Please reload.';
    btn.disabled = false;
    btn.textContent = 'Sign In';
    return;
  }
  
  google.script.run
    .withSuccessHandler(function(result) {
      console.log('🔐 Login response:', JSON.stringify(result));
      if (result && result.allowed) {
        window._userRole = result.role || 'user';
        window._userEmail = result.email || '';
        window._userManager = result.manager || '';
        window._userNickname = result.nickname || result.name || '';
        window._userEmoji = result.emoji || '\uD83D\uDC64';
        console.log('✅ Login success:', result.email, '(' + result.role + ')');
        
        document.getElementById('loginScreen').classList.add('hide');
        document.getElementById('splash').classList.add('active');
        
        if (typeof initUserUI === 'function') initUserUI();
        
        // Fetch permissions FIRST, then load data
        if (window._userRole === 'admin') {
          window._userPages = 'all';
          if (typeof applyPermissionsToUI === 'function') applyPermissionsToUI();
          if (typeof loadData === 'function') loadData();
          setTimeout(function(){
            if(typeof obShowTopBtn==='function') obShowTopBtn();
            if(typeof rtStartPolling==='function') rtStartPolling();
          }, 2500);
        } else {
          google.script.run
            .withSuccessHandler(function(permResult) {
              if (permResult && permResult.pages !== 'all') {
                window._userPages = permResult.pages;
              } else {
                window._userPages = 'all';
              }
              // Apply UI restrictions
              if (typeof applyPermissionsToUI === 'function') applyPermissionsToUI();
              if (typeof loadData === 'function') loadData();
            })
            .withFailureHandler(function() {
              window._userPages = 'all';
              if (typeof loadData === 'function') loadData();
            })
            .getUserPermissions({ role: window._userRole });
        }
      } else {
        errEl.textContent = result ? (result.error || 'Access denied') : 'Login failed';
        btn.disabled = false;
        btn.textContent = 'Sign In';
      }
    })
    .withFailureHandler(function(err) {
      console.error('🔐 Login error:', err);
      errEl.textContent = 'Connection error: ' + (err.message || err);
      btn.disabled = false;
      btn.textContent = 'Sign In';
    })
    .loginUser({ email: email, password: password, remember: document.getElementById('loginRemember').checked });
}

function doLogout() {
  window._userRole = '';
  window._userEmail = '';
  window._userManager = '';
  var dd = document.getElementById('userProfileDD');
  if (dd) dd.classList.remove('show');
  document.getElementById('loginScreen').classList.remove('hide');
  document.getElementById('loginPassword').value = '';
  document.getElementById('loginError').textContent = '';
  document.getElementById('loginBtn').disabled = false;
  document.getElementById('loginBtn').textContent = 'Sign In';
}

document.getElementById('loginEmail').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') { e.preventDefault(); document.getElementById('loginPassword').focus(); }
});

console.log('🔐 Login screen ready');
</script>

