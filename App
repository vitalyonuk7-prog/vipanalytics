function loadServiceSheet(key) {
  _svcCurrentKey = key;
  var labels = { type: '🏷️ Type Mapping', manager: '👤 Manager Mapping', vocabulary: '📖 Vocabulary', tags: '🏷️ Tags', sms_settings: '📱 SMS Settings' };
  document.getElementById('svcSheetTitle').textContent = labels[key] || key;
  document.getElementById('svcMsg').textContent = '';
  
  // Use preloaded cache if available
  if (_svcCache[key]) {
    renderServiceSheet(key);
    return;
  }
  
  document.getElementById('svcTableBody').innerHTML = '<tr><td style="text-align:center;padding:30px;color:#94a3b8">Loading...</td></tr>';
  
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        _svcCache[key] = result;
        renderServiceSheet(key);
      } else {
        document.getElementById('svcTableBody').innerHTML = '<tr><td style="text-align:center;padding:30px;color:#ef4444">' + (result ? result.error : 'Error') + '</td></tr>';
      }
    })
    .withFailureHandler(function(err) {
      document.getElementById('svcTableBody').innerHTML = '<tr><td style="text-align:center;padding:30px;color:#ef4444">' + err + '</td></tr>';
    })
    .getServiceSheet(key);
}

function renderServiceSheet(key) {
  var data = _svcCache[key];
  if (!data) return;
  var headers = data.headers || [];
  var rows = data.rows || [];
  
  // Header
  var headHtml = '<tr>';
  headHtml += '<th style="width:40px;text-align:center">#</th>';
  headers.forEach(function(h) { headHtml += '<th>' + h + '</th>'; });
  headHtml += '<th style="width:50px;text-align:center">Del</th>';
  headHtml += '</tr>';
  document.getElementById('svcTableHead').innerHTML = headHtml;
  
  // Body
  if (rows.length === 0) {
    document.getElementById('svcTableBody').innerHTML = '<tr><td colspan="' + (headers.length + 2) + '" style="text-align:center;padding:30px;color:#94a3b8">No data. Click "Add Row" to start.</td></tr>';
    return;
  }
  
  var bodyHtml = '';
  rows.forEach(function(row, ri) {
    bodyHtml += '<tr>';
    bodyHtml += '<td style="text-align:center;color:#94a3b8;font-size:11px">' + (ri + 1) + '</td>';
    for (var ci = 0; ci < headers.length; ci++) {
      var val = ci < row.length ? row[ci] : '';
      bodyHtml += '<td><input type="text" value="' + val.replace(/"/g, '&quot;') + '" class="svc-cell" data-key="' + key + '" data-row="' + ri + '" data-col="' + ci + '" onchange="svcCellChanged(this)" style="width:100%;padding:6px 8px;border:1.5px solid transparent;border-radius:6px;font-size:12px;font-weight:600;font-family:inherit;outline:none;background:transparent;transition:all 0.15s" onfocus="this.style.borderColor=\'#6366f1\';this.style.background=\'#fff\'" onblur="this.style.borderColor=\'transparent\';this.style.background=\'transparent\'"></td>';
    }
    bodyHtml += '<td style="text-align:center"><button class="admin-btn-sm admin-btn-danger" onclick="svcDeleteRow(\'' + key + '\',' + ri + ')">🗑️</button></td>';
    bodyHtml += '</tr>';
  });
  document.getElementById('svcTableBody').innerHTML = bodyHtml;
}

function svcCellChanged(input) {
  var key = input.dataset.key;
  var ri = parseInt(input.dataset.row);
  var ci = parseInt(input.dataset.col);
  var val = input.value;
  
  input.style.borderColor = '#f59e0b';
  input.style.background = '#fffbeb';
  
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        input.style.borderColor = '#10b981';
        input.style.background = '#ecfdf5';
        if (_svcCache[key] && _svcCache[key].rows[ri]) _svcCache[key].rows[ri][ci] = val;
        setTimeout(function() { input.style.borderColor = 'transparent'; input.style.background = 'transparent'; }, 1200);
      } else {
        input.style.borderColor = '#ef4444';
        input.style.background = '#fef2f2';
      }
    })
    .withFailureHandler(function() {
      input.style.borderColor = '#ef4444';
      input.style.background = '#fef2f2';
    })
    .saveServiceSheetCell(key, ri, ci, val);
}

function svcAddRow() {
  if (!_svcCurrentKey) return;
  var key = _svcCurrentKey;
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        // Add empty row locally
        if (_svcCache[key]) {
          var cols = (_svcCache[key].headers || []).length || 1;
          var empty = [];
          for (var i = 0; i < cols; i++) empty.push('');
          _svcCache[key].rows.push(empty);
          renderServiceSheet(key);
        }
        var msg = document.getElementById('svcMsg');
        msg.style.color = '#10b981'; msg.textContent = '✅ Row added';
        setTimeout(function() { msg.textContent = ''; }, 1500);
      }
    })
    .withFailureHandler(function(err) {
      var msg = document.getElementById('svcMsg');
      msg.style.color = '#ef4444'; msg.textContent = '❌ ' + err;
    })
    .addServiceSheetRow(key);
}

function svcDeleteRow(key, rowIdx) {
  if (!confirm('Delete row ' + (rowIdx + 1) + '?')) return;
  google.script.run
    .withSuccessHandler(function(result) {
      if (result && result.success) {
        if (_svcCache[key] && _svcCache[key].rows) {
          _svcCache[key].rows.splice(rowIdx, 1);
          renderServiceSheet(key);
        }
      } else {
        alert('Error: ' + (result ? result.error : 'Unknown'));
      }
    })
    .withFailureHandler(function(err) { alert('Error: ' + err); })
    .deleteServiceSheetRow(key, rowIdx);
}

