function ttNavDate(dir) {
  var d = new Date(ttViewDate);
  if (ttViewMode === 'week') d.setDate(d.getDate() + dir * 7);
  else if (ttViewMode === 'day') d.setDate(d.getDate() + dir);
  else d.setMonth(d.getMonth() + dir);
  ttViewDate = d; ttRenderPage();
}
function ttGoToday() { ttViewDate = new Date(); ttViewDate.setHours(0,0,0,0); ttRenderPage(); }

function ttGetDatesForView() {
  var dates = [];
  if (ttViewMode === 'day') {
    dates.push(new Date(ttViewDate));
  } else if (ttViewMode === 'week') {
    var d = new Date(ttViewDate);
    var day = d.getDay(); var diff = day === 0 ? -6 : 1 - day;
    d.setDate(d.getDate() + diff);
    for (var i = 0; i < 7; i++) { dates.push(new Date(d)); d.setDate(d.getDate()+1); }
  } else {
    var d2 = new Date(ttViewDate.getFullYear(), ttViewDate.getMonth(), 1);
    var end = new Date(ttViewDate.getFullYear(), ttViewDate.getMonth()+1, 0);
    var startDay = d2.getDay(); var startDiff = startDay===0?-6:1-startDay;
    d2.setDate(d2.getDate()+startDiff);
    while (d2 <= end || d2.getDay()!==1) {
      dates.push(new Date(d2)); d2.setDate(d2.getDate()+1);
      if (dates.length > 42) break;
    }
  }
  return dates;
}

function ttDateKey(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }

function ttGetShiftForDate(assignment, date) {
  var dk = ttDateKey(date);
  if (assignment.exceptions) {
    var ex = assignment.exceptions.find(function(e){return e.date===dk;});
    if (ex) {
      if (ex.type === 'off') return null;
      if (ex.type === 'custom') {
        // Return a virtual shift copy with overridden times
        var baseSh = (ttData.shifts||[]).find(function(s){return s.id===assignment.shiftId;});
        if (!baseSh) return null;
        return Object.assign({}, baseSh, { startTime: ex.customStart, endTime: ex.customEnd, _custom: true });
      }
      if (ex.shiftId) return (ttData.shifts||[]).find(function(s){return s.id===ex.shiftId;});
      return null;
    }
  }
  if (!assignment.startDate || !assignment.shiftId) return null;
  var sh = (ttData.shifts||[]).find(function(s){return s.id===assignment.shiftId;});
  if (!sh) return null;
  var start = new Date(assignment.startDate + 'T00:00:00');
  var diffDays = Math.floor((date - start) / 86400000);
  if (diffDays < 0) return null;
  if (sh.pattern === '5/2') {
    var dayName = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][date.getDay()];
    var daysOff = (sh.daysOff || 'Sat,Sun').split(',');
    return daysOff.indexOf(dayName) !== -1 ? null : sh;
  } else {
    var cycle = sh.workDays + sh.restDays;
    var pos = diffDays % cycle;
    return pos < sh.workDays ? sh : null;
  }
}

function ttAdjustTime(time, tz) {
  if (!time) return '';
  if (tz === 'warsaw') {
    var parts = time.split(':'); var h2 = parseInt(parts[0]); var m2 = parseInt(parts[1]||0);
    h2 = h2 - 1; if (h2 < 0) h2 = 23;
    return String(h2).padStart(2,'0') + ':' + String(m2).padStart(2,'0');
  }
  return time;
}

