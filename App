var trafficMode = 'monthly'; // monthly | weekly
var trafficGroupBy = 'trafficType'; // trafficType | trafficSource | trafficDirection
var trafficChart = null;
var trafficPlayersCache = {}; // period → { achieved: [], dropped: [] }
var trafficFilters = { periods: [], types: [] };
var trafficAllPeriods = [];
var trafficAllTypes = [];

function getTrafficRv2Data() {
  // Use FTD mode for traffic analysis
  var mode = trafficMode === 'monthly' ? 'monthly_ftd' : 'weekly_ftd';
  return rv2Data[mode] || null;
}

function populateTrafficFilters() {
  var data = getTrafficRv2Data();
  if (!data) return;
  
  var isWeekly = trafficMode === 'weekly';
  var periods = [];
  if (data.rows) {
    data.rows.forEach(function(r) { periods.push(isWeekly ? r.week : r.month); });
  }
  trafficAllPeriods = periods;
  if (trafficFilters.periods.length === 0) trafficFilters.periods = periods.slice();
  
  // Period checkboxes
  var periodHtml = '';
  periods.forEach(function(p) {
    var checked = trafficFilters.periods.includes(p);
    periodHtml += '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (checked ? '#667eea' : '#f1f5f9') + ';color:' + (checked ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.2s">';
    periodHtml += '<input type="checkbox" ' + (checked ? 'checked' : '') + ' onchange="toggleTrafficFilter(\'periods\',\'' + p.replace(/'/g, "\\'") + '\')" style="display:none">' + p + '</label>';
  });
  document.getElementById('trafficPeriodChecks').innerHTML = periodHtml;
  
  // Collect types from playerDetails
  var typesSet = {};
  if (data.playerDetails) {
    Object.keys(data.playerDetails).forEach(function(email) {
      var d = data.playerDetails[email];
      var type = rv2GetPlayerType(d);
      if (type && type !== '') typesSet[type] = true;
    });
  }
  trafficAllTypes = Object.keys(typesSet).sort();
  
  // Type checkboxes
  var typeHtml = '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (trafficFilters.types.length === 0 ? '#667eea' : '#f1f5f9') + ';color:' + (trafficFilters.types.length === 0 ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600"><input type="checkbox" ' + (trafficFilters.types.length === 0 ? 'checked' : '') + ' onchange="toggleTrafficFilterAll(\'types\')" style="display:none">All</label>';
  trafficAllTypes.forEach(function(t) {
    var checked = trafficFilters.types.includes(t);
    typeHtml += '<label style="display:flex;align-items:center;gap:4px;padding:6px 12px;background:' + (checked ? '#667eea' : '#f1f5f9') + ';color:' + (checked ? '#fff' : '#475569') + ';border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all 0.2s">';
    typeHtml += '<input type="checkbox" ' + (checked ? 'checked' : '') + ' onchange="toggleTrafficFilter(\'types\',\'' + t.replace(/'/g, "\\'") + '\')" style="display:none">' + t + '</label>';
  });
  document.getElementById('trafficTypeChecks').innerHTML = typeHtml;
  updateTrafficFilterBadge();
}

function toggleTrafficFilter(filterType, value) {
  var idx = trafficFilters[filterType].indexOf(value);
  if (idx > -1) trafficFilters[filterType].splice(idx, 1);
  else trafficFilters[filterType].push(value);
  renderTrafficAnalytics();
}

function toggleTrafficFilterAll(filterType) {
  trafficFilters[filterType] = [];
  renderTrafficAnalytics();
}

function updateTrafficFilterBadge() {
  var badge = document.getElementById('trafficFilterBadge');
  if (!badge) return;
  var count = 0;
  if (trafficFilters.periods.length > 0 && trafficFilters.periods.length < trafficAllPeriods.length) count++;
  if (trafficFilters.types.length > 0) count++;
  badge.style.display = count > 0 ? 'inline' : 'none';
  if (count > 0) badge.textContent = count + ' active';
}

function trafficPlayerMatchesFilter(email, pd) {
  if (trafficFilters.types.length > 0) {
    var d = pd[email];
    if (!d) return false;
    var type = rv2GetPlayerType(d);
    if (trafficFilters.types.indexOf(type) === -1) return false;
  }
  return true;
}

function switchTrafficMode(mode) {
  trafficMode = mode;
  trafficFilters.periods = []; // reset periods for new mode
  document.getElementById('trafficMonthlyBtn').classList.toggle('active', mode === 'monthly');
  document.getElementById('trafficWeeklyBtn').classList.toggle('active', mode === 'weekly');
  renderTrafficAnalytics();
}

function switchTrafficGroup(group) {
  trafficGroupBy = group;
  document.getElementById('trafficGroupType').classList.toggle('active', group === 'trafficType');
  document.getElementById('trafficGroupSource').classList.toggle('active', group === 'trafficSource');
  document.getElementById('trafficGroupDirection').classList.toggle('active', group === 'trafficDirection');
  renderTrafficAnalytics();
}

function getTrafficData() {
  trafficPlayersCache = {};
  var data = getTrafficRv2Data();
  if (!data || !data.rows || !data.srcEmails || !data.activeEmails || !data.playerDetails) {
    return { periods: [], groups: [], data: {} };
  }
  
  var isWeekly = trafficMode === 'weekly';
  var pd = data.playerDetails;
  var selectedPeriods = trafficFilters.periods;
  var hasTypeFilter = trafficFilters.types.length > 0;
  var activePeriods = isWeekly ? (data.weeks || []) : (data.months || []);
  
  var periods = [];
  var periodData = {};
  
  data.rows.forEach(function(row, rowIdx) {
    var label = isWeekly ? row.week : row.month;
    if (!label) return;
    if (selectedPeriods.length > 0 && selectedPeriods.indexOf(label) === -1) return;
    periods.push(label);
    periodData[label] = {};
    
    var srcEmails = data.srcEmails[rowIdx] || [];
    // Last active period's emails for this cohort
    var lastActiveIdx = activePeriods.length - 1;
    var activeSet = {};
    if (data.activeEmails[lastActiveIdx]) {
      data.activeEmails[lastActiveIdx].forEach(function(e) { activeSet[e] = true; });
    }
    
    var achieved = [], dropped = [];
    srcEmails.forEach(function(email) {
      if (hasTypeFilter && !trafficPlayerMatchesFilter(email, pd)) return;
      var player = buildPlayerFromDetails(email, pd);
      if (activeSet[email]) { achieved.push(player); }
      else { dropped.push(player); }
    });
    
    trafficPlayersCache[label] = { achieved: achieved, dropped: dropped };
    
    [].concat(achieved, dropped).forEach(function(p) {
      var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
      if (!periodData[label][g]) periodData[label][g] = { ftd: 0, active: 0, dropped: 0 };
      periodData[label][g].ftd++;
    });
    achieved.forEach(function(p) {
      var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
      if (periodData[label][g]) periodData[label][g].active++;
    });
    dropped.forEach(function(p) {
      var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
      if (periodData[label][g]) periodData[label][g].dropped++;
    });
  });
  
  var allGroups = {};
  Object.values(periodData).forEach(function(groups) {
    Object.keys(groups).forEach(function(g) { allGroups[g] = true; });
  });
  
  return { periods: periods, groups: Object.keys(allGroups).sort(), data: periodData };
}

function renderTrafficAnalytics() {
  var data = getTrafficRv2Data();
  if (!data) {
    var cards = document.getElementById('trafficSummaryCards');
    if (cards) cards.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#64748b">No retention data available.<br><small>Open Retention Rate tab first.</small></div>';
    document.getElementById('traffic-table').innerHTML = '';
    return;
  }
  
  populateTrafficFilters();
  var td = getTrafficData();
  renderTrafficSummary(td);
  renderTrafficChart(td);
  renderTrafficTable(td);
  renderTrafficFinance(td);
}

function getPlayerFinance(p) {
  // Try Dashboard data first (most accurate), fallback to player fields
  var email = (p.email || p.id || '').trim().toLowerCase();
  var dash = (email && window.dashboardTagMap && window.dashboardTagMap[email]) ? window.dashboardTagMap[email] : null;
  return {
    depositSum: dash ? dash.depositSum : (p.depositSum || 0),
    cashoutSum: dash ? dash.cashoutSum : (p.cashoutSum || 0),
    inout: dash ? dash.inout : (p.inout || 0),
    depositCount: dash ? dash.depositCount : (p.depositCount || p.actualDeposits || 0)
  };
}

function renderTrafficFinance(td) {
  var table = document.getElementById('traffic-finance-table');
  if (!table) return;
  
  if (td.groups.length === 0) {
    table.innerHTML = '<tr><td style="padding:20px;text-align:center;color:#94a3b8">No data</td></tr>';
    return;
  }
  
  var groupFin = {};
  td.groups.forEach(function(g) { groupFin[g] = { players: 0, depSum: 0, cashSum: 0, inout: 0, depCount: 0 }; });
  
  Object.keys(trafficPlayersCache).forEach(function(period) {
    var cache = trafficPlayersCache[period];
    [].concat(cache.achieved || [], cache.dropped || []).forEach(function(p) {
      var g = (p[trafficGroupBy] || '').trim() || 'Unknown';
      if (!groupFin[g]) return;
      var fin = getPlayerFinance(p);
      groupFin[g].players++;
      groupFin[g].depSum += fin.depositSum;
      groupFin[g].cashSum += fin.cashoutSum;
      groupFin[g].inout += fin.inout;
      groupFin[g].depCount += fin.depositCount;
    });
  });
  
  var sorted = Object.keys(groupFin).sort(function(a, b) { return groupFin[b].depSum - groupFin[a].depSum; });
  
  var totP = 0, totDep = 0, totCash = 0, totIO = 0, totDC = 0;
