      for (var i = 0; i < reasonSel.options.length; i++) {
        if (reasonSel.options[i].value === p.closureReason) { reasonSel.selectedIndex = i; break; }
      }
    }
    // Manager select
    var mgrSel = row.querySelector('td:nth-child(5) select');
    if (mgrSel && p.manager) {
      var found = false;
      for (var i = 0; i < mgrSel.options.length; i++) {
        if (mgrSel.options[i].value === p.manager) { mgrSel.selectedIndex = i; found = true; break; }
      }
      if (!found && p.manager) {
        var opt = document.createElement('option');
        opt.value = p.manager;
        opt.textContent = p.manager;
        mgrSel.appendChild(opt);
        mgrSel.value = p.manager;
      }
    }
  });
}

