// ---- FAILURE ANALYSIS ----
var qaAnalysisPeriod = null; // null = current month

function qaRenderFailureAnalysis(c) {
  var months = qaAllMonths();
  var now = new Date();
  var curMonth = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');
  if (!qaAnalysisPeriod) qaAnalysisPeriod = months.indexOf(curMonth) !== -1 ? curMonth : (months.length ? months[months.length-1] : null);

  var h = '<div style="font-size:16px;font-weight:800;color:#1e293b;margin-bottom:14px">\uD83D\uDD0D Failure Analysis</div>';

  // Period selector
  h += '<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:16px">';
  months.forEach(function(m) {
    var active = qaAnalysisPeriod === m;
    h += '<button data-ap="' + m + '" class="qa-ap-btn" style="padding:5px 12px;border:1.5px solid ' + (active ? '#667eea' : '#e2e8f0') + ';background:' + (active ? '#667eea' : '#fff') + ';color:' + (active ? '#fff' : '#64748b') + ';font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">' + qaFmtMonth(m) + '</button>';
  });
  h += '<button data-ap="lifetime" class="qa-ap-btn" style="padding:5px 12px;border:1.5px solid ' + (qaAnalysisPeriod === 'lifetime' ? '#10b981' : '#e2e8f0') + ';background:' + (qaAnalysisPeriod === 'lifetime' ? '#10b981' : '#fff') + ';color:' + (qaAnalysisPeriod === 'lifetime' ? '#fff' : '#64748b') + ';font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">Lifetime</button>';
  h += '</div>';

  // Collect failures for selected period
  var periodResults = qaAnalysisPeriod === 'lifetime' ? qaResults : qaResults.filter(function(r) { return r.month === qaAnalysisPeriod; });
  var failMap = {}; // key: "bi:ei:blockName:errName" -> {count, managers:{}, months:{}}
  var totalFailures = 0;

  periodResults.forEach(function(res) {
    var failures = []; try { failures = JSON.parse(res.failures_json || '[]'); } catch(e) {}
    var tpl = null; qaTemplates.forEach(function(t) { if (t.name === res.template_name) tpl = t; });
    if (!tpl) return;
    failures.forEach(function(f) {
      var block = tpl.blocks[f.bi];
      if (!block) return;
      var err = block.errors[f.ei];
      var key = f.bi + ':' + f.ei + ':' + (block.name || '') + ':' + (err ? err.name : '');
      if (!failMap[key]) failMap[key] = { blockName: block.name || '', errName: err ? err.name : '', info: err ? (err.info || '') : '', level: f.level, count: 0, managers: {}, months: {} };
      failMap[key].count++;
      totalFailures++;
      var mgr = qaAllUsers.find(function(u) { return u.email === res.manager; });
      var mgrLabel = mgr ? qaLabel(mgr) : res.manager;
      failMap[key].managers[mgrLabel] = (failMap[key].managers[mgrLabel] || 0) + 1;
      failMap[key].months[res.month] = (failMap[key].months[res.month] || 0) + 1;
    });
  });

  var sorted = Object.keys(failMap).map(function(k) { return failMap[k]; }).sort(function(a, b) { return b.count - a.count; });

  if (!sorted.length) {
    h += '<div style="text-align:center;padding:40px;color:#94a3b8;background:#fff;border:1.5px solid #e2e8f0;border-radius:14px"><div style="font-size:40px;margin-bottom:8px">\u2705</div>No failures in this period</div>';
    c.innerHTML = h;
    c.querySelectorAll('.qa-ap-btn').forEach(function(b) { b.onclick = function() { qaAnalysisPeriod = this.dataset.ap; qaRenderFailureAnalysis(c); }; });
    return;
  }

  // Top failures chart
  h += '<div style="background:#fff;border:1.5px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:20px"><canvas id="qaFailChart" height="250" style="max-height:250px;width:100%"></canvas></div>';

  // Failures table
  h += '<div style="overflow-x:auto">';
  sorted.forEach(function(f, fi) {
    var pct = totalFailures > 0 ? (f.count / totalFailures * 100) : 0;
    var lc = f.level === 'warning' ? '#f59e0b' : f.level === 'level1' ? '#3b82f6' : f.level === 'level2' ? '#f97316' : '#ef4444';
    var mgrList = Object.keys(f.managers).map(function(m) { return { name: m, count: f.managers[m] }; }).sort(function(a, b) { return b.count - a.count; });

    h += '<div class="qa-fail-item" data-fn="' + f.errName.replace(/"/g,'&quot;') + '" data-bn="' + f.blockName.replace(/"/g,'&quot;') + '" data-info="' + (f.info||'').replace(/"/g,'&quot;') + '" style="background:#fff;border:1.5px solid #e2e8f0;border-radius:14px;padding:16px 20px;margin-bottom:10px;cursor:pointer;transition:all 0.15s" onmouseover="this.style.borderColor=\'' + lc + '40\';this.style.boxShadow=\'0 4px 12px rgba(0,0,0,0.04)\'" onmouseout="this.style.borderColor=\'#e2e8f0\';this.style.boxShadow=\'\'">';
    h += '<div style="display:flex;align-items:center;gap:14px">';
    // Rank
    h += '<div style="width:32px;height:32px;border-radius:10px;background:' + lc + '10;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:' + lc + ';flex-shrink:0">#' + (fi + 1) + '</div>';
    // Info
    h += '<div style="flex:1;min-width:0">';
    h += '<div style="font-weight:800;font-size:14px;color:#1e293b">' + f.errName + '</div>';
    h += '<div style="font-size:11px;color:#94a3b8;margin-top:2px">' + f.blockName;
    if (f.info) h += ' \u2022 <span style="color:#667eea">\u2139\uFE0F ' + f.info.replace(/</g, '&lt;') + '</span>';
    h += '</div></div>';
    // Stats
    h += '<div style="display:flex;gap:12px;align-items:center;flex-shrink:0">';
    h += '<div style="text-align:center"><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Count</div><div style="font-size:20px;font-weight:900;color:#1e293b">' + f.count + '</div></div>';
    h += '<div style="text-align:center"><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Share</div><div style="font-size:20px;font-weight:900;color:' + lc + '">' + pct.toFixed(1) + '%</div></div>';
    h += '<div style="text-align:center"><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">People</div><div style="font-size:20px;font-weight:900;color:#64748b">' + mgrList.length + '</div></div>';
    h += '</div></div>';
    // Who makes it
    h += '<div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">';
    mgrList.forEach(function(m) {
      h += '<span style="padding:3px 8px;border-radius:6px;font-size:10px;font-weight:700;background:#f8fafc;border:1px solid #e2e8f0;color:#475569">' + m.name + ' (' + m.count + ')</span>';
    });
    h += '</div>';
    h += '</div>';
  });
  h += '</div>';

  c.innerHTML = h;
  c.querySelectorAll('.qa-ap-btn').forEach(function(b) { b.onclick = function() { qaAnalysisPeriod = this.dataset.ap; qaRenderFailureAnalysis(c); }; });
  c.querySelectorAll('.qa-fail-item').forEach(function(item) {
    item.onclick = function() { qaShowFailDetail(this.dataset.fn, this.dataset.bn, this.dataset.info, null); };
  });

  // Draw chart
  qaDrawFailureChart(sorted.slice(0, 10), totalFailures);
}

function qaShowFailDetail(failName, blockName, info, filterMgr) {
  // Auto-lookup info from templates
  if (!info) {
    qaTemplates.forEach(function(t) { t.blocks.forEach(function(b) { if ((b.name||'')===blockName) { (b.errors||[]).forEach(function(e) { if ((e.name||'')===failName && e.info) info = e.info; }); } }); });
  }
  var months = qaAllMonths();
  var monthData = {};
  var mgrData = {};
  months.forEach(function(m) { monthData[m] = 0; });

  qaResults.forEach(function(res) {
    if (filterMgr && res.manager !== filterMgr) return;
    var ff = []; try { ff = JSON.parse(res.failures_json || '[]'); } catch(e) {}
    var tp = null; qaTemplates.forEach(function(t) { if (t.name === res.template_name) tp = t; });
    if (!tp) return;
    ff.forEach(function(f) {
      var bl = tp.blocks[f.bi]; if (!bl) return;
      var er = bl.errors[f.ei];
      if ((er ? er.name : '') === failName && (bl.name || '') === blockName) {
