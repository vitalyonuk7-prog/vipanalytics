// ── Aggregate raw rows into periods with day-accurate filtering ──
function biAggregate(rows, mode, dateFrom, dateTo) {
  // result[periodKey][stage] = { received:{eurTotal,count}, updated:{eurTotal,count}, expiry:{eurTotal,count}, _total }
  var result = {};

  function periodKey(dateStr) {
    if (!dateStr) return null;
    if (mode === 'monthly') return dateStr.slice(0, 7);
    // Weekly: ISO week
    var d = new Date(dateStr + 'T00:00:00Z');
    var wk = biIsoWeek(d);
    return wk.year + '-W' + String(wk.week).padStart(2, '0');
  }

  function inRange(dateStr) {
    if (!dateStr) return false;
    if (!dateFrom && !dateTo) return true; // no filter = all in range
    if (dateFrom && dateStr < dateFrom) return false;
    if (dateTo   && dateStr > dateTo)   return false;
    return true;
  }

  function add(pk, stage, slot, eur) {
    if (!result[pk])              result[pk] = {};
    if (!result[pk][stage])       result[pk][stage] = {
      received:{eurTotal:0,count:0}, updated:{eurTotal:0,count:0}, expiry:{eurTotal:0,count:0}, _total:0
    };
    result[pk][stage][slot].eurTotal += eur;
    result[pk][stage][slot].count++;
  }

  rows.forEach(function(r) {
    // Canonical date for _total and period grouping: prefer received → updated → expiry
    var canonical = r.received || r.updated || r.expiry;

    // Skip row only if filter is set AND no date falls in range
    var hasFilter = !!(dateFrom || dateTo);
    if (hasFilter) {
      var anyIn = (r.received && inRange(r.received)) ||
                  (r.updated  && inRange(r.updated))  ||
                  (r.expiry   && inRange(r.expiry));
      if (!anyIn) return;
    }

    // _total: count once per row using canonical date's period
    var canonicalInRange = inRange(canonical); // works correctly now (no filter = true)
    var pk0 = canonical ? periodKey(canonical) : null;

    if (r.received && inRange(r.received)) {
      var pk = periodKey(r.received);
      if (pk) {
        add(pk, r.stage, 'received', r.eurRec);
        // _total for issuedData: same key, stage 'ISSUED'
        if (!result[pk]['__issued__']) result[pk]['__issued__'] = {received:{eurTotal:0,count:0},updated:{eurTotal:0,count:0},expiry:{eurTotal:0,count:0},_total:0};
        result[pk]['__issued__'].received.eurTotal += r.eurRec;
        result[pk]['__issued__'].received.count++;
      }
    }
    if (r.updated && inRange(r.updated)) {
      var pk = periodKey(r.updated);
      if (pk) {
        add(pk, r.stage, 'updated', r.eurUpd);
        if (!result[pk]['__issued__']) result[pk]['__issued__'] = {received:{eurTotal:0,count:0},updated:{eurTotal:0,count:0},expiry:{eurTotal:0,count:0},_total:0};
        result[pk]['__issued__'].updated.eurTotal += r.eurUpd;
        result[pk]['__issued__'].updated.count++;
      }
    }
    if (r.expiry && inRange(r.expiry)) {
      var pk = periodKey(r.expiry);
      if (pk) {
        add(pk, r.stage, 'expiry', r.eurExp);
        if (!result[pk]['__issued__']) result[pk]['__issued__'] = {received:{eurTotal:0,count:0},updated:{eurTotal:0,count:0},expiry:{eurTotal:0,count:0},_total:0};
        result[pk]['__issued__'].expiry.eurTotal += r.eurExp;
        result[pk]['__issued__'].expiry.count++;
      }
    }

    // _total: increment once per row in its canonical period (if canonical date is in range)
    if (pk0) {
      if (!result[pk0])              result[pk0] = {};
      if (!result[pk0][r.stage])     result[pk0][r.stage] = {received:{eurTotal:0,count:0},updated:{eurTotal:0,count:0},expiry:{eurTotal:0,count:0},_total:0};
      result[pk0][r.stage]._total++;
    }
  });

  return result;
}

function biIsoWeek(d) {
  var dt = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));
  var day = dt.getUTCDay() || 7;
  dt.setUTCDate(dt.getUTCDate() + 4 - day);
  var yearStart = new Date(Date.UTC(dt.getUTCFullYear(), 0, 1));
  return { year: dt.getUTCFullYear(), week: Math.ceil((((dt - yearStart) / 86400000) + 1) / 7) };
}

