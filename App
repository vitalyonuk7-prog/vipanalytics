      extra += '<option value="level1" data-pct="' + l1Pct + '">⬇ Level 1 → deduction -' + l1Pct + '%</option>';
      extra += '<option value="warning" data-pct="0">⬇ Warning → deduction 0%</option>';
    } else if (aLevel === 'level2') {
      extra += '<option value="level1" data-pct="' + l1Pct + '">⬇ Level 1 → deduction -' + l1Pct + '%</option>';
      extra += '<option value="warning" data-pct="0">⬇ Warning → deduction 0%</option>';
    } else {
      extra += '<option value="warning" data-pct="0">⬇ Warning → deduction 0%</option>';
