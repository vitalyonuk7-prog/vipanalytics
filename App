function qaRenderCompModalBody(e, typeFilter) {
  var d = e.data;
  var sections = profilingData && profilingData.fieldConfig && profilingData.fieldConfig._sections ? profilingData.fieldConfig._sections : null;
  
  var h = '';
  
  // Type tabs
  var types = d.types || {};
  var typeKeys = Object.keys(types).sort();
  if (typeKeys.length > 1) {
    h += '<div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:14px">';
    var allActive = typeFilter === 'ALL';
    h += '<button class="qa-type-btn" data-type="ALL" style="padding:5px 14px;border:1.5px solid ' + (allActive ? '#667eea' : '#e2e8f0') + ';background:' + (allActive ? '#667eea' : '#fff') + ';color:' + (allActive ? '#fff' : '#64748b') + ';font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">ALL <span style="opacity:0.7">' + d.players + '</span></button>';
    typeKeys.forEach(function(tk) {
      var isA = typeFilter === tk;
      var tc = tk === 'VIP' ? '#f59e0b' : tk === 'PRE-VIP' ? '#3b82f6' : tk === 'CHURN' ? '#ef4444' : '#10b981';
      h += '<button class="qa-type-btn" data-type="' + tk + '" style="padding:5px 14px;border:1.5px solid ' + (isA ? tc : '#e2e8f0') + ';background:' + (isA ? tc : '#fff') + ';color:' + (isA ? '#fff' : tc) + ';font-size:11px;font-weight:700;border-radius:6px;cursor:pointer">' + tk + ' <span style="opacity:0.7">' + types[tk].players + '</span></button>';
    });
    h += '</div>';
  }
  
  // Get filtered data
  var fd = d; // default ALL
  if (typeFilter !== 'ALL' && types[typeFilter]) {
    fd = types[typeFilter];
  }
  
  var totalPct = fd.total > 0 ? Math.round(fd.filled / fd.total * 100) : 0;
  var oldPct = fd.totalOld > 0 ? Math.round(fd.filledOld / fd.totalOld * 100) : 0;
  
  h += '<div style="font-size:12px;color:#94a3b8;margin-bottom:14px">' + fd.players + ' players \u2022 ' + (fd.playersOld||0) + ' >1 month \u2022 Team: ' + e.team + '</div>';

  // Section stats - use fd (filtered by type)
  var sectionStats = [];
  var useCols = fd.cols || d.cols || {};
  if (sections) {
    Object.keys(sections).forEach(function(sn) {
      var fields = sections[sn];
      var t = 0, f = 0, tO = 0, fO = 0;
      fields.forEach(function(key) {
        if (key === '_order' || key === '_sections') return;
        var col = useCols[key];
        if (col) { t += col.total; f += col.filled; tO += col.totalOld; fO += col.filledOld; }
      });
      if (t > 0) sectionStats.push({ name: sn, total: t, filled: f, totalOld: tO, filledOld: fO, enabled: true });
    });
  }
  if (useCols) {
    var matchedCols = {};
    if (sections) Object.keys(sections).forEach(function(sn) { sections[sn].forEach(function(k) { matchedCols[k] = true; }); });
    var otherT = 0, otherF = 0, otherTO = 0, otherFO = 0;
    Object.keys(useCols).forEach(function(k) {
      if (!matchedCols[k]) { otherT += useCols[k].total; otherF += useCols[k].filled; otherTO += useCols[k].totalOld; otherFO += useCols[k].filledOld; }
    });
    if (otherT > 0) sectionStats.push({ name: 'Other', total: otherT, filled: otherF, totalOld: otherTO, filledOld: otherFO, enabled: true });
  }

  if (!sectionStats.length) {
    h += '<div style="text-align:center;padding:20px;font-size:32px;font-weight:900;color:' + completionColor(totalPct) + '">' + totalPct + '%</div>';
  } else {
    h += '<div id="qaCompSections">' + qaRenderCompSectionTable(sectionStats, fd) + '</div>';
  }
  
  document.getElementById('qaFDBody').innerHTML = h;
  window._qaCompSectionStats = sectionStats;
  window._qaCompDetailData = fd;
  
  // Type tab clicks
  document.querySelectorAll('.qa-type-btn').forEach(function(btn) {
    btn.onclick = function() {
      window._qaCompTypeFilter = this.dataset.type;
      qaRenderCompModalBody(window._qaCompEntries[window._qaCompModalEi], this.dataset.type);
    };
  });
  // Section toggle handlers
  document.querySelectorAll('.qa-comp-toggle').forEach(function(cb) {
    cb.onchange = function() {
      var idx = parseInt(this.dataset.si);
      window._qaCompSectionStats[idx].enabled = this.checked;
      document.getElementById('qaCompSections').innerHTML = qaRenderCompSectionTable(window._qaCompSectionStats, window._qaCompDetailData);
      document.querySelectorAll('.qa-comp-toggle').forEach(function(cb2) { cb2.onchange = cb.onchange; });
    };
  });
}

function qaRenderCompSectionTable(stats, d) {
  // Calc totals based on enabled sections
  var tAll = 0, fAll = 0, tOAll = 0, fOAll = 0;
  stats.forEach(function(s) { if (s.enabled) { tAll += s.total; fAll += s.filled; tOAll += s.totalOld; fOAll += s.filledOld; } });
  var pAll = tAll > 0 ? Math.round(fAll / tAll * 100) : 0;
  var pOAll = tOAll > 0 ? Math.round(fOAll / tOAll * 100) : 0;

  var h = '<div style="display:flex;gap:14px;margin-bottom:16px">';
  h += '<div style="flex:1;text-align:center;padding:12px;background:' + completionColor(pAll) + '08;border:1.5px solid ' + completionColor(pAll) + '25;border-radius:12px"><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">All Players</div><div style="font-size:28px;font-weight:900;color:' + completionColor(pAll) + ';margin-top:4px">' + pAll + '%</div></div>';
  h += '<div style="flex:1;text-align:center;padding:12px;background:' + completionColor(pOAll) + '08;border:1.5px solid ' + completionColor(pOAll) + '25;border-radius:12px"><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">>1 Month Players</div><div style="font-size:28px;font-weight:900;color:' + completionColor(pOAll) + ';margin-top:4px">' + pOAll + '%</div></div>';
  h += '</div>';

  h += '<table style="width:100%;border-collapse:collapse;font-size:12px;border:1.5px solid #e2e8f0;border-radius:12px;overflow:hidden">';
  h += '<thead><tr><th style="padding:10px 10px;text-align:left;font-weight:800;color:#1e293b;font-size:12px;width:30px;background:#fff"></th><th style="padding:10px 8px;text-align:left;font-weight:800;color:#1e293b;font-size:12px;background:#fff">SECTION</th><th style="padding:10px 8px;text-align:center;font-weight:800;color:#1e293b;font-size:12px;background:#fff">ALL %</th><th style="padding:10px 8px;text-align:center;font-weight:800;color:#1e293b;font-size:12px;background:#fff">>1 MONTH %</th></tr></thead><tbody>';
  stats.forEach(function(s, si) {
    var sp = s.total > 0 ? Math.round(s.filled / s.total * 100) : 0;
    var spO = s.totalOld > 0 ? Math.round(s.filledOld / s.totalOld * 100) : 0;
    var opacity = s.enabled ? '1' : '0.4';
    h += '<tr style="border-top:1px solid #f1f5f9;opacity:' + opacity + '">';
    h += '<td style="padding:6px 10px"><input type="checkbox" data-si="' + si + '" class="qa-comp-toggle" ' + (s.enabled ? 'checked' : '') + ' style="accent-color:#667eea;cursor:pointer"></td>';
    h += '<td style="padding:6px 8px;font-weight:700;color:#1e293b">' + s.name + '</td>';
    h += '<td style="padding:6px 8px;text-align:center"><span style="font-weight:800;color:' + completionColor(sp) + '">' + sp + '%</span><div style="height:3px;background:#f1f5f9;border-radius:2px;margin-top:3px"><div style="height:100%;width:' + sp + '%;background:' + completionColor(sp) + ';border-radius:2px"></div></div></td>';
    h += '<td style="padding:6px 8px;text-align:center"><span style="font-weight:800;color:' + completionColor(spO) + '">' + spO + '%</span><div style="height:3px;background:#f1f5f9;border-radius:2px;margin-top:3px"><div style="height:100%;width:' + spO + '%;background:' + completionColor(spO) + ';border-radius:2px"></div></div></td>';
    h += '</tr>';
  });
  h += '</tbody></table>';
  return h;
}

