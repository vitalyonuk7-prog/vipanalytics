function calcSectionCompletion(fields, player) {
  var total = 0, filled = 0;
  fields.forEach(function(key) {
    if (key === '_order' || key === '_sections') return;
    if (key.toLowerCase() === 'last_webhook_at') return;
    var fi = profilingData.fieldConfig[key];
    if (!fi) return;
    total++;
    var val = player.data[key];
    if (val !== undefined && val !== null && String(val).trim() !== '') filled++;
  });
  return total > 0 ? Math.round(filled / total * 100) : 0;
}

function calcTotalCompletion(sections, player) {
  var total = 0, filled = 0;
  Object.keys(sections).forEach(function(sn) {
    sections[sn].forEach(function(key) {
      if (key === '_order' || key === '_sections') return;
      if (key.toLowerCase() === 'last_webhook_at') return;
      var fi = profilingData.fieldConfig[key];
      if (!fi) return;
      total++;
      var val = player.data[key];
      if (val !== undefined && val !== null && String(val).trim() !== '') filled++;
    });
  });
  return total > 0 ? Math.round(filled / total * 100) : 0;
}

function completionColor(pct) {
  return pct >= 80 ? '#10b981' : pct >= 50 ? '#f59e0b' : '#ef4444';
}

function refreshCompletionUI(player) {
  var sections = profilingData.fieldConfig._sections;
