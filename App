      var mgr = (qaAllUsers||[]).find(function(u){return u.email===asgn.managerEmail;});
      var mgrName = mgr ? (mgr.nickname||mgr.name||asgn.managerEmail.split('@')[0]) : asgn.managerEmail.split('@')[0];
      var sh = (ttData.shifts||[]).find(function(s){return s.id===asgn.shiftId;});

      var row = document.createElement('div');
      row.style.cssText = 'display:grid;grid-template-columns:160px repeat(7,minmax(80px,1fr));border-bottom:1px solid #f1f5f9;min-height:70px';

      var nameCell = document.createElement('div');
      nameCell.style.cssText = 'padding:8px 10px;border-right:2px solid #e2e8f0;display:flex;flex-direction:column;justify-content:center;gap:3px;background:#fafafa;min-height:70px;box-sizing:border-box;overflow:hidden';
      var _lunchTime = asgn.defaultLunch ? '🍽️ '+asgn.defaultLunch : '🍽️';
      var _lunchBtn = '<button onclick="ttOpenLunchModal(' + ai + ', null)" style="padding:2px 6px;border:1px solid #fde68a;background:#fffbeb;color:#d97706;font-size:9px;font-weight:700;border-radius:4px;cursor:pointer">' + _lunchTime + '</button>';
      var _lblBtn = ttGetLabels().length ? '<button data-lblai="' + ai + '" class="tt-lbl-default-btn" style="padding:2px 6px;border:1px solid #c4b5fd;background:#f5f3ff;color:#7c3aed;font-size:9px;font-weight:700;border-radius:4px;cursor:pointer">🏷️</button>' : '';
      var _adminBtns = window._userRole === 'admin' ?
        '<div style="display:flex;gap:3px;margin-top:2px;flex-wrap:wrap">' +
        '<button onclick="ttOpenChangeShiftModal(' + ai + ')" style="padding:2px 6px;border:1px solid #bfdbfe;background:#eff6ff;color:#2563eb;font-size:9px;font-weight:700;border-radius:4px;cursor:pointer">✏ Shift</button>' + _lblBtn +
        '<button onclick="ttOpenSwapModal(' + ai + ')" style="padding:2px 6px;border:1px solid #c4b5fd;background:#f5f3ff;color:#7c3aed;font-size:9px;font-weight:700;border-radius:4px;cursor:pointer">⇄ Swap</button>' +
        _lunchBtn +
        '<button onclick="ttRemoveAssignment(' + ai + ')" style="padding:2px 6px;border:1px solid #fca5a5;background:#fef2f2;color:#ef4444;font-size:9px;font-weight:700;border-radius:4px;cursor:pointer">Del</button>' +
        '</div>' :
        // Regular manager sees their own lunch button
        (asgn.managerEmail.toLowerCase() === (window._userEmail||'').toLowerCase() ?
          '<div style="display:flex;gap:3px;margin-top:2px">' + _lunchBtn + _lblBtn + '</div>' : '');
      nameCell.innerHTML = '<div style="font-weight:700;font-size:12px;color:#1e293b;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + mgrName + '</div>' +
        '<div style="font-size:10px;color:#94a3b8">' + (sh?sh.name:'No shift') + '</div>' +
        _adminBtns;
      row.appendChild(nameCell);

      dates.forEach(function(d) {
        var dk = ttDateKey(d);
        var activeSh = ttGetShiftForDate(asgn, d);
        var isToday = dk===today; var isWe = d.getDay()===0||d.getDay()===6;
        var col = activeSh ? (shiftColorMap[activeSh.id]||'#6366f1') : null;
        var cell = document.createElement('div');
        cell.style.cssText = 'padding:4px;border-right:1px solid #f1f5f9;display:flex;align-items:flex-start;justify-content:center;min-height:70px;box-sizing:border-box;background:' + (isToday?'#f5f3ff':isWe&&!activeSh?'#fafafa':'#fff');

        if (activeSh) {
          var s = ttAdjustTime(activeSh.startTime, ttTimezone);
          var e2 = ttAdjustTime(activeSh.endTime, ttTimezone);
          var inner = document.createElement('div');
          inner.style.cssText = 'width:100%;padding:5px 6px;background:' + hexToRgba(col,0.08) + ';border:1.5px solid ' + (activeSh._custom ? col : hexToRgba(col,0.22)) + ';border-radius:8px;cursor:pointer;text-align:center;transition:all 0.15s;box-sizing:border-box';
          var lunchT = ttAdjustTime(ttGetLunchTime(asgn, dk), ttTimezone);
          var lunchStr = lunchT ? '<div style="display:inline-flex;align-items:center;gap:3px;margin-top:3px;padding:2px 6px;background:#fef3c7;border:1px solid #fde68a;border-radius:5px;font-size:8px;font-weight:700;color:#d97706">🍽️ '+lunchT+' – '+ttLunchEndTime(lunchT,asgn.lunchDuration)+'</div>' : '';
          // Labels for this day
          var _dayLabels = (asgn.dayLabels||{})[dk] || [];
          var _lblData = ttGetLabels();
          var labelsStr = '';
          _dayLabels.forEach(function(lid){
            var l=_lblData.find(function(x){return x.id===lid;}); if(!l) return;
            labelsStr += '<span class="tt-label-chip" data-ai="'+ai+'" data-dk="'+dk+'" style="display:inline-block;padding:1px 5px;border-radius:5px;font-size:7px;font-weight:700;background:'+l.color+';color:'+(l.textColor||'#fff')+';margin-right:2px;margin-top:2px;cursor:pointer">'+l.text+'</span>';
          });
          inner.innerHTML = '<div style="font-size:10px;font-weight:800;color:' + col + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + activeSh.name + (activeSh._custom ? ' ✏️' : '') + '</div>' +
            '<div style="font-size:9px;color:' + col + ';opacity:0.75;margin-top:1px">' + s + '–' + e2 + '</div>' +
            (lunchStr ? '<div style="margin-top:2px">' + lunchStr + '</div>' : '') +
            (labelsStr ? '<div style="margin-top:2px;line-height:1.4">'+labelsStr+'</div>' : '');
          inner.onmouseover = function(){ this.style.background=hexToRgba(col,0.14); };
          inner.onmouseout  = function(){ this.style.background=hexToRgba(col,0.08); };
          if (window._userRole === 'admin') {
            inner.onclick = function(e) { if(e.target.classList&&e.target.classList.contains('tt-label-chip')){ttOpenLabelPicker(ai,dk);return;} ttOpenExceptionModal(ai, dk); };
          } else if (asgn.managerEmail.toLowerCase() === (window._userEmail||'').toLowerCase()) {
            (function(_ai, dateKey, shiftName) {
              inner.onclick = function(e) {
                if (e.target.classList && e.target.classList.contains('tt-label-chip')) return;
                ttOpenRequestModal(dateKey, shiftName);
              };
              inner.addEventListener('dblclick', function(){ ttOpenLabelPicker(_ai, dateKey); });
              // Right-click → lunch override for this day
              inner.oncontextmenu = function(e){ e.preventDefault(); ttOpenLunchModal(_ai, dateKey); };
              // Long-press or right-click → lunch
              inner.oncontextmenu = function(e){ e.preventDefault(); ttOpenLunchModal(_ai, dateKey); };
              inner.style.cursor = 'pointer';
            })(ai, dk, activeSh.name);
          } else {
            inner.style.cursor = 'default';
          }
          cell.appendChild(inner);
        } else {
          var ex = asgn.exceptions && asgn.exceptions.find(function(e){return e.date===dk&&e.type==='off';});
          var inner2 = document.createElement('div');
          inner2.style.cssText = 'width:100%;min-height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;border-radius:8px;border:1.5px dashed ' + (ex?'#f59e0b':'transparent');
          // Check if this is a pattern-based OFF day (no shift assigned)
          var isPatternOff = !activeSh && !ex;
          if (ex) {
            inner2.style.background = 'rgba(245,158,11,0.06)';
            inner2.style.borderColor = '#f59e0b';
            inner2.innerHTML = '<span style="font-size:9px;font-weight:800;color:#f59e0b">🏖️ OFF</span>';
          } else if (isPatternOff && asgn.shiftId) {
            // Pattern OFF - show subtle indicator
            inner2.style.borderColor = '#e2e8f0';
            inner2.style.background = isWe ? '#f8f9fa' : 'transparent';
            inner2.innerHTML = '<span style="font-size:9px;font-weight:600;color:#cbd5e1">— off —</span>';
          }
          if (window._userRole === 'admin') {
            inner2.onclick = function() { ttOpenExceptionModal(ai, dk); };
          } else if (asgn.managerEmail.toLowerCase() === (window._userEmail||'').toLowerCase()) {
            inner2.style.cursor = 'pointer';
            (function(dateKey) { inner2.onclick = function() { ttOpenRequestModal(dateKey); }; })(dk);
          } else {
            inner2.style.cursor = 'default';
          }
          cell.appendChild(inner2);
        }
        row.appendChild(cell);
      });
      wrap.appendChild(row);
    });
  }
  container.appendChild(wrap);
  // Wire label default buttons
  container.querySelectorAll('.tt-lbl-default-btn').forEach(function(btn){
    btn.onclick=function(){ ttOpenLabelPicker(parseInt(this.dataset.lblai), ttDateKey(new Date())); };
  });
  // Wire inline label chips
  container.querySelectorAll('.tt-label-chip').forEach(function(chip){
    chip.onclick=function(e){ e.stopPropagation(); ttOpenLabelPicker(parseInt(this.dataset.ai), this.dataset.dk); };
  });
}

// ── MONTH VIEW (calendar grid: each cell = 1 day, shows all managers) ──
function ttRenderMonthGrid(container, teamAssignments, shiftColorMap, today, monthNames, dayNames) {
  var dates = ttGetDatesForView();
  var curMonth = ttViewDate.getMonth();

  var titleEl = document.createElement('div');
  titleEl.style.cssText = 'font-size:15px;font-weight:800;color:#1e293b;margin-bottom:12px';
  titleEl.textContent = monthNames[ttViewDate.getMonth()] + ' ' + ttViewDate.getFullYear();
  container.appendChild(titleEl);

  var wrap = document.createElement('div');
  wrap.style.cssText = 'background:#fff;border-radius:16px;border:1.5px solid #e2e8f0;overflow:hidden';

  // Day-of-week header
  var header = document.createElement('div');
  header.style.cssText = 'display:grid;grid-template-columns:repeat(7,1fr);background:#f8fafc;border-bottom:2px solid #e2e8f0';
  dayNames.forEach(function(dn, di) {
    var isWe = di >= 5;
    var h2 = document.createElement('div');
    h2.style.cssText = 'padding:10px 0;text-align:center;font-size:11px;font-weight:800;color:' + (isWe?'#a78bfa':'#64748b') + ';text-transform:uppercase;letter-spacing:0.5px';
    h2.textContent = dn;
    header.appendChild(h2);
  });
  wrap.appendChild(header);

  // Calendar cells
  var grid = document.createElement('div');
  grid.style.cssText = 'display:grid;grid-template-columns:repeat(7,1fr)';

  dates.forEach(function(d) {
    var dk = ttDateKey(d);
    var isToday = dk === today;
    var isWe = d.getDay()===0||d.getDay()===6;
    var isOtherMonth = d.getMonth() !== curMonth;

    var cell = document.createElement('div');
    cell.style.cssText = 'min-height:100px;padding:6px;border-right:1px solid #f1f5f9;border-bottom:1px solid #f1f5f9;background:' +
      (isToday?'#f5f3ff':isOtherMonth?'#fafafa':isWe?'#fdfdff':'#fff') + ';position:relative;box-sizing:border-box';

    // Date number
    var dateNum = document.createElement('div');
    dateNum.style.cssText = 'display:flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:' +
      (isToday?'#6366f1':'transparent') + ';color:' + (isToday?'#fff':isOtherMonth?'#cbd5e1':isWe?'#a78bfa':'#1e293b') + ';font-size:12px;font-weight:' + (isToday?'900':'700') + ';margin-bottom:4px';
    dateNum.textContent = d.getDate();
    cell.appendChild(dateNum);

    // Shifts for each manager — sorted by start time
    var dayEntries = [];
    teamAssignments.forEach(function(asgn, ai) {
      var activeSh = ttGetShiftForDate(asgn, d);
      var isOff = !activeSh && (asgn.exceptions && asgn.exceptions.find(function(e){return e.date===dk&&e.type==='off';}));
      if (!activeSh && !isOff) return;
      var mgr = (qaAllUsers||[]).find(function(u){return u.email===asgn.managerEmail;});
      var mgrName = mgr ? (mgr.nickname||mgr.name||asgn.managerEmail.split('@')[0]) : asgn.managerEmail.split('@')[0];
      var sortKey = activeSh ? parseInt((activeSh.startTime||'99:00').split(':')[0])*60 + parseInt((activeSh.startTime||'99:00').split(':')[1]||0) : 9999;
      dayEntries.push({ asgn:asgn, ai:ai, activeSh:activeSh, mgrName:mgrName, sortKey:sortKey, isOff:isOff });
    });
    dayEntries.sort(function(a,b){ return a.sortKey - b.sortKey; });
    dayEntries.forEach(function(entry) {
      var asgn = entry.asgn; var ai = entry.ai; var activeSh = entry.activeSh; var mgrName = entry.mgrName;

      var pill = document.createElement('div');
      if (activeSh) {
        var col = shiftColorMap[activeSh.id]||'#6366f1';
        var s = ttAdjustTime(activeSh.startTime, ttTimezone);
        var e2 = ttAdjustTime(activeSh.endTime, ttTimezone);
        pill.style.cssText = 'padding:2px 6px;border-radius:5px;background:' + hexToRgba(col,0.08) + ';border-left:3px solid ' + col + ';margin-bottom:2px;cursor:pointer;transition:background 0.1s';
        var _mLunch = ttAdjustTime(ttGetLunchTime(entry.asgn, dk), ttTimezone);
        var _mLabels = (entry.asgn.dayLabels||{})[dk] || [];
        var _mLblData = ttGetLabels();
        var _mLblHtml = _mLabels.map(function(lid){ var l=_mLblData.find(function(x){return x.id===lid;}); return l?'<span style="display:inline-block;padding:1px 4px;border-radius:3px;font-size:7px;font-weight:700;background:'+l.color+';color:'+(l.textColor||'#fff')+';margin-right:1px">'+l.text+'</span>':''; }).join('');
        pill.innerHTML = '<div style="font-size:9px;font-weight:800;color:' + col + ';overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + mgrName + '</div>' +
          '<div style="font-size:8px;color:' + col + ';opacity:0.7">' + s + '–' + e2 + (_mLunch?' 🍽️'+_mLunch+'–'+ttLunchEndTime(_mLunch,entry.asgn&&entry.asgn.lunchDuration):'') + '</div>' +
          (_mLblHtml ? '<div style="margin-top:1px">'+_mLblHtml+'</div>' : '');
        pill.onmouseover = function(){ this.style.background=hexToRgba(col,0.16); };
        pill.onmouseout  = function(){ this.style.background=hexToRgba(col,0.08); };
        (function(_ai2, _dk2, _isAdmin, _isOwn, _shName) {
          if (_isAdmin) {
            pill.onclick = function(e){ if(e.target.classList&&e.target.classList.contains('tt-label-chip')) return; ttOpenExceptionModal(_ai2, _dk2); };
            pill.oncontextmenu = function(e){ e.preventDefault(); ttOpenLunchModal(_ai2, _dk2); };
          } else if (_isOwn) {
            pill.onclick = function(e){ if(e.target.classList&&e.target.classList.contains('tt-label-chip')) return; ttOpenRequestModal(_dk2, _shName); };
            pill.oncontextmenu = function(e){ e.preventDefault(); ttOpenLunchModal(_ai2, _dk2); };
            pill.addEventListener('dblclick', function(){ ttOpenLabelPicker(_ai2, _dk2); });
          }
        })(ai, dk, window._userRole==='admin', asgn.managerEmail.toLowerCase()===(window._userEmail||'').toLowerCase(), activeSh && activeSh.name);
      } else {
        pill.style.cssText = 'padding:2px 6px;border-radius:5px;background:#fff7ed;border-left:3px solid #f59e0b;margin-bottom:2px;cursor:pointer';
        pill.innerHTML = '<div style="font-size:9px;font-weight:800;color:#92400e;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + mgrName + ' — OFF</div>';
        if (window._userRole === 'admin') {
          pill.onclick = function() { ttOpenExceptionModal(ai, dk); };
        }
      }
      cell.appendChild(pill);
    });

    grid.appendChild(cell);
  });
  wrap.appendChild(grid);
  container.appendChild(wrap);
}

// ── DAY VIEW (vertical timeline: hours as rows, managers as columns) ──
function ttRenderDayGrid(container, teamAssignments, shiftColorMap, today, monthNames, dayNames) {
  var d = ttViewDate;
  var dk = ttDateKey(d);
  var isToday = dk === today;
  var dayIdx = (d.getDay()+6)%7;

  // Title
  var titleEl = document.createElement('div');
  titleEl.style.cssText = 'font-size:15px;font-weight:800;color:#1e293b;margin-bottom:12px;display:flex;align-items:center;gap:10px';
  titleEl.innerHTML = '<span>' + dayNames[dayIdx] + ', ' + d.getDate() + ' ' + monthNames[d.getMonth()] + ' ' + d.getFullYear() + '</span>' +
    (isToday ? '<span style="padding:3px 10px;background:#6366f1;color:#fff;border-radius:20px;font-size:10px;font-weight:700">Today</span>' : '');
  container.appendChild(titleEl);

  if (!teamAssignments.length) {
    var empty = document.createElement('div');
    empty.style.cssText = 'padding:50px;text-align:center;color:#94a3b8;background:#fff;border-radius:16px;border:1.5px solid #e2e8f0;font-size:13px';
    empty.textContent = 'No managers assigned. Click "+ Assign Manager" to start.';
    container.appendChild(empty);
    return;
  }

  // Pre-compute shift info for each manager
  var mgrsInfo = teamAssignments.map(function(asgn, ai) {
    var mgr = (qaAllUsers||[]).find(function(u){return u.email===asgn.managerEmail;});
    var mgrName = mgr ? (mgr.nickname||mgr.name||asgn.managerEmail.split('@')[0]) : asgn.managerEmail.split('@')[0];
    var activeSh = ttGetShiftForDate(asgn, d);
    var col = activeSh ? (shiftColorMap[activeSh.id]||'#6366f1') : null;
    var startH = null, endH = null;
    if (activeSh) {
      startH = parseInt((activeSh.startTime||'09:00').split(':')[0]);
      var rawEndH = parseInt((activeSh.endTime||'18:00').split(':')[0]);
      endH = (rawEndH === 0) ? 24 : rawEndH; // midnight "00:00" → 24
      if (ttTimezone === 'warsaw') { startH--; endH--; }
      if (startH < 0) startH = 0;
      if (endH < 0) endH = 24;
    }
    var isEx = asgn.exceptions && asgn.exceptions.find(function(e){return e.date===dk&&e.type==='off';});
    return { asgn:asgn, ai:ai, mgrName:mgrName, activeSh:activeSh, col:col, startH:startH, endH:endH, isManualOff:!!isEx };
  });

  // Compute hour range
  // Always show full 24-hour day so night shifts are visible
  var minHour = 0;
  var maxHour = 24;

  var shColors = ['#6366f1','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#84cc16'];
  function hexToRgba(hex, alpha) {
    var r = parseInt(hex.slice(1,3),16);
    var g = parseInt(hex.slice(3,5),16);
    var b = parseInt(hex.slice(5,7),16);
    return 'rgba('+r+','+g+','+b+','+alpha+')';
  }

  var cols = mgrsInfo.length;
  var gridCols = '60px repeat(' + cols + ',1fr)';

  var wrap = document.createElement('div');
  wrap.style.cssText = 'background:#fff;border-radius:16px;border:1.5px solid #e2e8f0;overflow:hidden';

  // ── HEADER: Manager columns ──
  var header = document.createElement('div');
  header.style.cssText = 'display:grid;grid-template-columns:' + gridCols + ';background:#f8fafc;border-bottom:2px solid #e2e8f0';

  var tzCell = document.createElement('div');
  tzCell.style.cssText = 'padding:12px 8px;font-size:9px;font-weight:800;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;border-right:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center';
  tzCell.textContent = ttTimezone === 'warsaw' ? 'WAW' : 'KYV';
  header.appendChild(tzCell);

  mgrsInfo.forEach(function(info) {
    var col = info.col || '#94a3b8';
    var cell = document.createElement('div');
    cell.style.cssText = 'padding:10px 8px;border-right:1px solid #e2e8f0;text-align:center;border-top:3px solid ' + col;
    cell.innerHTML =
      '<div style="font-size:11px;font-weight:800;color:#1e293b;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + info.mgrName + '</div>' +
      '<div style="margin-top:4px">';
    if (info.activeSh) {
      cell.innerHTML += '<span style="display:inline-block;padding:2px 8px;background:' + hexToRgba(col, 0.12) + ';border:1px solid ' + hexToRgba(col, 0.3) + ';border-radius:20px;font-size:10px;font-weight:700;color:' + col + '">' +
        info.activeSh.name + ' · ' + ttAdjustTime(info.activeSh.startTime, ttTimezone) + '–' + ttAdjustTime(info.activeSh.endTime, ttTimezone) + '</span>';
    } else {
      cell.innerHTML += '<span style="display:inline-block;padding:2px 8px;background:#fef2f2;border:1px solid #fca5a5;border-radius:20px;font-size:10px;font-weight:700;color:#ef4444">Day Off</span>';
    }
    cell.innerHTML += '</div>';
    header.appendChild(cell);
  });
  wrap.appendChild(header);

  // ── BODY: Hour rows ──
  var body = document.createElement('div');
  body.style.cssText = 'max-height:540px;overflow-y:auto';

  var nowHour = new Date().getHours();

  var displayMaxHour = 23; // show 00:00–23:00 rows (24 rows total)
  for (var hour = minHour; hour <= displayMaxHour; hour++) {
    var isCurrentHour = isToday && nowHour === hour;
    var hRow = document.createElement('div');
    hRow.style.cssText = 'display:grid;grid-template-columns:' + gridCols + ';min-height:52px;border-bottom:1px solid ' + (isCurrentHour ? '#c4b5fd' : '#f1f5f9') + ';background:' + (isCurrentHour ? '#faf5ff' : '#fff');

    // Time label
    var timeLabel = document.createElement('div');
    timeLabel.style.cssText = 'padding:0 8px;font-size:10px;font-weight:' + (isCurrentHour?'800':'600') + ';color:' + (isCurrentHour?'#6366f1':'#94a3b8') + ';border-right:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center;white-space:nowrap;background:' + (isCurrentHour ? '#f0ebff' : '#fafafa');
    timeLabel.textContent = String(hour).padStart(2,'0') + ':00';
    hRow.appendChild(timeLabel);

    // Capture hour for closure
    (function(h) {
      mgrsInfo.forEach(function(info) {
        var cell = document.createElement('div');
        cell.style.cssText = 'border-right:1px solid #f1f5f9;cursor:pointer;display:flex;align-items:stretch';

        if (info.activeSh && info.startH !== null) {
          // Handle cross-midnight shifts (e.g. 23:00–08:00)
          var crossMidnight = info.endH < info.startH;
          var isWorking = crossMidnight
            ? (h >= info.startH || h < info.endH)
            : (h >= info.startH && h < info.endH);
          var col = info.col;
          var bg = isWorking ? hexToRgba(col, 0.10) : 'transparent';
          cell.style.background = bg;

          if (isWorking) {
            var inner = document.createElement('div');
            inner.style.cssText = 'flex:1;display:flex;align-items:stretch;padding:2px 4px';
            var _tLunch = ttAdjustTime(ttGetLunchTime(info.asgn, dk), ttTimezone);
            var _tLunchH = _tLunch ? parseInt(_tLunch.split(':')[0]) : -1;
            var _tLabels = (info.asgn.dayLabels||{})[dk]||[];
            var _tLblData = ttGetLabels();
