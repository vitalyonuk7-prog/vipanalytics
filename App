    h += '<div style="font-size:13px;font-weight:800;color:#1e293b;margin-bottom:8px">\uD83D\uDC65 ' + tn + '</div>';
    h += '<div style="display:flex;align-items:center;gap:12px"><div style="font-size:28px;font-weight:900;color:' + tc + '">' + tp + '%</div>';
    h += '<div style="flex:1"><div style="height:6px;background:#f1f5f9;border-radius:3px;overflow:hidden"><div style="height:100%;width:' + tp + '%;background:' + tc + ';border-radius:3px"></div></div>';
    h += '<div style="font-size:10px;color:#94a3b8;margin-top:3px">' + tm.count + ' managers' + (tpO !== null ? ' \u2022 >1mo: ' + tpO + '%' : '') + '</div></div></div></div>';
  });
  h += '</div>';

  // Manager cards
  h += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px">';
  entries.forEach(function(e, ei) {
    var pct = e.pct; var cc = completionColor(pct);
    var emoji = qaGetUserEmoji(e.user.email);
    var mgrFor = e.user.manager || e.data.name || '';
    h += '<div data-ei="' + ei + '" class="qa-comp-card" style="background:#fff;border:1.5px solid #e2e8f0;border-radius:16px;overflow:hidden;cursor:pointer;transition:all 0.2s" onmouseover="this.style.borderColor=\'' + cc + '40\';this.style.boxShadow=\'0 6px 20px rgba(0,0,0,0.06)\'" onmouseout="this.style.borderColor=\'#e2e8f0\';this.style.boxShadow=\'\'">';
    h += '<div style="height:4px;background:linear-gradient(90deg,' + cc + ',' + cc + '80)"></div>';
    h += '<div style="padding:16px">';
    h += '<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">';
    h += '<div style="width:42px;height:42px;border-radius:12px;background:' + cc + '10;display:flex;align-items:center;justify-content:center;font-size:20px">' + emoji + '</div>';
    h += '<div style="flex:1;min-width:0"><div style="font-weight:800;font-size:14px;color:#1e293b">' + qaLabel(e.user) + '</div>';
    h += '<div style="font-size:10px;color:#94a3b8">\uD83D\uDC64 ' + mgrFor + ' \u2022 ' + e.team + ' \u2022 ' + e.data.players + ' players</div></div>';
    h += '<div style="text-align:center"><div style="font-size:24px;font-weight:900;color:' + cc + '">' + pct + '%</div><div style="font-size:8px;font-weight:700;color:#94a3b8;text-transform:uppercase">total</div></div></div>';
    // Progress bar
    h += '<div style="height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden;margin-bottom:8px"><div style="height:100%;width:' + pct + '%;background:' + cc + ';border-radius:3px"></div></div>';
    // Stats row
    h += '<div style="display:flex;gap:10px;font-size:11px">';
    h += '<div><span style="color:#94a3b8">Fields:</span> <span style="font-weight:700">' + e.data.filled + '/' + e.data.total + '</span></div>';
    if (e.pctOld !== null) {
      var ccO = completionColor(e.pctOld);
      h += '<div><span style="color:#94a3b8">>1mo:</span> <span style="font-weight:700;color:' + ccO + '">' + e.pctOld + '% (' + e.data.playersOld + ' players)</span></div>';
    }
    h += '<div><span style="color:#94a3b8">\u226580%:</span> <span style="font-weight:700;color:' + (e.data.playersFull === e.data.players ? '#10b981' : '#f59e0b') + '">' + e.data.playersFull + '/' + e.data.players + '</span></div>';
