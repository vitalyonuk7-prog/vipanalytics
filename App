function heatmapColor(pct){const p=Math.max(0,Math.min(1,pct));const colors=['#f8fafc','#e0e7ff','#c7d2fe','#a5b4fc','#818cf8','#6366f1','#4f46e5','#4338ca','#3730a3','#312e81'];return colors[Math.floor(p*9)]}
function depositHeatmapColor(pct,rowIndex,maxRows){
  var p = Math.max(0, Math.min(1, pct));
  if (p === 0) return '#f8fafc';
  // ✅ Even smallest non-zero value gets visible color
  // Map 0→1 to range 0.15→1.0 so minimum is clearly colored
  p = 0.15 + p * 0.85;
  // Deep purple gradient with high saturation
  var r = Math.round(238 - p * 189); // 238→49
  var g = Math.round(240 - p * 194); // 240→46  
  var b = Math.round(255 - p * 92);  // 255→163
  return 'rgb('+r+','+g+','+b+')';
}
function retentionHeatmapColor(pct,columnOffset,maxOffset){
  var p=Math.max(0,Math.min(1,pct));
  if(p===0) return '#f8fafc';
  // Red(0%) → Orange(25%) → Yellow(50%) → LightGreen(75%) → Green(100%)
  var r,g,b;
  if(p<0.25){var t=p/0.25;r=Math.round(220-t*30);g=Math.round(60+t*100);b=Math.round(60+t*10)}
  else if(p<0.5){var t=(p-0.25)/0.25;r=Math.round(190-t*40);g=Math.round(160+t*40);b=Math.round(70-t*10)}
  else if(p<0.75){var t=(p-0.5)/0.25;r=Math.round(150-t*80);g=Math.round(200+t*20);b=Math.round(60+t*30)}
  else{var t=(p-0.75)/0.25;r=Math.round(70-t*30);g=Math.round(220-t*40);b=Math.round(90+t*30)}
  // Lighten slightly for distant columns
  var lighten=Math.min(0.3,columnOffset/(maxOffset||1)*0.3);
  r=Math.round(r+(255-r)*lighten);g=Math.round(g+(255-g)*lighten);b=Math.round(b+(255-b)*lighten);
  return 'rgb('+r+','+g+','+b+')'
}

function getTextColor(bg){
  var r,g,b;
  if(bg.startsWith('rgb')){
    var m=bg.match(/(\d+)/g);
    if(m&&m.length>=3){r=parseInt(m[0]);g=parseInt(m[1]);b=parseInt(m[2])}else{return'#1e293b'}
  }else{
    var hex=bg.replace('#','');
    r=parseInt(hex.substr(0,2),16);g=parseInt(hex.substr(2,2),16);b=parseInt(hex.substr(4,2),16);
  }
  return((r*299+g*587+b*114)/1000)>155?'#1e293b':'#f8fafc';
}

