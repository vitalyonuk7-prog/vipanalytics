  h += '<div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Total</div><div style="font-size:20px;font-weight:900;color:#1e293b">' + total + '</div></div>';
  h += '<div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Months Active</div><div style="font-size:20px;font-weight:900;color:#667eea">' + months.filter(function(m) { return monthData[m] > 0; }).length + '</div></div>';
  h += '<div><div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">Avg/Month</div><div style="font-size:20px;font-weight:900;color:#f59e0b">' + (months.length > 0 ? (total / months.length).toFixed(1) : '0') + '</div></div>';
  h += '</div>';

  document.getElementById('qaFDBody').innerHTML = h;
  document.getElementById('qaFailDetailModal').style.display = 'flex';

  // Draw chart
  setTimeout(function() {
    var canvas = document.getElementById('qaFDChart'); if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var labels = months.map(qaFmtMonth);
    var data = months.map(function(m) { return monthData[m] || 0; });
