function ppMarkContactedCustom(email, dateStr) {
  if (!playerContactsCache[email]) playerContactsCache[email] = { lastDate: null, history: [] };
  var info = playerContactsCache[email];
  // Insert in sorted position (newest first)
  info.history.unshift(dateStr);
  info.history.sort(function(a,b){ return b.localeCompare(a); });
  if (info.history.length > 100) info.history = info.history.slice(0,100);
  info.lastDate = info.history[0];
  // Update UI
  var lastEl = document.getElementById('ppLastContactDate');
  if (lastEl) { lastEl.textContent = info.lastDate; lastEl.style.color='#b45309'; }
  var thisMonth = ppTodayStr().slice(0,7);
  var monthCount = info.history.filter(function(d){ return d && d.slice(0,7)===thisMonth; }).length;
  var monthEl = document.getElementById('ppMonthCount');
  if (monthEl) monthEl.textContent = monthCount;
  var histEl = document.getElementById('ppContactHistoryList');
  if (histEl) ppFillHistoryContainer(histEl, info.history, email);
  var headerDateEl = document.getElementById('ppHeaderLastDate');
  if (headerDateEl) headerDateEl.textContent = info.lastDate || '';
  if (profilingData.viewMode === 'calendar') renderProfilingCalendar();
  showToast('✅ Contact added: ' + dateStr);
  // Save full sorted history
  google.script.run
    .withFailureHandler(function(e){ showToast('⚠️ Save error: '+e); })
    .savePlayerContactHistory(email, info.history);
}

function ppMarkContacted(email) {
  var btn = document.getElementById('ppContactedBtn');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Saving...'; btn.style.opacity = '0.6'; }
  var today = ppTodayStr();

  // Optimistic update
  if (!playerContactsCache[email]) playerContactsCache[email] = { lastDate: null, history: [] };
  var info = playerContactsCache[email];
  info.history.unshift(today);
  if (info.history.length > 100) info.history = info.history.slice(0, 100);
  info.lastDate = today;

  // Update UI instantly
  var lastEl = document.getElementById('ppLastContactDate');
  if (lastEl) { lastEl.textContent = today; lastEl.style.color = '#b45309'; }
  var thisMonth = today.slice(0,7);
  var monthCount = info.history.filter(function(d){ return d && d.slice(0,7) === thisMonth; }).length;
  var monthEl = document.getElementById('ppMonthCount');
  if (monthEl) monthEl.textContent = monthCount;
  var histEl = document.getElementById('ppContactHistoryList');
  if (histEl) ppFillHistoryContainer(histEl, info.history, email);
  else {
    // If no history section yet, re-render tab
    var player = profilingData.selectedPlayer;
    if (player) {
      var contentArea = document.querySelector('#profilingPlayerDetail .section-content-area, #vipPlayerDetails > div > div');
      if (contentArea) renderProfilingContactTab(player, contentArea);
    }
  }
  if (btn) { btn.disabled = false; btn.textContent = '📞 Contacted'; btn.style.opacity = '1'; }

  // Update calendar if active
  if (profilingData.viewMode === 'calendar') renderProfilingCalendar();

  // Save to server
  google.script.run
    .withSuccessHandler(function(r) {
      if (!r || !r.success) showToast('⚠️ Contact save failed');
      else showToast('✅ Contact recorded: ' + today);
    })
    .withFailureHandler(function(e) { showToast('⚠️ Error: ' + e); })
    .savePlayerContact(email, today);
}

