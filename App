function qaResolveSubmit() {
  var comment = document.getElementById('qaAppealText').value.trim();
  var params = { id: _qaResolveAppealId, status: _qaResolveAction, comment: comment, resolved_by: window._userEmail || '' };
  if (_qaResolveAction === 'downgraded') {
    var lvEl = document.getElementById('qaAppealNewLevel');
    params.new_level = lvEl ? lvEl.value : 'warning';
    params.new_pct = lvEl ? parseFloat(lvEl.options[lvEl.selectedIndex].dataset.pct) || 0 : 0;
  }
  document.getElementById('qaAppealModal').style.display = 'none';
  
  // Optimistic: update local data immediately
  var appeal = qaAppeals.find(function(x) { return String(x.id) === String(_qaResolveAppealId); });
  console.log('Resolve optimistic: appealId=' + _qaResolveAppealId + ' found=' + !!appeal);
  if (appeal) {
    appeal.status = params.status;
    appeal.admin_comment = comment;
    // Update scorecard locally too
    var res = qaResults.find(function(x) { return String(x.manager).toLowerCase() === String(appeal.manager).toLowerCase() && String(x.month) === String(appeal.month); });
    console.log('Resolve: scorecard found=' + !!res + ' manager=' + appeal.manager + ' month=' + appeal.month);
    if (res) {
      var failures = []; try { failures = JSON.parse(res.failures_json || '[]'); } catch(e) {}
      var abi = parseInt(appeal.bi); var aei = parseInt(appeal.ei); var afi = appeal.fi !== undefined ? parseInt(appeal.fi) : -1;
      var matched = false;
      for (var fi = 0; fi < failures.length; fi++) {
        var isMatch = (afi >= 0) ? (fi === afi) : (parseInt(failures[fi].bi) === abi && parseInt(failures[fi].ei) === aei);
        if (isMatch) {
          matched = true;
          console.log('Resolve: matched failure fi=' + fi + ' afi=' + afi + ' bi=' + abi + ' ei=' + aei);
          if (params.status === 'accepted') {
            failures[fi].original_pct = failures[fi].pct;
            failures[fi].pct = 0;
            failures[fi].appealed = 'accepted';
            failures[fi].appeal_comment = comment;
          } else if (params.status === 'downgraded') {
            failures[fi].original_pct = failures[fi].pct;
            failures[fi].original_level = failures[fi].level;
            failures[fi].level = params.new_level;
            failures[fi].pct = parseFloat(params.new_pct) || 0;
            failures[fi].appealed = 'downgraded';
            failures[fi].appeal_comment = comment;
          } else {
            failures[fi].appealed = 'rejected';
            failures[fi].appeal_comment = comment;
          }
          break;
        }
      }
      // Recalculate score
      if (!matched) console.log('Resolve: NO MATCH in ' + failures.length + ' failures');
      var td = 0; failures.forEach(function(f) { if (f.level !== 'warning') td += parseFloat(f.pct) || 0; });
      res.score = String(Math.max(0, 100 - td));
      res.failures_json = JSON.stringify(failures);
      console.log('Resolve: new score=' + res.score);
    }
  } else {
    console.log('Resolve: appeal NOT FOUND in qaAppeals, count=' + qaAppeals.length);
  }
  // Always re-render both views
  try { qaRenderPage(); } catch(e) {}
  try { if (typeof qcRenderPage === 'function') qcRenderPage(); } catch(e) {}
  showToast('Appeal ' + params.status);
  
  // Sync with server in background, re-render when done
  google.script.run.withSuccessHandler(function(r) {
    if (!r || !r.success) { showToast('Sync error: ' + (r ? r.error : '')); }
    var done = 0;
    function ckSync() {
      done++;
      if (done >= 2) {
        try { qaRenderPage(); } catch(e) {}
        try { if (typeof qcRenderPage === 'function') qcRenderPage(); } catch(e) {}
      }
    }
    google.script.run.withSuccessHandler(function(r2) { if (r2 && r2.success) qaResults = r2.rows || []; ckSync(); }).getQaResults();
    google.script.run.withSuccessHandler(function(r3) { if (r3 && r3.success) qaAppeals = r3.appeals || []; ckSync(); }).getQaAppeals();
  }).withFailureHandler(function(e) { showToast('Error: ' + e); }).resolveQaAppeal(params);
}

