function getSegmentData() {
  var groups = window.kpiGroups || {};
  var totalTab = null;
  var segments = [];
  var groupTotals = [];
  Object.keys(kpiDataByTab).forEach(function(tab) {
    var g = groups[tab];
    if (!g && tab.toUpperCase().indexOf('TOTAL') !== -1) {
      totalTab = tab;
    } else if (g) {
      if (tab.toUpperCase().indexOf('TOTAL') !== -1) {
        groupTotals.push(tab);
      } else {
        segments.push(tab);
      }
    }
  });
  if (!totalTab || (segments.length === 0 && groupTotals.length === 0)) return null;
  segments.sort(function(a, b) { return a.localeCompare(b); });
  groupTotals.sort(function(a, b) { return a.localeCompare(b); });
  return { totalTab: totalTab, segments: segments, groupTotals: groupTotals };
}

function findMetricKey(metrics, patterns) {
  var metricsLower = {};
  metrics.forEach(function(m) { metricsLower[m.toLowerCase().trim()] = m; });
  for (var i = 0; i < patterns.length; i++) {
    if (metricsLower[patterns[i]]) return metricsLower[patterns[i]];
  }
  for (var j = 0; j < metrics.length; j++) {
    var ml = metrics[j].toLowerCase();
    for (var k = 0; k < patterns.length; k++) {
      var words = patterns[k].split(' ');
      if (words.every(function(w) { return ml.indexOf(w) !== -1; })) return metrics[j];
    }
  }
  return null;
}

function getMetricVal(tabName, ym, metricKey) {
  var data = kpiDataByTab[tabName];
  if (!data || !data.months || !metricKey) return 0;
  if (ym === '__ALL__') {
    var sum = 0;
    data.months.forEach(function(m) { sum += (m.monthly[metricKey] || m.sumWeeks[metricKey] || 0); });
    return sum;
  }
  for (var i = 0; i < data.months.length; i++) {
    if (data.months[i].ym === ym) return data.months[i].monthly[metricKey] || data.months[i].sumWeeks[metricKey] || 0;
  }
  return 0;
}

