function doCreateCalEvent() {
  var dateVal = document.getElementById('calCreateDate').value;
  var name = document.getElementById('calCreateName').value.trim();
  var type = document.getElementById('calCreateType').value;
  var desc = document.getElementById('calCreateDesc').value.trim();
  
  if (!dateVal) { document.getElementById('calCreateDate').style.borderColor = '#ef4444'; return; }
  if (!name) { document.getElementById('calCreateName').style.borderColor = '#ef4444'; return; }
  
  // Parse to dd.MM.yyyy
  var parts = dateVal.split('-');
  var dateFormatted = parts[2] + '.' + parts[1] + '.' + parts[0];
  
  var btn = document.getElementById('calCreateBtn');
  btn.textContent = 'Saving...';
  btn.disabled = true;
  
  // Optimistic: add to local array immediately
  var evDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
  var today = new Date(); today.setHours(0,0,0,0);
  var diffDays = Math.ceil((evDate - today) / 86400000);
  var monthNames3 = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var dayNames3 = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  
  var newEvent = {
    date: dateFormatted,
    dateShort: parseInt(parts[2]) + ' ' + monthNames3[parseInt(parts[1]) - 1],
    dayOfWeek: dayNames3[evDate.getDay()],
    event: name,
    type: type,
    description: desc,
    status: '',
    daysUntil: diffDays,
    isPast: diffDays < 0,
    isToday: diffDays === 0
  };
  
  calEvents.push(newEvent);
  renderCalendar();
  
  // Navigate to event month if different
  var evMonth = parseInt(parts[1]) - 1;
  var evYear = parseInt(parts[0]);
  if (evMonth !== calMonth || evYear !== calYear) {
    calMonth = evMonth;
    calYear = evYear;
    renderCalendar();
  }
  calSelectDay(parseInt(parts[2]));
  
  document.getElementById('calCreateModal').style.display = 'none';
  btn.textContent = 'Create Event';
  btn.disabled = false;
  showToast('✅ Event "' + name + '" added');
  
  // Save to backend
  google.script.run
    .withFailureHandler(function(err) { showToast('❌ Save failed: ' + err.message); })
    .addCalendarEvent({ date: dateFormatted, event: name, type: type, description: desc });
}

