function renderBonusBarDetailModalContent() {
  var period = window._barDetailPeriod;
  var groups = window._bonusBarPeriodGroups;
  if(!groups || !groups[period]) return;
  var rows = groups[period];
  var tc = getBonusTypeColors();
  var metricKey = bonusChartMetric;
  var colLabel = BONUS_ALL_COLS.find(function(c){return c.key===metricKey;});
  var metricLabel = colLabel ? colLabel.label : metricKey;
  var isCount = metricKey.indexOf('count')===0;
  function fmtVal(v){ return isCount ? v.toLocaleString() : '€'+v.toLocaleString('en',{maximumFractionDigits:2}); }
  
  // Build items with all metrics
  var items = rows.map(function(r){
    return { type:r.type, title:r.title, countIssued:r.countIssued||0, totalInEUR:r.totalInEUR||0, betsEUR:r.betsEUR||0, depositEUR:r.depositEUR||0, countCancelled:r.countCancelled||0, countWagerDone:r.countWagerDone||0, countActive:r.countActive||0, metricVal:r[metricKey]||0 };
  });
  
  var sk = _barDetailSort.key, sd = _barDetailSort.dir;
  items.sort(function(a,b){
    var va = a[sk]!==undefined?a[sk]:a.metricVal, vb = b[sk]!==undefined?b[sk]:b.metricVal;
    if(typeof va==='string') return sd==='asc'?va.localeCompare(vb):vb.localeCompare(va);
    return sd==='asc'?va-vb:vb-va;
  });
  
  var grandTotal = items.reduce(function(a,i){return a+i.metricVal;},0);
  function arrow(k){ return _barDetailSort.key===k?(_barDetailSort.dir==='asc'?' ↑':' ↓'):''; }
  var thS = 'padding:10px 12px;color:#fff;font-size:11px;font-weight:700;text-transform:uppercase;cursor:pointer;user-select:none';
  
  var html = '<div style="display:flex;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center" id="bonusBarDetailModal" onclick="if(event.target.id===\'bonusBarDetailModal\')this.remove()">';
  html += '<div style="background:#fff;border-radius:16px;max-width:850px;width:95%;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.3)">';
  html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:2px solid #e2e8f0">';
  html += '<div><h2 style="margin:0;font-size:20px;font-weight:800;color:#1e293b">📊 '+period+'</h2>';
  html += '<div style="font-size:13px;color:#64748b;font-weight:600;margin-top:4px">'+metricLabel+': '+fmtVal(grandTotal)+' • '+items.length+' bonuses</div></div>';
  html += '<button onclick="this.closest(\'#bonusBarDetailModal\').remove()" style="background:none;border:none;font-size:28px;color:#64748b;cursor:pointer;line-height:1">×</button></div>';
  html += '<div style="overflow-y:auto;flex:1;padding:0 24px 24px">';
  html += '<table style="width:100%;border-collapse:collapse;margin-top:12px">';
  html += '<thead><tr style="background:linear-gradient(135deg,#667eea,#764ba2)">';
  html += '<th style="text-align:left;'+thS+';border-radius:8px 0 0 0" onclick="sortBarDetailModal(\'type\')">Type'+arrow('type')+'</th>';
  html += '<th style="text-align:left;'+thS+'" onclick="sortBarDetailModal(\'title\')">Title'+arrow('title')+'</th>';
  html += '<th style="text-align:right;'+thS+'" onclick="sortBarDetailModal(\'metricVal\')">'+metricLabel+arrow('metricVal')+'</th>';
  html += '<th style="text-align:right;'+thS+'" onclick="sortBarDetailModal(\'countIssued\')">Count'+arrow('countIssued')+'</th>';
