function ppCalRenderWeek(dateMap, today, mNames, dNames) {
  var year = ppCalDate.getFullYear();
  var mon  = ppCalDate.getMonth();
  var firstDay = new Date(year, mon, 1);
  var lastDay  = new Date(year, mon+1, 0);
  var title = mNames[mon] + ' ' + year;
  var h = '<div style="font-size:15px;font-weight:800;color:#1e293b;margin-bottom:12px">' + title + '</div>';
  h += '<div style="background:#fff;border-radius:16px;border:1.5px solid #e2e8f0;overflow:hidden">';

  // Build weeks within the month (only rows that include at least 1 day of this month)
  var weeks = [];
  var cur = new Date(firstDay);
  var startOffset = cur.getDay() === 0 ? 6 : cur.getDay() - 1;
  cur.setDate(cur.getDate() - startOffset);
  while (cur <= lastDay) {
    var week = [];
    for (var i = 0; i < 7; i++) { week.push(new Date(cur)); cur.setDate(cur.getDate()+1); }
    weeks.push(week);
  }

  // Header
  h += '<div style="display:grid;grid-template-columns:72px repeat(7,1fr);background:#f8fafc;border-bottom:2px solid #e2e8f0">';
  h += '<div style="padding:10px 8px;font-size:10px;font-weight:800;color:#94a3b8;text-transform:uppercase;border-right:2px solid #e2e8f0;text-align:center">WEEK</div>';
  dNames.forEach(function(dn, di) {
    h += '<div style="padding:10px 4px;text-align:center;font-size:10px;font-weight:800;color:' + (di>=5?'#a78bfa':'#64748b') + ';text-transform:uppercase">' + dn + '</div>';
  });
  h += '</div>';

  // Week rows
  weeks.forEach(function(week, wi) {
    var mid = week[3];
    var jan1 = new Date(mid.getFullYear(), 0, 1);
    var weekNum = Math.ceil((((mid - jan1) / 86400000) + jan1.getDay() + 1) / 7);
    var rowBg = (wi % 2 === 0) ? '#fff' : '#fafafe';

    // Collect all players in this week across all 7 days
    var weekAllPlayers = [];
    week.forEach(function(d) {
      var dk = ppCalDk(d);
      if (dateMap[dk]) weekAllPlayers = weekAllPlayers.concat(dateMap[dk]);
    });
    var weekTotal = weekAllPlayers.length;
    var weekEnc = encodeURIComponent(weekAllPlayers.map(function(p){ return p.data.email||''; }).join('||'));

    h += '<div style="display:grid;grid-template-columns:72px repeat(7,1fr);border-bottom:1px solid #f1f5f9;background:' + rowBg + ';min-height:72px">';

    // Week label column
    h += '<div style="padding:8px 6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-right:2px solid #e2e8f0;background:#f8fafc">';
    h += '<div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase">WK ' + weekNum + '</div>';
    if (weekTotal > 0) {
      h += '<div data-ppemails="' + weekEnc + '" data-ppdate="Week ' + weekNum + '" class="pp-cal-bubble" style="display:inline-flex;align-items:center;justify-content:center;min-width:30px;height:30px;padding:0 8px;border-radius:20px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-size:13px;font-weight:900;cursor:pointer;box-shadow:0 2px 8px rgba(102,126,234,0.4);transition:transform 0.15s">' + weekTotal + '</div>';
    } else {
      h += '<div style="font-size:11px;color:#e2e8f0;font-weight:600">—</div>';
    }
    h += '</div>';

    // Day cells
    week.forEach(function(d) {
      var dk = ppCalDk(d);
      var players = dateMap[dk] || [];
      var cnt = players.length;
      var isT = dk === today;
      var isOtherMonth = d.getMonth() !== mon;
      var isW = d.getDay() === 0 || d.getDay() === 6;
      var bg = isT ? '#f5f3ff' : isOtherMonth ? '#f9f9f9' : isW ? '#fdfdff' : '#fff';

      h += '<div style="padding:8px 4px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:5px;border-right:1px solid #f1f5f9;background:' + bg + '">';
      // Date number
      h += '<div style="width:24px;height:24px;border-radius:50%;background:' + (isT?'#667eea':'transparent') + ';color:' + (isT?'#fff':isOtherMonth?'#d1d5db':isW?'#a78bfa':'#1e293b') + ';font-size:12px;font-weight:' + (isT?'900':'600') + ';display:flex;align-items:center;justify-content:center">' + d.getDate() + '</div>';
      // Count bubble
      if (cnt) {
        var enc = encodeURIComponent(players.map(function(p){ return p.data.email||''; }).join('||'));
        h += '<div data-ppemails="' + enc + '" data-ppdate="' + dk + '" class="pp-cal-bubble" style="display:inline-flex;align-items:center;justify-content:center;min-width:24px;height:24px;padding:0 7px;border-radius:20px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-size:11px;font-weight:800;cursor:pointer;box-shadow:0 2px 5px rgba(102,126,234,0.3);transition:transform 0.15s">' + cnt + '</div>';
