function ttDoChangeShift(ai) {
  var teamAs = (ttData.assignments||[]).filter(function(a){return a.teamId===ttSelectedTeam;});
  var asgn = teamAs[ai]; if (!asgn) return;

  var newShiftId = document.getElementById('ttChShiftSel').value;
  var fromDate   = document.getElementById('ttChShiftDate').value;
  if (!newShiftId || !fromDate) { showToast('⚠️ Select shift and date'); return; }
  if (newShiftId === asgn.shiftId) { showToast('⚠️ Same shift selected'); return; }

  var today = ttDateKey(new Date());

  // If effective date is today or in the future — update assignment from that date
  // Strategy: keep old exceptions, update shiftId and startDate
  // But we need to preserve history → store the old shift as exceptions for days before fromDate
  // Simpler approach: just update startDate + shiftId. Past days in the calendar will show correctly
  // since ttGetShiftForDate recalculates from startDate.
  // To keep past dates showing the OLD shift, we snapshot exceptions for the range [old startDate → fromDate-1]
  
  var oldShiftId  = asgn.shiftId;
  var oldStart    = asgn.startDate;

  // Generate day-by-day exceptions for the historical period [oldStart → fromDate - 1]
  if (oldStart && oldStart < fromDate) {
    if (!asgn.exceptions) asgn.exceptions = [];
    var d = new Date(oldStart + 'T00:00:00');
    var stopD = new Date(fromDate + 'T00:00:00');
    // Only snapshot days where old shift was active (to avoid polluting with off-days that are already correct)
    while (d < stopD) {
      var dk2 = ttDateKey(d);
      // Only add exception if not already set
      var alreadySet = asgn.exceptions.find(function(e){return e.date===dk2;});
      if (!alreadySet) {
        // Check if old shift was working that day (pattern logic)
        var tempAsgn = { shiftId: oldShiftId, startDate: oldStart, exceptions: [] };
        var wasWorking = ttGetShiftForDate(tempAsgn, d);
        if (wasWorking) {
          asgn.exceptions.push({ date: dk2, type: 'shift', shiftId: oldShiftId });
        } else {
          asgn.exceptions.push({ date: dk2, type: 'off', shiftId: '' });
        }
      }
      d.setDate(d.getDate() + 1);
    }
  }

  // Now update to new shift from fromDate
  asgn.shiftId   = newShiftId;
  asgn.startDate = fromDate;

  document.getElementById('ttChangeShiftModal').style.display = 'none';
  ttSaveData();
  ttRenderPage();
  showToast('✅ Shift changed from ' + fromDate);
}


