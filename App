function formatBonusIssuePeriod(p) {
  if (!p) return '';
  if (p.indexOf('-W') !== -1) {
    var parts = p.split('-W');
    return 'W' + parts[1] + ' ' + parts[0];
  }
  var moNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var parts = p.split('-');
  if (parts.length === 2) return (moNames[parseInt(parts[1])-1]||parts[1]) + ' ' + parts[0];
  return p;
}


