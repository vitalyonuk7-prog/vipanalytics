function ttNormDate(d) {
  if (!d) return '';
  if (/^\d{4}-\d{2}-\d{2}$/.test(d)) return d;
  var dt = new Date(d);
  if (isNaN(dt.getTime())) return d;
  return dt.getFullYear() + '-' + String(dt.getMonth()+1).padStart(2,'0') + '-' + String(dt.getDate()).padStart(2,'0');
}

function ttDecideRequest(id, decision, btn) {
  var decidedBy = window._userEmail || 'admin';

  // Optimistic local update
  var req = ttRequests.find(function(r){ return r.id === id; });
  if (req) { req.status = decision; req.decidedBy = decidedBy; }

  // If approved day_off → inject exception into local ttData and save
  if (decision === 'approved' && req && req.type === 'day_off') {
    var dateFrom = ttNormDate(req.date);
    var dateTo   = req.dateEnd ? ttNormDate(req.dateEnd) : dateFrom;
    var dates = [];
    if (dateFrom) {
      var cur = new Date(dateFrom + 'T12:00:00'); // noon to avoid TZ issues
      var end = dateTo ? new Date(dateTo + 'T12:00:00') : cur;
      while (cur <= end) {
        dates.push(cur.getFullYear() + '-' + String(cur.getMonth()+1).padStart(2,'0') + '-' + String(cur.getDate()).padStart(2,'0'));
        cur.setDate(cur.getDate() + 1);
      }
    }
    if (dates.length) {
      var matched = 0;
      (ttData.assignments || []).forEach(function(asgn) {
        if ((asgn.managerEmail||'').trim().toLowerCase() !== (req.email||'').trim().toLowerCase()) return;
        matched++;
        if (!asgn.exceptions) asgn.exceptions = [];
        dates.forEach(function(dk) {
          asgn.exceptions = asgn.exceptions.filter(function(e){ return e.date !== dk; });
          asgn.exceptions.push({ date: dk, type: 'off' });
        });
      });
      if (!matched) showToast('⚠️ No assignment found for ' + req.email);
      else showToast('📅 Added OFF for ' + dates.length + ' day(s) — switching to timetable...');
      // Switch to timetable so user sees the update immediately
      setTimeout(function() { ttActiveTab = 'timetable'; ttRenderPage(); }, 800);
      // Save to server
      google.script.run
        .withSuccessHandler(function(r){
          if (!r||!r.success) { showToast('⚠️ Timetable save failed'); return; }
          // Re-render timetable grid in background so it's ready when user switches
          // No need to call ttRenderPage - just data is updated in memory already
        })
        .withFailureHandler(function(e){ showToast('⚠️ Timetable save error: '+e); })
        .saveTimetableData(ttData);
    }
  }

  // Re-render requests list
  var c2 = document.getElementById('ttMainContent');
  if (c2) {
    var isAdmin2 = window._userRole === 'admin';
    var myEmail2 = window._userEmail || '';
    var rows2 = isAdmin2 ? ttRequests : ttRequests.filter(function(r){ return r.email === myEmail2; });
    ttRenderRequestsList(c2, rows2, isAdmin2);
  }

  showToast(decision === 'approved' ? '✅ Approved' : '❌ Rejected');

  // Persist decision
  google.script.run
    .withSuccessHandler(function(r){ if (!r || !r.success) showToast('⚠️ Decision save failed: '+(r?r.error:'')); })
    .withFailureHandler(function(e){ showToast('⚠️ Decision error: '+e); })
    .decideTimetableRequest(id, decision, decidedBy);
}


