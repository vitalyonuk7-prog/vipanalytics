function openCalCreateModal(prefillDay) {
  var dateInput = document.getElementById('calCreateDate');
  if (prefillDay) {
    var m = String(calMonth + 1).length < 2 ? '0' + (calMonth + 1) : String(calMonth + 1);
    var d = String(prefillDay).length < 2 ? '0' + prefillDay : String(prefillDay);
    dateInput.value = calYear + '-' + m + '-' + d;
  } else if (calSelectedDay) {
    var m = String(calMonth + 1).length < 2 ? '0' + (calMonth + 1) : String(calMonth + 1);
    var d = String(calSelectedDay).length < 2 ? '0' + calSelectedDay : String(calSelectedDay);
    dateInput.value = calYear + '-' + m + '-' + d;
  } else {
