function qaEditMonth(){
  var mgr=qaAllUsers.find(function(u){return u.email===window._qaCurrentMgrEmail;});
  if(!mgr)return;
  var res=qaResults.find(function(r){return r.manager===mgr.email&&r.month===qaActiveMonth;});
  if(!res)return;
  if(String(res.locked||'').toUpperCase()==='TRUE'){showToast('Period is completed and locked');return;}
  var tpl=null;qaTemplates.forEach(function(t){if(t.name===res.template_name)tpl=t;});
  if(!tpl){showToast('Template "'+res.template_name+'" not found');return;}
  window._qaActiveTemplate=JSON.parse(JSON.stringify(tpl));
  window._qaFailures=[];try{window._qaFailures=JSON.parse(res.failures_json||'[]');}catch(e){}
  window._qaLiveMgr=mgr.email;
  window._qaLiveMonth=res.month;
  window._qaLiveTplName=res.template_name;
  qaActiveMonth='__live__';
  qaRenderPage();
}

// ---- NEW MONTH ----
function qaOpenNewMonth(email){
  window._qaNewMonthMgr=email;
  var now=new Date();
  document.getElementById('qaNewMonth').value=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0');
  var sel=document.getElementById('qaNewMonthTemplate');
  sel.innerHTML='<option value="">— choose —</option>';
  qaTemplates.forEach(function(t,i){sel.innerHTML+='<option value="'+i+'">'+(t.name||'Template '+(i+1))+'</option>';});
  document.getElementById('qaNewMonthModal').style.display='flex';
}
function qaCreateMonth(){
  var month=document.getElementById('qaNewMonth').value;
  var tplIdx=document.getElementById('qaNewMonthTemplate').value;
  if(!month||tplIdx===''){showToast('Select month and template');return;}
  var tpl=qaTemplates[parseInt(tplIdx)];
  document.getElementById('qaNewMonthModal').style.display='none';
  window._qaActiveTemplate=JSON.parse(JSON.stringify(tpl));
  window._qaFailures=[];
  window._qaLiveMgr=window._qaNewMonthMgr;
  window._qaLiveMonth=month;
  window._qaLiveTplName=tpl.name;
  qaActiveMonth='__live__';
  qaRenderPage();
}

