function ctDoAddToList(listId, listName) {
  var dd = document.getElementById('ctExistingDropdown');
  if (dd) dd.style.display = 'none';
  var newPlayers = ctBuildPlayersArray();
  var list = listsData.find(function(l) { return l.id === listId; });
  if (!list) { showToast('List not found'); return; }
  var existing = list.players || [];
  var existingEmails = {};
  existing.forEach(function(p) { existingEmails[p.email] = true; });
  var added = 0;
  newPlayers.forEach(function(p) { if (!existingEmails[p.email]) { existing.push(p); added++; } });
  list.players = existing;
  var sm = document.getElementById('ctSummaryModal');
  if (sm) sm.style.display = 'none';
  ctShowSuccessBanner('📥 Added ' + added + ' players to "' + listName + '"');
  google.script.run.withFailureHandler(function(e) { showToast('❌ ' + e.message); }).updateList(listId, { players: existing });
}

