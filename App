function loadPaymentsDataAsync() {
  return new Promise(function(resolve) {
    google.script.run
      .withSuccessHandler(function(result) {
        if (!result || result.error) { console.warn('⚠️ Payments preload:', result ? result.error : 'no data'); resolve(); return; }
        window.paymentsRawData = result.rows || [];
        window.paymentsFilters = result.filters || {};
        window.paymentsDataLoaded = true;
        enrichPaymentsWithPlayerType();
        console.log('✅ Payments preloaded:', window.paymentsRawData.length, 'rows');
        if(result.headers) console.log('📋 Payments headers:', result.headers);
        if(result.columnMap) console.log('🗺️ Payments column mapping:', result.columnMap);
        resolve();
      })
      .withFailureHandler(function(err) { console.error('Payments preload error:', err); resolve(); })
      .getPaymentsData();
  });
}

function loadPaymentsData() {
  if (window.paymentsDataLoaded) {
    populatePaymentsFilters();
    renderPaymentsView();
    return;
  }
  document.getElementById('pmKpiCards').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#64748b"><div style="font-size:28px;margin-bottom:8px">⏳</div>Loading payments data...</div>';
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.error) { document.getElementById('pmKpiCards').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#ef4444">❌ ' + result.error + '</div>'; return; }
      window.paymentsRawData = result.rows || [];
      window.paymentsFilters = result.filters || {};
      window.paymentsDataLoaded = true;
      enrichPaymentsWithPlayerType();
      populatePaymentsFilters();
      renderPaymentsView();
    })
    .withFailureHandler(function(err) { document.getElementById('pmKpiCards').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#ef4444">❌ ' + err.message + '</div>'; })
    .getPaymentsData();
}

function enrichPaymentsWithPlayerType() {
  if (!window.paymentsRawData || !window.paymentsRawData.length) return;
  var ptypes = {};
  var ptotals = {};
  var pmgrs = {};
  window.paymentsRawData.forEach(function(r) {
    var email = (r.email || '').toLowerCase();
    var tags = '';
    // Get tags from dashboardTagMap (built from Dashboard sheet)
    if (window.dashboardTagMap && window.dashboardTagMap[email]) {
      tags = window.dashboardTagMap[email].tags; // ✅ FIX: extract .tags from object
    }
    var pt = tags ? getPlayerTypeFromTags(tags) : 'UNKNOWN';
    r.playerType = pt;
    if (pt) ptypes[pt] = true;
    // ✅ Also enrich with typeTotal from TYPE sheet mapping
    var tt = (typeToTotal && pt && pt !== 'UNKNOWN') ? (typeToTotal[pt] || '') : '';
    r.playerTypeTotal = tt;
    if (tt) ptotals[tt] = true;
    // ✅ Also enrich with manager from tags
    var mgr = '';
    if (tags && typeof getManager === 'function') mgr = getManager(tags) || '';
    r.playerManager = mgr;
    if (mgr) pmgrs[mgr] = true;
  });
  // ✅ Update filters with enriched player data
  window.paymentsFilters.playerTypes = Object.keys(ptypes).sort();
  window.paymentsFilters.playerTypeTotals = Object.keys(ptotals).sort();
  window.paymentsFilters.playerManagers = Object.keys(pmgrs).sort();
  console.log('✅ Payments enriched with playerType:', Object.keys(ptypes), 'typeTotals:', Object.keys(ptotals), 'managers:', Object.keys(pmgrs));
}

function populatePaymentsFilters() {
  var f = window.paymentsFilters;
  var fill = function(id, arr) { var el = document.getElementById(id); if(!el) return; var v = el.value; el.innerHTML = '<option value="">All</option>'; (arr||[]).forEach(function(t) { el.innerHTML += '<option value="' + t + '">' + t + '</option>'; }); el.value = v; };
  // ✅ Use enriched player types/managers instead of raw PAYMENTS columns
  fill('pmTypeFilter', f.playerTypes || f.types);
  fill('pmTypeTotalFilter', f.playerTypeTotals || f.typeTotals);
  fill('pmManagerFilter', f.playerManagers || f.managers);
  fill('pmCountryFilter', f.countries);
  fill('pmPaySysFilter', f.paymentSystems);
  fill('pmProviderFilter', f.providers);
}

function getFilteredPayments() {
  var cF = document.getElementById('pmCreatedFrom').value, cT = document.getElementById('pmCreatedTo').value;
  var fF = document.getElementById('pmFinishedFrom').value, fT = document.getElementById('pmFinishedTo').value;
  var tf = document.getElementById('pmTypeFilter').value, ttf = document.getElementById('pmTypeTotalFilter').value;
  var mf = document.getElementById('pmManagerFilter').value, cf = document.getElementById('pmCountryFilter').value;
  var psf = document.getElementById('pmPaySysFilter').value, prf = document.getElementById('pmProviderFilter').value;
  var es = document.getElementById('pmEmailSearch').value.trim().toLowerCase();
  return window.paymentsRawData.filter(function(r) {
    if (es && r.email.indexOf(es) === -1) return false;
    if (cF || cT) { var c = r.createdAt ? r.createdAt.substring(0,10) : ''; if (!c) return false; if (cF && c < cF) return false; if (cT && c > cT) return false; }
    if (fF || fT) { var f = r.finishedAt ? r.finishedAt.substring(0,10) : ''; if (!f) return false; if (fF && f < fF) return false; if (fT && f > fT) return false; }
    // ✅ Filter by enriched player type/typeTotal/manager
    if (tf && r.playerType !== tf) return false;
    if (ttf && r.playerTypeTotal !== ttf) return false;
    if (mf && r.playerManager !== mf) return false;
    if (cf && r.country !== cf) return false;
    if (psf && r.paymentSystem !== psf) return false;
    if (prf && r.provider !== prf) return false;
    return true;
  });
}

function pmFmt(n) { return n.toFixed(2); }

function renderPaymentsView() {
  var filtered = getFilteredPayments();
