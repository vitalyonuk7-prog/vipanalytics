            showToast('✅ Meeting created!'+(meetUrl?' <a href="'+meetUrl+'" target="_blank" style="color:#fff;text-decoration:underline">Open Meet</a>':''), 5000);
          } else { showToast('❌ '+(r?r.error:'Failed')); }
        })
        .withFailureHandler(function(e){ createBtn.disabled=false; createBtn.textContent='🎥 Create Google Meet'; showToast('❌ '+e); })
        .createSingleMeeting({userEmail:userEmail,tutorEmail:tutorEmail,title:titleIn.value,date:dt,startTime:st,endTime:et,description:'Onboarding '+dayIndex+' | Trainee: '+userEmail+' | Tutor: '+tutorEmail});
    }

    if (oldLink && oldLink.eventId) {
      // Delete old calendar event first
      google.script.run
        .withSuccessHandler(function(){ doCreate(); })
        .withFailureHandler(function(){ doCreate(); }) // proceed even if delete fails
        .deleteCalendarEventById({ eventId: oldLink.eventId });
    } else { doCreate(); }
  });
  body.appendChild(createBtn);
  box.appendChild(body);
  _obSchedModal.innerHTML=''; _obSchedModal.appendChild(box);

  // Slot rendering
  function isBusy(busyArr, sMs, eMs) {
    if (!busyArr||!busyArr.length) return false;
    return busyArr.some(function(b){ var bs=new Date(b.start).getTime(),be=new Date(b.end).getTime(); return sMs<be&&eMs>bs; });
  }

  function pad(n){ return n<10?'0'+n:String(n); }

  function updateSelInfo() {
    if (!selectedSlots.length) { selInfo.textContent=''; return; }
    var sorted = selectedSlots.slice().sort();
    selInfo.textContent = sorted[0]+' – '+sorted[sorted.length-1].split(':')[0]+':'+(sorted[sorted.length-1].split(':')[1]||'00');
    // Update manual pickers
    startIn.value = sorted[0];
    // end = last slot + 30min
    var lastH = parseInt(sorted[sorted.length-1].split(':')[0]);
    var lastM = parseInt(sorted[sorted.length-1].split(':')[1]||'0');
    lastM += 30; if (lastM>=60){lastH++;lastM-=60;}
    endIn.value = pad(lastH)+':'+pad(lastM);
  }

  function renderSlots(busyMap) {
    slotsWrap.innerHTML='';
    var grid=document.createElement('div');
    grid.style.cssText='display:grid;grid-template-columns:repeat(auto-fill,minmax(78px,1fr));gap:4px';
    for (var h=8;h<20;h++) {
      ['00','30'].forEach(function(m) {
        var slotStart = pad(h)+':'+m;
        var nh = m==='30'?h+1:h, nm = m==='30'?'00':'30';
        var slotEnd = pad(nh)+':'+nm;
        var sMs=new Date(dateIn.value+'T'+slotStart+':00').getTime();
        var eMs=new Date(dateIn.value+'T'+slotEnd+':00').getTime();
        var busyTutor=isBusy(busyMap[tutorEmail],sMs,eMs);
        var busyUser=isBusy(busyMap[userEmail],sMs,eMs);
        var anyBusy=busyTutor||busyUser;
        var btn=document.createElement('button');
        var isSelected=selectedSlots.indexOf(slotStart)!==-1;
        btn.dataset.slot=slotStart;
        btn.style.cssText='padding:5px 2px;border-radius:7px;font-size:10px;font-weight:700;cursor:'+(anyBusy?'not-allowed':'pointer')+';border:1.5px solid '+(isSelected?'#6366f1':anyBusy?'#fecaca':'#e2e8f0')+';background:'+(isSelected?'linear-gradient(135deg,#6366f1,#4f46e5)':anyBusy?'#fef2f2':'#f8fafc')+';color:'+(isSelected?'#fff':anyBusy?'#ef4444':'#1e293b')+';text-align:center;line-height:1.3;transition:all 0.1s';
        btn.innerHTML=slotStart+'<br><span style="font-size:8px;opacity:0.7">'+(anyBusy?'Busy':'Free')+'</span>';
        btn.disabled=anyBusy;
        if (!anyBusy) {
          btn.onclick=function(){
            var s=this.dataset.slot;
            var idx=selectedSlots.indexOf(s);
            if (idx===-1) selectedSlots.push(s); else selectedSlots.splice(idx,1);
            // Re-style all buttons
            grid.querySelectorAll('button').forEach(function(b){
              var sel=selectedSlots.indexOf(b.dataset.slot)!==-1;
              b.style.background=sel?'linear-gradient(135deg,#6366f1,#4f46e5)':'#f8fafc';
              b.style.borderColor=sel?'#6366f1':'#e2e8f0';
              b.style.color=sel?'#fff':'#1e293b';
            });
            updateSelInfo();
          };
        }
        grid.appendChild(btn);
      });
    }
    slotsWrap.appendChild(grid);
  }

  function loadSlots() {
    selectedSlots=[];
    slotsWrap.innerHTML='<div style="text-align:center;padding:16px;color:#94a3b8;font-size:12px"><span style="display:inline-block;animation:spin 0.7s linear infinite;font-size:16px">🔄</span> Checking...</div>';
    var emails=[userEmail,tutorEmail].filter(Boolean);
    if (!emails.length) { renderSlots({}); return; }
    google.script.run
      .withSuccessHandler(function(r){ renderSlots(r&&r.success?r.busy:{}); })
      .withFailureHandler(function(){ renderSlots({}); })
      .getFreeBusy({emails:emails, date:dateIn.value});
  }

  // Auto-reload slots when date changes
  dateIn.addEventListener('change', function(){ loadSlots(); });

  loadSlots();
}



